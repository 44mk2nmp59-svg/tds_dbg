&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("АвтоТест") Тогда
		Возврат;
	КонецЕсли;

	Если Параметры.Свойство("ДоументСервер") Тогда
//		ЕстьНомерСтрокиДок =  Параметры.ДоументСервер ИЛИ Параметры.ВидДокумента ="ПриемТовара";
		ЕстьНомерСтрокиДок =  Параметры.ДоументСервер;

		
		Если ЕстьНомерСтрокиДок Тогда
			ПозицияВвода = 1;
		Иначе
			ПозицияВвода = 2;
		КонецЕсли;

	Иначе
		ЕстьНомерСтрокиДок =  Ложь;
		ПозицияВвода = 2;
	КонецЕсли;
	
	Если Параметры.Свойство("ВидДокумента") И Параметры.ВидДокумента = "IN" Тогда	
		ДобовлятьКоличество =  Истина;
	КонецЕсли;
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "МаксимальноеКоличествоИнфо", "Видимость", Ложь);
	ОбщегоНазначения.УстановитьЦветИнформационныхНадписей(ЭтаФорма, "МаксимальноеКоличествоИнфо");
	
	ИсключенныеСвойства = "ЗакрыватьПриВыборе, ЗакрыватьПриЗакрытииВладельца, ТолькоПросмотр";
	ЗаполнитьЗначенияСвойств(ЭтаФорма, Параметры, ,ИсключенныеСвойства);
	
	
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "КоличествоДокумент", "Видимость", ДобовлятьКоличество);

	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "КоличествоОжидаемое", "Видимость", ДоументСервер);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "НомерСтрокиДокумента", "Видимость", ЕстьНомерСтрокиДок);
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "УдалитьСтроку", "ЦветРамки", ЦветаСтиля.ЦветФонаФормы);
	
	НастроитьФормуПоЗначениямНастроек();
	
	ОформитьСтатичныеЗаголовкиИПоля();
	
	// ОриентацияЭкрана
	НастроитьФормуПоОриентацииЭкрана();
	
	
	
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	Если ПозицияВвода = 1 Тогда
		ЭтаФорма.ТекущийЭлемент = Элементы.НомерСтрокиДокумента;
	ИначеЕсли  ПозицияВвода = 2 Тогда
		ЭтаФорма.ТекущийЭлемент = Элементы.Количество;
	КонецЕсли;
	
	
	#Если МобильноеПриложениеКлиент  Тогда
		ПодключитьОбработчикОжидания("ВключитьРедактированиеЭлемента",0.01,Истина);
	#КонецЕсли	
	
КонецПроцедуры

