&НаКлиенте
Процедура УдалитьСтроку(Команда)
	
	ПараметрыЗакрытия = Новый Структура;
	ПараметрыЗакрытия.Вставить("УдалитьСтроку");
	
	Закрыть(ПараметрыЗакрытия);
	
КонецПроцедуры

&НаКлиенте
Процедура Готово(Команда)
	
	ПараметрыЗакрытия = Новый Структура;
	ПараметрыЗакрытия.Вставить("Сохранить");
	ПараметрыЗакрытия.Вставить("Количество", Количество);
	ПараметрыЗакрытия.Вставить("НомерСтрокиДокумента", НомерСтрокиДокумента);
	
	Закрыть(ПараметрыЗакрытия);
	
КонецПроцедуры

&НаКлиенте
Процедура СканироватьШтрихкод(Команда)
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("Форма", ЭтаФорма);
	ДополнительныеПараметры.Вставить("ИмяОбработчикаЗакрытияСканирования", "ОбработкаЗакрытияСканирования");
	
	ПодключаемоеОборудованиеКлиент.ПолучитьШтрихкод(ДополнительныеПараметры);
	
КонецПроцедуры


#КонецОбласти

#Область СлужебныеПроцедурыИФункции


&НаСервере
Процедура ОформитьСтатичныеЗаголовкиИПоля()
	
	// заголовок формы
	ЗаголовокФормы = НСтр("ru = 'Строка №%НомерСтроки%'");
	ЗаголовокФормы = СтрЗаменить(ЗаголовокФормы, "%НомерСтроки%", НомерСтроки);
	Заголовок      = ЗаголовокФормы;
	
	// количество
	ЗаголовокКоличества =  НСтр("ru = 'Количество, %ЕдИзм%'");
	ЗаголовокКоличества = СтрЗаменить(ЗаголовокКоличества, "%ЕдИзм%", НаименованиеЕденицы);
	Элементы.Количество.Заголовок = ЗаголовокКоличества;
		

	
	Если ТолькоПросмотрФормы Тогда
		Элементы.Отмена.Заголовок = НСтр("ru = 'Закрыть'");
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "Готово, УдалитьСтроку", "Видимость", Ложь);
		
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "Количество", "КнопкаРегулирования", Ложь);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "Количество", "ТолькоПросмотр", Истина);
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура НастроитьФормуПоЗначениямНастроек()
	
	Если ЕстьНомерСтрокиДок И НомерСтрокиДокумента <> "0" Тогда
		ПозицияВвода = 2;
	КонецЕсли;
	Если ПозицияВвода = 1 Тогда
		ЭтаФорма.ТекущийЭлемент = Элементы.НомерСтрокиДокумента;
		//Элементы.НомерСтрокиДокумента.УстановитьГраницыВыделения(СтрДлина(Элементы.НомерСтрокиДокумента),СтрДлина(Элементы.НомерСтрокиДокумента)+1);
		//Элементы.НомерСтрокиДокумента.АктивизироватьПоУмолчанию = Истина;	
	Иначе
		ЭтаФорма.ТекущийЭлемент = Элементы.Количество;
		Элементы.Количество.УстановитьГраницыВыделения(СтрДлина(Элементы.Количество),СтрДлина(Элементы.Количество)+1);
		Элементы.Количество.АктивизироватьПоУмолчанию = Истина;	
	КонецЕсли;
	
	ОбщегоНазначения.УстановитьШрифт(ЭтаФорма);
	//ОбщегоНазначения.ОформитьКоличественныеПоля(ЭтаФорма, "Количество");
	ОбщегоНазначения.ОформитьКоличественныеПоля(ЭтаФорма, "КоличествоДокумент");
	ОбщегоНазначения.ОформитьКоличественныеПоля(ЭтаФорма, "КоличествоОжидаемое");

	Количество = Формат(Число(Количество), "ЧРД=.");
	
	ОбщегоНазначения.УстановитьВысотуПоляНаименованиеТовара(ЭтаФорма, ,"Номенклатура");
		
	
КонецПроцедуры


