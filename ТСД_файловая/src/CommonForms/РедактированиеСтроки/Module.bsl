&НаКлиенте
Процедура НомерСтрокиДокументаПриИзменении(Элемент)
	Попытка
		НомерСтрокиДокумента = Формат(Число(НомерСтрокиДокумента),  "ЧЦ=10");
	Исключение
		Количество = 0;
	КонецПопытки;
	ЭтаФорма.ТекущийЭлемент = Элементы.Количество;
	#Если МобильноеПриложениеКлиент  Тогда
		НачатьРедактированиеЭлемента();
	#КонецЕсли	

	ПозицияВвода = 2;
КонецПроцедуры

&НаКлиенте
Процедура ПровертьЗакрытиеФормы()
		
	Если ПозицияВвода =  3  Тогда
		ПараметрыЗакрытия = Новый Структура;
		ПараметрыЗакрытия.Вставить("Сохранить");
		Если ДобовлятьКоличество Тогда
			ПараметрыЗакрытия.Вставить("Количество", Количество+КоличествоДокумент);
		Иначе
			ПараметрыЗакрытия.Вставить("Количество", Количество);
		КонецЕсли;
		ПараметрыЗакрытия.Вставить("НомерСтрокиДокумента", НомерСтрокиДокумента);
		
		Закрыть(ПараметрыЗакрытия);
	КонецЕсли;

КонецПроцедуры


&НаКлиенте
Процедура КоличествоПриИзменении(Элемент)
	Попытка
		Количество = Формат(Число(Количество),  "ЧЦ=15; ЧДЦ=3");
		ЭтаФорма.ТекущийЭлемент  = Элементы.Готово;
		ПозицияВвода = 3;
		
	Исключение
		Количество = 0;
	КонецПопытки;

	
	ПодключитьОбработчикОжидания("ПровертьЗакрытиеФормы", 0.01, Истина);
	
КонецПроцедуры


