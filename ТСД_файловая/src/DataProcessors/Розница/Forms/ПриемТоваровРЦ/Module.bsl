			СтрокаКороб.ИД_Короб = ИД_Короб;
		Иначе
			СтрокаКороб = Неопределено;	
		КонецЕсли;
	Иначе   
		СтрокаКороб = мКороба[0]; 
	КонецЕсли;
	
	Возврат СтрокаКороб 
	
КонецФункции 
