 &НаКлиенте
Процедура ОповещениеПриемТоваровPKG(Результат, Параметры)Экспорт
	
	Если Результат = Неопределено Тогда
		ПодсветитьСтроку(ТекИдентификаторСтроки);

		Возврат;
	КонецЕсли;

	
	МСтрокиКороб =  Объект.Короба.НайтиСтроки(Новый Структура("ИД_Короб",Результат.ИД_Короб));
	СтрокаКроб = МСтрокиКороб[0];
	СтрокаКроб.Принят = 1;
	
	МСтрокиДокумент=  Объект.Документы.НайтиСтроки(Новый Структура("ИД_Документ",Результат.ИД_Документ));
	СтрокаДокумент = МСтрокиДокумент[0];       
	СтрокаДокумент.ПринятоPKG = ПринятоPKGДокумента(Результат.ИД_Документ);
	СтрокаДокумент.ЗаписьПоСтроке = "Прийнято PKG - "+СтрокаДокумент.ПринятоPKG+" з "+СтрокаДокумент.ВсегоPKG+Символы.ПС+СтрокаДокумент.СкладСборки;
	Для Каждого ТоварPKG Из Результат.ТоварыPKG Цикл 
		МассивТоварыPKG = Объект.Товары.НайтиСтроки(Новый Структура("ИД_Короб,Артикул,МРЦ",Результат.ИД_Короб,ТоварPKG.Артикул,ТоварPKG.МРЦ));  
		СтрокаТоварPKG = МассивТоварыPKG[0];
		СтрокаТоварPKG.КоличествоВведено = ТоварPKG.КоличествоВведено;
		СтрокаТоварPKG.КоличествоРасхождение = ТоварPKG.КоличествоРасхождение;
		СтрокаТоварPKG.ПричинаРасхождения = ТоварPKG.ПричинаРасхождения;   
	КонецЦикла;    
	
	ПодсветитьСтроку(ТекИдентификаторСтроки);
	
КонецПроцедуры




&НаКлиенте
Процедура Записать(Команда)
	ОчиститьСообщения();
	Если Объект.Документы.Количество() = 0 Тогда
		Сообщить("Нема документів для запису!");
		Возврат;
	КонецЕсли;
	Если ПроверкаСервер() Тогда
		  Возврат;
	 КонецЕсли;
	 
	 
	МассивДокументовБезPKG = ПроверитьСтрокиПриема();
	
	ЗакончитьПриемPKG(МассивДокументовБезPKG);
	
	
КонецПроцедуры

Функция ПроверкаСервер() 
	Рез = Ложь;	
	Если ПустаяСтрока(ПараметрыСеанса.Сотрудник) Тогда
		Сообщить("Користувач не ініціалізований");
		Рез = Истина;
	КонецЕсли;
  	Возврат Рез;
КонецФункции

&НаСервере
Функция ПроверитьСтрокиПриема()
	
	МассивДокументовБезPKG = Новый Массив;

	Если ТипДокумента = Справочники.ТипыДокументов.БезакцептныйПриемPKG Тогда
		Возврат МассивДокументовБезPKG;
	КонецЕсли;

	Для Каждого ДокументПриема Из Объект.Документы Цикл 
		ВсегоPKG_ВДокументе = ДокументПриема.ВсегоPKG;
		
		КоличествоПринято = ПринятоPKGДокумента(ДокументПриема.ИД_Документ);   
		Если ВсегоPKG_ВДокументе <> КоличествоПринято И НЕ КоличествоПринято = 0 Тогда  
			МассивДокументовБезPKG.Добавить(
			Новый Структура("ИД_Документ,Номер,Дата,ВсегоPKG,ПринятоPKG"
			,ДокументПриема.ИД_Документ,ДокументПриема.Номер,ДокументПриема.Дата,ВсегоPKG_ВДокументе,КоличествоПринято));
		КонецЕсли;
		
		
	КонецЦикла;
	
	Возврат МассивДокументовБезPKG;
	
КонецФункции

 &НаКлиенте
Асинх Процедура ЗакончитьПриемPKG(МассивДокументовБезPKG)
	
	Если ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.БезакцептныйПриемPKG") Тогда
		ТекстВопроса =	"Закінчити безакцептний прийом PKG?";
	ИначеЕсли МассивДокументовБезPKG.Количество() Тогда
		ФорматТекстВопроса = "Прийняті не всі PKG за документами"+Символы.ПС+"<<Важливо ! на невідскановий ПКГ буде сформований Акт розбіжності>>";
		ТекстВопроса = Новый ФорматированнаяСтрока(ФорматТекстВопроса, Новый Шрифт(,,11),Новый Цвет(255, 0, 0));

	Иначе
		ТекстВопроса ="Закінчити прийом PKG?";
	КонецЕсли;
	
    Режим = РежимДиалогаВопрос.ДаНет;
    Ответ = Ждать ВопросАсинх(ТекстВопроса, Режим, 0);
    Если Ответ = КодВозвратаДиалога.Нет Тогда
        Возврат;
	КонецЕсли;  
	
	РезультатВыгрузки = ВыгрузитьРезультатыСканирования();
	Если НЕ РезультатВыгрузки.Результат Тогда  
		Если НЕ ПустаяСтрока(РезультатВыгрузки.ОписаниеОшибки) Тогда
			Сообщить(РезультатВыгрузки.ОписаниеОшибки); 
		КонецЕсли;
		
		Возврат; 
	Иначе
		Объект.Документы.Очистить();
		Объект.Короба.Очистить();
		Объект.Товары.Очистить();
		Оповестить("ОбновитьЗадания");	
		Если РезультатВыгрузки.Ответ.Свойство("ПечатьАкт") Тогда
			ОбщегоНазначенияКлиент.ВывестиПДФ_НаПечать(Base64Значение(РезультатВыгрузки.Ответ.ПечатьАкт));
		КонецЕсли;
		
	КонецЕсли; 
	
	ВыполняетсяЗакрытие = Истина;
	Закрыть();
	
	
КонецПроцедуры

&НаСервере
Функция ВыгрузитьРезультатыСканирования()
	
	СтруктураДокумента = Новый Структура; 
	СтруктураДокумента.Вставить("UUID_Сотрудник",ПараметрыСеанса.Сотрудник_ID);

	МассивДокументы = Новый Массив;  
	МасивДокНаВыгрузку = Новый Массив;
	СтрокаСтруктура = "ИД_Документ,ВсегоPKG,РК";
	Для Каждого ТекДокумент Из Объект.Документы Цикл
		Если ТекДокумент.ВсегоPKG <> ТекДокумент.ПринятоPKG И ТекДокумент.ПринятоPKG = 0 Тогда
			Продолжить;
		КонецЕсли;
		МасивДокНаВыгрузку.Добавить(ТекДокумент.ИД_Документ);
		СтруктураДокументПриема = Новый Структура(СтрокаСтруктура);
		ЗаполнитьЗначенияСвойств(СтруктураДокументПриема,ТекДокумент);
		МассивДокументы.Добавить(СтруктураДокументПриема);
	КонецЦикла;  
	Если МасивДокНаВыгрузку.Количество() = 0 Тогда
       	Возврат Новый Структура("Результат,ОписаниеОшибки",Ложь,"Немає прийнятих документів");
	КонецЕсли;
	
	
	СтруктураДокумента.Вставить("Документы",МассивДокументы);
	
	МассивКороба = Новый Массив;
	СтрокаСтруктура = "ИД_Короб,ИД_Документ,Принят,Отсканирован,НомерУпаковки,РК";
	Для Каждого ТекКороб Из Объект.Короба Цикл 
		Если МасивДокНаВыгрузку.Найти(ТекКороб.ИД_Документ) = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		СтруктураКоробаПриема = Новый Структура(СтрокаСтруктура);
		ЗаполнитьЗначенияСвойств(СтруктураКоробаПриема,ТекКороб);
		МассивКороба.Добавить(СтруктураКоробаПриема);
	КонецЦикла;
	СтруктураДокумента.Вставить("Короба",МассивКороба);
	
	МассивТовары = Новый Массив;
   	СтрокаСтруктура = "ИД_Документ,ИД_Короб,Артикул,Коэффициент,КоличествоПоставщика,КоличествоВведено,КоличествоРасхождение,КодПричины,МРЦ";
	Для Каждого ТекТовар Из Объект.Товары Цикл 
		Если МасивДокНаВыгрузку.Найти(ТекТовар.ИД_Документ) = Неопределено Тогда
			Продолжить;
		КонецЕсли;

		СтруктураТоварПриема = Новый Структура(СтрокаСтруктура);
		ЗаполнитьЗначенияСвойств(СтруктураТоварПриема,ТекТовар);
		СтруктураТоварПриема.КодПричины = ?(ЗначениеЗаполнено(ТекТовар.ПричинаРасхождения),ТекТовар.ПричинаРасхождения.Код,"");
		МассивТовары.Добавить(СтруктураТоварПриема);
	КонецЦикла;
	СтруктураДокумента.Вставить("Товары",МассивТовары);
	
	
	СтруктураОтвет = РозницаТК.ВыгрузитьДокументПриемРЦ(СтруктураДокумента,ПредварительныйПрием);   
	Возврат СтруктураОтвет;
	
КонецФункции

&НаКлиенте
