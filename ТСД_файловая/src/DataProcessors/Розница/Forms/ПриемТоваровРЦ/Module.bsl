		ОткрытьФорму("Обработка.Розница.Форма.ФормаКороба"
			,Новый Структура("ТипДокумента,ИД_Документ,Товары,Документы,Короба"
			,ТипДокумента
			,ТекущиеДанные.ИД_Документ
			,Объект.Товары,Объект.Документы,Объект.Короба)
			,ЭтотОбъект,,,,ОписаниеОповещения,РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс); 
	КонецЕсли;
	
КонецПроцедуры

