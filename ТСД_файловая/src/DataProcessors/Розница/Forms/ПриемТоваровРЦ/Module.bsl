&НаКлиенте
Перем ВыполняетсяЗакрытие;


	
	
	
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Если Параметры.Свойство("АвтоТест") Тогда
		Возврат;
	КонецЕсли;
	ТипДокумента = Параметры.ТипДокумента;	
	ИнициализироватьКонстантыФормы();
	ОбновитьПодразделение();
	ОбновитьСотрудника();	
	
	НастроитьФормуПоЗначениямНастроек();
	ЗагрузитьСписокДокументовСервер();
	//	ЗагрузитьСохраненныеДанные();	
//	Элементы.ФормаКоманднаяПанель.Видимость = Ложь;
	//ЭтаФорма.ОтображатьКнопкуЗакрытия = Ложь;
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	ВыполняетсяЗакрытие = Ложь; 
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ГруппаСообщение", "Видимость",Ложь);
    
	#Если МобильноеПриложениеКлиент Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "Сканировать", "Видимость", Ложь);
	#КонецЕсли

КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	
	Если ЗавершениеРаботы Тогда
		Возврат;
	КонецЕсли;
	
	
	Если ВыполняетсяЗакрытие Тогда
		ОбщегоНазначенияКлиентСервер.ОчиститьСотрудника(); 
		СохранитьТекущиеДанные()
	Иначе
		Отказ = Истина;    
		
		
		Кнопки = Новый СписокЗначений;
		Кнопки.Добавить("Да", "Так");
		Кнопки.Добавить("Нет", "Ні");
		ПараметрыНапоминания = Новый Структура;
	//	ПараметрыНапоминания.Вставить("Картинка", БиблиотекаКартинок.Информация32);
		ПараметрыНапоминания.Вставить("Заголовок", "Увага");
		ПараметрыНапоминания.Вставить("ПредлагатьБольшеНеЗадаватьЭтотВопрос", Ложь);
		СтандартныеПодсистемыКлиент.ПоказатьВопросПользователю(
			Новый ОписаниеОповещения("ПередЗакрытиемЗавершение",ЭтотОбъект), "Закрити документ?", Кнопки, ПараметрыНапоминания);

		//ПоказатьВопрос(Новый ОписаниеОповещения("ПередЗакрытиемЗавершение",ЭтотОбъект),"Закрити документ?",РежимДиалогаВопрос.ДаНет);
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ПодключаемоеОборудованиеКлиент.ЭтоОповещениеСканераШтрихкода(ИмяСобытия) И ВводДоступен() Тогда
		
		ДополнительныеПараметры = Новый Структура;
		ДополнительныеПараметры.Вставить("Форма", ЭтаФорма);
		ОбработатьПолученныйШтрихкод(Параметр, ДополнительныеПараметры);
		
	ИначеЕсли ИмяСобытия = "ИзмененоПодразделение" Тогда
		
		ОбновитьПодразделение();
		
	ИначеЕсли ИмяСобытия = "ИзмененСотрудник" Тогда
		
		ОбновитьСотрудника();
		
		Если ПользовательИнициализирован И ОтсканированPKG = Ложь Тогда
			  ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ГруппаСообщение", "Видимость",Истина);
		КонецЕсли;
		
	КонецЕсли;

КонецПроцедуры




////    

&НаСервере
Процедура ЗагрузитьСохраненныеДанные()
	
	Если ТипДокумента <> Справочники.ТипыДокументов.ПриемPKG Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РозницаДокументы.ИД_Документ КАК ИД_Документ,
		|	РозницаДокументы.Номер КАК Номер,
		|	РозницаДокументы.Дата КАК Дата,
		|	РозницаДокументы.ВидДокумента КАК ВидДокумента,
		|	РозницаДокументы.ВсегоPKG КАК ВсегоPKG,
		|	РозницаДокументы.РК КАК РК
		|ИЗ
		|	РегистрСведений.РозницаДокументы КАК РозницаДокументы
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	РозницаТовары.ИД_Документ КАК ИД_Документ,
		|	РозницаТовары.ИД_Короб КАК ИД_Короб,
		|	РозницаТовары.Артикул КАК Артикул,
		|	РозницаТовары.МРЦ КАК МРЦ,
		|	РозницаТовары.Коэффициент КАК Коэффициент,
		|	РозницаТовары.ШтрихКод КАК ШтрихКод,
		|	РозницаТовары.НаименованиеТовара КАК НаименованиеТовара,
		|	РозницаТовары.НаименованиеЕдиницы КАК НаименованиеЕдиницы,
		|	РозницаТовары.КоличествоПоставщика КАК КоличествоПоставщика,
		|	РозницаТовары.КоличествоВведено КАК КоличествоВведено,
		|	РозницаТовары.КоличествоРасхождение КАК КоличествоРасхождение,
		|	РозницаТовары.ПричинаРасхождения КАК ПричинаРасхождения,
		|	РозницаТовары.Весовой КАК Весовой,
		|	РозницаТовары.ПриемДо КАК ПриемДо
		|ИЗ
		|	РегистрСведений.РозницаТовары КАК РозницаТовары
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	РозницаКороба.ИД_Короб КАК ИД_Короб,
		|	РозницаКороба.ИД_Документ КАК ИД_Документ,
		|	РозницаКороба.Принят КАК Принят,
		|	РозницаКороба.НомерУпаковки КАК НомерУпаковки,
		|	РозницаКороба.Отсканирован КАК Отсканирован,
		|	РозницаКороба.СкладСборки КАК СкладСборки,
		|	РозницаКороба.РК КАК РК
		|ИЗ
		|	РегистрСведений.РозницаКороба КАК РозницаКороба";
	
	ПакетЗапроса = Запрос.ВыполнитьПакет();
	РезультатДокументы = ПакетЗапроса[0];  
	Если РезультатДокументы.Пустой() Тогда
		Возврат;
	КонецЕсли;
	РезультатКороба = ПакетЗапроса[2];
	ВыборкаКороба = РезультатКороба.Выбрать();
	Пока ВыборкаКороба.Следующий() Цикл  
		СтрокаКороба = ПолучитьСтрокуКороб(ВыборкаКороба.ИД_Документ,ВыборкаКороба.ИД_Короб);;
		Если СтрокаКороба = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ЗаполнитьЗначенияСвойств(СтрокаКороба,ВыборкаКороба,,"СкладСборки");
	КонецЦикла;

	
	ВыборкаДокументы = РезультатДокументы.Выбрать(); 
	Пока ВыборкаДокументы.Следующий() Цикл  
		СтрокаДокумент = ПолучитьСтрокуДокумент(ВыборкаДокументы.ИД_Документ);
		Если СтрокаДокумент = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ЗаполнитьЗначенияСвойств(СтрокаДокумент,ВыборкаДокументы); 
		СтрокаДокумент.ПринятоPKG = ПринятоPKGДокумента(СтрокаДокумент.ИД_Документ);	

		СтрокаДокумент.ЗаписьПоСтроке = "Прийнято PKG - "+СтрокаДокумент.ПринятоPKG+" з "+СтрокаДокумент.ВсегоPKG+Символы.ПС+СтрокаДокумент.СкладСборки;
	КонецЦикла;

	РезультатТовары = ПакетЗапроса[1];
	ВыборкаТовары = РезультатТовары.Выбрать();
	Пока ВыборкаТовары.Следующий() Цикл   
		СтрокаДокумент = ПолучитьСтрокуДокумент(ВыборкаТовары.ИД_Документ);
		Если СтрокаДокумент = Неопределено Тогда
			Продолжить;
		КонецЕсли;

		СтрокаТовары = ПолучитьСтрокуТоваров(ВыборкаТовары.ИД_Документ,ВыборкаТовары.ИД_Короб,ВыборкаТовары.Артикул,ВыборкаТовары.МРЦ,Истина);
		ЗаполнитьЗначенияСвойств(СтрокаТовары,ВыборкаТовары);
	КонецЦикла;
	
	

КонецПроцедуры

&НаСервере
Процедура ЗагрузитьСписокДокументовСервер() 
	СтруктураОтвет = РозницаТК.ПолучитьСписокДокументовPKG(ТипДокумента); 
	
	Если  Не СтруктураОтвет.Результат Тогда
		
		Если НЕ ПустаяСтрока(СтруктураОтвет.ОписаниеОшибки) Тогда
			Сообщить(СтруктураОтвет.ОписаниеОшибки);
		Иначе 
			Сообщить("Помилка отримання списка PKG");
		КонецЕсли;
		Возврат;
		
	КонецЕсли;
	ДоставкаRK = СтруктураОтвет.Ответ.RK;   
	 ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "СообщениеПользователю", "Заголовок",?(ДоставкаRK = 1,"Відскануйте RK","Відскануйте PKG"));
	
	МассивДокументов = СтруктураОтвет.Ответ.МассивДокументов;
	Для Каждого СтрокаДокумент из  МассивДокументов Цикл 
		мДокументы = Объект.Документы.НайтиСтроки(Новый Структура("ИД_Документ",СтрокаДокумент.ОснованиеUUID));
		
		Если мДокументы.Количество() Тогда
			НоваяСтрокаДокумент = мДокументы[0];
		Иначе   
			НоваяСтрокаДокумент = Объект.Документы.Добавить();  
		КонецЕсли; 
		
		НоваяСтрокаДокумент.ИД_Документ = СтрокаДокумент.ОснованиеUUID; 
		НоваяСтрокаДокумент.Номер =СтрокаДокумент.Номер; 
		НоваяСтрокаДокумент.Дата =СтрокаДокумент.Дата; 
		НоваяСтрокаДокумент.ВидДокумента ="Переміщення"; 
		НоваяСтрокаДокумент.ВсегоPKG = СтрокаДокумент.ВсегоPKG;  
		НоваяСтрокаДокумент.СкладСборки = СтрокаДокумент.СкладОтправитель;  	
		Для Каждого СтрокаПКГ Из СтрокаДокумент.МассивPKG Цикл 
			
			мКороба = Объект.Короба.НайтиСтроки(Новый Структура("ИД_Короб,ИД_Документ",СтрокаПКГ.ИД_Короб,СтрокаДокумент.ОснованиеUUID));
			//
			Если НЕ мКороба.Количество() Тогда
				СтрокаКороб = Объект.Короба.Добавить();
				СтрокаКороб.ИД_Короб = СтрокаПКГ.ИД_Короб;
				СтрокаКороб.ИД_Документ = СтрокаДокумент.ОснованиеUUID;
				СтрокаКороб.НомерУпаковки = СтрокаПКГ.НомерУпаковки;  
				СтрокаКороб.СкладСборки = СтрокаПКГ.СкладСборки;
				Если ПредварительныйПрием И СтрокаПКГ.Состояние = 2 Тогда
					СтрокаКороб.Принят = 1;
				КонецЕсли;
			КонецЕсли; 
		КонецЦикла;  
		НоваяСтрокаДокумент.ПринятоPKG = ПринятоPKGДокумента(НоваяСтрокаДокумент.ИД_Документ);	
		НоваяСтрокаДокумент.ЗаписьПоСтроке = "Прийнято PKG - "+НоваяСтрокаДокумент.ПринятоPKG+" з "+СтрокаДокумент.ВсегоPKG+Символы.ПС+НоваяСтрокаДокумент.СкладСборки;
		
	КонецЦикла; 
	
	Объект.Документы.Сортировать("СкладСборки");
	Если Объект.Документы.Количество() > 0 Тогда
		ЗагрузитьСохраненныеДанные();   
	КонецЕсли;
	
КонецПроцедуры



&НаСервере
Процедура СохранитьТекущиеДанные()
	Если ТипДокумента <> Справочники.ТипыДокументов.ПриемPKG Тогда
		Возврат;
	КонецЕсли;
	
	НаборДокументы = РегистрыСведений.РозницаДокументы.СоздатьНаборЗаписей();
	НаборДокументы.Загрузить(Объект.Документы.Выгрузить());
	НаборДокументы.Записать();
	
	НаборКороба = РегистрыСведений.РозницаКороба.СоздатьНаборЗаписей();
	НаборКороба.Загрузить(Объект.Короба.Выгрузить());
	НаборКороба.Записать();
	
	НаборТовары = РегистрыСведений.РозницаТовары.СоздатьНаборЗаписей();
	НаборТовары.Загрузить(Объект.Товары.Выгрузить());
	НаборТовары.Записать();
	
	
КонецПроцедуры


&НаСервере
Процедура ИнициализироватьКонстантыФормы()
	
	ИспользуетсяАсинхронныйСканер = ЗначениеНастроекВызовСервераПовтИсп.ИспользуетсяАсинхронныйСканерШтрихкодов();
	Инициализирован = НЕ ПустаяСтрока(ПараметрыСеанса.Подразделение);
    ПользовательИнициализирован = НЕ ПустаяСтрока(ПараметрыСеанса.Сотрудник);
КонецПроцедуры
 
&НаСервере
Процедура ОбновитьПодразделение()
	
	Если ПустаяСтрока(ПараметрыСеанса.Подразделение) Тогда
		Элементы.СообщениеИнициализации.Заголовок = "Пристрій не ініціалізований";
		ОбщегоНазначения.УстановитьЦветПолейОшибок(ЭтаФорма, "СообщениеИнициализации");
		Инициализирован = Ложь;
		
	Иначе

		Элементы.СообщениеИнициализации.Заголовок = ПараметрыСеанса.Подразделение;
		ОбщегоНазначения.УстановитьЦветИнформационныхНадписей(ЭтаФорма, "СообщениеИнициализации");
		Инициализирован = Истина;
		
	КонецЕсли;
	
	ОпределитьДоступностьКнопкиСканирования();
	
КонецПроцедуры

 &НаСервере
Процедура ОбновитьСотрудника()
	
	Если ПустаяСтрока(ПараметрыСеанса.Сотрудник) Тогда
		Элементы.СообщениеИнициализацииПользователя.Заголовок = "Користувач не ініціалізований";
		ОбщегоНазначения.УстановитьЦветПолейОшибок(ЭтаФорма, "СообщениеИнициализацииПользователя");
		ПользовательИнициализирован = Ложь;
	Иначе
		Элементы.СообщениеИнициализацииПользователя.Заголовок = ПараметрыСеанса.Сотрудник;
		ОбщегоНазначения.УстановитьЦветИнформационныхНадписей(ЭтаФорма, "СообщениеИнициализацииПользователя");
		ПользовательИнициализирован = Истина;
	КонецЕсли;
	
	УстановитьДоступностьПоНастройкам();
	
КонецПроцедуры

 &НаСервере
Процедура ОпределитьДоступностьКнопкиСканирования()
	
	ЕстьОборудованиеСканирования = ЗначениеЗаполнено(ЗначениеНастроекВызовСервераПовтИсп.ТипУстройстваСканирования());
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "Сканировать", "Видимость",
	(ЕстьОборудованиеСканирования И НЕ ИспользуетсяАсинхронныйСканер) И Инициализирован И ПользовательИнициализирован
	);
	
КонецПроцедуры   

 &НаСервере
Процедура НастроитьФормуПоЗначениямНастроек()
	
		
	//ОбщегоНазначения.УстановитьШрифт(ЭтаФорма);
	
	ОпределитьДоступностьКнопкиСканирования();
	
	НастроитьЭлементыАсинхронногоСканера();
	Если ТипДокумента = Справочники.ТипыДокументов.БезакцептныйПриемPKG Тогда
		ЭтотОбъект.Заголовок = "Безакцептний прийом PKG";
		ПредварительныйПрием = Истина;
	КонецЕсли;
	
	
КонецПроцедуры

&НаСервере
Процедура УстановитьДоступностьПоНастройкам()

	ОпределитьДоступностьКнопкиСканирования();
	
//	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "Сканировать", "Доступность", Инициализирован И ПользовательИнициализирован);
 	
	
КонецПроцедуры

 &НаСервере
Процедура НастроитьЭлементыАсинхронногоСканера()
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "АктивироватьСканер", "Видимость", 
		ИспользуетсяАсинхронныйСканер
	);
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытиемЗавершение(РезультатВопроса,ДопоплнительныеПараметры) Экспорт
	
	Если РезультатВопроса = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если РезультатВопроса.Значение = "Да" Тогда
		ВыполняетсяЗакрытие = Истина;
		Закрыть();
	КонецЕсли;
	
	
КонецПроцедуры

&НаКлиенте
Процедура ВыполнитьПослеЗакрытияВводаСотрудника(Результат,ДополнительныеПараметры)Экспорт 
	
КонецПроцедуры


    
&НаКлиенте
Процедура ОбработатьПолученныйШтрихкод(ПолученныйШтрихкод, Параметры) Экспорт
	
	Если ПустаяСтрока(ПолученныйШтрихкод) Тогда
		Возврат;
	КонецЕсли;
	
	
	Если НЕ ПользовательИнициализирован Тогда
		
		Результат	= ИнтеграцияТК_Клиент.ПолучитьСотрудника(ПолученныйШтрихкод);

		Если Результат.Результат Тогда
			Оповестить("ИзмененСотрудник");
		Иначе
			Сообщить("Необхідна авторизація користувача");
		КонецЕсли;
		
		Возврат;
	ИначеЕсли ПользовательИнициализирован И ОтсканированPKG  Тогда
		
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ГруппаСообщение", "Видимость",Ложь);
		
	КонецЕсли;
	
	Если ПредварительныйПрием Тогда
		
		Если СтрЧислоВхождений(ПолученныйШтрихкод,";")=2 Тогда
			ОчиститьСообщения();
			МассивСтрок = СтрРазделить(ПолученныйШтрихкод,";");
			ИД_PKG = МассивСтрок[0];
			
			ДанныеПКГ(ИД_PKG);  
			ПодсветитьСтроку(ТекИдентификаторСтроки);
		ИначеЕсли СтрНачинаетсяС(ПолученныйШтрихкод,"RK;") Тогда  
			МассивРК = СтрРазделить(ПолученныйШтрихкод,";");	 
			РКUUID = МассивРК[1]; 

			ДанныеПКГ(РКUUID,Истина);  
			ПодсветитьСтроку(ТекИдентификаторСтроки);

		Иначе
			ОбработкаФормыКлиент.ЗвукОшибки();	
		КонецЕсли;
		
	Иначе
		Если СтрЧислоВхождений(ПолученныйШтрихкод,";")=2 Тогда
			ОчиститьСообщения();
			МассивСтрок = СтрРазделить(ПолученныйШтрихкод,";");
			ИД_PKG = МассивСтрок[0];
			
			ДанныеПКГ(ИД_PKG);  
			ПодсветитьСтроку(ТекИдентификаторСтроки);
			
			//Если ПредварительныйПрием Тогда
			//	Возврат;
			//КонецЕсли;
			
			
			мКороба = Объект.Короба.НайтиСтроки(Новый Структура("ИД_Короб",ИД_PKG));
			Если мКороба.Количество() = 0 Тогда
				Возврат;
			КонецЕсли;
			СтрокаКороб = мКороба[0];
			//Если СтрокаКороб.Принят Тогда
			//	Возврат;
			//КонецЕсли;  
			ОписаниеОповещения = Новый ОписаниеОповещения("ОповещениеПриемТоваровPKG", ЭтотОбъект);
			ОткрытьФорму("Обработка.Розница.Форма.ФормаТоварыКороба"
			,Новый Структура("ТипДокумента,ИД_Короб,ИД_Документ,Товары,Документы,Короба",ТипДокумента,СтрокаКороб.ИД_Короб,СтрокаКороб.ИД_Документ,Объект.Товары,Объект.Документы,Объект.Короба)
			,ЭтотОбъект,,,,ОписаниеОповещения,РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);	
		Иначе
			ОбработкаФормыКлиент.ЗвукОшибки();	
		КонецЕсли;                 
	КонецЕсли;
	
	
КонецПроцедуры 


&НаСервере 
Функция ПолучитьСтрокуТоваров(ИД_Документ,ИД_Короб,Артикул,МРЦ,ДобавлятьСтроку = Ложь)
	
	мКороба = Объект.Товары.НайтиСтроки(Новый Структура("ИД_Документ,ИД_Короб,Артикул,МРЦ",ИД_Документ,ИД_Короб,Артикул,МРЦ));
	
	Если НЕ мКороба.Количество() Тогда     
		Если ДобавлятьСтроку Тогда
			СтрокаТоварыКороб = Объект.Товары.Добавить();
			СтрокаТоварыКороб.ИД_Документ = ИД_Документ;
			СтрокаТоварыКороб.ИД_Короб    = ИД_Короб;
			СтрокаТоварыКороб.Артикул     = Артикул;  
			СтрокаТоварыКороб.МРЦ     = МРЦ;    
		Иначе   
			СтрокаТоварыКороб = Неопределено;
		КонецЕсли;
	Иначе
		 СтрокаТоварыКороб = мКороба[0];
	КонецЕсли;
	
	Возврат СтрокаТоварыКороб;
	
КонецФункции

