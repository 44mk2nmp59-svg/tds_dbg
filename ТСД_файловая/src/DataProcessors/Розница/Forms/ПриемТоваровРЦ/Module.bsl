&НаСервере  
Процедура ДанныеПКГ(ИД_PKG,Это_RK=Ложь)
	
	
	ТекИдентификаторСтроки = 1000;
	
	Если Это_RK Тогда
		СтруктураОтвет = РозницаТК.ПолучитьДанныеPKG_На_РК(ИД_PKG); 
	Иначе
		СтруктураОтвет = РозницаТК.ПолучитьДанныеPKG(ИД_PKG,ПредварительныйПрием); 
	КонецЕсли;
	
	Если  Не СтруктураОтвет.Результат Тогда
		
		Если НЕ ПустаяСтрока(СтруктураОтвет.ОписаниеОшибки) Тогда
			Сообщить(СтруктураОтвет.ОписаниеОшибки);
		Иначе 
			Сообщить("Помилка отримання PKG");
			
		КонецЕсли;
		Возврат;
		
	КонецЕсли;
	
	Если Это_RK Тогда
		МассивPKG = СтруктураОтвет.Ответ.МассивДокументов;
		Для Каждого СтрокаPKG Из МассивPKG Цикл 
			мДокументы = Объект.Документы.НайтиСтроки(Новый Структура("ИД_Документ",СтрокаPKG.ИД_Документ));
			Если мДокументы.Количество() Тогда
				СтрокаДокумент = мДокументы[0];
			Иначе
				Сообщить("Помилка отримання PKG - "+СтрокаPKG.Номер +" від "+Формат(СтрокаPKG.Дата,"ДФ=dd.MM.yy"));
				Продолжить;
			КонецЕсли;      
			СтрокаДокумент.РК = 1;
			ТекИдентификаторСтроки = СтрокаДокумент.ПолучитьИдентификатор();
			мКороба = Объект.Короба.НайтиСтроки(Новый Структура("ИД_Короб,ИД_Документ",СтрокаPKG.ИД_PKG,СтрокаPKG.ИД_Документ)); 
			Если мКороба.Количество() Тогда 
				СтрокаКороб = мКороба[0]; 
			Иначе 
				Сообщить("Помилка отримання PKG - "+СтрокаPKG.Номер +" від "+Формат(СтрокаPKG.Дата,"ДФ=dd.MM.yy"));

				Продолжить;
			КонецЕсли;
			СтрокаКороб.Отсканирован = 1;
			СтрокаКороб.Принят = 1;
            СтрокаКороб.РК = 1;
            СтрокаДокумент.РК = 1;
			СтрокаДокумент.ПринятоPKG = ПринятоPKGДокумента(СтрокаPKG.ИД_Документ);
			СтрокаДокумент.ЗаписьПоСтроке = "Прийнято PKG - "+СтрокаДокумент.ПринятоPKG+" з "+СтрокаДокумент.ВсегоPKG+Символы.ПС+СтрокаДокумент.СкладСборки;

		КонецЦикла;
		
		
		Возврат;	
	КонецЕсли;
	
	
	
	
	СтруктураPKG = СтруктураОтвет.Ответ;
	Если СтруктураPKG.stat = 0 Тогда
		Сообщить("ВАЖЛИВО!"+Символы.ПС+СтруктураPKG.info);
		Возврат;
	КонецЕсли;
	ИД_Документ = СтруктураPKG.Основание.ОснованиеUUID; 
	мДокументы = Объект.Документы.НайтиСтроки(Новый Структура("ИД_Документ",ИД_Документ));
	
	Если мДокументы.Количество() Тогда
		СтрокаДокумент = мДокументы[0];
	Иначе   
		СтрокаДокумент = Объект.Документы.Добавить();
	КонецЕсли;   

	ТекИдентификаторСтроки = СтрокаДокумент.ПолучитьИдентификатор();
	
	СтрокаДокумент.ИД_Документ = ИД_Документ; 
	СтрокаДокумент.Номер =СтруктураPKG.Основание.Номер; 
	СтрокаДокумент.Дата =СтруктураPKG.Основание.Дата; 
	СтрокаДокумент.ВидДокумента ="Переміщення"; 
	СтрокаДокумент.ВсегоPKG = СтруктураPKG.Основание.КоличествоPKG;        
	
	
	
	мКороба = Объект.Короба.НайтиСтроки(Новый Структура("ИД_Короб,ИД_Документ",ИД_PKG,ИД_Документ));
	
	Если НЕ мКороба.Количество() Тогда
		СтрокаКороб = Объект.Короба.Добавить();
		СтрокаКороб.ИД_Короб = ИД_PKG;
		СтрокаКороб.ИД_Документ = ИД_Документ;
		СтрокаКороб.НомерУпаковки = СтруктураPKG.НомерУпаковки;
		СтрокаКороб.Отсканирован = 1;
		Если ПредварительныйПрием Тогда
			СтрокаКороб.Принят = 1;
		КонецЕсли;
	Иначе  
		СтрокаКороб = мКороба[0]; 
		СтрокаКороб.Отсканирован = 1;
		Если ПредварительныйПрием Тогда
			СтрокаКороб.Принят = 1;
		КонецЕсли;

	КонецЕсли; 
	СтрокаДокумент.ПринятоPKG = ПринятоPKGДокумента(ИД_Документ);
	СтрокаДокумент.ЗаписьПоСтроке = "Прийнято PKG - "+СтрокаДокумент.ПринятоPKG+" з "+СтрокаДокумент.ВсегоPKG+Символы.ПС+СтрокаДокумент.СкладСборки;

	
	Если СтруктураPKG.Свойство("ТоварыPKG") Тогда    
		Для Каждого стрТоварыPKG Из  СтруктураPKG.ТоварыPKG Цикл 
			СтрокаТоваров = ПолучитьСтрокуТоваров(ИД_Документ,ИД_PKG,стрТоварыPKG.Артикул,стрТоварыPKG.МРЦ,Истина);  
			СтрокаТоваров.НаименованиеТовара = стрТоварыPKG.Tovar;
			СтрокаТоваров.НаименованиеЕдиницы = стрТоварыPKG.ЕдИзм;
			СтрокаТоваров.Коэффициент = стрТоварыPKG.Коф;
			СтрокаТоваров.КоличествоПоставщика = стрТоварыPKG.Кол;
			СтрокаТоваров.Весовой  = стрТоварыPKG.фВес;
			СтрокаТоваров.МРЦ   = стрТоварыPKG.МРЦ;     
			
			Если стрТоварыPKG.Свойство("sht") Тогда
				Если стрТоварыPKG.Свойство("sht2")	И стрТоварыPKG.sht2 <> 0 Тогда  
					СтрокаТоваров.ПриемДо = ТекущаяДата()+(стрТоварыPKG.sht/100)*стрТоварыPKG.sht2*86400-864000;
				Иначе
					СтрокаТоваров.ПриемДо = ТекущаяДата()+(стрТоварыPKG.sht/3*2)*86400-864000;
				КонецЕсли
			КонецЕсли;
		КонецЦикла;  
	КонецЕсли;
	

КонецПроцедуры



