&НаКлиенте
Перем ВыполняетсяЗакрытие;


	
   
   
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	ИД_Короб = Параметры.ИД_Короб;   
	ИД_Документ = Параметры.ИД_Документ;
	МДокумент = Параметры.Документы.НайтиСтроки(Новый Структура("ИД_Документ",Параметры.ИД_Документ)); 
	НомерДокумент = МДокумент[0].Номер; 
	ДатаДокумента = МДокумент[0].Дата;
    ТипДокумента = Параметры.ТипДокумента;
	МКороба = Параметры.Короба.НайтиСтроки(Новый Структура("ИД_Короб",Параметры.ИД_Короб));
    PKG = МКороба[0].НомерУпаковки;
	
	МТоварыДокумента = Параметры.Товары.НайтиСтроки(Новый Структура("ИД_Короб",Параметры.ИД_Короб)); 
	Если МТоварыДокумента.Количество() = 0 Тогда
		Отказ = истина;
		Сообщить("Відскануйте PKG");
		Возврат;
	КонецЕсли;
	
	сч = 1;
	Для Каждого СтрокаМтоварыДокумента Из МТоварыДокумента Цикл 
		   СтрокаТоварыPKG =  ТоварыPKG.Добавить(); 
		   ЗаполнитьЗначенияСвойств(СтрокаТоварыPKG,СтрокаМтоварыДокумента);   
		   СтрокаТоварыPKG.НомерСтроки = сч;
		   ОбновитьЗаписьПоСтроке(,СтрокаТоварыPKG); 
		   сч = сч +1;
	КонецЦикла;
	
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	ВыполняетсяЗакрытие = Ложь; 

КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	
	Если НЕ ВыполняетсяЗакрытие Тогда
		Отказ = Истина;
		ПоказатьВопрос(Новый ОписаниеОповещения("ПередЗакрытиемЗавершение",ЭтотОбъект),"Закрити PKG?"+Символы.ПС+"Без збереження!",РежимДиалогаВопрос.ДаНет);
	КонецЕсли;
	
КонецПроцедуры 

 &НаКлиенте
Процедура ПередЗакрытиемЗавершение(РезультатВопроса,ДопоплнительныеПараметры) Экспорт
	
	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
		ВыполняетсяЗакрытие = Истина;
		Закрыть();
	КонецЕсли;
	
	
КонецПроцедуры  



&НаСервере
Процедура ОбновитьЗаписьПоСтроке(ИдентификаторСтроки = Неопределено,Знач Строка = Неопределено)
	
	Если НЕ ИдентификаторСтроки = Неопределено Тогда
		СтрокаТовара = ТоварыPKG.НайтиПоИдентификатору(ИдентификаторСтроки);
	Иначе
		СтрокаТовара = Строка;
	КонецЕсли;
	
	//Если СтрокаТовара.МРЦ<>0  Тогда
	//	тНаименованиеТовара = СтрокаТовара.НаименованиеТовара  + " МРЦ - " + СтрокаТовара.МРЦ;
	//Иначе
	//	тНаименованиеТовара = СтрокаТовара.НаименованиеТовара;
	//КонецЕсли;
	Цвет = 0;
	Если СтрокаТовара.КоличествоВведено = СтрокаТовара.КоличествоПоставщика Тогда
		 Цвет = 1;
	 ИначеЕсли СтрокаТовара.КоличествоВведено> 0 И СтрокаТовара.КоличествоВведено <> СтрокаТовара.КоличествоПоставщика Тогда
		  Цвет = 2;
	 КонецЕсли;
		 
	СтрокаТовара.Цвет = Цвет;	 
	//
	//ЧастьСтроки = Новый Массив;
	//Формат(СтрокаТовара.НомерСтроки,"ЧГ=") +", "+ СтрокаТовара.Артикул +", "+ СтрокаТовара.НаименованиеТовара+?(СтрокаТовара.МРЦ<>0," МРЦ-"+Формат(СтрокаТовара.МРЦ,"ЧГ="),"")+Символы.ПС
	
	ЗаписьПоСтроке = "%сдп% Прий. %КоличествоВведено% із %Количество%%НаименованиеЕдиницы% Х %Коэффициент% %МРЦ%";
	ЗаписьПоСтроке = СтрЗаменить(ЗаписьПоСтроке, "%КоличествоВведено%",    Формат(СтрокаТовара.КоличествоВведено, ?(СтрокаТовара.Весовой = 1,ЗначениеНастроекПовтИсп.ФорматВес(),ЗначениеНастроекПовтИсп.ФорматЦелоеЧисло())));
	ЗаписьПоСтроке = СтрЗаменить(ЗаписьПоСтроке, "%Количество%",           Формат(СтрокаТовара.КоличествоПоставщика,?(СтрокаТовара.Весовой = 1,ЗначениеНастроекПовтИсп.ФорматВес(),ЗначениеНастроекПовтИсп.ФорматЦелоеЧисло())));
	ЗаписьПоСтроке = СтрЗаменить(ЗаписьПоСтроке, "%НаименованиеЕдиницы%",  Строка(СтрокаТовара.НаименованиеЕдиницы));
	ЗаписьПоСтроке = СтрЗаменить(ЗаписьПоСтроке, "%Коэффициент%",          Строка(СтрокаТовара.Коэффициент));
	ЗаписьПоСтроке = СтрЗаменить(ЗаписьПоСтроке, "%МРЦ%",   ?(СтрокаТовара.МРЦ<>0," МРЦ - " + СтрокаТовара.МРЦ,""));
	
	ЗаписьПоСтроке = СтрЗаменить(ЗаписьПоСтроке, "%сдп%",      ?(ЗначениеЗаполнено(СтрокаТовара.ПриемДо), "ддп "+Формат(СтрокаТовара.ПриемДо,"ДФ=dd.MM.yyyy"),""));
	СтрокаТовара.ЗаписьПоСтроке = ЗаписьПоСтроке;
		
КонецПроцедуры  


&НаСервере
Процедура ОбработатьСтроку(ИдентификаторСтроки,ДанныеТовара)

	
	ТекИдентификаторСтроки = ИдентификаторСтроки;
	
	СтрокаТовара = ТоварыPKG.НайтиПоИдентификатору(ИдентификаторСтроки);
	
	СтрокаТовара.КоличествоВведено = СтрокаТовара.КоличествоВведено + ДанныеТовара.Количество;
	
	
	Если СтрокаТовара.КоличествоВведено > СтрокаТовара.КоличествоПоставщика Тогда
		Сообщить("Відскановано: "+Формат(СтрокаТовара.КоличествоВведено, "ЧЦ=15; ЧДЦ=3; ЧН=; ЧГ=")+Символы.ПС +"можна прийняти: "+Формат(СтрокаТовара.КоличествоПоставщика, "ЧЦ=15; ЧДЦ=3; ЧН=; ЧГ="));
		
		СтрокаТовара.КоличествоВведено = СтрокаТовара.КоличествоПоставщика;
		СтрокаТовара.КоличествоРасхождение =  СтрокаТовара.КоличествоПоставщика - СтрокаТовара.КоличествоВведено;
		
		
	Иначе
		СтрокаТовара.КоличествоРасхождение =  СтрокаТовара.КоличествоПоставщика - СтрокаТовара.КоличествоВведено;
		
	КонецЕсли;  
	ОбновитьЗаписьПоСтроке(,СтрокаТовара);
КонецПроцедуры



