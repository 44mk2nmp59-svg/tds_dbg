&НаКлиенте
Процедура ТоварыВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	ПараметрыСтроки = ПолучитьПараметрыСтроки();
	ТекИдентификаторСтроки =  ПараметрыСтроки.ИдентификаторСтроки;
	
	Если НЕ ПараметрыСтроки = Неопределено Тогда
		
		ДополнительныеПараметры = Новый Структура;
		ДополнительныеПараметры.Вставить("ИдентификаторСтроки", ПараметрыСтроки.ИдентификаторСтроки);
		
		ОписаниеОповещения = Новый ОписаниеОповещения("ОповещениеИзменитьСтроку", ЭтотОбъект, ДополнительныеПараметры);
		
		ОткрытьФорму("ОбщаяФорма.РедактированиеСтрокиV2", ПараметрыСтроки, ЭтаФорма,,,,ОписаниеОповещения);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Функция ПолучитьПараметрыСтроки()
	
	ТекущиеДанные = Элементы.ТоварыPKG.ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	СтруктураПараметров = Новый Структура;
	
	СтруктураПараметров.Вставить("ИдентификаторСтроки", ТекущиеДанные.ПолучитьИдентификатор());
	СтруктураПараметров.Вставить("НомерСтроки",         ТекущиеДанные.НомерСтроки);
	СтруктураПараметров.Вставить("НаименованиеТовара",        ТекущиеДанные.НаименованиеТовара);
	СтруктураПараметров.Вставить("НаименованиеЕдиницы",          ТекущиеДанные.НаименованиеЕдиницы);
	СтруктураПараметров.Вставить("Коэффициент",                ТекущиеДанные.Коэффициент);
	СтруктураПараметров.Вставить("КоличествоПоставщика",                ТекущиеДанные.КоличествоПоставщика);
	СтруктураПараметров.Вставить("КоличествоВведено",                ТекущиеДанные.КоличествоВведено);
	СтруктураПараметров.Вставить("Коэффициент",                ТекущиеДанные.Коэффициент);
	СтруктураПараметров.Вставить("Весовой",                ТекущиеДанные.Весовой);
	СтруктураПараметров.Вставить("МРЦ",                ТекущиеДанные.МРЦ);
	СтруктураПараметров.Вставить("ТипДокумента",           ТипДокумента);   
	Если ТекущиеДанные.МРЦ = 0 Тогда
		СтруктураПараметров.Вставить("ИспМРЦ",Ложь);
	Иначе
		СтруктураПараметров.Вставить("ИспМРЦ",Истина);   
	КонецЕсли;
	

	Возврат СтруктураПараметров;

КонецФункции


&НаКлиенте
Процедура ОповещениеИзменитьСтроку(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено ИЛИ Результат = КодВозвратаДиалога.Отмена Тогда
		Возврат;
	КонецЕсли;                   	
	ИдентификаторСтроки = ДополнительныеПараметры.ИдентификаторСтроки;
	СтрокаТаблицы = ТоварыPKG.НайтиПоИдентификатору(ИдентификаторСтроки);
	//
	Если Результат.Свойство("Сохранить") Тогда
		
		ЗаполнитьЗначенияСвойств(СтрокаТаблицы, Результат,"КоличествоВведено,КоличествоРасхождение");
		
		ОбновитьЗаписьПоСтроке(ИдентификаторСтроки);
		
		Модифицированность = Истина;
		
		ПодсветитьСтроку(ИдентификаторСтроки);
	КонецЕсли;

	
КонецПроцедуры



&НаКлиенте
Процедура СтрокаПоискаТоварыПриИзменении(Элемент)
	ОбработатьВводСтрокиШК();
КонецПроцедуры




&НаКлиенте
Процедура ОбработатьВводСтрокиШК()
	Если ПустаяСтрока(СтрокаПоиска) Тогда
		Возврат;
	КонецЕсли;



	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("Форма", ЭтотОбъект);
	ОбработатьПолученныйШтрихкод(СтрокаПоиска, ДополнительныеПараметры);
	
КонецПроцедуры

 
&НаКлиенте
Процедура ОбработатьПолученныйШтрихкод(ПолученныйШтрихкод, Параметры) Экспорт
	Если ПустаяСтрока(ПолученныйШтрихкод) Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыТовара  = "ШтрихКод|Тара|ИспМРЦ";
	
	ДанныеПоТовару = ИнтеграцияТК_Клиент.ПолучитьДанныеПоТоваруКлиент(ПолученныйШтрихкод,,Ложь,ПараметрыТовара);
	
	ОбработатьПолученныеДанные(ДанныеПоТовару,Параметры);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьПолученныеДанные(ДанныеПоТовару, ДополнительныеПараметры) Экспорт
	
	Если ДанныеПоТовару.Результат = ложь Тогда
		Сообщить(?(ЗначениеЗаполнено(ДанныеПоТовару.ОписаниеОшибки), ДанныеПоТовару.ОписаниеОшибки,"Дані за штрих-кодом не отримані"));
		Возврат;
	КонецЕсли;
	
	ДанныеТовара = ДанныеПоТовару.Ответ;
		
	Если ДанныеТовара.Свойство("ИспМРЦ")  И Булево(ДанныеТовара.ИспМРЦ) Тогда
		
		
		///Костыль
	//	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма,"СтрокаПоиска","Вид",ВидПоляФормы.ПолеНадписи);
		
		ВыбратьМРЦ_Асинх(ДанныеТовара,ДополнительныеПараметры);
		
	Иначе
		ОбработатьПолученныеДанныеВыбор(ДанныеТовара, ДополнительныеПараметры) 
	КонецЕсли;
	//
Конецпроцедуры

 &НаКлиенте
Асинх Процедура ВыбратьМРЦ_Асинх(ДанныеТовара,ДополнительныеПараметры)
	Обещание =  ВвестиЧислоАсинх(0,"МРЦ",10,2);
	ВыбМРЦ = Ждать Обещание;  
	ОбработатьПолученныеДанныеВыбор(ДанныеТовара,ДополнительныеПараметры,ВыбМРЦ);
КонецПроцедуры  


 &НаКлиенте
Процедура ОбработатьПолученныеДанныеВыбор(ДанныеТовара, ДополнительныеПараметры,МРЦ=0) 
	
		
	
	ИД_Строка = ОпределитьСтроку(ДанныеТовара.Артикул,МРЦ);
	ТекИдентификаторСтроки = ИД_Строка;
	Если ИД_Строка = Неопределено Тогда
		
		ЗвукОшибки(Истина,"Товару немає в PKG!");
		Возврат;
	КонецЕсли;
	
	
	ОбработатьСтроку(ИД_Строка,ДанныеТовара);
	ПодсветитьСтроку(ИД_Строка);
	
	СтрокаПоиска ="";
КонецПроцедуры

 &НаСервере
Функция ОпределитьСтроку(Артикул,МРЦ=0)
	
			
	НайденныеСтроки = ТоварыPKG.НайтиСтроки(Новый Структура("Артикул,МРЦ", Артикул,МРЦ));

	Если НайденныеСтроки.Количество() = 0 Тогда
		Возврат Неопределено;
	Иначе
		СтрокаТЧ = НайденныеСтроки[0];
		
	КонецЕсли;
	
	Возврат СтрокаТЧ.ПолучитьИдентификатор();
	
КонецФункции


&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ПодключаемоеОборудованиеКлиент.ЭтоОповещениеСканераШтрихкода(ИмяСобытия) И ВводДоступен() Тогда
		ДополнительныеПараметры = Новый Структура;
		ДополнительныеПараметры.Вставить("Форма", ЭтотОбъект);
		ОбработатьПолученныйШтрихкод(Параметр, ДополнительныеПараметры);
	КонецЕсли;
	
КонецПроцедуры

 &НаКлиенте
Процедура ЗвукОшибки(ВыполнитьОшибку = Ложь,ТекстОшибки ="")
	
	#Если МобильноеПриложениеКлиент Тогда
		
		СредстваМультимедиа.ВоспроизвестиЗвуковоеОповещение("errorscan",Истина);
		
	#КонецЕсли
	
	Если ВыполнитьОшибку Тогда
		
		 ВызватьИсключение ТекстОшибки;
	КонецЕсли;
	
	
КонецПроцедуры

&НаКлиенте
Процедура ПодсветитьСтроку(ИдентификаторСтроки)
	
	
	СтрокаТоваров = ТоварыPKG.НайтиПоИдентификатору(ИдентификаторСтроки);
	Если НЕ СтрокаТоваров = Неопределено Тогда
		Элементы.ТоварыPKG.ТекущаяСтрока = ТекИдентификаторСтроки;
	
		НомерСтрокиДляПодсветки = СтрокаТоваров.НомерСтроки;
	
		ПодключитьОбработчикОжидания("Подключаемый_ТекущаяСтрока", 1,Истина);
		
		ИнтервалСек = 2;
		ПодключитьОбработчикОжидания("Подключаемый_ОчиститьНомерСтрокиДляПодсветки", ИнтервалСек,Истина);
	КонецЕсли;
	
КонецПроцедуры


&НаКлиенте
Процедура Подключаемый_ОчиститьНомерСтрокиДляПодсветки()
	
	НомерСтрокиДляПодсветки = Неопределено;
	
КонецПроцедуры


&НаКлиенте
Процедура Подключаемый_ТекущаяСтрока()
	
	Элементы.ТоварыPKG.ТекущаяСтрока = ТекИдентификаторСтроки;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗавершитьПриемPKG(Команда)
		
	ТоварыРасхождение.Очистить();
	
	Для Каждого пТовары Из ТоварыPKG Цикл
		расх = пТовары.КоличествоВведено - пТовары.КоличествоПоставщика;
		Если расх <> 0 Тогда
			
			нтРс = ТоварыРасхождение.Добавить();	 
			нтРс.Количество = расх;
			нтРс.СтрокаИД = пТовары.ПолучитьИдентификатор();
			нтРс.СтрокаТовара = пТовары.Артикул+?(пТовары.МРЦ>0," МРЦ-"+Формат(пТовары.МРЦ,"ЧЦ=10; ЧДЦ=2"),"")+ " "+пТовары.НаименованиеТовара;  
		КонецЕсли;
	КонецЦикла; 
	
	Если ТоварыРасхождение.Количество() Тогда
		
		ДополнительныеПараметры = Новый Структура;
		ДополнительныеПараметры.Вставить("ТаблицаРасхождений", ТоварыРасхождение);
		ДополнительныеПараметры.Вставить("ПарамВопрос", "ПриемPKG");	
		ОписаниеОповещения = Новый ОписаниеОповещения("ОповещениеАктПоПриему", ЭтотОбъект);
		
		ОткрытьФорму("ОбщаяФорма.ФормаВопрос", ДополнительныеПараметры, ЭтаФорма,,,,ОписаниеОповещения);
	Иначе
		ВыполняетсяЗакрытие = Истина;	
		Закрыть(Новый Структура("ИД_Документ,ИД_Короб,ТоварыPKG",ИД_Документ,ИД_Короб,ТоварыPKG)); 
	КонецЕсли;
	
		

КонецПроцедуры

 &НаКлиенте
Процедура ОповещениеАктПоПриему(Результат, Параметры)Экспорт
	
	Если Результат.СоздатьАКТ Тогда
		
		Для Каждого СтрПричина Из Результат.ТабицаПричин Цикл 
			
			СтрокаТоваров = ТоварыPKG.НайтиПоИдентификатору(СтрПричина.СтрокаИД);
			СтрокаТоваров.ПричинаРасхождения = СтрПричина.Причина; 
			
		КонецЦикла;
		
		ВыполняетсяЗакрытие = Истина;	
		Закрыть(Новый Структура("ИД_Документ,ИД_Короб,ТоварыPKG",ИД_Документ,ИД_Короб,ТоварыPKG)); 	
		
	КонецЕсли;
	
КонецПроцедуры


