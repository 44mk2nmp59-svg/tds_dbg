&НаКлиенте
Процедура ОткрытьДиалогСканирования()
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("Форма", ЭтаФорма);
	ДополнительныеПараметры.Вставить("ПотоковоеСканирование");
	ДополнительныеПараметры.Вставить("ЗаголовокСканирования", НСтр("ru = 'Считайте штрих-код'"));
	ДополнительныеПараметры.Вставить("ИмяОбработчикаЗакрытияСканирования", "ОбработкаЗакрытияСканирования");
	
	ПодключаемоеОборудованиеКлиент.ПолучитьШтрихкод(ДополнительныеПараметры);
	
КонецПроцедуры

 &НаКлиенте
Процедура СообщениеИнициализацииПользователяНажатие(Элемент)
	ДополнительныеПараметры = Новый Структура;
	ДопПарметрыФормы = Новый Структура;
	опЗакрытие = Новый ОписаниеОповещения("ВыполнитьПослеЗакрытияВводаСотрудника",ЭтаФорма,ДополнительныеПараметры);
	ОткрытьФорму("Обработка.Сервис.Форма.ИнициализацияСотрудник",ДопПарметрыФормы, ЭтаФорма,,,,опЗакрытие, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);

КонецПроцедуры




//////
&НаСервере
Процедура ПолучитьДанныеPKG_В_Дороге()

 текстЗапроса = "/Logistika/"+ПараметрыСеанса.UUID+"/PKGroad?uuidcom="+ПараметрыСеанса.Сотрудник_ID;

  РезОтвет = КомплектовщикТК.ПодготовитьGETЗапрос(текстЗапроса);
  Объект.Документы.Очистить();
  
  Если РезОтвет.Результат Тогда
	  
	 МассивДокументы = РезОтвет.Ответ; 
	 Для Каждого ДокументыДоставки Из МассивДокументы Цикл 
	    НстрокаДоставка =  Объект.Документы.Добавить();
	    НстрокаДоставка.ТочкаДоставки  = ДокументыДоставки.АдресДоставки;
	    НстрокаДоставка.сч_док  = ДокументыДоставки.сч_док;    
		НстрокаДоставка.ЗаписьПоСтроке = ДокументыДоставки.АдресДоставки;   
		НстрокаДоставка.ЗаписьПоСтроке2 = "PKG "+Формат(НстрокаДоставка.сч_док,"ЧЦ=10; ЧГ=");
	    Для Каждого СтрокаPKG Из  ДокументыДоставки.МассивPKG Цикл 
	    	 НстрокаPKG =  Объект.Документы.Добавить();
	    	 НстрокаPKG.ИД_УП  = СтрокаPKG.ИД_PKG;
	 //        НстрокаPKG.РК = СтрокаТочкаДоставки.РК;
 	    	 НстрокаPKG.ЗаписьПоСтроке =  "PKG "+  СтрокаPKG.НомерPKG+ " від "+СтрокаPKG.ДатаPKG;
	     КонецЦикла;
	 КонецЦикла;
	 
	  
  Иначе
	 тОш =  ?(ЗначениеЗаполнено(РезОтвет.ОписаниеОшибки),РезОтвет.ОписаниеОшибки,"Помилка отримання даних"); 
	 Сообщить(тОш);    
	 ОбщегоНазначенияКлиентСервер.ОчиститьСотрудника();
	 ОбновитьСотрудника();
  КонецЕсли;
  

КонецПроцедуры

&НаСервере
Функция ПечатьНаСервере(ИД_УП)
	текстЗапроса = "/Logistika/"+ПараметрыСеанса.UUID+"/PKGprint?uuidcom="+ПараметрыСеанса.Сотрудник_ID+"&chk="+ИД_УП;
	
	РезОтвет = КомплектовщикТК.ПодготовитьGETЗапрос(текстЗапроса);
    Возврат РезОтвет;
КонецФункции



&НаКлиенте
Процедура Подключаемый_ТекущаяСтрока()
	
	Элементы.Документы.ТекущаяСтрока = ТекИдентификаторСтроки;
	
КонецПроцедуры


&НаКлиенте
Процедура Подключаемый_ОчиститьНомерСтрокиДляПодсветки()
	
	НомерСтрокиДляПодсветки = Неопределено;
	
КонецПроцедуры


&НаКлиенте
Процедура ДокументыВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
    ТекущиеДанные = Элементы.Документы.ТекущиеДанные;
	Если НЕ ЗначениеЗаполнено(ТекущиеДанные.ИД_УП) Тогда
		Возврат;
	КонецЕсли;
	
	Ответ = ПечатьНаСервере(ТекущиеДанные.ИД_УП);
	Если Ответ.Результат = Ложь Тогда
		Сообщить(Ответ.ОписаниеОшибки);
	Иначе
		ОбщегоНазначенияКлиент.ВывестиПДФ_НаПечать(Base64Значение(Ответ.Ответ));
	КонецЕсли;
	
	
КонецПроцедуры



&НаКлиенте
Процедура ОбновитьСписок(Команда)
	Если ПользовательИнициализирован Тогда
		ПолучитьДанныеPKG_В_Дороге();	
	КонецЕсли;
	
КонецПроцедуры


