&НаКлиенте
Процедура Записать(Команда)
	ОчиститьСообщения();
	Если НЕ Объект.Документы.НайтиСтроки(Новый Структура("Короб,сч_скан",Истина,0)).Количество() = 0 Тогда
		 Сообщить("Не всі PKG відскановані");
		Возврат;
	КонецЕсли;
	
	 ЗакончитьЗагрузкуАсинх();

КонецПроцедуры

&НаКлиенте
Асинх Процедура ЗакончитьЗагрузкуАсинх()
    Режим = РежимДиалогаВопрос.ДаНет;
    Ответ = Ждать ВопросАсинх("Завантажити дані сканування?", Режим, 0);
    Если Ответ = КодВозвратаДиалога.Нет Тогда
        Возврат;
	КонецЕсли;  
	
	РезультатВыгрузки = ВыгрузитьРезультатыСканирования();
	Если НЕ РезультатВыгрузки.Результат Тогда  
		Если НЕ ПустаяСтрока(РезультатВыгрузки.ОписаниеОшибки) Тогда
			Сообщить(РезультатВыгрузки.ОписаниеОшибки); 
		КонецЕсли;
		
		Возврат;
	КонецЕсли; 
	
	ВыполняетсяЗакрытие = Истина;
	Закрыть();
	
	
КонецПроцедуры

&НаКлиенте
Процедура ДокументыВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	ТекущиеДанные = Элементы.Документы.ТекущиеДанные;
	ОткрытьФорму("ОбщаяФорма.ФормаПечати",СформироватьСтруктуруДляПечатиНаСервере(ТекущиеДанные.ТЧ_Global_ID,ТекущиеДанные.ИД_ТТН,ТекущиеДанные.ТочкаДоставки),ЭтаФорма,,,,,РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);

КонецПроцедуры

&НаСервере
Функция СформироватьСтруктуруДляПечатиНаСервере(ТЧ_Global_ID,ИД_ТТН,ТочкаДоставки)
	
	МассивСтрок = Объект.Документы.НайтиСтроки(Новый Структура("ТЧ_Global_ID,ИД_ТТН,Короб",ТЧ_Global_ID,ИД_ТТН,Истина));	 
	ТаблицаPKG = Объект.Документы.Выгрузить(МассивСтрок,"СкладСборки,НомерТУ,сч_скан");
	ТаблицаPKG.Свернуть("СкладСборки,НомерТУ","сч_скан");
	СтруктураСтрок = Новый Структура;
	СтруктураСтрок.Вставить("PKG");
	СтруктураСтрок.Вставить("ТочкаДоставки",ТочкаДоставки);
	МассивPKG = Новый Массив;
	Для Каждого ТекТаблицаPKG Из ТаблицаPKG Цикл 
		МассивPKG.Добавить(Новый Структура("СкладСборки,НомерТУ,сч_скан",ТекТаблицаPKG.СкладСборки,ТекТаблицаPKG.НомерТУ,ТекТаблицаPKG.сч_скан));
	КонецЦикла;
	СтруктураСтрок.Вставить("ДанныеPKG",МассивPKG);
	
	Возврат СтруктураСтрок;
	
КонецФункции


