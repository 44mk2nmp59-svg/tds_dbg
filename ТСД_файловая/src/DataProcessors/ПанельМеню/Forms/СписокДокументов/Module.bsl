
&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ПодключаемоеОборудованиеКлиент.ЭтоОповещениеСканераШтрихкода(ИмяСобытия) И ВводДоступен() Тогда
		
		Если ТипыДокументов = ПредопределенноеЗначение("Перечисление.ТипыДокументов.ПриемПоЗаказу")
			ИЛИ ТипыДокументов = ПредопределенноеЗначение("Перечисление.ТипыДокументов.Перемещение") 
			ИЛИ ТипыДокументов = ПредопределенноеЗначение("Перечисление.ТипыДокументов.ПриемТоваров") Тогда	
			ДополнительныеПараметры = Новый Структура;
			ДополнительныеПараметры.Вставить("Форма", ЭтаФорма);
			ОбработатьПолученныйШтрихкод(Параметр, ДополнительныеПараметры);
		КонецЕсли;
		
	ИначеЕсли ИмяСобытия = "ИзмененыЗначенияНастроек" Тогда
		
		НастроитьФормуПоЗначениямНастроек();
		
	ИначеЕсли ИмяСобытия = "ИзмененоПодразделение" Тогда
		
		ОбновитьПодразделение();   
		
	ИначеЕсли  ИмяСобытия = "KeyPress"  И ВводДоступен() Тогда
		Если ЭтаФорма.ТекущийЭлемент	= Элементы.КонтрагентОтбор Тогда
			Если  НРег(Параметр) = "enter"Тогда
				ПолучитьКонтрагента(Неопределено);
			КонецЕсли;
			
		КонецЕсли;
	ИначеЕсли ИмяСобытия = "ОбновитьЗадания" Тогда
		
		  ЗаполнитьСписокЗаданий();
		  
	КонецЕсли;

КонецПроцедуры



&НаКлиенте
Процедура ОбработатьПолученныйШтрихкод(ПолученныйШтрихкод, Параметры) Экспорт
	
	СтрокаПоиска = ПолученныйШтрихкод;
	Если ПустаяСтрока(ПолученныйШтрихкод) Тогда
		Возврат;
	КонецЕсли;
	
	Если ТипыДокументов = ПредопределенноеЗначение("Перечисление.ТипыДокументов.ПриемПоЗаказу") Тогда
		
		ДанныеЗаказа = ИнтеграцияТК_Клиент.ПолучитьДанныеПоЗаказам(ПолученныйШтрихкод);
		
		ОбработатьПолученныеДанные(ДанныеЗаказа,Параметры);
		
	ИначеЕсли ТипыДокументов = ПредопределенноеЗначение("Перечисление.ТипыДокументов.Перемещение") Тогда
	    ОбработатьШтрихкодПеремещения(ПолученныйШтрихкод);
	ИначеЕсли ТипыДокументов = 	ПредопределенноеЗначение("Перечисление.ТипыДокументов.ПриемТоваров") Тогда
		ДанныеЗаказа = ИнтеграцияТК_Клиент.ПолучитьДанныеПоЗаказам(ПолученныйШтрихкод,0);
	
		ОбработатьПолученныеДанные(ДанныеЗаказа,Параметры);
	КонецЕсли;
	СтрокаПоиска = "";
	
КонецПроцедуры


&НаКлиенте
Процедура ОбработатьПолученныеДанные(ДанныеЗаказа, ДополнительныеПараметры) Экспорт
	
	Если ДанныеЗаказа.Результат = ложь Тогда
		Сообщить(?(ЗначениеЗаполнено(ДанныеЗаказа.ОписаниеОшибки), ДанныеЗаказа.ОписаниеОшибки,"Данные не получены"));
		Возврат;
	КонецЕсли;
	
	ЗаполнитьТаблицуЗаказов(ДанныеЗаказа);
	
Конецпроцедуры

&НаКлиенте
Процедура ОбработатьШтрихкодПеремещения(ПолученныйШтрихкод)
	
	Если ПустаяСтрока(ПолученныйШтрихкод) Тогда
		Сообщить("Штрих-код не введен! Форма не будет открыта!");
	Иначе		
		
		Если СтрДлина(ПолученныйШтрихкод)<= 10 Тогда
			ПараметрыДокумента = Новый Структура;
			ПараметрыДокумента.Вставить("ВидДокумента", "ПеремещениеТоваров");
			ПараметрыДокумента.Вставить("ДокументUUID", ПолученныйШтрихкод);
			
			ДанныеДокумента = ИнтеграцияТК_ВызовСервера.ПолучитьДанныеДокумента(ПараметрыДокумента);
			Если ДанныеДокумента.Результат Тогда
				
				ОписаниеОповещения = Новый ОписаниеОповещения("ОповещениеВыборДокументаПеремещение", ЭтотОбъект);
				
				тПараметры = Новый Структура("ТаблицаДокумтов", ДанныеДокумента.Ответ);
				ОткрытьФорму("ОбщаяФорма.ФормаВыбораПеремещения",тПараметры,Этаформа,,,,ОписаниеОповещения,РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);	
				
			Иначе
				Сообщить(ДанныеДокумента.ОписаниеОшибки);
			КонецЕсли;
			
			
			
		Иначе
			
			ПараметрыФормы = Новый Структура;
			ПараметрыФормы.Вставить("ТипДокумента", ПредопределенноеЗначение("Справочник.ТипыДокументов.ПеремещениеТоваров"));
			ПараметрыФормы.Вставить("ОснованиеUUID", СокрЛП(ПолученныйШтрихкод));
			ПараметрыФормы.Вставить("ЦветоваяИндикация", ЦветоваяИндикация);
			ПараметрыФормы.Вставить("ПриходПоПеремещению", Истина);
			
			ОткрытьФорму("Обработка.ПанельМеню.Форма.ФормаДокумента", ПараметрыФормы, ЭтаФорма,,,,, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
		КонецЕсли;	
	КонецЕсли;	
	
КонецПроцедуры
&НаКлиенте
Процедура ОповещениеВыборДокументаПеремещение(ПолученныйШтрихкод,ДополнительныеПараметры)Экспорт
	
	Если ПолученныйШтрихкод = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ТипДокумента", ПредопределенноеЗначение("Справочник.ТипыДокументов.ПеремещениеТоваров"));
	ПараметрыФормы.Вставить("ОснованиеUUID", "OS-"+СокрЛП(ПолученныйШтрихкод));
	ПараметрыФормы.Вставить("ЦветоваяИндикация", ЦветоваяИндикация);
	ПараметрыФормы.Вставить("ПриходПоПеремещению", Истина);
	
	ОткрытьФорму("Обработка.ПанельМеню.Форма.ФормаДокумента", ПараметрыФормы, ЭтаФорма,,,,, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	
	
КонецПроцедуры



&НаСервере
Процедура ЗаполнитьТаблицуЗаказов(ДанныеЗаказа) 
	
	Объект.Документы.Очистить();
	Если  ТипыДокументов = 	ПредопределенноеЗначение("Перечисление.ТипыДокументов.ПриемТоваров")  Тогда
		ТД = "Поступление";
	Иначе
		 ТД = "Заказ";
	КонецЕсли;
	
	Для Каждого СтрДок Из ДанныеЗаказа.Ответ Цикл 
		нСтрока = Объект.Документы.Добавить();
		нСтрока.ТипДокумента = ТД;
		нСтрока.Дата =  СтрДок.ДатаПоставки;
		нСтрока.НомерДокумента =  СтрДок.Номер;
		нСтрока.Контрагент =  СтрДок.Поставщик;
		нСтрока.ДокументUUID =  СтрДок.Док_ID;
		нСтрока.Сумма =  СтрДок.Сумма;
		ОбновитьЗаписьПоСтроке(нСтрока);
	КонецЦикла;
	
	УстановитьВидимостьСтраницСервер();
	
		
	
КонецПроцедуры

&НаСервере
Процедура УстановитьВидимостьСтраницСервер()
	
	
		Если Объект.Документы.Количество() > 0 Тогда
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "СтраницаОтбор", "Видимость", Ложь);
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "СтраницаДокументы", "Видимость", Истина);
		Иначе
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "СтраницаОтбор", "Видимость", Истина);
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "СтраницаДокументы", "Видимость", Ложь);
			
		КонецЕсли; 

КонецПроцедуры

&НаСервере
Процедура ОбновитьДанныеФормыПоПечатиНаСервере(ИдентификаторСтроки,РезультатПечати)
	
	СтрокаТаблицы = Объект.Документы.НайтиПоИдентификатору(ИдентификаторСтроки);

	ДанныеПечати = РезультатПечати.ДанныеПоПечати;
	МассивТоваров = ДанныеПечати.Товары;
	СтрокаТаблицы.КоличествоПринято = МассивТоваров.Количество();
	
	Если СтрокаТаблицы.КоличествоПринято =  СтрокаТаблицы.КоличествоПоставщика Тогда
		СтрокаТаблицы.ДокументЗакрыт = 2;
	ИначеЕсли СтрокаТаблицы.КоличествоПринято <> 0 Тогда
		СтрокаТаблицы.ДокументЗакрыт = 1;
	Иначе
		СтрокаТаблицы.ДокументЗакрыт = 0;
	КонецЕсли;
	
	Для Каждого ТоварПечать Из МассивТоваров Цикл 
		нСтрокиТоваров = Объект.Товары.НайтиСтроки(ТоварПечать);
		Если нСтрокиТоваров.Количество()> 0 Тогда
			нСтрокиТоваров[0].КоличествоПодтверждено = 1;
		КонецЕсли;
		
	КонецЦикла;
	
	

	
КонецПроцедуры



&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	 		
	Если Параметры.Свойство("АвтоТест") Тогда
		Возврат;
	КонецЕсли;
	 
	
	ПериодДокументов = ТекущаяДата();
	
	Если Параметры.Свойство("КлючОткрытия") Тогда
		
		ТипыДокументов = Перечисления.ТипыДокументов.Задание;
		Если Параметры.КлючОткрытия = "Задание" Тогда
			Заголовок = "Задачи";
			ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Задание");
		ИначеЕсли Параметры.КлючОткрытия = "ЗаданиеВФ" Тогда
			
			Заголовок = "Верификация";
			ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеВФ");
		ИначеЕсли Параметры.КлючОткрытия = "ЗаданиеТБД" Тогда
	        Заголовок = "Не продається";//"ТБД";
			ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеТБД");
		ИначеЕсли Параметры.КлючОткрытия = "ЗаданиеТНП" Тогда
	        Заголовок = "Термін придатності";//"ТНП";
			ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеТНП");
	   	ИначеЕсли Параметры.КлючОткрытия = "Стандарты" Тогда
              Заголовок = "Перевірка стандартів";//"Анкеты";
			ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ПроверкаСтандартов");

		Иначе
			Заголовок = "Инвентаризации";
			ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеИН");
		КонецЕсли;
		
		ЗаполнитьСписокЗаданий();
	ИначеЕсли Параметры.Свойство("Переоценки") Тогда
		
		ТипДокумента = Справочники.ТипыДокументов.Переоценки;
		ТипыДокументов = Перечисления.ТипыДокументов.Переоценка;
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ТипыДокументов,СтрокаПоиска,ОтборКонтрагент", "Видимость", Ложь);
		
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "СтраницаДокументы", "Заголовок", "Переоценки");
		
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "СтраницыПролистывания", "ОтображениеСтраниц", ОтображениеСтраницФормы.ЗакладкиСверху);
		
		
	Иначе
		
		
		Элементы.ТипыДокументов.СписокВыбора.Очистить();
		ПервыйТипдокумента = Неопределено;
		Если  ЗначениеНастроекВызовСервераПовтИсп.ИспользуетсяПриемПоЗаказу() Тогда
			Элементы.ТипыДокументов.СписокВыбора.Добавить(Перечисления.ТипыДокументов.ПриемПоЗаказу,"Прийом замовлення");
			ПервыйТипдокумента=  Перечисления.ТипыДокументов.ПриемПозаказу;	
		КонецЕсли;
		
		Если  ЗначениеНастроекВызовСервераПовтИсп.ИспользуетсяПриемПоПриходу() Тогда
			Элементы.ТипыДокументов.СписокВыбора.Добавить(Перечисления.ТипыДокументов.ПриемТоваров ,"Прийом приходу");	
			Если ПервыйТипдокумента = Неопределено Тогда
				ПервыйТипдокумента=  Перечисления.ТипыДокументов.ПриемТоваров;	
			КонецЕсли;
			
		КонецЕсли;
		
		Если  ЗначениеНастроекВызовСервераПовтИсп.ИспользуетсяПриемПоПеремещению() Тогда
			Элементы.ТипыДокументов.СписокВыбора.Добавить(Перечисления.ТипыДокументов.Перемещение  ,"Прийом переміщенню");	
			Если ПервыйТипдокумента = Неопределено Тогда
				ПервыйТипдокумента=  Перечисления.ТипыДокументов.Перемещение;	
			КонецЕсли;
			
		КонецЕсли;
		
		Если  ЗначениеНастроекВызовСервераПовтИсп.ИспользуетсяПереоценка() Тогда
			Элементы.ТипыДокументов.СписокВыбора.Добавить(Перечисления.ТипыДокументов.Переоценка  ,"Переоцінка");	
			Если ПервыйТипдокумента = Неопределено Тогда
				ПервыйТипдокумента=  Перечисления.ТипыДокументов.Переоценка;	
			КонецЕсли;
			
		КонецЕсли;
		
		Если  ЗначениеНастроекВызовСервераПовтИсп.ИспользуетсяЖурналИнвентаризация() Тогда
			Элементы.ТипыДокументов.СписокВыбора.Добавить(Перечисления.ТипыДокументов.Инвентаризация   ,"Інвентаризація");	
			Если ПервыйТипдокумента = Неопределено Тогда
				ПервыйТипдокумента=  Перечисления.ТипыДокументов.Инвентаризация;	
			КонецЕсли;
			
		КонецЕсли;
		Если  ЗначениеНастроекВызовСервераПовтИсп.ИспользуетсяЖурналИнвентаризация() Тогда
			Элементы.ТипыДокументов.СписокВыбора.Добавить(Перечисления.ТипыДокументов.Печать,"Друк (Реєстр)");	
			Если ПервыйТипдокумента = Неопределено Тогда
				ПервыйТипдокумента=  Перечисления.ТипыДокументов.Печать;	
			КонецЕсли;
			
		КонецЕсли;
		
		Если  ЗначениеНастроекВызовСервераПовтИсп.ИспользуетсяЖурналЗаказыПоставщику() Тогда
			Элементы.ТипыДокументов.СписокВыбора.Добавить(Перечисления.ТипыДокументов.Zak,"Замовлення постачальнику");	
			Если ПервыйТипдокумента = Неопределено Тогда
				ПервыйТипдокумента=  Перечисления.ТипыДокументов.Zak;	
			КонецЕсли;
			
		КонецЕсли;
					Если  ЗначениеНастроекВызовСервераПовтИсп.ИспользуетсяЖурналРекламация() Тогда
				Элементы.ТипыДокументов.СписокВыбора.Добавить(Перечисления.ТипыДокументов.Рекламация ,"Рекламація");	
				Если ПервыйТипдокумента = Неопределено Тогда
					ПервыйТипдокумента=  Перечисления.ТипыДокументов.Рекламация;	
				КонецЕсли;
				
			КонецЕсли;

		
		Элементы.ТипыДокументов.СписокВыбора.Добавить(Перечисления.ТипыДокументов.Заявка,"ServiceDesk");
		
		Если Элементы.ТипыДокументов.СписокВыбора.Количество() = 0 Тогда
			Отказ = Истина;
			Сообщить("Немає операцій журналу, настройте доступн");
			Возврат;
		КонецЕсли;
		
		
		ТипыДокументов = ПервыйТипдокумента;	
	КонецЕсли;
	
	НастроитьФормуПоЗначениямНастроек();
	НастроитьФормуПоОриентацииЭкрана();

	
КонецПроцедуры

&НаСервере
Процедура НастроитьФормуПоЗначениямНастроек()
	
	
	Инициализирован = НЕ ПустаяСтрока(ПараметрыСеанса.Подразделение);
	
	ОбщегоНазначения.УстановитьШрифт(ЭтаФорма);
	
	ОбновитьПодразделение();
	
	НастроитьФормуПоТипуДокумента();
	
	ПечатьДокументаТип = 1;
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьПодразделение()
	
	Если ПустаяСтрока(ПараметрыСеанса.Подразделение) Тогда
		Элементы.СообщениеИнициализации.Заголовок = "Устройство не инициализировано";
		ОбщегоНазначения.УстановитьЦветПолейОшибок(ЭтаФорма, "СообщениеИнициализации");
		Склад = "";
		Инициализирован = Ложь;
		
	Иначе
		Если ПараметрыСеанса.Подразделение <> Элементы.СообщениеИнициализации.Заголовок Тогда
			Склад = "";
			СкладUUID = "";
		КонецЕсли;
		

		Элементы.СообщениеИнициализации.Заголовок = ПараметрыСеанса.Подразделение;
		ОбщегоНазначения.УстановитьЦветИнформационныхНадписей(ЭтаФорма, "СообщениеИнициализации");
		Инициализирован = Истина;
		
	КонецЕсли;

	
КонецПроцедуры


&НаСервере
Процедура НастроитьФормуПоОриентацииЭкрана()
	ГоризонтальнаяОриентацияЭкрана = ПараметрыСеанса.ГоризонтальнаяОриентацияЭкрана;
	
	Если ПараметрыСеанса.ГоризонтальнаяОриентацияЭкрана Тогда
	//	Элементы.страницы.ТекущаяСтраница = Элементы.СтраницаГоризонтальная;
	Иначе
		Элементы.страницы.ТекущаяСтраница = Элементы.СтраницаВертикальная;
	КонецЕсли;
	

КонецПроцедуры

&НаКлиенте
Процедура СообщениеИнициализацииНажатие(Элемент)
	ОткрытьФорму("Обработка.Сервис.Форма.Инициализация", , ЭтаФорма,,,,, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
КонецПроцедуры








&НаКлиенте
Процедура Заполнить(Команда)
	Если Не Инициализирован Тогда
		Сообщить("Пристрій не ініціалізований");
		Возврат;
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(ТипыДокументов) Тогда
		 Сообщить("Не вказано <Операція>");
	КонецЕсли;

	Если ТипыДокументов = ПредопределенноеЗначение("Перечисление.ТипыДокументов.Заявка") Тогда
		ПараметрыФормы = Новый Структура("ТипДокумента",ПредопределенноеЗначение("Справочник.ТипыДокументов.Заявка"));
		ОткрытьФорму("Обработка.ПанельМеню.Форма.ФормаДокумента",ПараметрыФормы, ЭтаФорма,,,,, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	
	Иначе
		
		Если ТипыДокументов = ПредопределенноеЗначение("Перечисление.ТипыДокументов.Печать") И ПечатьДокументаТип = 8 Тогда
			
			ПараметрыОткрытия = Новый Структура;
			ПараметрыОткрытия.Вставить("СформироватьОтчетОстаткиТНП");
			
			ОткрытьФорму("ОбщаяФорма.ФормаПечати",ПараметрыОткрытия,ЭтаФорма,,,,,РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
			
		Иначе
			ЗаполнитьСписокДокументов();
		КонецЕсли;
		
	КонецЕсли;
	
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСписокДокументов()
	
	Объект.Документы.Очистить();

	//Попытка	
	//	УдалитьФайлы(КаталогВременныхФайлов(),"*.pdf"); 
	//Исключение
	//КонецПопытки;
	 
	Если ТипыДокументов = Перечисления.ТипыДокументов.Zak тогда
		ТипДок = "ZAK";
	ИначеЕсли ТипыДокументов = Перечисления.ТипыДокументов.ПриемПоЗаказу Тогда
		//ТипДок = "ZAK";
		Возврат;   
	ИначеЕсли ТипыДокументов = Перечисления.ТипыДокументов.Рекламация Тогда	 
		ТипДок = "RECLAM";
	ИначеЕсли ТипыДокументов = Перечисления.ТипыДокументов.Инвентаризация Тогда
		ТипДок = "Инвентаризация";
		
		ДанныеДокументов = ИнтеграцияТК_ВызовСервера.ПолучитьСписокДокументов(ПериодДокументов,ТипДок,?(ПустаяСтрока(КонтрагентОтборUUID),"null",КонтрагентОтборUUID));
		ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЛокальнаяИнвентаризация");
	//	Объект.Документы.Очистить();
		Если ДанныеДокументов.Результат Тогда
			Если НЕ ПустаяСтрока(ДанныеДокументов.ОписаниеОшибки) Тогда
				Сообщить(ДанныеДокументов.ОписаниеОшибки);
				Возврат;
			КонецЕсли;
			
			для Каждого стДок Из ДанныеДокументов.Ответ Цикл 
				нСтрокадокумент = Объект.Документы.Добавить();
				нСтрокадокумент.ТипДокумента   = ТипДок;
				нСтрокадокумент.Дата           = Дата(стДок.Data);
				нСтрокадокумент.НомерДокумента = стДок.NomDoc;
				нСтрокадокумент.ДокументUUID   = стДок.DocUUID;
				нСтрокадокумент.СкладUUID      = стДок.SkladUUID;
				нСтрокадокумент.Инфо           = стДок.Info;

				ОбновитьЗаписьПоСтроке(нСтрокадокумент);
			КонецЦикла;
			
		КонецЕсли;
		 ЭтаФорма.ТекущийЭлемент  = Элементы.СтраницаДокументы;
		Возврат;
		 
	ИначеЕсли ТипыДокументов = Перечисления.ТипыДокументов.ПриемТоваров Тогда
		ТипДок = "PRIX";
	ИначеЕсли ТипыДокументов = Перечисления.ТипыДокументов.СписокПриходов Тогда
		ТипДок = "РеестрПриходов";
		ДанныеДокументов = ИнтеграцияТК_ВызовСервера.ПолучитьСписокДокументов(ПериодДокументов,ТипДок,?(ПустаяСтрока(КонтрагентОтборUUID),"null",КонтрагентОтборUUID));
		Если ДанныеДокументов.Результат Тогда
			
			Если НЕ ПустаяСтрока(ДанныеДокументов.ОписаниеОшибки) Тогда
				Сообщить(ДанныеДокументов.ОписаниеОшибки);
				Возврат;
			КонецЕсли;
			
			для Каждого стДок Из ДанныеДокументов.Ответ Цикл 
				нСтрокадокумент = Объект.Документы.Добавить();
				нСтрокадокумент.ТипДокумента   = ТипДок;
				Попытка
					нСтрокадокумент.Дата           = Дата(стДок.Дата);
				Исключение
				КонецПопытки;
				нСтрокадокумент.НомерДокумента = стДок.НомерДокумента;
				нСтрокадокумент.Контрагент     = стДок.Контрагент;
				нСтрокадокумент.Проведен       = стДок.Проведен;
				нСтрокадокумент.Регл           = стДок.Регл;
				нСтрокадокумент.Акт            = стДок.Акт;
				нСтрокадокумент.КоличествоПринято            = стДок.КоличествоПринято;
				нСтрокадокумент.КоличествоПоставщика         = стДок.КоличествоПоставщика;

				нСтрокадокумент.ДокументUUID   = стДок.DocUUID;
				нСтрокадокумент.ДокументыЗаписьПоСтроке  =  ?(стДок.Регл=1,"Ф1","Ф2")+ " - "+нСтрокадокумент.Контрагент +?(стДок.Акт=1," - АКТ","");
			КонецЦикла;
			
		КонецЕсли;
		ЭтаФорма.ТекущийЭлемент  = Элементы.СтраницаДокументы;
		Возврат;
		
	ИначеЕсли ТипыДокументов = Перечисления.ТипыДокументов.Переоценка Тогда
		ТипДок = "Переоценка";
		ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Переоценки");

		Объект.Товары.Очистить();
		ДанныеДокументов = ИнтеграцияТК_ВызовСервера.ПолучитьСписокДокументов(ПериодДокументов,ТипДок,"null");
		Если ДанныеДокументов.Результат Тогда
			
			Если НЕ ПустаяСтрока(ДанныеДокументов.ОписаниеОшибки) Тогда
				Сообщить(ДанныеДокументов.ОписаниеОшибки);
				Возврат;
			КонецЕсли;
			ИД = 0;
			для Каждого стДок Из ДанныеДокументов.Ответ Цикл 
				ЦветЦенника = "Білий";
				Если стДок.КодЦенника = 27 Тогда
					ЦветЦенника =  "Жовтий";
				ИначеЕсли стДок.КодЦенника = 28 Тогда
					ЦветЦенника =  "Синій";
				ИначеЕсли стДок.КодЦенника = 29 ИЛИ стДок.КодЦенника = 26 ИЛИ стДок.КодЦенника = 36  Тогда	
					ЦветЦенника =  "Помаранчевий";                       
				Иначе
					ЦветЦенника =  "Білий";
				КонецЕсли;
				   
				
				нСтрокадокумент = Объект.Документы.Добавить();
				нСтрокадокумент.ТипДокумента   = ТипДок;
				нСтрокадокумент.Дата           = ПериодДокументов;
				нСтрокадокумент.НомерДокумента = стДок.КодЦенника;
				нСтрокадокумент.Контрагент     = стДок.НазваниеЦенника +" "+ЦветЦенника;
				
                сч = 0;
				Для Каждого ТоварЦенника Из стДок.ДанныеПоТоварам Цикл 
					сч = сч + 1;
					нСтрокаТовары = Объект.Товары.Добавить();
					нСтрокаТовары.Артикул = ТоварЦенника.Артикул;
					нСтрокаТовары.НаименованиеТовара = ТоварЦенника.Номенклатура;
					нСтрокаТовары.Характеристика = ТоварЦенника.Характеристика;
					нСтрокаТовары.КодХарактеристики = ТоварЦенника.КодХар;
					нСтрокаТовары.Продажи = ТоварЦенника.Цена;
					нСтрокаТовары.НомерСтрокиДокумента = ИД;
					
				КонецЦикла;
				нСтрокадокумент.Сумма     = сч;
				нСтрокадокумент.КоличествоПоставщика     = сч;

				нСтрокадокумент.ИД        = ИД;
				ИД = ИД + 1;
				ОбновитьЗаписьПоСтроке(нСтрокадокумент);

				
				
			КонецЦикла;
		Иначе
			Если НЕ ПустаяСтрока(ДанныеДокументов.ОписаниеОшибки) Тогда
				Сообщить(ДанныеДокументов.ОписаниеОшибки);
				Возврат;
			КонецЕсли;

		КонецЕсли;
		ЭтаФорма.ТекущийЭлемент  = Элементы.СтраницаДокументы;
		Возврат;
	ИначеЕсли 	ТипыДокументов = Перечисления.ТипыДокументов.Печать Тогда
		МассивДокРеестр = Новый Массив;	
		Если  ПечатьДокументаТип = 1 Тогда
			МассивДокРеестр.Добавить("PrintPR");
			//ТипДок = "PrintPR";
		ИначеЕсли ПечатьДокументаТип = 2 Тогда
			МассивДокРеестр.Добавить("PrintSP");
			//ТипДок = "PrintSP";
		ИначеЕсли ПечатьДокументаТип = 5 Тогда 
			МассивДокРеестр.Добавить("PrintVP");
			//ТипДок = "PrintVP";
		ИначеЕсли ПечатьДокументаТип = 4 Тогда
			МассивДокРеестр.Добавить("PrintPRP");
			//ТипДок = "PrintPRP";
		ИначеЕсли ПечатьДокументаТип = 6 Тогда 
			МассивДокРеестр.Добавить("PrintIN");
			//ТипДок = "PrintIN";
		ИначеЕсли ПечатьДокументаТип = 7 Тогда  
			//МассивДокРеестр.Добавить("PrintRE");
			МассивДокРеестр.Добавить("РеестрПриходов");
			МассивДокРеестр.Добавить("PrintIN");
			МассивДокРеестр.Добавить("PrintPRP");
			МассивДокРеестр.Добавить("PrintVP"); 
			МассивДокРеестр.Добавить("PrintSP"); 
			МассивДокРеестр.Добавить("PrintPR");
			//	ТипДок = "PrintRE";
		ИначеЕсли ПечатьДокументаТип = 8 Тогда
			Возврат;      
		ИначеЕсли ПечатьДокументаТип = 9 Тогда
			МассивДокРеестр.Добавить("PrintZSD");
		Иначе	
			//ТипДок = "РеестрПриходов";  
			МассивДокРеестр.Добавить("РеестрПриходов");
			
		КонецЕсли;
		
		Для Каждого ТипДок Из МассивДокРеестр Цикл 
			ДанныеДокументов = ИнтеграцияТК_ВызовСервера.ПолучитьСписокДокументов(ПериодДокументов,ТипДок,?(ПустаяСтрока(КонтрагентОтборUUID),"null",КонтрагентОтборUUID));
			
			Если ДанныеДокументов.Результат  = Ложь Тогда
				
				Если НЕ ПустаяСтрока(ДанныеДокументов.ОписаниеОшибки)  И НЕ ПечатьДокументаТип = 7 Тогда
					Сообщить(ДанныеДокументов.ОписаниеОшибки);
				КонецЕсли; 
				Продолжить;

			Иначе	
				для Каждого стДок Из ДанныеДокументов.Ответ Цикл 
					нСтрокадокумент = Объект.Документы.Добавить();
					нСтрокадокумент.ТипДокумента   = ТипДок; 
					нСтрокадокумент.ДокументUUID   = стДок.DocUUID;
					
					
					Если стДок.Свойство("Дата") Тогда	
						Попытка
							нСтрокадокумент.Дата           = Дата(стДок.Дата);
						Исключение
						КонецПопытки;   
					КонецЕсли; 
					Если стДок.Свойство("Data") Тогда	
						нСтрокадокумент.Дата           = Дата(стДок.Data); 
					КонецЕсли;
					
					Если стДок.Свойство("НомерДокумента") Тогда
						нСтрокадокумент.НомерДокумента = стДок.НомерДокумента;
					КонецЕсли;     
					
					Если стДок.Свойство("NomDoc") Тогда
						нСтрокадокумент.НомерДокумента = стДок.NomDoc;
					КонецЕсли;
					
					Если стДок.Свойство("Контрагент") Тогда
						нСтрокадокумент.Контрагент     = стДок.Контрагент;
					КонецЕсли;  
					Если стДок.Свойство("Client") Тогда
						нСтрокадокумент.Контрагент     = стДок.Client; 
					КонецЕсли; 
					Если стДок.Свойство("Naz") Тогда   
						нСтрокадокумент.Контрагент =  стДок.Naz
					КонецЕсли;
					
					Если стДок.Свойство("Sum") Тогда
						нСтрокадокумент.Сумма          = стДок.Sum; 
					КонецЕсли;
					
					Если стДок.Свойство("Проведен") Тогда
						нСтрокадокумент.Проведен       = стДок.Проведен;
					КонецЕсли;   
					Если стДок.Свойство("Регл") Тогда	
						нСтрокадокумент.Регл           = стДок.Регл; 
					КонецЕсли;  
					Если стДок.Свойство("Акт") Тогда
						нСтрокадокумент.Акт            = стДок.Акт; 
					КонецЕсли; 
					Если стДок.Свойство("КоличествоПринято") Тогда
						нСтрокадокумент.КоличествоПринято            = стДок.КоличествоПринято; 
					КонецЕсли;
					Если стДок.Свойство("КоличествоПоставщика") Тогда
						нСтрокадокумент.КоличествоПоставщика         = стДок.КоличествоПоставщика;  
					КонецЕсли;
					
					Если стДок.Свойство("kol") Тогда
						нСтрокадокумент.КоличествоПринято          = стДок.kol;
					КонецЕсли;
					
					Если стДок.Свойство("Регл") И стДок.Свойство("Акт") Тогда
						нСтрокадокумент.ДокументыЗаписьПоСтроке  =  ?(стДок.Регл=1,"Ф1","Ф2")+ " - "+нСтрокадокумент.Контрагент +?(стДок.Акт=1," - АКТ","");
					Иначе
						ОбновитьЗаписьПоСтроке(нСтрокадокумент);
					КонецЕсли;
				КонецЦикла;
				
			КонецЕсли; 
		КонецЦикла;
		ЭтаФорма.ТекущийЭлемент  = Элементы.СтраницаДокументы;

			Возврат;

		КонецЕсли;
	
	ДанныеДокументов = ИнтеграцияТК_ВызовСервера.ПолучитьСписокДокументов(ПериодДокументов,ТипДок,?(ПустаяСтрока(КонтрагентОтборUUID),"null",КонтрагентОтборUUID));
	
	//Объект.Документы.Очистить();
	Если ДанныеДокументов.Результат Тогда
		для Каждого стДок Из ДанныеДокументов.Ответ Цикл 
			нСтрокадокумент = Объект.Документы.Добавить();
			нСтрокадокумент.Дата           = Дата(стДок.Data);
			нСтрокадокумент.ТипДокумента   = ТипДок;
			нСтрокадокумент.НомерДокумента = стДок.NomDoc;
			нСтрокадокумент.ДокументUUID   = стДок.DocUUID;
			нСтрокадокумент.Контрагент     = стДок.Client;
			нСтрокадокумент.КонтрагентUUID = стДок.ClientUUID;
			нСтрокадокумент.Сумма          = стДок.Sum;
			ОбновитьЗаписьПоСтроке(нСтрокадокумент);
		КонецЦикла;
		
		Элементы.СтраницыПролистывания.ТекущаяСтраница = Элементы.СтраницаДокументы;
		
	КонецЕсли;
	Если Объект.Документы.Количество() = 0 Тогда
		Сообщить("Немає документів");  
	КонецЕсли;
	
	УстановитьВидимостьСтраницСервер();
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСписокЗаданий()
	
	Объект.Документы.Очистить();
	ТипДок = ТипДокумента.ИмяПредопределенныхДанных;
	ДанныеДокументов = ИнтеграцияТК_ВызовСервера.ПолучитьСписокДокументов(ПериодДокументов,ТипДок,"null");
	
	Если ДанныеДокументов.Результат Тогда
		для Каждого стДок Из ДанныеДокументов.Ответ Цикл 
			нСтрокадокумент = Объект.Документы.Добавить();
			нСтрокадокумент.Дата           = Дата(стДок.Data);
			нСтрокадокумент.ДатаИсполнения = ?(ПустаяСтрока(стДок.DataF),ТекущаяДатаСеанса(),Дата(стДок.DataF));
			Если стДок.Свойство("TipDoc") Тогда
				нСтрокадокумент.ТипДокумента     =  стДок.TipDoc;
			Иначе
				нСтрокадокумент.ТипДокумента   = ТипДок;
			КонецЕсли;
		
			нСтрокадокумент.Инфо = стДок.NomDoc;
			нСтрокадокумент.ДокументUUID   = стДок.DocUUID;
			Если стДок.Свойство("Kontr") Тогда
				нСтрокадокумент.Контрагент=стДок.Kontr;
			КонецЕсли;
			Если стДок.Свойство("zp") Тогда 
				нСтрокадокумент.ЗаданиеПроцесса=стДок.zp;
			КонецЕсли;
			
			Если стДок.Свойство("MenUUID") Тогда
				нСтрокадокумент.КонтрагентUUID     =  стДок.MenUUID;//ИД сотрудник
			КонецЕсли;

			ОбновитьЗаписьПоСтроке(нСтрокадокумент);
		КонецЦикла;
		
		
	КонецЕсли;
	ЭтаФорма.ТекущийЭлемент  = Элементы.СтраницаДокументы;
	

КонецПроцедуры


&НаСервере
Функция ПолучитьИмядокумента(Знач ТипДок)
	ТипДокВозврат ="";
	Если ТипДок = "ZAK" Тогда
	   ТипДокВозврат = "Заказ поставщику";
   ИначеЕсли ТипДок = "IN" ИЛИ ТипДок = "Инвентаризация" Тогда
	   ТипДокВозврат = "Инвентаризация товаров";
   КонецЕсли;
   
   Возврат ТипДокВозврат
	
КонецФункции


&НаСервере
Процедура ОбновитьЗаписьПоСтроке(Знач Строка, ИдентификаторСтроки = Неопределено)
	
	Если НЕ ИдентификаторСтроки = Неопределено Тогда
		СтрокаТЧ = Объект.Документы.НайтиПоИдентификатору(ИдентификаторСтроки);
	Иначе
		СтрокаТЧ = Строка;
	КонецЕсли;
	Если ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Задание") Тогда
		Если СтрокаТЧ.ЗаданиеПроцесса = 1 Тогда
			ЗаписьПоСтроке = НСтр("ru = '%Инфо%'");
			ЗаписьПоСтроке = СтрЗаменить(ЗаписьПоСтроке, "%Инфо%",?(ПустаяСтрока(СтрокаТЧ.Инфо),"","<"+СтрокаТЧ.Инфо+" "+СтрокаТЧ.Контрагент+ ">"));
		Иначе
			ЗаписьПоСтроке = НСтр("ru = 'Исполнить до %ДатаФ% %Инфо%'");
			ЗаписьПоСтроке = СтрЗаменить(ЗаписьПоСтроке, "%ДатаФ%",СтрокаТЧ.ДатаИсполнения );
			ЗаписьПоСтроке = СтрЗаменить(ЗаписьПоСтроке, "%Инфо%",?(ПустаяСтрока(СтрокаТЧ.Инфо),"","<"+СтрокаТЧ.Инфо+" "+СтрокаТЧ.Контрагент+ ">"));
		КонецЕсли;
	Иначе
		
		ЗаписьПоСтроке = НСтр("ru = '%Документ% %Контрагент% %Сумма% %Инфо%'");
		
		ЗаписьПоСтроке = СтрЗаменить(ЗаписьПоСтроке, "%Документ%",ПолучитьИмядокумента(СтрокаТЧ.ТипДокумента) );
		ЗаписьПоСтроке = СтрЗаменить(ЗаписьПоСтроке, "%Контрагент%",?(ПустаяСтрока(СтрокаТЧ.Контрагент),"","<"+СтрокаТЧ.Контрагент+">"));
		ЗаписьПоСтроке = СтрЗаменить(ЗаписьПоСтроке, "%Сумма%",     Формат(СтрокаТЧ.Сумма, ОбщегоНазначенияПовтИсп.ФорматСуммовыхПолей()));
		ЗаписьПоСтроке = СтрЗаменить(ЗаписьПоСтроке, "%Инфо%",?(ПустаяСтрока(СтрокаТЧ.Инфо),"","<"+СтрокаТЧ.Инфо+">"));
	КонецЕсли;
	
	СтрокаТЧ.ДокументыЗаписьПоСтроке = ЗаписьПоСтроке;
	
КонецПроцедуры


