		ЭтаФорма.УсловноеОформление.Элементы.Получить(4).Использование = Истина;

	Иначе
		ЭтаФорма.УсловноеОформление.Элементы.Получить(2).Использование = Ложь;
		ЭтаФорма.УсловноеОформление.Элементы.Получить(3).Использование = Ложь;
		ЭтаФорма.УсловноеОформление.Элементы.Получить(4).Использование = Ложь;

