		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "СтраницыПролистывания", "ОтображениеСтраниц", ОтображениеСтраницФормы.Нет);
		Элементы.СтрокаПоиска.Заголовок = "Ш\К, Артикул товара / Номер заказа";
		
	ИначеЕсли ТипыДокументов = ПредопределенноеЗначение("Перечисление.ТипыДокументов.Инвентаризация") ИЛИ ТипыДокументов = ПредопределенноеЗначение("Перечисление.ТипыДокументов.СписокПриходов") Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "СтраницаДокументы,ПериодДокументов,ГруппаПодвал", "Видимость", Истина);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "СтрокаПоиска,ГруппаПечать", "Видимость", Ложь);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "СтраницыПролистывания", "ОтображениеСтраниц", ОтображениеСтраницФормы.ЗакладкиСверху);
	ИначеЕсли ТипыДокументов = ПредопределенноеЗначение("Перечисление.ТипыДокументов.Перемещение") Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "СтраницаДокументы,ГруппаПечать,ГруппаПечатьДокументов,ПериодДокументов,ГруппаПодвал", "Видимость", Ложь);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "СтрокаПоиска", "Видимость", Истина);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "СтраницыПролистывания", "ОтображениеСтраниц", ОтображениеСтраницФормы.Нет);
		Элементы.СтрокаПоиска.Заголовок = "ID перемещения";
		ЦветоваяИндикация = Истина;
	ИначеЕсли ТипыДокументов = ПредопределенноеЗначение("Перечисление.ТипыДокументов.Переоценка") Тогда
	 	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "СтраницаДокументы,ПериодДокументов,ГруппаПодвал", "Видимость", Истина);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "СтрокаПоиска,ГруппаПечать,ГруппаПечатьДокументов", "Видимость", Ложь);
