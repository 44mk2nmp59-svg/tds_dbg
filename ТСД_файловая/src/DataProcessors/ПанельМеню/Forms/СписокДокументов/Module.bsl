&НаКлиенте
Процедура ПечатьРеестра(Команда)

	Если Объект.Документы.Количество() = 0 Тогда
		Сообщить("Нет документов для печати!");
		Возврат;
	КонецЕсли;
	
	Если ПечатьДокументаТип = 0 Тогда
		ТипДок = "ПоступлениеТоваров";
	ИначеЕсли ПечатьДокументаТип = 1 Тогда
		ТипДок = "Перемещение";
	ИначеЕсли ПечатьДокументаТип = 2 Тогда
		ТипДок = "Списание";
	ИначеЕсли ПечатьДокументаТип = 3 Тогда
		ТипДок = "Инвентаризация"; 
	ИначеЕсли ПечатьДокументаТип = 5 Тогда
		ТипДок = "ВозвратПоставщику";
	ИначеЕсли ПечатьДокументаТип = 6 Тогда
		ТипДок = "ИнвентаризацияРеестр";
   	ИначеЕсли ПечатьДокументаТип = 7 Тогда
		ТипДок = "Реестр";

	Иначе
		ТипДок = "ПоступлениеТоваров";

	КонецЕсли;
	
	
	
	Если ЗначениеНастроекВызовСервераПовтИсп.ИспользуетсяПечатьНаПринтер() Тогда
		
		ТабДок = ПечатнаяФормаРеестра(ТипДок);  
		ОбщегоНазначенияКлиент.ВывестиПДФ_НаПечать(ТабДок);
	Иначе
		
		ДанныеДляПечати  = СформироватьТабдокРеестра(ТипДок);
		
		
		Если Не ДанныеДляПечати.Результат Тогда
			Если НЕ ПустаяСтрока(ДанныеДляПечати.ОписаниеОшибки) Тогда
				Сообщить(ДанныеДляПечати.ОписаниеОшибки);
			КонецЕсли;
		Иначе	
			Сообщить("Реестр отправлен на печать");
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ПечатнаяФормаРеестра(ТипДок) 
	Если ТипДок = "Реестр" Тогда  
		ТабДок = Обработки.ПанельМеню.ПечатьРеестрОбщий(Объект.Документы);
	Иначе
		ТабДок = Обработки.ПанельМеню.ПечатьРеестра(Объект.Документы,ТипДок);
	КонецЕсли;
	Возврат  ТабДок
КонецФункции

&НаСервере
Функция СформироватьТабдокРеестра(ТипДок)
	ТабДок = ПечатнаяФормаРеестра(ТипДок);
	
	Рез = ИнтеграцияТК_ВызовСервера.ПоставитьВочередьНаПечать(ТабДок,"РеестрПриходов");	
	
	Возврат Рез ;
	
КонецФункции


&НаКлиенте
Процедура Фото(Команда)
	#Если МобильноеПриложениеКлиент Тогда 
		
		ФайлКартинки = ПолучитьИмяВременногоФайла("jpg");
		Запуск = Новый ЗапускПриложенияМобильногоУстройства("android.media.action.IMAGE_CAPTURE");
		
		Запуск.ДополнительныеДанные.Добавить("output", "file://" + ФайлКартинки, "Uri");
		
		Рез = Запуск.Запустить(Истина);
	#КонецЕсли

КонецПроцедуры


&НаКлиенте
Процедура ПечатьАкта(Команда)
	
	
	ПараметрыСтроки = ПолучитьПараметрыСтроки();
	
	Если ПараметрыСтроки = Неопределено Тогда
		Сообщить("Нет документа для печати");
		Возврат;
	Иначе	
		СтруктураДокумента = Новый Структура("ДокументUUID,ДоументСервер",ПараметрыСтроки.ДокументUUID,Истина);
		
		Если ПечатьДокументаТип = 0 Тогда
			ТекВидДок ="PrintPTA";
			
		Иначе
			Сообщить("Не известный тип документа");
			Возврат;
		КонецЕсли;
		
		Если ЗначениеНастроекВызовСервераПовтИсп.ИспользуетсяПечатьНаПринтер() Тогда
			
			СтруктураДокумента.Вставить("ТипДокумента",ТекВидДок);
			Рез =  ИнтеграцияТК_ВызовСервера.ЗапросПечатнаяФорма(СтруктураДокумента);
			
			Если Рез.Результат Тогда
				ОбщегоНазначенияКлиент.ВывестиПДФ_НаПечать(Рез.Ответ);
			Иначе
				Сообщить(Рез.ОписаниеОшибки);
			КонецЕсли;
			
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Функция ВернутьТипПечати(ТекДок)
    ПарамПечатнаяФорма = "PrintPT";
	Если ТекДок = "РеестрПриходов" Тогда 
		ПарамПечатнаяФорма = "PrintPT";
	ИначеЕсли ТекДок = "PrintPR" ИЛИ ТекДок = "PrintPRP" Тогда   
		ПарамПечатнаяФорма = "PrintPR";
	Иначе   
		ПарамПечатнаяФорма = ТекДок;
	КонецЕсли;
	
	Возврат ПарамПечатнаяФорма;
	
КонецФункции


&НаКлиенте
Процедура Печать(Команда)
	ПараметрыСтроки = ПолучитьПараметрыСтроки();
	
	Если ПараметрыСтроки = Неопределено Тогда
		Сообщить("Нет документа для печати");
		Возврат;
	Иначе	
		СтруктураДокумента = Новый Структура("ДокументUUID,ДоументСервер",ПараметрыСтроки.ДокументUUID,Истина);
		ПарамТекВидДок = ВернутьТипПечати(ПараметрыСтроки.ВидДокумента);
	КонецЕсли;
	
	Если ПарамТекВидДок = "PrintPT" Тогда
		//ВыбратьФормуПечати(СтруктураДокумента);
		ПечататьДокумент(СтруктураДокумента, "PrintPTA");
	Иначе
		ПечататьДокумент(СтруктураДокумента, ПарамТекВидДок);
	КонецЕсли;
	

КонецПроцедуры  


&НаКлиенте
 Асинх Процедура ВыбратьФормуПечати(СтруктураДокумента) 
	 
	 СписокВыбора = Новый СписокЗначений;
	 СписокВыбора.Добавить("PrintPTA","АКТ");
	 СписокВыбора.Добавить("PrintPT","Накладна");  
	
	 Ответ = Ждать ВыбратьИзМенюАсинх(СписокВыбора);   
	 Если Не Ответ = Неопределено Тогда
		 ЗначениеВыбора = Ответ.Значение; 
		 ПечататьДокумент(СтруктураДокумента,ЗначениеВыбора) 
	 КонецЕсли;
	 
	  
 КонецПроцедуры


&НаКлиенте
Процедура ПечататьДокумент(СтруктураДокумента,ТекВидДок)  
		
	Если ЗначениеНастроекВызовСервераПовтИсп.ИспользуетсяПечатьНаПринтер() Тогда
		
		СтруктураДокумента.Вставить("ТипДокумента",ТекВидДок);
		Рез =  ИнтеграцияТК_ВызовСервера.ЗапросПечатнаяФорма(СтруктураДокумента);
		
		Если Рез.Результат Тогда
			ОбщегоНазначенияКлиент.ВывестиПДФ_НаПечать(Рез.Ответ);
		Иначе
			Сообщить(Рез.ОписаниеОшибки);
		КонецЕсли;
		
	Иначе
		
		Рез = ИнтеграцияТК_ВызовСервера.ИнициализироватьДанныеДляПечати(СтруктураДокумента,ТекВидДок);
		
		Если Рез.Результат Тогда
			Сообщить("Документ отправлен на печать!");
			
		Иначе
			Сообщить(Рез.ОписаниеОшибки);
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры


