&НаКлиенте
Процедура ДокументыВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	
	Если ТипыДокументов = ПредопределенноеЗначение("Перечисление.ТипыДокументов.СписокПриходов")
		ИЛИ ТипыДокументов = ПредопределенноеЗначение("Перечисление.ТипыДокументов.Печать") Тогда
		Возврат;
	КонецЕсли;
	
	
	ПараметрыСтроки = ПолучитьПараметрыСтроки();

 	Если НЕ ПараметрыСтроки = Неопределено Тогда
		
		Попытка
			 
			ДополнительныеПараметры = Новый Структура;
			ДополнительныеПараметры.Вставить("ИдентификаторСтроки", ПараметрыСтроки.ИдентификаторСтроки);
			
			ОписаниеОповещения = Новый ОписаниеОповещения("ОповещениеИзменитьСтроку", ЭтотОбъект, ДополнительныеПараметры);
			
			
			Если ПараметрыСтроки.ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ФотоСчетчика") Тогда
				РезОткрытия = ОткрытьФорму("Обработка.ПанельМеню.Форма.ФормаФотоСчетчика", ПараметрыСтроки, ЭтаФорма,,,,ОписаниеОповещения,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
			//Если ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеВФ") Тогда
			//	РезОткрытия = ОткрытьФорму("Обработка.ПанельМеню.Форма.ПроверкаЦен", ПараметрыСтроки, ЭтаФорма,,,,ОписаниеОповещения);

			Иначе			
				РезОткрытия = ОткрытьФорму("Обработка.ПанельМеню.Форма.ФормаДокумента", ПараметрыСтроки, ЭтаФорма,,,,ОписаниеОповещения,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
			КонецЕсли;
		Исключение
			Сообщить(ОписаниеОшибки());
		КонецПопытки;
		
	КонецЕсли;

	
	
КонецПроцедуры

&НаКлиенте
Процедура ОповещениеИзменитьСтроку(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено ИЛИ Результат = КодВозвратаДиалога.Отмена Тогда
		Возврат;
	КонецЕсли;
	
	ИдентификаторСтроки = ДополнительныеПараметры.ИдентификаторСтроки;

	
	Если Результат.Свойство("УдалитьСтроку") Тогда
			
		Если ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеВФ") 
			ИЛИ ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Задание") 
			ИЛИ ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеИН")
			ИЛИ ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеТБД") Тогда
			
			//Если Объект.Документы.Количество() > 0 Тогда
			//	//СтрокаТаблицы = Объект.Документы.НайтиПоИдентификатору(ИдентификаторСтроки);
			//ИндексСтроки = Объект.Документы.Индекс(СтрокаТаблицы);
			//Объект.Документы.Удалить(ИндексСтроки);
			//
			Оповестить("ПроверитьЗадачи");
			Если Объект.Документы.Количество() = 0 Тогда
				Закрыть();
			КонецЕсли;
			
			//Иначе
			//	Оповестить("ПроверитьЗадачи");
			//	Закрыть();
			//	
			//КонецЕсли;
			
		Иначе
			СтрокаТаблицы = Объект.Документы.НайтиПоИдентификатору(ИдентификаторСтроки);

			ИндексСтроки = Объект.Документы.Индекс(СтрокаТаблицы);
			Объект.Документы.Удалить(ИндексСтроки);

			УстановитьВидимостьСтраницСервер();
		КонецЕсли;
	ИначеЕсли Результат.Свойство("ОбработатьСтрокиПоПереоценки") Тогда
		   
		  ОбновитьДанныеФормыПоПечатиНаСервере(ИдентификаторСтроки,Результат);
		///Модифицированность = Истина;
	КонецЕсли;
	
	
КонецПроцедуры


&НаКлиенте
Функция ПолучитьПараметрыСтроки()
	//
	//Если ГоризонтальнаяОриентацияЭкрана Тогда
	//	ТекущиеДанные = Элементы.ТоварыГоризонт.ТекущиеДанные;
	//Иначе
		ТекущиеДанные = Элементы.Документы.ТекущиеДанные;
	//КонецЕсли;
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("ОбновитьДанные",Истина);
	СтруктураПараметров.Вставить("ИдентификаторСтроки", ТекущиеДанные.ПолучитьИдентификатор());
	СтруктураПараметров.Вставить("Контрагент",          ТекущиеДанные.Контрагент);
	СтруктураПараметров.Вставить("КонтрагентUUID",      ТекущиеДанные.КонтрагентUUID);
	СтруктураПараметров.Вставить("НомерСтроки",         ТекущиеДанные.НомерСтроки);
	СтруктураПараметров.Вставить("ДокументUUID",        ТекущиеДанные.ДокументUUID);
	СтруктураПараметров.Вставить("СкладUUID",           ТекущиеДанные.СкладUUID);
	СтруктураПараметров.Вставить("НаименованиеДокумента",       "Номер "+ТекущиеДанные.НомерДокумента +" від "+ ТекущиеДанные.Дата+" ");

	
	СтруктураПараметров.Вставить("ВидДокумента",        ТекущиеДанные.ТипДокумента);
	Если ТекущиеДанные.ТипДокумента = "ZAK" Тогда
		СтруктураПараметров.Вставить("ТипДокумента",    ПредопределенноеЗначение("Справочник.ТипыДокументов.Zak"));
	ИначеЕсли ТекущиеДанные.ТипДокумента = "PRIX" Тогда
		СтруктураПараметров.Вставить("ТипДокумента",     ПредопределенноеЗначение("Справочник.ТипыДокументов.ПриемПоПриходу"));
		СтруктураПараметров.Вставить("НомерДокумента",  ТекущиеДанные.НомерДокумента);
	ИначеЕсли ТекущиеДанные.ТипДокумента = "Инвентаризация" Тогда
		СтруктураПараметров.Вставить("ТипДокумента",    ПредопределенноеЗначение("Справочник.ТипыДокументов.ЛокальнаяИнвентаризация"));
	ИначеЕсли ТекущиеДанные.ТипДокумента = "Заказ" Тогда
		СтруктураПараметров.Вставить("ТипДокумента",    ПредопределенноеЗначение("Справочник.ТипыДокументов.ПриемПоЗаказу"));
	ИначеЕсли ТекущиеДанные.ТипДокумента = "Поступление" Тогда
		СтруктураПараметров.Вставить("ТипДокумента",    ПредопределенноеЗначение("Справочник.ТипыДокументов.ПриемПоПриходу"));
	ИначеЕсли ТекущиеДанные.ТипДокумента = "RECLAM" Тогда
		СтруктураПараметров.Вставить("ТипДокумента",    ПредопределенноеЗначение("Справочник.ТипыДокументов.Рекламация"));
	ИначеЕсли ТекущиеДанные.ТипДокумента = "Задание" Тогда
		СтруктураПараметров.Вставить("ТипДокумента",    ПредопределенноеЗначение("Справочник.ТипыДокументов.Задание"));
	ИначеЕсли ТекущиеДанные.ТипДокумента = "ЗаданиеИН" Тогда
		СтруктураПараметров.Вставить("ТипДокумента",    ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеИН"));
	ИначеЕсли ТекущиеДанные.ТипДокумента = "Переоценка" Тогда
		СтруктураПараметров.Вставить("ТипДокумента",    ПредопределенноеЗначение("Справочник.ТипыДокументов.Переоценки"));

		нМассивСтрок = Объект.Товары.НайтиСтроки(Новый Структура("НомерСтрокиДокумента",ТекущиеДанные.ИД));
		МассивСтрок = Новый Массив;
		стрСтруктура = "Артикул,НаименованиеТовара,КодХарактеристики,Характеристика,Продажи";
		
		для Каждого нСтрока Из нМассивСтрок Цикл 
			структураСтроки = Новый Структура(стрСтруктура);
			ЗаполнитьЗначенияСвойств(структураСтроки,нСтрока,стрСтруктура);
			МассивСтрок.Добавить(структураСтроки);
			
		КонецЦикла;
		СтруктураПараметров.Вставить("ТоварыПереоценки",МассивСтрок);
		СтруктураПараметров.Вставить("ИД_Переоценки",ТекущиеДанные.НомерДокумента);
	ИначеЕсли ТекущиеДанные.ТипДокумента = "ЗаданиеВФ" Тогда
		СтруктураПараметров.Вставить("ТипДокумента",    ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеВФ"));
		СтруктураПараметров.Вставить("ОписаниеЗадания", ТекущиеДанные.ДокументыЗаписьПоСтроке);
	ИначеЕсли ТекущиеДанные.ТипДокумента = "ЗаданиеТБД" Тогда	
		СтруктураПараметров.Вставить("ТипДокумента",    ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеТБД"));
	ИначеЕсли ТекущиеДанные.ТипДокумента = "ЗаданиеТНП" Тогда	
		СтруктураПараметров.Вставить("ТипДокумента",    ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеТНП")); 
	ИначеЕсли ТекущиеДанные.ТипДокумента = "ПроверкаСтандартов" Тогда	
		СтруктураПараметров.Вставить("ТипДокумента",    ПредопределенноеЗначение("Справочник.ТипыДокументов.ПроверкаСтандартов"));
	ИначеЕсли  ТекущиеДанные.ТипДокумента = "zadel" Тогда
		СтруктураПараметров.Вставить("ТипДокумента",    ПредопределенноеЗначение("Справочник.ТипыДокументов.ФотоСчетчика"));
	ИначеЕсли  ТекущиеДанные.ТипДокумента = "zadyv" Тогда
		СтруктураПараметров.Вставить("ТипДокумента",    ПредопределенноеЗначение("Справочник.ТипыДокументов.Уведомление"));
		СтруктураПараметров.Вставить("Инфо",ТекущиеДанные.Инфо);   
	ИначеЕсли  ТекущиеДанные.ТипДокумента = "zadvds" Тогда
		СтруктураПараметров.Вставить("ТипДокумента",    ПредопределенноеЗначение("Справочник.ТипыДокументов.ВыдачаДС"));
		СтруктураПараметров.Вставить("Инфо",ТекущиеДанные.Инфо);
	
	КонецЕсли;
	

	
	Возврат СтруктураПараметров;
КонецФункции


&НаСервере
Процедура НастроитьФормуПоТипуДокумента()
	 	
	ОчиститьДок = Истина;
    ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "Заполнить", "Заголовок","Заповнити");

	ЦветоваяИндикация = Ложь;
	Если ТипыДокументов = ПредопределенноеЗначение("Перечисление.ТипыДокументов.ПриемПозаказу") Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "СтраницаДокументы,ПериодДокументов,ГруппаПечатьДокументов,ГруппаПодвал,ГруппаПечать", "Видимость", Ложь);
