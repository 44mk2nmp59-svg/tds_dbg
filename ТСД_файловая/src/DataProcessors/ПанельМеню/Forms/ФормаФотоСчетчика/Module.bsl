&НаКлиенте
Перем ВыполняетсяЗакрытие;




&НаСервере
Процедура НастроитьФормуПоЗначениямНастроек(Отказ)
	
	
	Параметры.Свойство("ТипДокумента",ТипДокумента);
	
	Параметры.Свойство("ДокументUUID",ДокументUUID);
	
	БазаПодключения = Перечисления.БазаПодключения.ТК;
	
	ИспользуетсяАсинхронныйСканер = ЗначениеНастроекВызовСервераПовтИсп.ИспользуетсяАсинхронныйСканерШтрихкодов();
	
	Инициализирован = НЕ ПустаяСтрока(ПараметрыСеанса.Подразделение);	
	ПользовательИнициализирован = НЕ ПустаяСтрока(ПараметрыСеанса.Сотрудник);
	
	ОбщегоНазначения.УстановитьШрифт(ЭтаФорма);
	
	ОбновитьПодразделение();
	ОбновитьСотрудника();
	
	УстановитьДоступностьПоНастройкам();	
	

	ЗаполнитьДанныеПоСчетчикам(Отказ);
	
	
КонецПроцедуры

&НаСервере
Процедура НастроитьФормуПоОриентацииЭкрана()
	

КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДанныеПоСчетчикам(Отказ)
	Если НЕ Инициализирован Тогда
		Возврат;
	КонецЕсли;

	ДанныеДокумента = ИнтеграцияТК_ВызовСервера.ПолучитьMarketDoc(ТипДокумента.ИмяПредопределенныхДанных);
	Если  ДанныеДокумента.Результат = Ложь Тогда
		Отказ = Истина;
		Если НЕ ПустаяСтрока(ДанныеДокумента.ОписаниеОшибки) Тогда
			Сообщить(ДанныеДокумента.ОписаниеОшибки);
		КонецЕсли;
		Возврат;
	КонецЕсли;
	
	сч = 1;
	Для Каждого СтрСч Из ДанныеДокумента.Ответ Цикл
		нСтр = ТаблицаСчетчики.Добавить();
		нСтр.Номер = сч;
		ЗаполнитьЗначенияСвойств(нСтр,СтрСч);
		сч =  сч + 1;
	КонецЦикла;
	
	
	
КонецПроцедуры


&НаСервере
Процедура УстановитьДоступностьПоНастройкам()
	
	ЕстьОборудованиеСканирования = ЗначениеЗаполнено(ЗначениеНастроекВызовСервераПовтИсп.ТипУстройстваСканирования());
	
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "Сканировать", "Видимость",
	(ЕстьОборудованиеСканирования И НЕ ИспользуетсяАсинхронныйСканер) И Инициализирован И ПользовательИнициализирован И ЗначениеНастроекВызовСервераПовтИсп.ЭтоРежимПодключениеТК()
	);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ТаблицаСчетчики,ГруппаФото,ДекорацияСчетчик,Сохранить", "Видимость", ПользовательИнициализирован);

	//	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ДобавитьВдокумент", "Видимость",
	//ВводкКоличества
	//);

	//
	//ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "Страницы", "Видимость",
	//Инициализирован И ПользовательИнициализирован  И ЗначениеНастроекВызовСервераПовтИсп.ЭтоРежимПодключениеТК()
	//);
	//
	//	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "Контрагент", "Видимость",
	//Инициализирован И ПользовательИнициализирован  И ЗначениеНастроекВызовСервераПовтИсп.ЭтоРежимПодключениеТК() И НЕ КонтрагентВыбран
	//);
	
	
КонецПроцедуры


&НаСервере
Процедура ОбновитьПодразделение()
	
	
	Если ПустаяСтрока(ПараметрыСеанса.Подразделение) Тогда
		Элементы.СообщениеИнициализации.Заголовок = "Устройство не инициализировано";
		ОбщегоНазначения.УстановитьЦветПолейОшибок(ЭтаФорма, "СообщениеИнициализации");
		Инициализирован = Ложь;
	Иначе
		Элементы.СообщениеИнициализации.Заголовок = ПараметрыСеанса.Подразделение;
		ОбщегоНазначения.УстановитьЦветИнформационныхНадписей(ЭтаФорма, "СообщениеИнициализации");
		Инициализирован = Истина;

	КонецЕсли;
	
	УстановитьДоступностьПоНастройкам();
	
	

	
КонецПроцедуры


&НаСервере
Процедура ОбновитьСотрудника()
	
	Если ПустаяСтрока(ПараметрыСеанса.Сотрудник) Тогда
		Элементы.СообщениеИнициализацииПользователя.Заголовок = "Пользователь не инициализирован";
		ОбщегоНазначения.УстановитьЦветПолейОшибок(ЭтаФорма, "СообщениеИнициализацииПользователя");
		Сотрудник = "";
		ПользовательИнициализирован = Ложь;
		
	Иначе
		Если ПараметрыСеанса.Сотрудник <> Элементы.СообщениеИнициализацииПользователя.Заголовок Тогда
			Сотрудник = "";
		КонецЕсли;
		

		Элементы.СообщениеИнициализацииПользователя.Заголовок = ПараметрыСеанса.Сотрудник;
		ОбщегоНазначения.УстановитьЦветИнформационныхНадписей(ЭтаФорма, "СообщениеИнициализацииПользователя");
		ПользовательИнициализирован = Истина;
		
	КонецЕсли;
	
	
	
	
	УстановитьДоступностьПоНастройкам();

	
КонецПроцедуры







&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("АвтоТест") Тогда
		Возврат;
	КонецЕсли;
	

	НастроитьФормуПоЗначениямНастроек(Отказ);
	НастроитьФормуПоОриентацииЭкрана();

КонецПроцедуры






