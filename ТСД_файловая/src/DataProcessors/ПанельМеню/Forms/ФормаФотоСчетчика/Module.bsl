&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
		
	Если ВыполняетсяЗакрытие Тогда
		ОбщегоНазначенияКлиентСервер.ОчиститьСотрудника();
	Иначе
		Отказ = Истина;
		
		ПоказатьВопрос(Новый ОписаниеОповещения("ПередЗакрытиемЗавершение",ЭтотОбъект),"Закрыть документ?",РежимДиалогаВопрос.ДаНет);
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытиемЗавершение(РезультатВопроса,ДопоплнительныеПараметры) Экспорт
	
	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
		ВыполняетсяЗакрытие = Истина;
		Закрыть();
	КонецЕсли;
	
	
КонецПроцедуры


&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ПодключаемоеОборудованиеКлиент.ЭтоОповещениеСканераШтрихкода(ИмяСобытия) И ВводДоступен() Тогда
		
		ДополнительныеПараметры = Новый Структура;
		ДополнительныеПараметры.Вставить("Форма", ЭтаФорма);
		ОбработатьПолученныйШтрихкод(Параметр, ДополнительныеПараметры);
		
	ИначеЕсли ИмяСобытия = "ИзмененоПодразделение" Тогда
		
		ОбновитьПодразделение();
		
	ИначеЕсли ИмяСобытия = "ИзмененСотрудник" Тогда
		
		ОбновитьСотрудника();
		
	КонецЕсли;

КонецПроцедуры


&НаКлиенте
Процедура ОбработатьПолученныйШтрихкод(ПолученныйШтрихкод, Параметры) Экспорт
	Если ПустаяСтрока(ПолученныйШтрихкод) Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ ПользовательИнициализирован Тогда
		
		Результат	= ИнтеграцияТК_Клиент.ПолучитьСотрудника(ПолученныйШтрихкод);
		
		
		Если Результат.Результат Тогда
			Оповестить("ИзмененСотрудник");
		Иначе
			Сообщить("Необходима авторизация пользователя (ТКС)");
		КонецЕсли;
		
		Возврат;
	КонецЕсли;
	
КонецПроцедуры


&НаКлиенте
Процедура ДобавитьФото(Команда)
	
	#Если МобильноеПриложениеКлиент Тогда 
		ТекСтрока = Команда.ИспользуемаяТаблица.ТекущиеДанные;
		Если ТекСтрока = Неопределено Тогда
			Сообщить("Потрібно вибрати лічильник");
			Возврат;
		 КонецЕсли;
		 
		Если СредстваМультимедиа.ПоддерживаетсяФотоснимок(ТипКамерыУстройства.Задняя) Тогда
			Результат =  СредстваМультимедиа.СделатьФотоснимок(ТипКамерыУстройства.Задняя,,100,Истина,,Новый ОтметкаНаФотоснимке(Истина,,));
			Если НЕ Результат = Неопределено Тогда
								
				Двоичные = Результат.ПолучитьДвоичныеДанные();
				ПутьФото = ПоместитьВоВременноеХранилище(Двоичные,Новый УникальныйИдентификатор);
				ТекСтрока.Фото = ПутьФото;
				ТекСтрока.ЕстьФото = Истина;
				
				
				ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ГруппаЕстьФото", "Видимость",  Истина);
				ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ГруппаНетФото", "Видимость",  Ложь);
			Иначе
				ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ГруппаЕстьФото", "Видимость",  Ложь);
				ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ГруппаНетФото", "Видимость",  Истина);

			КонецЕсли;
			
		КонецЕсли;
	#КонецЕсли
	
КонецПроцедуры


&НаКлиенте
Процедура ТаблицаСчетчикиВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	
КонецПроцедуры


&НаКлиенте
Процедура ТаблицаСчетчикиПриАктивизацииСтроки(Элемент)
	
	ТекущиеДанные = Элементы.ТаблицаСчетчики.ТекущиеДанные;
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ГруппаЕстьФото", "Видимость",  ТекущиеДанные.ЕстьФото);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ГруппаНетФото", "Видимость",  НЕ ТекущиеДанные.ЕстьФото);
	ПутьФото = ТекущиеДанные.Фото;
	Элементы.ДекорацияСчетчик.Заголовок = ТекущиеДанные.Счетчик  +" "+Формат(ТекущиеДанные.Показание,"ЧЦ=15; ЧС=; ЧН=Введіть!; ЧГ=");
	НомерСтрокиДляПодсветки = ТекущиеДанные.Номер;
КонецПроцедуры


&НаСервере
Функция СохранитьНаСервере()
	
	СтруктураДокумента = Новый Структура();
	СтруктураДокумента.Вставить("UUID_Сотрудник", ПараметрыСеанса.Сотрудник_ID);
	СтруктураДокумента.Вставить("ДокументUUID", ДокументUUID);
	
	мСчетчики = Новый Массив;
	
	Для Каждого стрСчетчики Из ТаблицаСчетчики Цикл 
		Если стрСчетчики.ЕстьФото Тогда
			СодержимоеФайла	 = Base64Строка(ПолучитьИзВременногоХранилища(стрСчетчики.Фото));
			мСчетчики.Добавить(Новый Структура("СчетчикИД,Фото,Показание",стрСчетчики.СчетчикИД,СодержимоеФайла,стрСчетчики.Показание));
		КонецЕсли;
	КонецЦикла;
	
	СтруктураДокумента.Вставить("Счетчики", мСчетчики);

	Рез = ИнтеграцияТК_ВызовСервера.ПередатьДокументНаСервер(СтруктураДокумента,ТипДокумента);
	
	Возврат Рез;

КонецФункции


&НаКлиенте
Процедура Сохранить(Команда)
	
	стрВопрос = "";
	счВсего = 0;
	счБезФото = 0;
	счБезПоказания = 0;
	Для Каждого стрСчетчик  Из ТаблицаСчетчики Цикл 
		счВсего = счВсего + 1;
		Если стрСчетчик.ЕстьФото = Ложь Тогда
			счБезФото = счБезФото +1;
			стрВопрос = стрВопрос + "Лічильник "+  стрСчетчик.Счетчик + " немає фото"+Символы.ПС;
		КонецЕсли;
		Если стрСчетчик.ЕстьНомер = Ложь Тогда
			счБезПоказания = счБезПоказания +1;
			стрВопрос = стрВопрос + "Лічильник "+  стрСчетчик.Счетчик + "  немає свідчення"+Символы.ПС;

		КонецЕсли;
		
	КонецЦикла;
	Если счВсего = счБезФото ИЛИ счВсего = счБезПоказания Тогда
		Сообщить(стрВопрос);
		Возврат;
	КонецЕсли;

	ПоказатьВопрос(Новый ОписаниеОповещения("ОповещенияОтправки",ЭтотОбъект),стрВопрос +"Вивантажити дані на сервер?",РежимДиалогаВопрос.ДаНет);
	
	
КонецПроцедуры

&НаКлиенте
Процедура ОповещенияОтправки(Результат, Параметры)Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		ВыгрузитьДокументНаКлиенте();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВыгрузитьДокументНаКлиенте()
	
	Рез = СохранитьНаСервере();
	Если Рез.Результат Тогда
		Сообщить("Фото вивантажено успішно");
		Оповестить("ОбновитьЗадания");

		ВыполняетсяЗакрытие = Истина;
		Закрыть();
	Иначе
		Если ПустаяСтрока(Рез.ОписаниеОшибки) Тогда
			Сообщить("Помилка надсилання фото!");
		Иначе
			Сообщить(Рез.ОписаниеОшибки);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДекорацияСчетчикНажатие(Элемент)
	ТекущиеДанные = Элементы.ТаблицаСчетчики.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не выбран счетчик");
		Возврат;
	КонецЕсли;
	
	ДопПараметры = Новый Структура("ТекСчетчик",ТекущиеДанные);
	
	Оповещение = Новый ОписаниеОповещения("ПослеВводаКоличества", ЭтотОбъект,ДопПараметры);
	ПоказатьВводЧисла(Оповещение, ТекущиеДанные.Показание, "Введите показания "+ТекущиеДанные.Счетчик,,0);
	
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеВводаКоличества(Число, Параметры) Экспорт
    Если НЕ Число = Неопределено Тогда
		Параметры.ТекСчетчик.Показание = Число;
		Параметры.ТекСчетчик.ЕстьНомер = Истина;
		
		Элементы.ДекорацияСчетчик.Заголовок = Параметры.ТекСчетчик.Счетчик +" "+Формат(Число,"ЧЦ=15; ЧС=; ЧН=Введіть!; ЧГ=");
		
    КонецЕсли;
КонецПроцедуры;