&НаКлиенте
Функция СтруктураПараметровДляПечатиЧека()
	
	СуммаДокумента = СуммаДокументаКОплате();
	ПозицииЧека = Новый Массив();
	
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("СуммаДокумента", СуммаДокумента);
	СтруктураПараметров.Вставить("ДанныеОплатыПоПлатежнойКартеЧекаПродажи", ДанныеОплатыПоПлатежнойКартеЧекаПродажи);
	СтруктураПараметров.Вставить("ВидОперации", Объект.ВидОперации);
	СтруктураПараметров.Вставить("ДанныеОплатыПоПлатежнойКарте", ДанныеОплатыПоПлатежнойКарте());
	СтруктураПараметров.Вставить("ВидОплаты", Неопределено);
	СтруктураПараметров.Вставить("ЧекПродажи", Объект.ЧекПродажи);
	
	// Печать
	
	Для Каждого СтрокаТаблицы Из Объект.Товары Цикл
		
		СтрокаТаблицыТоваров = Новый Структура();
		СтрокаТаблицыТоваров.Вставить("ФискальнаяСтрока");
		СтрокаТаблицыТоваров.Вставить("Наименование", Строка(СтрокаТаблицы.Номенклатура));  // 1 - Наименование
		СтрокаТаблицыТоваров.Вставить("Количество"  ,СтрокаТаблицы.Количество);             // 2 - Количество
		СтрокаТаблицыТоваров.Вставить("Цена"        ,СтрокаТаблицы.Цена);                   // 3 - Цена
		СтрокаТаблицыТоваров.Вставить("Сумма"       ,СтрокаТаблицы.Сумма);                  // 4 - Сумма
		СтрокаТаблицыТоваров.Вставить("НомерСекции" ,1);                                    // 5 - НомерСекции
		
		Если Объект.ЦенаВключаетНДС Тогда
			Ставка = ЦенообразованиеКлиентСерверПовтИсп.ПолучитьСтавкуНДСЦелымЧислом(СтрокаТаблицы.СтавкаНДС);
		Иначе
			Ставка = Неопределено;
		КонецЕсли;
		
		СтрокаТаблицыТоваров.Вставить("СтавкаНДС"   ,Ставка);                               // 6 - СтавкаНДС
		
		ПозицииЧека.Добавить(СтрокаТаблицыТоваров);
		
	КонецЦикла;
	
	// Печать штрихкода в теле чека.
	Если ЗначениеНастроекВызовСервераПовтИсп.ПечататьШтрихкодНаЧеке() 
		И ЗначениеЗаполнено(ЗначениеНастроекВызовСервераПовтИсп.ОборудованиеПечати()) Тогда
		
		ЗаполнитьШтрихкодЧека();
		
		СтрокаПозицииЧека = Новый Структура();
		СтрокаПозицииЧека.Вставить("ТипШтрихкода", "EAN13"); // Одно из значений:"EAN8","EAN13","CODE39","QR".
		СтрокаПозицииЧека.Вставить("ШтрихКод", Объект.ШтрихкодЧека);
		
		ПозицииЧека.Добавить(СтрокаПозицииЧека);
		
	КонецЕсли;
	
	// ПОДГОТОВКА ТАБЛИЦЫ ОПЛАТ
	
	ТаблицаОплат = Новый Массив();
	
	// ПОДГОТОВКА ОБЩИХ ПАРАМЕТРОВ
	
	Объект.Дата = ОбщегоНазначенияКлиентСервер.ПолучитьТекущуюДату();
	Если НЕ ЗначениеЗаполнено(Объект.Номер) Тогда
		УстановитьНовыйНомер();
	КонецЕсли;
	
	// Структура чека
	ОбщиеПараметры = Новый Структура();
	
	Если Объект.ВидОперации = ПродажиКлиентСерверПовтИсп.ВидОперацииЧека_Продажа() Тогда
		
		ТипЧека = ПродажиКлиентСерверПовтИсп.ТипЧека_Продажа();
		
	ИначеЕсли Объект.ВидОперации = ПродажиКлиентСерверПовтИсп.ВидОперацииЧека_Возврат() Тогда
		
		ТипЧека = ПродажиКлиентСерверПовтИсп.ТипЧека_ВозвратПродажи();
		
	КонецЕсли;
	
	ОбщиеПараметры.Вставить("ТипЧека"            , ТипЧека);
	ОбщиеПараметры.Вставить("ПозицииЧека"        , ПозицииЧека);
	ОбщиеПараметры.Вставить("ТаблицаОплат"       , ТаблицаОплат);
	ОбщиеПараметры.Вставить("НомерЧека"          , Объект.Номер);
	ОбщиеПараметры.Вставить("НомерСмены"         , ПродажиВызовСервера.ПолучитьНомерСмены());
	
	//ОбщиеПараметры.Вставить("ПараметрыЧекаЕГАИС" , Неопределено);
	//
	//Если ИспользуетсяЕГАИС Тогда
	//	
	//	ОбщиеПараметры.ПараметрыЧекаЕГАИС = ПодготовитьДанныеДляПодписиЧека();
	//	
	//КонецЕсли;
	
	СтруктураПараметров.Вставить("ОбщиеПараметры", ОбщиеПараметры);
	
	Возврат СтруктураПараметров;
	
КонецФункции

