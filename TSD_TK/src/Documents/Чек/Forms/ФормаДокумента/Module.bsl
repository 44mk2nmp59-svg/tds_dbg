//	
//	//Возврат ИнтеграцияЕГАИСМК.ПодготовитьВходящиеДанныеДляПодписиЧека(Объект);
//	
//КонецФункции

&НаСервере
Процедура ПроверитьСмешаннуюОплатуВозврата(ПараметрыОплаты, Отказ)
	
	Если НЕ СмешаннаяОплатаВозврата Тогда
		Возврат;
	КонецЕсли;
	
	ОплатыЧекаПродажи = Объект.ЧекПродажи.Оплаты;
	
	Наличные = 0;
	Безналичные = 0;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЧекОплаты.ТипОплаты,
		|	ЧекОплаты.Сумма
		|ПОМЕСТИТЬ Оплаты
		|ИЗ
		|	Документ.Чек.Оплаты КАК ЧекОплаты
		|ГДЕ
		|	ЧекОплаты.Ссылка = &Ссылка
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ЧекОплаты.ТипОплаты,
		|	-ЧекОплаты.Сумма
		|ИЗ
		|	Документ.Чек.Оплаты КАК ЧекОплаты
		|ГДЕ
		|	ЧекОплаты.Ссылка.ЧекПродажи = &Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Оплаты.ТипОплаты КАК ТипОплаты,
		|	СУММА(Оплаты.Сумма) КАК Сумма
		|ИЗ
		|	Оплаты КАК Оплаты
		|
		|СГРУППИРОВАТЬ ПО
		|	Оплаты.ТипОплаты";
	
	Запрос.УстановитьПараметр("Ссылка", Объект.ЧекПродажи);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		Если Выборка.ТипОплаты = Перечисления.ТипыОплаты.Наличные Тогда
			Наличные = Выборка.Сумма;
		Иначе
			Безналичные = Выборка.Сумма;
		КонецЕсли;
	КонецЦикла;
	
	Если ПараметрыОплаты.СуммаДокумента >= Безналичные Тогда
		
		Если ПараметрыОплаты.СуммаДокумента > Наличные Тогда
			ПараметрыОплаты.Вставить("Безналичные", Безналичные);
		Иначе
			ПараметрыОплаты.Вставить("АльтернативнаяОплата", Истина);
			ПараметрыОплаты.Вставить("Безналичные", Безналичные);
		КонецЕсли;
	Иначе
		
		Если ПараметрыОплаты.СуммаДокумента > Наличные Тогда
			
			ТекстСообщение = НСтр("ru = 'Не хватает суммы наличных для возврата.
			|Оплата картой отменяется только полностью.'");
			
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщение);
			Отказ = Истина;
			
		Иначе
			ПараметрыОплаты.Вставить("Безналичные", 0);
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

