#КонецОбласти


#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Готово(Команда)
	Закрыть();
КонецПроцедуры

&НаКлиенте
Процедура Сканировать(Команда)
	ИдетПроцессСканирования = Истина;
	ОткрытьДиалогСканирования();

КонецПроцедуры


&НаКлиенте
Процедура АктивироватьСканер(Команда)
	
	ПодключаемоеОборудованиеКлиент.ИнициализироватьАсинхронныйСканер(ЭтаФорма);
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьДиалогСканирования()
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("Форма", ЭтаФорма);
	ДополнительныеПараметры.Вставить("ПотоковоеСканирование");
	ДополнительныеПараметры.Вставить("ЗаголовокСканирования", НСтр("ru = 'Считайте штрих-код'"));
	ДополнительныеПараметры.Вставить("ИмяОбработчикаЗакрытияСканирования", "ОбработкаЗакрытияСканирования");
	
	ПодключаемоеОборудованиеКлиент.ПолучитьШтрихкод(ДополнительныеПараметры);
	
КонецПроцедуры


#КонецОбласти



#Область ПрограммныйИнтерфейс

&НаСервереБезКонтекста
Функция ВерунутьУИДПодразделения()
	Возврат ПараметрыСеанса.UUID;	
КонецФункции



&НаКлиенте
Процедура ОбработатьПолученныйШтрихкод(ПолученныйШтрихкод, Параметры) Экспорт
	
	Если ЗначениеНастроекВызовСервераПовтИсп.ЭтоРежимПодключениеТК() Тогда
		
		ШтрихКодЗапрос = ?(СканированиеЗУП,ПолученныйШтрихкод+"|zup|"+ВерунутьУИДПодразделения(), ПолученныйШтрихкод);
		Если ПустаяСтрока(ШтрихКодЗапрос) Тогда   
			Элементы.Страницы.ТекущаяСтраница  = Элементы.ГруппаПусто;
			Элементы.Описание.Заголовок = "Пустая строка"; 
			Возврат;
		КонецЕсли;	
		Результат	= ИнтеграцияТК_Клиент.ПолучитьСотрудника(ШтрихКодЗапрос);	
		Если Результат.Результат Тогда
			
			
			Если СканированиеЗУП Тогда
				
				тзФормыСотрудник = Параметры.Форма.ВладелецФормы.ТаблицаСотрудник;	
				тзФормыСотрудник.Очистить();
				ДекорацияСтатусСотрудник = "";
				Если Результат.Ответ.Свойство("zup") Тогда
					Для Каждого  тzup Из Результат.Ответ.zup Цикл 
						НоваяСтрока = тзФормыСотрудник.Добавить();
						НоваяСтрока.Сотрудник =  тzup.EmployeeNeme;
						НоваяСтрока.СотрудникUUID =  тzup.EmployeeUUID;
						НоваяСтрока.Должность =  тzup.Position;
						НоваяСтрока.ДолжностьUUID =  тzup.PositionUUID;
						//
						//Если СтрНайти(тzup.info,"Новый вход")>0 Тогда
						//   СтатусСотрудника ="";
						//ИначеЕсли тzup.Status Тогда
						//	СтатусСотрудника = "Приход";
						//Иначе
						//	СтатусСотрудника = "Уход";
						//КонецЕсли;
						
						ДекорацияСтатусСотрудник = НоваяСтрока.Сотрудник;//+ "" +	НоваяСтрока.Должность +" "+СтатусСотрудника +" "+тzup.info+Символы.ПС;
					КонецЦикла;
					
				КонецЕсли;
				Если Результат.Ответ.Свойство("zupPrihod") Тогда
					
					zupPrihod =  Результат.Ответ.zupPrihod;
					Если zupPrihod.Количество()= 1 Тогда
						 Status = zupPrihod[0].Status; 
						 Time   = zupPrihod[0].Time; 
						Если Не Status = Неопределено Тогда
							 ДекорацияСтатусСотрудник = ДекорацияСтатусСотрудник+Символы.ПС +?( Status = Истина,"Приход","Уход");
						КонецЕсли; 
						
						Если Не Time = Неопределено Тогда
							  ДекорацияСтатусСотрудник = ДекорацияСтатусСотрудник +" "+ Time;
						КонецЕсли;
						
					КонецЕсли;
					
					
				КонецЕсли;
				
				
				Если Результат.Ответ.Свойство("КоличествоАнкет") Тогда
					Если Результат.Ответ.КоличествоАнкет > 0 Тогда
						Параметры.Форма.ВладелецФормы.Элементы.ДекорацияАнкетирование.Заголовок = "Информация по проверкам "+Формат(Результат.Ответ.КоличествоАнкет,"ЧЦ=2; ЧДЦ=0; ЧН=0");
						Параметры.Форма.ВладелецФормы.Элементы.ДекорацияАнкетирование.Видимость = Истина;
					КонецЕсли;
				 КонецЕсли;
			КонецЕсли;
			
			Параметры.Форма.ВладелецФормы.Элементы.ДекорацияСтатусСотрудник.Заголовок = ДекорацияСтатусСотрудник;
			Элементы.ТекущийСотрудник.Заголовок = Результат.Ответ.Name;
			Элементы.Страницы.ТекущаяСтраница  = Элементы.СтраницаСотр;
			Оповестить("ИзмененСотрудник");
			ПодключитьОбработчикОжидания("ЗакрытьФорму",1,Истина);
			
		Иначе
			Элементы.Страницы.ТекущаяСтраница  = Элементы.ГруппаПусто;
			Элементы.Описание.Заголовок = Результат.ОписаниеОшибки;
		КонецЕсли;
		
	Иначе
		Закрыть(ПолученныйШтрихкод);
	КонецЕсли;
	
КонецПроцедуры


