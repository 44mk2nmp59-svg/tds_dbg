

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("АвтоТест") Тогда
		Возврат;
	КонецЕсли;
	Если Параметры.Свойство("СотрудникЗУП") Тогда
		СканированиеЗУП = Истина;
	КонецЕсли;
	
	
	
	НастроитьФормуПоЗначениямНастроек();
	
	// ОриентацияЭкрана
	НастроитьФормуПоОриентацииЭкрана();
	
	//УстановитьЗаголовокПодразделение();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	АсинхронныйСканерИнициализирован = ПодключаемоеОборудованиеВызовСервера.СканерШтрихкодовИнициализирован();

	Если ИспользуетсяАсинхронныйСканер И АсинхронныйСканерИнициализирован = Ложь Тогда
		ПодключитьОбработчикОжидания("Подключаемый_ПодключитьАссинхронныйСканерШтрихкодов", 0.1, Истина);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ПодключитьАссинхронныйСканерШтрихкодов()
	
	ИнициализироватьАсинхронныйСканер();
	
КонецПроцедуры

&НаКлиенте
Процедура ИнициализироватьАсинхронныйСканер()
	
	ПодключаемоеОборудованиеКлиент.ИнициализироватьАсинхронныйСканер(ЭтаФорма);
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьЗаголовокПодразделение(Результат)
	Если НЕ ПустаяСтрока(Результат.Ответ) Тогда
		Элементы.ТекущийСотрудник.Заголовок = Результат.Ответ;
		Элементы.Страницы.ТекущаяСтраница  = Элементы.СтраницаСотр;
		
	Иначе
		Элементы.Страницы.ТекущаяСтраница  = Элементы.ГруппаПусто;
	КонецЕсли;
	
КонецПроцедуры




&НаКлиенте
Процедура ПриИзмененииПараметровЭкрана()
	
	// ОриентацияЭкрана
	ПриИзмененииПараметровЭкранаСервер();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	Если ИмяСобытия = "ИзмененыЗначенияНастроек" Тогда
		
		НастроитьФормуПоЗначениямНастроек();
	КонецЕсли;

		
	Если ПодключаемоеОборудованиеКлиент.ЭтоОповещениеСканераШтрихкода(ИмяСобытия) И ВводДоступен() Тогда
		
		ДополнительныеПараметры = Новый Структура;
		ДополнительныеПараметры.Вставить("Форма", ЭтаФорма);
		ОбработатьПолученныйШтрихкод(Параметр, ДополнительныеПараметры);
		
	КонецЕсли;

КонецПроцедуры


#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура НастроитьФормуПоЗначениямНастроек()
	
	ИспользуетсяАсинхронныйСканер = ЗначениеНастроекВызовСервераПовтИсп.ИспользуетсяАсинхронныйСканерШтрихкодов();
	
	Если ЗначениеНастроекВызовСервераПовтИсп.ЭтоРежимПодключениеТК() Тогда
		Сотрудник = ПараметрыСеанса.Сотрудник;
		
		Если НЕ ПустаяСтрока(Сотрудник) Тогда
			Элементы.ТекущийСотрудник.Заголовок = Сотрудник;
			Элементы.Страницы.ТекущаяСтраница  = Элементы.СтраницаСотр;
		Иначе
			Элементы.Страницы.ТекущаяСтраница  = Элементы.ГруппаПусто;
			
		КонецЕсли;
		
		
		ОбщегоНазначения.УстановитьШрифт(ЭтаФорма);
		ОбщегоНазначения.УстановитьЖирныйШрифтПолей(ЭтаФорма, "ТекущийСотрудник,ТекущийСотрудникПусто");
		ОбщегоНазначения.УстановитьЦветПредупреждающихПолей(ЭтаФорма,"ТекущийСотрудникПусто");
		ОбщегоНазначения.УстановитьЦветИнформационныхНадписей(ЭтаФорма,"ТекущийСотрудник");
		
		
		ЕстьОборудованиеСканирования = ЗначениеЗаполнено(ЗначениеНастроекВызовСервераПовтИсп.ТипУстройстваСканирования());
		
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ГруппаСканированиеНевозможно", "Видимость",
		НЕ ЕстьОборудованиеСканирования);
		
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "Сканировать", "Доступность",
		ЕстьОборудованиеСканирования И НЕ ИспользуетсяАсинхронныйСканер
		);
	Иначе
		Элементы.ТекущийСотрудник.Заголовок = "Відскануйте ШК комірки";
		
	КонецЕсли;
	
	НастроитьЭлементыАсинхронногоСканера();

	
КонецПроцедуры

&НаСервере
Процедура НастроитьЭлементыАсинхронногоСканера()
	

	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "АктивироватьСканер", "Видимость", 
		ИспользуетсяАсинхронныйСканер
	);
	
КонецПроцедуры



#КонецОбласти

