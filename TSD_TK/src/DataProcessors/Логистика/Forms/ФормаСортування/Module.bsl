					Элементы.АдресаДоставки.ТекущаяСтрока = СтрокаАдрес.ПолучитьИдентификатор();    
					
					СтруктураФормаРК.Вставить("сч_скан",СтрокаАдрес.сч_скан);
					СтруктураФормаРК.Вставить("сч_док",СтрокаАдрес.сч_док);
					СтруктураФормаРК.Вставить("Global_ID",СтрокаАдрес.ТЧ_Global_ID);  
					СтруктураФормаРК.Вставить("ТД",СтрокаАдрес.ТД); 
					СтруктураФормаРК.Вставить("PKG",СтруктураРК.МассивPKG);  

				КонецЕсли; 
			
			КонецЕсли;
			 	ОписаниеОповещения = Новый ОписаниеОповещения("ОповещениеСканированиеРК", ЭтотОбъект);
					ОткрытьФорму("Обработка.Логистика.Форма.ФормаРК",СтруктураФормаРК,ЭтотОбъект,,,,ОписаниеОповещения,РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);	
				

		Иначе
			Сообщить("Помилка сканування РК "+ RKИнфо.ОписаниеОшибки);	
		КонецЕсли;
	
	Иначе  
		 Сообщить("Відскануйте ролл-кейдж для прив'язки PKG");
	//	
	//	МСтроки =  СтрРазделить(ПолученныйШтрихкод,";");   
	//	Если МСтроки.Количество() = 3  Тогда
	//		ИД_ПКГ = МСтроки[0];
