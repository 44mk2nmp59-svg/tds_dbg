&НаСервере
Процедура ПолучитьДанныеСортировки()

 текстЗапроса = "/Logistika/"+ПараметрыСеанса.UUID+"/TTNInfsort?uuidcom="+ПараметрыСеанса.Сотрудник_ID;

  РезОтвет = КомплектовщикТК.ПодготовитьGETЗапрос(текстЗапроса);
  Объект.АдресаДоставки.Очистить();
  Объект.Документы.Очистить();  
  
  Если РезОтвет.Результат Тогда
	  
	  Если ТипЗнч(РезОтвет.Ответ) = Тип("Структура") Тогда
		  МассивАдреса = РезОтвет.Ответ.ТЧ_РК; 
		  МассивПКГ =   РезОтвет.Ответ.ТЧ_РК_ПКГ;
	  Иначе   
		  МассивАдреса = РезОтвет.Ответ;
		  МассивПКГ = Новый Массив;
	  КонецЕсли;
	  
	  
	 Для Каждого АдресДоставки Из МассивАдреса Цикл 
	   НстрокаАдрес =  Объект.АдресаДоставки.Добавить();  
	   ЗаполнитьЗначенияСвойств(НстрокаАдрес,АдресДоставки);
	   НстрокаАдрес.ЗаписьПоСтроке = ?(НстрокаАдрес.РК,"ROLL CAGE ","")+"PKG "+ Формат(НстрокаАдрес.сч_док,"ЧЦ=3; ЧН=0; ЧГ=")+" х "+ Формат(НстрокаАдрес.сч_скан,"ЧЦ=3; ЧН=0; ЧГ=")
	 КонецЦикла;
	 
	 Для Каждого ПКГДоставки Из МассивПКГ Цикл 
		   НстрокаПКГ =  Объект.Документы.Добавить();   
		   НстрокаПКГ.ТЧ_Global_ID = ПКГДоставки.ТЧ_Global_ID;
		   НстрокаПКГ.СкладСборки  = ПКГДоставки.СкладСборки; 
		   НстрокаПКГ.ИД_УП        = ПКГДоставки.ИД_УП;
		   НстрокаПКГ.НомерТУ  = ПКГДоставки.ПКГНомер;
		   НстрокаПКГ.сч_скан  = ПКГДоставки.сч_скан;
	 КонецЦикла;

	  
  Иначе
	 тОш =  ?(ЗначениеЗаполнено(РезОтвет.ОписаниеОшибки),РезОтвет.ОписаниеОшибки,"Помилка отримання даних"); 
	 Сообщить(тОш);    
	 ОбщегоНазначенияКлиентСервер.ОчиститьСотрудника();
	 ОбновитьСотрудника();
  КонецЕсли;
  

КонецПроцедуры

 &НаСервере
Функция ПолучитьДанныеRK(ШК_RK)

	МассивRK = СтрРазделить(ШК_RK,";",);	 
	ТЕUUID = МассивRK[1]; 
	текстЗапроса = "/Logistika/"+ПараметрыСеанса.UUID+"/RKinf?uuidcom="+ПараметрыСеанса.Сотрудник_ID+"&chk="+ТЕUUID;
	
	РезОтвет = КомплектовщикТК.ПодготовитьGETЗапрос(текстЗапроса);

	Возврат РезОтвет; 
	
КонецФункции

 &НаСервере
Функция ПолучитьДанныеПКГ(ШК_ПКГ)

 
	текстЗапроса = "/Logistika/"+ПараметрыСеанса.UUID+"/PKGinf?uuidcom="+ПараметрыСеанса.Сотрудник_ID+"&chk="+ШК_ПКГ;
	
	РезОтвет = КомплектовщикТК.ПодготовитьGETЗапрос(текстЗапроса);
	
	Возврат РезОтвет; 
	
КонецФункции

 &НаСервере
Функция РазместитьПКГ(ШК_ПКГ)

 
	текстЗапроса = "/Logistika/"+ПараметрыСеанса.UUID+"/PKGLoad?uuidcom="+ПараметрыСеанса.Сотрудник_ID+"&chk="+ШК_ПКГ;
	
	РезОтвет = КомплектовщикТК.ПодготовитьGETЗапрос(текстЗапроса);
	
	Возврат РезОтвет; 
	
КонецФункции


