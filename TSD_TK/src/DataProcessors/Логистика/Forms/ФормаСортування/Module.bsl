&НаКлиенте
Процедура АдресаДоставкиВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)	
	СтандартнаяОбработка = Ложь;
	

	ТекущиеДанные = Элементы.АдресаДоставки.ТекущиеДанные;
	ОткрытьФорму("ОбщаяФорма.ФормаПечати",СформироватьСтруктуруДляПечатиНаСервере(ТекущиеДанные.ТЧ_Global_ID,ТекущиеДанные.ТД),ЭтаФорма,,,,,РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	

	
КонецПроцедуры

 &НаСервере
Функция СформироватьСтруктуруДляПечатиНаСервере(ТЧ_Global_ID,ТочкаДоставки)
	
	МассивСтрок = Объект.Документы.НайтиСтроки(Новый Структура("ТЧ_Global_ID",ТЧ_Global_ID,));	 
	СтруктураСтрок = Новый Структура;
	СтруктураСтрок.Вставить("PKG");
	СтруктураСтрок.Вставить("ТочкаДоставки",ТочкаДоставки);
	МассивPKG = Новый Массив;
	Для Каждого ТекТаблицаPKG Из МассивСтрок Цикл 
		МассивPKG.Добавить(Новый Структура("СкладСборки,НомерТУ,сч_скан",ТекТаблицаPKG.СкладСборки,ТекТаблицаPKG.НомерТУ,ТекТаблицаPKG.сч_скан));
	КонецЦикла;
	СтруктураСтрок.Вставить("ДанныеPKG",МассивPKG);
	
	Возврат СтруктураСтрок;
	
КонецФункции



