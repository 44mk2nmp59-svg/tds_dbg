 &НаКлиенте
Процедура ОповещениеСканированиеРК(Результат, Параметры)Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	    
	СтрокиАдресаДоставки = Объект.АдресаДоставки.НайтиСтроки(Новый Структура("ТЧ_Global_ID",Результат.Global_ID)); 
	Если СтрокиАдресаДоставки.Количество()=0 Тогда
		Возврат;
	КонецЕсли;
	
	СтрокаАдрес = СтрокиАдресаДоставки[0];      
	СтрокаАдрес.сч_скан = Результат.сч_скан;
	СтрокаАдрес.ЗаписьПоСтроке = ?(СтрокаАдрес.РК,"ROLL CAGE ","")+"PKG "+ Формат(СтрокаАдрес.сч_док,"ЧЦ=3; ЧН=0; ЧГ=")+" х "+ Формат(СтрокаАдрес.сч_скан,"ЧЦ=3; ЧН=0; ЧГ=");
	Для Каждого СтрПКГ Из Результат.PKG Цикл 
		СтрокиДок = Объект.Документы.НайтиСтроки(Новый Структура("ИД_УП",СтрПКГ.ИД_PKG)); 
		Если СтрокиДок.Количество()=1 Тогда
			СтрокаДок = СтрокиДок[0];
			СтрокаДок.сч_скан = 1;
		КонецЕсли;
		
	КонецЦикла;
	
	
КонецПроцедуры



