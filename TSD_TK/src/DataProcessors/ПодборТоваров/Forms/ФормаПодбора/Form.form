    <title>
      <key>ru</key>
      <value>Прайс лист</value>
    </title>
    <id>2</id>
    <valueType>
      <types>DynamicList</types>
    </valueType>
    <view>
      <common>true</common>
    </view>
    <edit>
      <common>true</common>
    </edit>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>ПрайсЛист.ЕстьСкидка</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>ПрайсЛист.Избранное</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>ПрайсЛист.Количество</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>ПрайсЛист.Наименование</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>ПрайсЛист.Номенклатура</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>ПрайсЛист.Ссылка</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>ПрайсЛист.Цена</segments>
    </notDefaultUseAlwaysAttributes>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	ИсточникДанных.Ссылка КАК Ссылка,
	ИсточникДанных.Ссылка КАК Номенклатура,
	ИсточникДанных.Родитель КАК Группа,
	ИсточникДанных.Наименование КАК Наименование,
	ИсточникДанных.Код КАК Артикул,
	ИсточникДанных.ЭтоГруппа КАК ЭтоГруппа,
	ВЫБОР
		КОГДА ИзбранныеТовары.Номенклатура ЕСТЬ NULL
			ТОГДА ЛОЖЬ
		ИНАЧЕ ИСТИНА
	КОНЕЦ КАК Избранное,
	0 КАК Количество,
	ВЫБОР
		КОГДА ИзбранныеТовары.Номенклатура ЕСТЬ NULL
			ТОГДА 1
		ИНАЧЕ 0
	КОНЕЦ КАК ИзбранноеИндекс,
	ЛОЖЬ КАК ЕстьСкидка,
	ЕСТЬNULL(БуферПодбораТоваров.Цена, 0) КАК Цена
ИЗ
	Справочник.Номенклатура КАК ИсточникДанных
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ИзбранныеТовары КАК ИзбранныеТовары
		ПО ИсточникДанных.Ссылка = ИзбранныеТовары.Номенклатура
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.БуферПодбораТоваров КАК БуферПодбораТоваров
		ПО ИсточникДанных.Ссылка = БуферПодбораТоваров.Ссылка
ГДЕ
	НЕ ИсточникДанных.ЭтоГруппа
	И НЕ ИсточникДанных.ПометкаУдаления</queryText>
      <mainTable>Catalog.Номенклатура</mainTable>
      <dynamicDataRead>true</dynamicDataRead>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
    </extInfo>
  </attributes>
