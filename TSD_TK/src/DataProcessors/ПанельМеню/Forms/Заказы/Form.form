    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>СписокЗаказов.ТелефонКлиента</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>СписокЗаказов.ФИОКлиента</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>СписокЗаказов.ЖелаемаяДатаПокупки</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>СписокЗаказов.СортировкаПоСтатусу</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>СписокЗаказов.СтатусЗаказа</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>СписокЗаказов.СуммаДокумента</segments>
    </notDefaultUseAlwaysAttributes>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	ЗаказКлиента.Ссылка КАК Ссылка,
	ЗаказКлиента.Номер КАК Номер,
	ЗаказКлиента.Дата КАК Дата,
	ЗаказКлиента.ЖелаемаяДатаПокупки КАК ЖелаемаяДатаПокупки,
	ЗаказКлиента.НомерЗаказа КАК НомерЗаказа,
	ЗаказКлиента.СтатусЗаказа КАК СтатусЗаказа,
	ЗаказКлиента.СуммаДокумента КАК СуммаДокумента,
	ВЫБОР
		КОГДА ЗаказКлиента.СтатусЗаказа = ЗНАЧЕНИЕ(ПЕРЕЧИСЛЕНИЕ.СтатусыЗаказовКлиентов.ВРаботе)
			ТОГДА 0
		ИНАЧЕ ВЫБОР
				КОГДА ЗаказКлиента.СтатусЗаказа = ЗНАЧЕНИЕ(ПЕРЕЧИСЛЕНИЕ.СтатусыЗаказовКлиентов.ГотовКОбмену)
					ТОГДА 1
				ИНАЧЕ ВЫБОР
						КОГДА ЗаказКлиента.СтатусЗаказа = ЗНАЧЕНИЕ(ПЕРЕЧИСЛЕНИЕ.СтатусыЗаказовКлиентов.Отправлен)
							ТОГДА 2
						ИНАЧЕ ВЫБОР
								КОГДА ЗаказКлиента.СтатусЗаказа = ЗНАЧЕНИЕ(ПЕРЕЧИСЛЕНИЕ.СтатусыЗаказовКлиентов.Архивный)
									ТОГДА 3
								ИНАЧЕ 99
							КОНЕЦ
					КОНЕЦ
			КОНЕЦ
	КОНЕЦ КАК СортировкаПоСтатусу,
	ЗаказКлиента.Контрагент КАК Контрагент,
	ЗаказКлиента.Телефон КАК Телефон,
	ЗаказКлиента.ПредставлениеЗаказа КАК ПредставлениеЗаказа
ИЗ
	Документ.ЗаказКлиента КАК ЗаказКлиента
ГДЕ
	ВЫБОР
			КОГДА &amp;ФильтрНаСегодня = ИСТИНА
				ТОГДА ЗаказКлиента.ЖелаемаяДатаПокупки &lt;= &amp;ТекущаяДата
						И ВЫБОР
							КОГДА НЕ ЗаказКлиента.ЖелаемаяДатаПокупки = &amp;ТекущаяДата
								ТОГДА ЗаказКлиента.СтатусЗаказа В (ЗНАЧЕНИЕ(ПЕРЕЧИСЛЕНИЕ.СтатусыЗаказовКлиентов.ВРаботе), ЗНАЧЕНИЕ(ПЕРЕЧИСЛЕНИЕ.СтатусыЗаказовКлиентов.ГотовКОбмену))
							ИНАЧЕ ИСТИНА
						КОНЕЦ
			ИНАЧЕ ВЫБОР
					КОГДА &amp;ФильтрНаЗавтра = ИСТИНА
						ТОГДА ЗаказКлиента.ЖелаемаяДатаПокупки = ДОБАВИТЬКДАТЕ(&amp;ТекущаяДата, ДЕНЬ, 1)
					ИНАЧЕ ИСТИНА
				КОНЕЦ
		КОНЕЦ</queryText>
      <mainTable>Document.ЗаказКлиента</mainTable>
      <dynamicDataRead>true</dynamicDataRead>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
    </extInfo>
  </attributes>
