&НаСервере
Функция ЗафиксироватьПосетителяНаСервере(ДаныеПосетителя)
	
	ДаныеПосетителя.Вставить("ДоументСервер",Ложь);
	ДаныеПосетителя.Вставить("ДатаСобытия",ТекущаяДатаСеанса());

	ТипДокумента  = Справочники.ТипыДокументов.Посетители;
	Рез = ИнтеграцияТК_ВызовСервера.ПередатьДокументНаСервер(ДаныеПосетителя,ТипДокумента);
	
	Возврат Рез;
	
	
КонецФункции


