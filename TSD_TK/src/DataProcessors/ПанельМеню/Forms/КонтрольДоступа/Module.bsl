	ДаныеПосетителя = Новый Структура("КодПоДРФО,ДатаОбновления,Приход", КодПоДРФО ,ДатаОбновления,0);
	Рез = ЗафиксироватьПосетителяНаСервере(ДаныеПосетителя);
	
