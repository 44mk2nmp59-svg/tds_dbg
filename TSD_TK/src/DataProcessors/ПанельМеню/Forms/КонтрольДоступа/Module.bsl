&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("АвтоТест") Тогда
		Возврат;
	КонецЕсли;
	МассивПараметров = ОбщегоНазначенияКлиентСервер.РазложитьСтрокуВМассивПодстрок(Параметры.СтрокаДоступа,";");
	Если МассивПараметров.Количество() = 0 Тогда
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	      
	ДанныеЗапроса = ИнтеграцияТК_ВызовСервера.ПолучитьСтатусДоверенногоЛица(МассивПараметров[1]);
	Если ДанныеЗапроса.Результат Тогда
		Если ДанныеЗапроса.Ответ.Статус = 0 Тогда
			ЭтаФорма.ТекущийЭлемент = Элементы.СтраницаДоступЗапрещен;
		Иначе
			ЭтаФорма.ТекущийЭлемент = Элементы.СтраницаДоступРазрешен;
			Элементы.ТекущийСотрудник.Заголовок = ДанныеЗапроса.Ответ.ФИО; 
			ДатаОбновления =  ДанныеЗапроса.Ответ.ДатаОбновления;
			КодПоДРФО      =  ДанныеЗапроса.Ответ.КодПоДРФО;
			Если ЗначениеЗаполнено(ДанныеЗапроса.Ответ.Фото) Тогда
				СтруктураПодключения = ИнтеграцияТК.ПараметрыПодключенияФайлаКартинки(ДанныеЗапроса.Ответ.Фото);
				Соединение = Новый HTTPСоединение(СтруктураПодключения.АдресСервера,,,,,,Новый ЗащищенноеСоединениеOpenSSL(Неопределено,Неопределено));
				
				Запрос = Новый HTTPЗапрос(СтруктураПодключения.ИмяКаталога);
				Ответ = Соединение.Получить(Запрос);
				Если Ответ.КодСостояния = 200 Тогда
					Картинка = Новый Картинка(Ответ.ПолучитьТелоКакДвоичныеДанные());
					ПутьФото =  ПоместитьВоВременноеХранилище(Картинка , Новый УникальныйИдентификатор);
				
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	Иначе
		ЭтаФорма.ТекущийЭлемент = Элементы.СтраницаОшибка;

		Элементы.Описание.Заголовок = ДанныеЗапроса.ОписаниеОшибки;
	КонецЕсли;
КонецПроцедуры

