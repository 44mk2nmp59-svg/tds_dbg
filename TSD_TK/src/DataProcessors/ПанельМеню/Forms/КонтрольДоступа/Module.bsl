&НаКлиенте
Процедура Декорация1Нажатие(Элемент)
	
	ДаныеПосетителя = Новый Структура("КодПоДРФО,ДатаОбновления,Приход", КодПоДРФО ,ДатаОбновления,1);
	Рез = ЗафиксироватьПосетителяНаСервере(ДаныеПосетителя);
	
	Если Рез.Результат Тогда
		ВыполняетсяЗакрытие = Истина;
		Закрыть();
	Иначе
		Сообщить("Не удалось записать!");
	КонецЕсли;

	
	
КонецПроцедуры

&НаКлиенте
