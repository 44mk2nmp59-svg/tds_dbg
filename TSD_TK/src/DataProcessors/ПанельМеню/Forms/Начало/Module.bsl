&НаКлиенте
Процедура ПослеЧтоНового(Результат, ДополнительныеПараметры) Экспорт
	
	ПослеЧтоНовогоСервер();
	
	ПроверитьУстановленныеДрайверы();
	
	ОткрыватьЧтоНового = Ложь;
	
	ЗапуститьПродолжитьОчередьПроцедурПослеОткрытия();
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеОбновленияБД(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат Тогда
		
		ОбновлениеБД = Ложь;
		
		ОткрыватьЧтоНового = Истина;
		
		ЗапуститьПродолжитьОчередьПроцедурПослеОткрытия();
		
	Иначе
		ЗавершитьРаботуСистемы();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура НастроитьФормуПоЗначениямНастроек()
	
	ОбщегоНазначения.УстановитьШрифт(ЭтаФорма);
	
	ИспользуетсяАсинхронныйСканер = ЗначениеНастроекВызовСервераПовтИсп.ИспользуетсяАсинхронныйСканерШтрихкодов();
	АвтономныйРежим =  ЗначениеНастроекВызовСервераПовтИсп.ЭтоАвтономныйРежим() ИЛИ НЕ ЗначениеНастроекВызовСервераПовтИсп.УстановленРежимСинхронизации();

	//НетИнициализации = ПустаяСтрока(ПараметрыСеанса.Подразделение);
	ЕстьНеустановленныеПараметры = Ложь;
	
	Если НЕ ЗначениеНастроекВызовСервераПовтИсп.УстановленРежимСинхронизации() Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ГруппаСообщениеРежимСинхронизации", "Видимость", Истина);
		ЕстьНеустановленныеПараметры = Истина;
	Иначе
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ГруппаСообщениеРежимСинхронизации", "Видимость", Ложь);
		
	КонецЕсли;
	
	Если ЗначениеНастроекВызовСервераПовтИсп.УстановленРежимСинхронизации()
		И НЕ ЗначениеНастроекВызовСервераПовтИсп.ЗаполненыПараметрыСинхронизации()
		И НЕ ЗначениеНастроекВызовСервераПовтИсп.ЭтоАвтономныйРежим() Тогда
		
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ГруппаСообщениеПараметрыСинхронизации", "Видимость", НЕ ЕстьНеустановленныеПараметры);
		ЕстьНеустановленныеПараметры = Истина;
	Иначе
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ГруппаСообщениеПараметрыСинхронизации", "Видимость", Ложь);
		
	КонецЕсли;
	
	Если НЕ ЗначениеНастроекВызовСервераПовтИсп.ЗаполненыПараметрыУчета() Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ГруппаСообщениеПараметрыУчета", "Видимость", НЕ ЕстьНеустановленныеПараметры);
		ЕстьНеустановленныеПараметры = Истина;
	Иначе
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ГруппаСообщениеПараметрыУчета", "Видимость", Ложь);
		
	КонецЕсли;
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, 
		"СообщениеРаботаНеВозможна",
		"Видимость",
		ЕстьНеустановленныеПараметры);
	//	
	//ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "СканированиеШтрихкода", "Видимость", 
	//	ЗначениеНастроекВызовСервераПовтИсп.ОтображатьКомандуСканированияШтрихкодаТоваров() И НЕ ИспользуетсяАсинхронныйСканер);
	//	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ГруппаГео", "Видимость", 
		ЗначениеНастроекВызовСервераПовтИсп.ИспользуетсяГеолокация()
	);
		
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ГруппаКассир", "Видимость", 
		ЗначениеНастроекВызовСервераПовтИсп.ИспользуетсяУчетПоКассирам()
	);
	
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ВиджетЗаказы", "Видимость", 
		ЗначениеНастроекВызовСервераПовтИсп.ИспользуютсяЗаказыКлиентов()  И АвтономныйРежим
	);

	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ГруппаПриемТовара", "Видимость", 
		ЗначениеНастроекВызовСервераПовтИсп.ИспользуетсяПриемТовара()  И НЕ АвтономныйРежим И ЗначениеНастроекВызовСервераПовтИсп.ЭтоРежимПодключениеТК()
	);

		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ГруппаСписание", "Видимость", 
		ЗначениеНастроекВызовСервераПовтИсп.ИспользуетсяСписаниеТоваров()  И НЕ АвтономныйРежим  И ЗначениеНастроекВызовСервераПовтИсп.ЭтоРежимПодключениеТК()
	);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ГруппаПроверкаЦен", "Видимость", 
		ЗначениеНастроекВызовСервераПовтИсп.ИспользуетсяПроверкаЦен() И НЕ АвтономныйРежим  И ЗначениеНастроекВызовСервераПовтИсп.ЭтоРежимПодключениеТК()
	);

		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ГруппаПеремещение", "Видимость", 
		ЗначениеНастроекВызовСервераПовтИсп.ИспользуетсяПеремещение()  И НЕ АвтономныйРежим И ЗначениеНастроекВызовСервераПовтИсп.ЭтоРежимПодключениеТК()
	);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ГруппаИнвентаризация", "Видимость", 
		ЗначениеНастроекВызовСервераПовтИсп.ИспользуетсяИнвентаризация()  И НЕ АвтономныйРежим И ЗначениеНастроекВызовСервераПовтИсп.ЭтоРежимПодключениеТК()
	);

		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ГруппаЖурналДокументов", "Видимость", 
		ЗначениеНастроекВызовСервераПовтИсп.ИспользуетсяЖурналДокументов()  И НЕ АвтономныйРежим И ЗначениеНастроекВызовСервераПовтИсп.ЭтоРежимПодключениеТК()
	);


	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ГруппаВозвратТовара", "Видимость", 
	ЗначениеНастроекВызовСервераПовтИсп.ИспользуетсяВозвратТовара()   И НЕ АвтономныйРежим И ЗначениеНастроекВызовСервераПовтИсп.ЭтоРежимПодключениеТК()
	);

	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ГруппаУценка", "Видимость", 
	ЗначениеНастроекВызовСервераПовтИсп.ИспользуетсяУценкаТовара()   И НЕ АвтономныйРежим И ЗначениеНастроекВызовСервераПовтИсп.ЭтоРежимПодключениеТК()
	);

	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ГруппаКомлектация", "Видимость", 
	ЗначениеНастроекВызовСервераПовтИсп.ИспользуетсяУценкаТовара()   И НЕ АвтономныйРежим И НЕ ЗначениеНастроекВызовСервераПовтИсп.ЭтоРежимПодключениеТК()
	);
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ГруппаКонтролер", "Видимость", 
	ЗначениеНастроекВызовСервераПовтИсп.ИспользуетсяКонтролер()   И НЕ АвтономныйРежим И ЗначениеНастроекВызовСервераПовтИсп.ЭтоРежимПодключениеТК()
	);
	
	                                                                         
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ГруппаИнвентаризацияКом", "Видимость", 
	ЗначениеНастроекВызовСервераПовтИсп.ИспользуетсяИнвентаризацияКоммисия()   И НЕ АвтономныйРежим И ЗначениеНастроекВызовСервераПовтИсп.ЭтоРежимПодключениеТК()
	);
	
	                                                                         
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ГруппаПереоценка", "Видимость", 
	ЗначениеНастроекВызовСервераПовтИсп.ИспользуетсяПереоценки()   И НЕ АвтономныйРежим И ЗначениеНастроекВызовСервераПовтИсп.ЭтоРежимПодключениеТК()
	);
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ГруппаМенеджерТЗ", "Видимость", 
	ЗначениеНастроекВызовСервераПовтИсп.ИспользуетсяМенеджерТЗ()   И НЕ АвтономныйРежим И ЗначениеНастроекВызовСервераПовтИсп.ЭтоРежимПодключениеТК()
	);
	
		
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ГруппаПриходУход", "Видимость", 
	ЗначениеНастроекВызовСервераПовтИсп.ИспользуетсяПриходУход()   И НЕ АвтономныйРежим И ЗначениеНастроекВызовСервераПовтИсп.ЭтоРежимПодключениеТК()
	);

	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ГруппаЗадачи", "Видимость", 
	ЗначениеНастроекВызовСервераПовтИсп.ИспользуетсяЗадачи()   И НЕ АвтономныйРежим И ЗначениеНастроекВызовСервераПовтИсп.ЭтоРежимПодключениеТК()
	);

	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ГруппаФото", "Видимость", 
	ЗначениеНастроекВызовСервераПовтИсп.ИспользуетсяФото()   И НЕ АвтономныйРежим И ЗначениеНастроекВызовСервераПовтИсп.ЭтоРежимПодключениеТК()
	);
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ГруппаСканировка", "Видимость", 
	ЗначениеНастроекВызовСервераПовтИсп.ИспользуетсяСканировкаТабак()   И НЕ АвтономныйРежим И ЗначениеНастроекВызовСервераПовтИсп.ЭтоРежимПодключениеТК()
	);
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ГруппаСклад", "Видимость", 
	ЗначениеНастроекВызовСервераПовтИсп.ИспользуетсяЛогистика()   И НЕ АвтономныйРежим И ЗначениеНастроекВызовСервераПовтИсп.ЭтоРежимПодключениеТК()
	);
	
	ОбновитьПодразделение();
	
	НастроитьЭлементыАсинхронногоСканера();
	
КонецПроцедуры

