Процедура Фото(Команда)

	Список = Новый СписокЗначений;
//	Список.Добавить("ФотоСчетчика",,,БиблиотекаКартинок.счетчик);
	Список.Добавить("ФотоОтчета","Фото отчета");
	Оповещение = Новый ОписаниеОповещения("ПослеВыбораИзМеню",ЭтотОбъект,Параметры);
