&НаКлиенте
Процедура ПослеВыбораИзМеню(ВыбранныйЭлемент, Параметры) Экспорт
   
	Если ВыбранныйЭлемент = Неопределено Тогда
		Возврат;
	КонецЕсли;
	Если ВыбранныйЭлемент.Значение = "ФотоОтчета" Тогда
		ФайлФото = ОбщегоНазначенияКлиент.СделатьФото();
		Если ФайлФото = Неопределено Тогда
			Возврат;
		КонецЕсли;
		
		СохранитьФотоНаСервер(ФайлФото)
	Иначе
		ПараметрыФормы = Новый Структура("ТипДокумента", ПредопределенноеЗначение("Справочник.ТипыДокументов.ФотоСчетчика"));
		ОткрытьФорму("Обработка.ПанельМеню.Форма.ФормаФотоСчетчика", ПараметрыФормы, ЭтаФорма,,,,, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);

	КонецЕсли;	
	
КонецПроцедуры

&НаСервере
Процедура СохранитьФотоНаСервер(ФайлФото)
	
	СтруктураДокумента = Новый Структура();
	СтруктураДокумента.Вставить("ДоументСервер",Ложь);
	СодержимоеФайла	 = Base64Строка(Новый ДвоичныеДанные(ФайлФото));
	СтруктураДокумента.Вставить("Фото",СодержимоеФайла);
	
	Если  ЗначениеНастроекВызовСервераПовтИсп.ЭтоРежимПодключениеТК() Тогда
		Рез = ИнтеграцияТК_ВызовСервера.ПередатьДокументНаСервер(СтруктураДокумента,Справочники.ТипыДокументов.Фото);
		Если Не Рез.Результат Тогда
			
			Если ПустаяСтрока(Рез.ОписаниеОшибки) Тогда
				Сообщить("Ошибка отправки фото!");
			Иначе
				Сообщить(Рез.ОписаниеОшибки);
			КонецЕсли;
			
		КонецЕсли;
		
		
	КонецЕсли;
	
КонецПроцедуры


