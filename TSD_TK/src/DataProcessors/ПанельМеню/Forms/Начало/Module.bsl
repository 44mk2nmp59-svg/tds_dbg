Процедура ОповещениеВыборКассираНаСервере(Результат)
	
	УстановитьЗаголовокКассир(Результат);
	
	ОбщегоНазначенияВызовСервера.СохранитьНастройкуПользователя("Кассир", Результат);
	ОбщегоНазначенияВызовСервера.УстановитьПараметрСеанса("ТекущийПользователь", Результат);
	
	ОбновитьПовторноИспользуемыеЗначения();
	
КонецПроцедуры

&НаСервере
Процедура УстановитьЗаголовокКассир(Пользователь)
	
	Если ЗначениеЗаполнено(Пользователь) Тогда
		
		Элементы.ТекущийКассир.Заголовок = Пользователь.Наименование;
		ОбщегоНазначения.УстановитьЦветИнформационныхНадписей(ЭтаФорма, "ТекущийКассир");
	Иначе
		
		Элементы.ТекущийКассир.Заголовок = НСтр("ru = 'Кассир не определен'");
		ОбщегоНазначения.УстановитьЦветПолейОшибок(ЭтаФорма, "ТекущийКассир");
		
	КонецЕсли;
	
