&НаКлиенте
Асинх Процедура ВыбратьМенюАнсинх() 
	
	СписокВыбора = Новый СписокЗначений;
	СписокВыбора.Добавить("МаршрутныйЛист","Маршрутний лист"); 
	СписокВыбора.Добавить("ВозвратПеремещение","Повернення-переміщення");
	СписокВыбора.Добавить("Сортировка","Сортування"); 
	СписокВыбора.Добавить("Загрузка","Завантаження машини"); 
	СписокВыбора.Добавить("Доставка","PKG у дорозі"); 
	СписокВыбора.Добавить("ЗипПакет","Забрати ЗіпПакет");  
		
	 Ответ = Ждать ВыбратьИзМенюАсинх(СписокВыбора);   
	 Если Не Ответ = Неопределено Тогда
		 ЗначениеВыбора = Ответ.Значение; 
		 
		 Если ЗначениеВыбора = "МаршрутныйЛист" Тогда
			 ПараметрыФормы = Новый Структура("ТипДокумента",ПредопределенноеЗначение("Справочник.ТипыДокументов.МаршрутныйЛист"));
			 ОткрытьФорму("Обработка.ПанельМеню.Форма.ФормаДокумента",ПараметрыФормы, ЭтаФорма,,,,, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
		 ИначеЕсли  ЗначениеВыбора = "ВозвратПеремещение" Тогда 
			 ПараметрыФормы = Новый Структура("ТипДокумента",ПредопределенноеЗначение("Справочник.ТипыДокументов.ВозвратПеремещение"));
			 ОткрытьФорму("Обработка.ПанельМеню.Форма.ФормаДокумента",ПараметрыФормы, ЭтаФорма,,,,, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
		 ИначеЕсли  ЗначениеВыбора = "Загрузка" Тогда 
			 ПараметрыФормы = Новый Структура();
			 ОткрытьФорму("Обработка.Логистика.Форма.Форма",ПараметрыФормы, ЭтаФорма,,,,, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
		 ИначеЕсли  ЗначениеВыбора = "ЗипПакет" Тогда 
			 ПараметрыФормы = Новый Структура();
			 ОткрытьФорму("Обработка.Логистика.Форма.ФормаЗипПакет",ПараметрыФормы, ЭтаФорма,,,,, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
		 ИначеЕсли  ЗначениеВыбора = "Сортировка" Тогда 
			 ПараметрыФормы = Новый Структура();
			 ОткрытьФорму("Обработка.Логистика.Форма.ФормаСортування",ПараметрыФормы, ЭтаФорма,,,,, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	      ИначеЕсли  ЗначениеВыбора = "Доставка" Тогда 
			 ПараметрыФормы = Новый Структура();
			 ОткрытьФорму("Обработка.Логистика.Форма.ФормаДоставка",ПараметрыФормы, ЭтаФорма,,,,, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);

		 КонецЕсли;
		 
	 КонецЕсли;
	 
	  
 КонецПроцедуры
 
&НаКлиенте
Асинх Процедура ВыбратьМенюКладощикАнсинх() 
	 
	 СписокВыбора = Новый СписокЗначений;
	 СписокВыбора.Добавить("Комплектовщик","Комплектувальник");  
	 СписокВыбора.Добавить("МассовыйОтбор","Масовий відбір");
     СписокВыбора.Добавить("КомплектовщикОтбор","Компл. відбір"); 
	 СписокВыбора.Добавить("НоменклатураВМестоХранение","Товар до місця збер."); 
	 СписокВыбора.Добавить("ПриоритетМестХранения","Порядок місця збер.");   
	 СписокВыбора.Добавить("Аудит1","Аудит ТО");
	 СписокВыбора.Добавить("Аудит2","Аудит PKG");
     	 Ответ = Ждать ВыбратьИзМенюАсинх(СписокВыбора);   
	 Если Не Ответ = Неопределено Тогда
		 ЗначениеВыбора = Ответ.Значение; 
		 
		 ПараметрыФормы = Новый Структура();    
		 ПараметрыФормы.Вставить("ТипДокумента",ЗначениеВыбора);
		 Если ЗначениеВыбора = "Комплектовщик" ИЛИ ЗначениеВыбора = "КомплектовщикОтбор" Тогда
			 ПутьФомы = "Обработка.Комплектовщик.Форма.ФормаКомплектовщик";
		 ИначеЕсли 	ЗначениеВыбора = "МассовыйОтбор" Тогда 
			 ПутьФомы = "ОбщаяФорма.ФормаОчередьСборки";
			// ПутьФомы = "Обработка.Комплектовщик.Форма.ФормаСобратьВолну";
		ИначеЕсли 	ЗначениеВыбора = "Аудит1" Тогда 
			ПутьФомы = "Обработка.Комплектовщик.Форма.Аудит";
			ПараметрыФормы.Вставить("ТипАудита",1);
		ИначеЕсли 	ЗначениеВыбора = "Аудит2" Тогда 
			ПутьФомы = "Обработка.Комплектовщик.Форма.Аудит";
			ПараметрыФормы.Вставить("ТипАудита",2);

		 Иначе
			 ПутьФомы = "Обработка.Комплектовщик.Форма.ФормаКладовщик";
		 КонецЕсли;
		
		 ОткрытьФорму(ПутьФомы,ПараметрыФормы, ЭтаФорма,,,,, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);		 
	 КонецЕсли;
	  
 КонецПроцедуры
 

 
 
