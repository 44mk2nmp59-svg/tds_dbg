	ОписаниеОбновлениеБД = Новый ОписаниеОповещения("ПослеОбновленияБД", ЭтотОбъект);
	ОткрытьФорму("ОбщаяФорма.ОбновлениеБД",, ЭтаФорма,,,,ОписаниеОбновлениеБД);
	
