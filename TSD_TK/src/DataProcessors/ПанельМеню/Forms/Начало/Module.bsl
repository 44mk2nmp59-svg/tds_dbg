&НаКлиенте
Процедура ПолучитьШтрихКодПеремещения()
	АсинхронныйСканерИнициализирован = ПодключаемоеОборудованиеВызовСервера.СканерШтрихкодовИнициализирован();

	Если ИспользуетсяАсинхронныйСканер И АсинхронныйСканерИнициализирован = Ложь Тогда
		ПодключитьОбработчикОжидания("Подключаемый_ПодключитьАссинхронныйСканерШтрихкодов", 0.1, Истина);
	КонецЕсли;
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("Форма", ЭтаФорма);
	ДополнительныеПараметры.Вставить("ПотоковоеСканирование");
	ДополнительныеПараметры.Вставить("ЗаголовокСканирования", НСтр("ru = 'Считайте штрих-код перемещения'"));
	ДополнительныеПараметры.Вставить("ИмяОбработчикаЗакрытияСканирования", "ОбработкаЗакрытияСканирования");
	ДополнительныеПараметры.Вставить("ТипДокумента", ПредопределенноеЗначение("Справочник.ТипыДокументов.ПеремещениеТоваров"));
	
	ПодключаемоеОборудованиеКлиент.ПолучитьШтрихкод(ДополнительныеПараметры);
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьШтрихкодПеремещения(ПолученныйШтрихкод)
	
	Если ПустаяСтрока(ПолученныйШтрихкод) Тогда
		Сообщить("Штрих-код не введен! Форма не будет открыта!");
	Иначе			
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("ТипДокумента", ПредопределенноеЗначение("Справочник.ТипыДокументов.ПеремещениеТоваров"));
		ПараметрыФормы.Вставить("ОснованиеUUID", СокрЛП(ПолученныйШтрихкод));
		ОткрытьФорму("Обработка.ПанельМеню.Форма.ФормаДокумента", ПараметрыФормы, ЭтаФорма,,,,, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	КонецЕсли;	
	
КонецПроцедуры

