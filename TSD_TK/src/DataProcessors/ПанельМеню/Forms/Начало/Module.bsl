&НаСервере
Процедура ПолучитьКоличествоЗадачСервер()
	Если НЕ ПустаяСтрока(ПараметрыСеанса.Подразделение) Тогда
		
		ДанныеПоЗадачам = ИнтеграцияТК_ВызовСервера.ПолучитьКоличествоЗадач();
		ВидимостьЗадачи = Ложь;
		ВидимостьИнвентаризация = Ложь;
		ВидимостьВерификация = Ложь;
		ВидимостьТБД = Ложь;
		ВидимостьТНП = Ложь;
        ВидимостьАнкета = Ложь;
		ЗадачОтдельнымСписком = 0;	
		Если ДанныеПоЗадачам.Результат Тогда
			парамВсегоЗадач = Неопределено;
			парамИнвентаризация = Неопределено;
			парамВерификация = Неопределено;
			парамТБД = Неопределено;
			парамТНП = Неопределено;
			парамАнкета = Неопределено;


			ДанныеПоЗадачам.Ответ.Свойство("ВсегоЗадач",парамВсегоЗадач);
			ДанныеПоЗадачам.Ответ.Свойство("Инвентаризация",парамИнвентаризация);
			ДанныеПоЗадачам.Ответ.Свойство("Верификация",парамВерификация);
			ДанныеПоЗадачам.Ответ.Свойство("ТБД",парамТБД);
			ДанныеПоЗадачам.Ответ.Свойство("ТНП",парамТНП);   
			ДанныеПоЗадачам.Ответ.Свойство("Анкета",парамАнкета);

					
			Если парамИнвентаризация <> Неопределено И парамИнвентаризация > 0 Тогда
				ВидимостьИнвентаризация = Истина;
				Элементы.СообщениеИнвентаризации.Заголовок = "Інвентаризація - "+парамИнвентаризация+"шт.";
				ЗадачОтдельнымСписком = ЗадачОтдельнымСписком+парамИнвентаризация;
			КонецЕсли;
			
			Если парамВерификация <> Неопределено И парамВерификация > 0 Тогда
				ВидимостьВерификация = Истина;
				Элементы.СообщениеВерификация.Заголовок = "Верификация - "+парамВерификация+" шт."; 
				ЗадачОтдельнымСписком = ЗадачОтдельнымСписком+парамВерификация;
			КонецЕсли;
			
			Если парамТБД <> Неопределено И парамТБД > 0 Тогда
				ВидимостьТБД = Истина;
				Элементы.СообщениеТБД.Заголовок = "Не продається - "+парамТБД+" шт."; 
				ЗадачОтдельнымСписком = ЗадачОтдельнымСписком+парамТБД;
			КонецЕсли;

			Если парамАнкета <> Неопределено И парамАнкета > 0 Тогда
				ВидимостьАнкета = Истина;
				Элементы.ДекорацияПроверкаСтандартов.Заголовок = "Перевірка стандартів - "+парамАнкета+" шт."; 
				ЗадачОтдельнымСписком = ЗадачОтдельнымСписком+парамАнкета;
			КонецЕсли;  
			Если парамТНП <> Неопределено И парамТНП > 0 Тогда
				ВидимостьТНП = Истина;
				Элементы.СообщениеТНП.Заголовок = "Термін придатності - "+парамТНП+" шт.";  
				ЗадачОтдельнымСписком = ЗадачОтдельнымСписком+парамТНП;
			КонецЕсли;
			
			Если парамВсегоЗадач <> Неопределено И ЗадачОтдельнымСписком<>парамВсегоЗадач Тогда
				ВидимостьЗадачи = Истина;
				Элементы.СообщениеЗадачи.Заголовок = "Завдання на виконання - "+Формат(парамВсегоЗадач-ЗадачОтдельнымСписком,"ЧЦ=3; ЧН=0; ЧГ=")+"шт.";
			КонецЕсли;


		КонецЕсли;
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "СообщениеЗадачи", "Видимость", ВидимостьЗадачи);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "СообщениеИнвентаризации", "Видимость", ВидимостьИнвентаризация);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "СообщениеВерификация", "Видимость", ВидимостьВерификация);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "СообщениеТБД", "Видимость", ВидимостьТБД);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "СообщениеТНП", "Видимость", ВидимостьТНП); 
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ДекорацияПроверкаСтандартов", "Видимость", ВидимостьАнкета);
	КонецЕсли;
КонецПроцедуры



&НаСервере
Процедура ОбновитьВиджеты()
	
	ОбновитьВиджетЗаказы();
	
КонецПроцедуры

&НаСервере
Процедура ОпределитьТекущегоКассира()
	
	ТекущийПользователь = ПараметрыСеанса.ТекущийПользователь;
	
	УстановитьЗаголовокКассир(ТекущийПользователь);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьКоординатыМестоположения()
	
	#Если МобильноеПриложениеКлиент Тогда
		
		Элементы.СтраницыГео.ТекущаяСтраница = Элементы.СтраницаИдетОбновление;
		
		ПодключитьОбработчикОжидания("Подключаемый_ОбновитьКоординатыМестоположения", 0.1, Истина);
		
	#КонецЕсли
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ОбновитьКоординатыМестоположения()
	
	#Если МобильноеПриложениеКлиент Тогда
		
		ДанныеМестоположения = ГеолокацияКлиент.ОбновитьМестоположение();
		
		Если НЕ ДанныеМестоположения = Неопределено Тогда
			
			Местоположение = ГеолокацияКлиент.ПолучитьПредставлениеМестоположения(ДанныеМестоположения.Координаты);
			
		Иначе
			Местоположение = НСтр("ru = 'Не удалось определить'");
		КонецЕсли;
		
		Элементы.СтраницыГео.ТекущаяСтраница = Элементы.СтраницаКоординаты;
		
	#КонецЕсли
	
КонецПроцедуры

&НаКлиенте
Процедура ОпределитьМестоположение()
	
	#Если МобильноеПриложениеКлиент Тогда
		
		ИмяПровайдераГеолокации = ОбщегоНазначенияВызовСервера.ПолучитьПараметрСеанса("ИмяПровайдераГеолокации");
		
		Если ЗначениеЗаполнено(ИмяПровайдераГеолокации) Тогда
			
			ДанныеМестоположения = СредстваГеопозиционирования.ПолучитьПоследнееМестоположение(ИмяПровайдераГеолокации);
			
			Если НЕ ДанныеМестоположения = Неопределено Тогда
				Местоположение = ГеолокацияКлиент.ПолучитьПредставлениеМестоположения(ДанныеМестоположения.Координаты);
			КонецЕсли;
			
		КонецЕсли;
		
	#КонецЕсли
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьМестоположение()
	
	Если НЕ ЗначениеНастроекВызовСервераПовтИсп.ИспользуетсяГеолокация() Тогда
		Возврат;
	КонецЕсли;
	
	ОбновитьКоординатыМестоположения();
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьДиалогВводаШтрихкода(ДополнительныеПараметры)
	
	ПодключаемоеОборудованиеКлиент.ПолучитьШтрихкод(ДополнительныеПараметры);
	
КонецПроцедуры

