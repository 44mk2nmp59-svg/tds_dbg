&НаКлиенте
Процедура СкладНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	Если Не Инициализирован Тогда
		Сообщить("Устройство не инициализировано");
		Возврат;
	КонецЕсли;
	
	Если ХозОперация =  "ПеремещениеТоваров" И  Элемент.Имя = "Склад"  И ПустаяСтрока(СкладОтправительUUID) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не выбран склад отправитель");
		Возврат;
	КонецЕсли;
	
		
	
	Если Элемент.Имя = "Склад" И ХозОперация = "ПеремещениеТоваровВФилиал" Тогда 
		СтуктураОтвет =  ИнтеграцияТК_Клиент.ПолучитьСписокТорговыхПлощадок();
	Иначе
		СтуктураОтвет =  ИнтеграцияТК_Клиент.ПолучитьСписокСкладов();
	КонецЕсли;
	
	Если ХозОперация =  "ПеремещениеТоваров" И  Элемент.Имя = "Склад" И СтуктураОтвет.Результат Тогда
		
		
		нСкладСпЗнач = СтуктураОтвет.Ответ.НайтиПоЗначению(СкладОтправительUUID);
		Если НЕ нСкладСпЗнач = Неопределено Тогда
			СтуктураОтвет.Ответ.Удалить(нСкладСпЗнач);
		КонецЕсли;
		
	КонецЕсли;
	
	
	
	Если СтуктураОтвет.Результат  Тогда
		
		Оповещение = Новый ОписаниеОповещения("ПослеВыбораЭлемента", ЭтаФорма, Элемент.Имя); 
		
		СтуктураОтвет.Ответ.ПоказатьВыборЭлемента(Оповещение, ?(Элемент.Имя = "Склад" И ХозОперация = "ПеремещениеТоваровВФилиал", "Магазин", "Склад"));
	Иначе
		Сообщить(СтуктураОтвет.ОписаниеОшибки);
	КонецЕсли;

	
КонецПроцедуры

&НаКлиенте
Процедура ПослеВыбораЭлемента(Результат,ДополнительныеПараметры) Экспорт
	
	
	Если ДополнительныеПараметры = "Склад" ИЛИ ДополнительныеПараметры = "Склад1" Тогда 
		
		Если Результат <> Неопределено Тогда
			Если СкладUUID <>  "b0855ae2-fd3e-11e3-8e10-0050568c0032" И Результат.Значение  = "b0855ae2-fd3e-11e3-8e10-0050568c0032" Тогда //смена РЦ
				Объект.Товары.Очистить();   
				Артикул = "";
				
			КонецЕсли;
			Склад      = Результат.Представление;
			СкладUUID  = Результат.Значение;
			СкладТНП  = Результат.Пометка;
		КонецЕсли;
		
	ИначеЕсли ДополнительныеПараметры = "СкладОтправитель" Тогда 
		
		Если Результат <> Неопределено Тогда
			
			Если ЗначениеЗаполнено(СкладОтправительUUID) И СкладОтправительUUID <> Результат.Значение Тогда
				Объект.Товары.Очистить();
				СтрокаНаименование = "";
				Остаток = 0;
				КоличествоВДокументе = 0;
				Продажи = 0;
			КонецЕсли;
			
			
			СкладОтправитель  	 = Результат.Представление;
			СкладОтправительUUID = Результат.Значение;
			СкладОтправительТНП   =Результат.Пометка;
			
		КонецЕсли;
		
	КонецЕсли;

	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ПричинаПеремещения", "Видимость", СкладТНП и ХозОперация =  "ПеремещениеТоваров"); 
 	
	
КонецПроцедуры

&НаКлиенте
Процедура СтрокаПоискаПриИзменении(Элемент)
	ОбработатьВводСтрокиШК()
КонецПроцедуры

&НаКлиенте
Процедура СтрокаПоискаТоварыПриИзменении(Элемент)
