	    СтрокаВозврат = "НомерСтроки,ШтрихКод,Артикул,НаименованиеТовара,НаименованиеЕдиницы,Коэффициент,Количество,КоличествоВведено,КоличествоПоставщика,КоличествоПодтверждено,ЭтоТара,ИспМРЦ,МРЦ,АМ,Весовой,ПриемДо";
	ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Комплектация") Тогда
	    СтрокаВозврат = "НомерСтроки,ШтрихКод,Артикул,НаименованиеТовара,НаименованиеЕдиницы,Коэффициент,Количество,КоличествоВведено,Весовой,ЭтоТара";
	ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Задание")Тогда	
		СтрокаВозврат = "НомерСтроки,ШтрихКод,Артикул,НаименованиеТовара,НаименованиеЕдиницы,Коэффициент,Количество,КоличествоВведено,ИспМРЦ,МРЦ";
