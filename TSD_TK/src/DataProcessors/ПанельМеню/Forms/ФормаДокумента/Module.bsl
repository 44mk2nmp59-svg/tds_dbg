	МенЗаписи =	РегистрыСведений.ДоступнаяНоменклатураДляВозвратара.СоздатьМенеджерЗаписи();
	МенЗаписи.Артикул = АртикулТовара;
	МенЗаписи.Прочитать();
	Если МенЗаписи.Выбран() Тогда
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;
	
