&НаКлиенте
Процедура ПричинаРасхожденияОтмена(Команда)
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ДанныеПоТоваруГруппа", "Видимость",Истина);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ПричиныРасхожденияГруппа", "Видимость",Ложь);
	
	Если ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Задание") Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "СтраницаСканирование", "Видимость",Истина);
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ПодвалОК(Команда)
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "СтраницаТовары,ГруппаПодвалКнопки,СтрокаПоискаТовары", "Видимость",Ложь);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ГруппаПодвалСохранить", "Видимость",Истина);

	Если ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Задание") Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "СтраницаСканирование", "Видимость",Ложь);
	ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Zak") Тогда
	   	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "СтрокаПоискаТовары,ГруппаПодвалДанныеПоставщика", "Видимость",Ложь);
	ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Контролер") 
		ИЛИ ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеТБД") Тогда
		
		ЕстьРасхождение  = Объект.Товары.Итог("КоличествоРасхождение");
		Если ЕстьРасхождение>0 Тогда
			УстановитьОформление(Истина,10);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "СтраницаТовары", "Видимость",Истина);
		КонецЕсли;
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "СтрокаПоискаТовары,СтраницаСканирование,ГруппаПодвалДанныеПоставщика", "Видимость",Ложь);
		Если  ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеТБД") Тогда
			ценПечать = КоличествоЦенниквДляПечати();
			Если ценПечать > 0 Тогда
				Элементы.ДекорацияПечатьЦенников.Заголовок = "Друк цінників ("+Формат(ценПечать,"ЧЦ=10; ЧН=0")+")";
				ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ДекорацияПечатьЦенников", "Видимость",Истина);
			Иначе
				ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ДекорацияПечатьЦенников", "Видимость",Ложь);
			КонецЕсли;
			
		КонецЕсли;
	//ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеТБД") Тогда
	//	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "СтрокаПоискаТовары,ГруппаПодвалДанныеПоставщика", "Видимость",Ложь);

	ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеТНП")
	ИЛИ ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеВФ") Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "СтрокаПоискаТовары,СтраницаСканирование,ГруппаПодвалДанныеПоставщика,НеПосчитаные", "Видимость",Ложь);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "СтраницыПролистывания", "ОтображениеСтраниц", ОтображениеСтраницФормы.Нет);

		
		Если  ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеВФ") Тогда	
			МассивПроверки = Объект.Товары.НайтиСтроки(Новый Структура("СканированиеТовар",0));
			Если МассивПроверки.Количество() > 0 Тогда
				УстановитьОформление(Истина,0);
				
				ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "СтраницаТовары,ДекорацияНадписьПроверка", "Видимость",Истина);
				ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ДекорацияНадписьПроверка", "Заголовок", Формат(МассивПроверки.Количество(),"ЧЦ=5; ЧГ=") +" товарів, будуть списані");
				
			КонецЕсли;
			
			ценПечать = КоличествоЦенниквДляПечати();
			Если ценПечать > 0 Тогда
				Элементы.ДекорацияПечатьЦенников.Заголовок = "Печать ценников ("+Формат(ценПечать,"ЧЦ=10; ЧН=0")+")";
				ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ДекорацияПечатьЦенников", "Видимость",Истина);
			Иначе
				ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ДекорацияПечатьЦенников", "Видимость",Ложь);
			КонецЕсли;
			
		КонецЕсли;

	ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.МаршрутныйЛист")Тогда
		ЕстьРасхождение  = Объект.Товары.НайтиСтроки(Новый Структура("Пересчет",Ложь));
		Если ЕстьРасхождение.Количество()>0 Тогда
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "СтраницаТовары,ДекорацияНадписьПроверка", "Видимость",Истина);
			Элементы.ДекорацияНадписьПроверка.Заголовок = Формат(ЕстьРасхождение.Количество(),"ЧЦ=10")+" документи не відскановано";	
		Иначе
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ДекорацияНадписьПроверка", "Видимость",Ложь);	
		КонецЕсли;
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "СтрокаПоискаТовары,ГруппаПодвалДанныеПоставщика", "Видимость",Ложь);
	ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Заявка")Тогда   
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ГруппаПодвалДанныеПоставщика,ФотоЗаявки,УслугаЗаявки,ОписаниеЗаявки", "Видимость",Ложь);
		УсловиеВозврата = 1;
		опДекПроверка = "";
		Если ПустаяСтрока(НаименованиеТовара) Тогда 
			УсловиеВозврата = 0;				
			опДекПроверка = "Опишіть заявку";
		КонецЕсли;	
		Если ПустаяСтрока(КонтрагентUUID) Тогда 	
			УсловиеВозврата = 0;
			Если ПустаяСтрока(опДекПроверка) Тогда
				опДекПроверка ="Виберіть послугу";
			Иначе
				опДекПроверка = опДекПроверка + Символы.ПС + "Виберіть послугу";
			КонецЕсли; 
			
		КонецЕсли;
		Если УсловиеВозврата = 0 Тогда
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ДекорацияНадписьПроверка", "Заголовок",опДекПроверка);
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ДекорацияНадписьПроверка", "Видимость",Истина);
		Иначе
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ДекорацияНадписьПроверка", "Видимость",Ложь);
			
		КонецЕсли;
	ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Пересортица")Тогда   
        ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ГруппаПодвалДанныеПоставщика", "Видимость",Ложь);

		
	КонецЕсли;

	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ГруппаПодвалСохранитьРеквизитыДокумента", "Видимость",СкладВидимость);
	
	
КонецПроцедуры

&НаКлиенте
Процедура ПодвалОтмена(Команда)
	Закрыть();	
КонецПроцедуры

&НаКлиенте
Процедура ПодвалСохранитьОК(Команда)

	
 	Если ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Комплектация") Тогда
		ТекстВопроса = "Подтв.: "+ Символы.ПС+Формат(Объект.Товары.Итог("КоличествоВведено"),"ЧЦ=15; ЧДЦ=3; ЧН=0")+" шт/кг"+Символы.ПС+"Закрыть окно с сохранением реализации?";
	ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Задание") Тогда
		КолВведено = Объект.Товары.Итог("КоличествоВведено");  
		Если КолВведено = 0 Тогда
			Сообщить("Таблица товаров пустая!");
			Возврат;
		КонецЕсли;
		
		ТекстВопроса = "Подтв.: "+ Символы.ПС+Формат(КолВведено,"ЧЦ=15; ЧДЦ=3; ЧН=0")+" шт/кг"+Символы.ПС+"Закрыть окно с сохранением?";
	ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Zak") Тогда	
		ТекстВопроса = "Подтв.: "+ Символы.ПС+Формат(Объект.Товары.Итог("Количество"),"ЧЦ=15; ЧДЦ=3; ЧН=0")+" шт/кг"+Символы.ПС+"Отправить заказ поставщику?";
    ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Контролер") Тогда
		ТекстВопроса = "Подтв.: "+ Символы.ПС+Формат(Объект.Товары.Итог("КоличествоВведено"),"ЧЦ=15; ЧДЦ=3; ЧН=0")+" шт/кг"+" из "+Формат(Объект.Товары.Итог("КоличествоПоставщика"),"ЧЦ=15; ЧДЦ=3; ЧН=0")+" шт/кг "+Символы.ПС+"Закрыть окно с сохранением реализации?";
	ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеТБД")  ИЛИ ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеВФ") Тогда
		тСтрок = Объект.Товары.Количество();
		тСтрокПересчет = Объект.Товары.НайтиСтроки(Новый Структура("Пересчет",Истина)).Количество();
		тСтрокБезТовара = Объект.Товары.НайтиСтроки(Новый Структура("СканированиеТовар",0)).Количество();
		стрЗав = ?(тСтрокБезТовара>0,"Сформивать инвентаризацию и завершить задание?" ,"Завершить задание?");
		
		ТекстВопроса = "Всего строк: "+Формат(тСтрок,"ЧЦ=15; ЧДЦ=0; ЧН=0")
		+Символы.ПС+ "Отсканировано: "+Формат(тСтрокПересчет,"ЧЦ=15; ЧДЦ=0; ЧН=0")
		+Символы.ПС+стрЗав;
	ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеТНП") Тогда
		тСтрок = Объект.Товары.Количество();
		тСтрокПересчет = Объект.Товары.НайтиСтроки(Новый Структура("Пересчет",Истина)).Количество();
		тСтрокИнвентаризация = Объект.Товары.НайтиСтроки(Новый Структура("Пересчет",Ложь)).Количество();
		стрЗав = ?(тСтрокИнвентаризация>0,"Не все товары отсканированы, завершить задание?" ,"Завершить задание?");

		ТекстВопроса = "Всего строк: "+Формат(тСтрок,"ЧЦ=15; ЧДЦ=0; ЧН=0")
		+Символы.ПС+ "Отсканировано: "+Формат(тСтрокПересчет,"ЧЦ=15; ЧДЦ=0; ЧН=0")
		+Символы.ПС+стрЗав;
	ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Уведомление") 
		ИЛИ  ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ВыдачаДС") Тогда

		ТекстВопроса  = "Виконати завдання?";
	ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.МаршрутныйЛист") Тогда
		тСтрок = Объект.Товары.Количество();
		тСтрокПересчет = Объект.Товары.НайтиСтроки(Новый Структура("Пересчет",Истина)).Количество();
		ТекстВопроса = "Документів: "+Формат(тСтрок,"ЧЦ=15; ЧДЦ=0; ЧН=0")
		+Символы.ПС+ "Відскановано: "+Формат(тСтрокПересчет,"ЧЦ=15; ЧДЦ=0; ЧН=0")
		+Символы.ПС+"Зберегти документи?";
	ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Заявка") Тогда
		Если УсловиеВозврата = 0 Тогда
			Сообщить("Вкажіть параметри заявки");  
			Возврат;
		КонецЕсли;
		ТекстВопроса = "Послуга: "+Контрагент+Символы.ПС+"Опис: "+НаименованиеТовара +Символы.ПС+"Створити зявку?";
	ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Пересортица") Тогда
	  	ТекстВопроса = "Сформувати документ?"+Символы.ПС+ "Списати : "+Формат(Объект.Товары.Итог("Количество"),"ЧЦ=15; ЧДЦ=3; ЧН=0")+" шт/кг";

	Иначе
		ТекстВопроса = "Всего арт.: "+Формат(Объект.Товары.Количество(),"ЧЦ=15; ЧН=0; ЧГ=")+" принято арт.: " +Формат(ПринятоСтрок(),"ЧЦ=15; ЧН=0; ЧГ=")+Символы.ПС;
		Если ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ПриемПоПриходу") Тогда
			ТекстВопроса = ТекстВопроса + "Принято: "+ Символы.ПС+Формат(Объект.Товары.Итог("КоличествоВведено"),"ЧЦ=15; ЧДЦ=3; ЧН=0")+" из "+Формат(Объект.Товары.Итог("КоличествоПоставщика"),"ЧЦ=15; ЧДЦ=3; ЧН=0")+" шт/кг "+Символы.ПС+"Закрыть окно с сохранением прихода?";
		Иначе
			ТекстВопроса = ТекстВопроса + "Принято: "+ Символы.ПС+Формат(Объект.Товары.Итог("КоличествоВведено"),"ЧЦ=15; ЧДЦ=3; ЧН=0")+" шт/кг"+Символы.ПС+"Закрыть окно с сохранением прихода?";
		КонецЕсли;
		
	КонецЕсли;
	
	Оповещение = Новый ОписаниеОповещения("ПослеЗакрытияВопроса", ЭтотОбъект);
	ПоказатьВопрос(Оповещение, ТекстВопроса, РежимДиалогаВопрос.ДаНет);
	
КонецПроцедуры

&НаКлиенте
Функция ПринятоСтрок()
	кСтрок = 0;
	Для Каждого Стр Из Объект.Товары Цикл 
		Если Стр.КоличествоВведено<>0 Тогда
			кСтрок = кСтрок + 1;
		КонецЕсли;
	КонецЦикла;
	Возврат кСтрок;
	
КонецФункции


&НаКлиенте
Процедура ПослеЗакрытияВопроса(Результат,Параметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Нет Тогда
		Возврат;
	КонецЕсли;

	Если ТочкаМаршрута = 4 Тогда    
		
		Параметрыф = Новый Структура;
		ОповещениеПечатьКоробкиТочкаМаршрута4 = Новый ОписаниеОповещения("ОповещениеПринтерОтсканированТочкаМаршрута4", ЭтотОбъект,Результат);
		ОткрытьФорму("ОбщаяФорма.ПечатьКоробки",Параметрыф,ЭтотОбъект,,,,ОповещениеПечатьКоробкиТочкаМаршрута4);

	Иначе
		ВыгрузитьДокументНаКлиенте(); 
	КонецЕсли;
	
КонецПроцедуры




&НаКлиенте
Процедура ПодвалСохранитьОтмена(Команда)
	
	Если ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Уведомление") 
		ИЛИ ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ВыдачаДС") Тогда
		Закрыть();
		Возврат;
	КонецЕсли;
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "СтраницаТовары,ГруппаПодвалКнопки,СтрокаПоискаТовары", "Видимость",Истина);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ГруппаПодвалСохранить", "Видимость",Ложь);
	Если ТипДокумента=ПредопределенноеЗначение("Справочник.ТипыДокументов.Контролер")
		ИЛИ ТипДокумента=ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеТБД") 
		ИЛИ ТипДокумента=ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеВФ") Тогда
		УстановитьОформление(Ложь,10);
	ИначеЕсли  ТипДокумента=ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеТНП") Тогда
		УстановитьОформление(Ложь,0);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "СтраницаСканирование,НеПосчитаные", "Видимость",Истина);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ДекорацияНадписьПроверка", "Видимость",Ложь);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "СтраницыПролистывания", "ОтображениеСтраниц", ОтображениеСтраницФормы.ЗакладкиСверху);
	ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.МаршрутныйЛист") Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "СтрокаПоискаТовары", "Видимость",Ложь);
	ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Заявка") Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "СтраницаСервисДеск,ФотоЗаявки,ОписаниеЗаявки,УслугаЗаявки", "Видимость",Истина); 
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "СтраницаТовары,СтрокаПоискаТовары", "Видимость",Ложь);
	ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Пересортица") Тогда
	   ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "СтрокаПоискаТовары", "Видимость",Ложь);
	КонецЕсли;
	
	
КонецПроцедуры




#Область ПеремещениеТоваров


&НаСервере
Процедура ЗаполнитьДокументПеремещение(Отказ)
	Если Отказ Тогда 
		Возврат;
	КонецЕсли;
	ГУИДПеремещения = Неопределено;
	Если Не Параметры.Свойство("ОснованиеUUID", ГУИДПеремещения) Тогда 
		Возврат;
	КонецЕсли;
	
	ПараметрыДокумента = Новый Структура;
	ПараметрыДокумента.Вставить("ВидДокумента", "ПеремещениеТоваров");
	ПараметрыДокумента.Вставить("ДокументUUID", ГУИДПеремещения);
	
	ДанныеДокумента = ИнтеграцияТК_ВызовСервера.ПолучитьДанныеДокумента(ПараметрыДокумента);
	
	//Vov41k 27.12.2019 Begin...
	Если ДанныеДокумента.Результат Тогда
		
			ОснованиеUUID 			= ГУИДПеремещения;
			Документ = ДанныеДокумента.Ответ;
			
			Если Документ.Свойство("ОснованиеUUID") Тогда
				ОснованиеUUID =  Документ.ОснованиеUUID;
			КонецЕсли;
			
			Склад 					= Документ.Sklad;
			СкладUUID 				= Документ.SkladUUID;
			СкладОтправитель 		= Документ.SkladSender;
			СкладОтправительUUID 	= Документ.SkladSenderUUID;
			
			СписокХозОпераций = Элементы.ХозОперация.СписокВыбора;
			
			
			Если СписокХозОпераций.НайтиПоЗначению("ПеремещениеТоваровИзФилиала") = Неопределено Тогда 
				СписокХозОпераций.Добавить("ПеремещениеТоваровИзФилиала", "Перемещение товаров из филиала");
			КонецЕсли;		
			
			ХозОперация				= "ПеремещениеТоваровИзФилиала";		
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ХозОперация, СкладОтправитель", "ТолькоПросмотр", Истина);
			
			Если Документ.Свойство("DocUUID") Тогда 
				ДокументUUID 		= Документ.DocUUID;
			КонецЕсли; 
			ЭтоРЦ = 0;
			Если Документ.Свойство("tpRC") Тогда 
				ЭтоРЦ = Документ.tpRC;	
			КонецЕсли;
			Если Документ.Свойство("UP") Тогда 
				ФормироватьТУ = Документ.UP;
			КонецЕсли;
			
			Для Каждого СтрТовары Из Документ.Tovary Цикл 
				нСтрокаТовары = Объект.Товары.Добавить();
				нСтрокаТовары.Артикул 			  = СтрТовары.Art;
				нСтрокаТовары.НаименованиеТовара  = СтрТовары.Tovar;
				нСтрокаТовары.НаименованиеЕдиницы = СтрТовары.EdIzm;
				нСтрокаТовары.Коэффициент		  = СтрТовары.Kof;
				нСтрокаТовары.Количество 		  = 0;
				нСтрокаТовары.КоличествоПоставщика = СтрТовары.KolvoOsn;
				
				Если СтрТовары.Свойство("МРЦ") Тогда
					Если ЗначениеЗаполнено(СтрТовары.МРЦ) Тогда
						нСтрокаТовары.ИспМРЦ = Истина;
					КонецЕсли;
					нСтрокаТовары.МРЦ = СтрТовары.МРЦ;
				КонецЕсли;
				Если СтрТовары.Свойство("Весовой") Тогда
					нСтрокаТовары.Весовой = СтрТовары.Весовой;
				КонецЕсли;
				//Если СтрТовары.Свойство("sht") И ЭтоРЦ = 1 Тогда  
				//	нСтрокаТовары.ПриемДо = ТекущаяДата()+(СтрТовары.sht/3*2)*86400;
				Если СтрТовары.Свойство("sht") Тогда
					Если СтрТовары.Свойство("sht2")	И СтрТовары.sht2 <> 0 Тогда  
						нСтрокаТовары.ПриемДо = ТекущаяДата()+(СтрТовары.sht/100)*СтрТовары.sht2*86400-864000;
					Иначе
						нСтрокаТовары.ПриемДо = ТекущаяДата()+(СтрТовары.sht/3*2)*86400-864000;
					КонецЕсли
				КонецЕсли;

				
				ОбновитьЗаписьПоСтроке(,нСтрокаТовары);
			КонецЦикла; 
			Если ЗначениеЗаполнено(ДокументUUID) Тогда
				ОбработатьДанныеВРаботе();   
			КонецЕсли;
			КэшТоваровПеремещения = Объект.Товары.Выгрузить();		
			Элементы.СтраницыПролистывания.ТекущаяСтраница = Элементы.СтраницаТовары;
	Иначе
		Отказ = Истина;
		Сообщить("Ошибка получение данных с сервера" + Символы.ПС+ДанныеДокумента.ОписаниеОшибки);
	КонецЕсли;
	//Vov41k 27.12.2019 End...

КонецПроцедуры


&НаСервере
Функция ВыгрузитьДокументПеремещениеНаСервере(ТаблицаАкт,ФормироватьТУ)
	
	СтруктураДокумента = Новый Структура();
	СтруктураДокумента.Вставить("UUID_Склад",СкладUUID);
	СтруктураДокумента.Вставить("UUID_СкладОтправитель", СкладОтправительUUID);
	СтруктураДокумента.Вставить("UUID_Сотрудник", ПараметрыСеанса.Сотрудник_ID);
	СтруктураДокумента.Вставить("UUID_Причина", ПричинаПеремещенияUUID);

	СтруктураДокумента.Вставить("ДоументСервер",Ложь);
	СтруктураДокумента.Вставить("ХозОперация", ХозОперация);
	СтруктураДокумента.Вставить("ПечатьТСД",?(ЗначениеНастроекВызовСервераПовтИсп.ИспользуетсяПечатьНаПринтер(),1,0));

	Если ТаблицаАкт <> Неопределено Тогда
		тзПричины = ТаблицаАкт.Выгрузить();
		тзПричины.Свернуть("Артикул,Причина");
		МассивПричины = Новый Массив;
		Для Каждого стПричина Из ТаблицаАкт Цикл 
			  МассивПричины.Добавить(Новый Структура("Артикул,КодПричины",стПричина.Артикул,стПричина.Причина.Код));
		КонецЦикла;
		СтруктураДокумента.Вставить("ПричиныВозврата",МассивПричины); 
		
		Если ФормироватьТУ Тогда     
		СтруктураДокумента.Вставить("ФормироватьТУ",Число(ФормироватьТУ));	
		СтруктураДокумента.Вставить("UUID_Принтер",ИД_Принтер);
		СтруктураДокумента.Вставить("КоличествоСтикеров",КоличествоСтикеров);
		КонецЕсли;
		

	КонецЕсли;
	
	
	
	ЕстьРасхождения = Неопределено;
	Если Не ПустаяСтрока(ДокументUUID) Тогда
		СтруктураДокумента.Вставить("UUID_Документ",ДокументUUID);
	КонецЕсли;
	Если Не ПустаяСтрока(ОснованиеUUID) Тогда 
		СтруктураДокумента.Вставить("UUID_Основание", ОснованиеUUID);	
	КонецЕсли;
	
	МассивТоваров = Новый Массив;	
		
	ПеремСтуктура = "Артикул, Количество,КоличествоПоставщика, Коэффициент,МРЦ";
	
	Для Каждого СтрТовар Из Объект.Товары Цикл 
		Если СтрТовар.Количество = 0 И СтрТовар.КоличествоПоставщика = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		
		СтруктураСтрока = Новый Структура(ПеремСтуктура);
		ЗаполнитьЗначенияСвойств(СтруктураСтрока,СтрТовар,ПеремСтуктура);
		СтруктураСтрока.Коэффициент = 1;
		МассивТоваров.Добавить(СтруктураСтрока);
		
	КонецЦикла;                                                  
	
	Если МассивТоваров.Количество() = 0 Тогда
		ВызватьИсключение ("Немає товарів для переміщення")
	КонецЕсли;
	
	СтруктураДокумента.Вставить("Товары",МассивТоваров);

	Рез = ИнтеграцияТК_ВызовСервера.ПередатьДокументНаСервер(СтруктураДокумента,ТипДокумента);
		
	Возврат Рез;

КонецФункции


