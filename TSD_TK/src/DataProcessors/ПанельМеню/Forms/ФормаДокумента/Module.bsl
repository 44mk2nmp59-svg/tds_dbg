&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ПодключаемоеОборудованиеКлиент.ЭтоОповещениеСканераШтрихкода(ИмяСобытия) И ВводДоступен() Тогда
		
		ДополнительныеПараметры = Новый Структура;
		ДополнительныеПараметры.Вставить("Форма", ЭтаФорма);
		ОбработатьПолученныйШтрихкод(Параметр, ДополнительныеПараметры);
	ИначеЕсли  ИмяСобытия = "KeyPress"  И ВводДоступен() Тогда
		
		   ОбработатьПолучениеСКлавиатуры(Параметр)
		   
	ИначеЕсли ИмяСобытия = "ИзмененоПодразделение" Тогда
		
		ОбновитьПодразделение();
		
	ИначеЕсли ИмяСобытия = "ИзмененСотрудник" Тогда
		
		ОбновитьСотрудника();
		Если ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ПроверкаСтандартов") И ПользовательИнициализирован Тогда
			ПроверкаСтандартовДанныеПоАнкете();	
		КонецЕсли;
		
	КонецЕсли;
	

КонецПроцедуры

 &НаСервере
Процедура ПроверкаСтандартовДанныеПоАнкете() 
	 
	Если ПараметрыСеанса.Сотрудник_ID <> КонтрагентUUID Тогда
		Возврат;
	КонецЕсли;
	
	Табдок.Очистить();
	ПараметрыДокумента = Новый Структура;
	ПараметрыДокумента.Вставить("ВидДокумента", "ProverkiZa");
	ПараметрыДокумента.Вставить("ДокументUUID", ДокументUUID);
	рез = ИнтеграцияТК_ВызовСервера.ПолучитьДанныеДокумента(ПараметрыДокумента);
	Если рез.Результат  Тогда
		
		ДанныеАнкетирования =  рез.Ответ;
		
		//	
		МакетОтчета = ПолучитьОбщийМакет("Анкетирование");
		Область = МакетОтчета.ПолучитьОбласть("Шапка");
		Табдок.Вывести(Область);
		
		Для Каждого Анкета Из ДанныеАнкетирования Цикл 
			Область = МакетОтчета.ПолучитьОбласть("ттАнкета");
			Область.Параметры.Анкета = "Анкета №"+Анкета.Номер +" від "+ Формат(Дата(Анкета.Дата),"ДФ=yyyy-MM-dd");
			Область.Параметры.ТТ = Анкета.Респондент;
			Табдок.Вывести(Область);
			
			Область = МакетОтчета.ПолучитьОбласть("Итого");
			Область.Параметры.Результат = Формат(Анкета.ПроцентВыполнения,"ЧЦ=3; ЧН=0")+"%";
			Область.Параметры.Сумма = Анкета.ИтогОценка;
			Табдок.Вывести(Область);

			Строка = МакетОтчета.ПолучитьОбласть("Строка");
			СтрокаЦвет = МакетОтчета.ПолучитьОбласть("СтрокаЦвет");
			
			НомерСтроки = 1;
			
			
			Для Каждого стрВопрос Из  Анкета.Вопросы Цикл 
				
				Если НомерСтроки % 2 = 0 Тогда
					СтрокаМакета = СтрокаЦвет;
				Иначе
					СтрокаМакета = Строка;
				КонецЕсли;
				
				СтрокаМакета.Параметры.Статья = стрВопрос.Формулировка;
				СтрокаМакета.Параметры.Сумма  = стрВопрос.Оценка;
				Табдок.Вывести(СтрокаМакета); 
				
				НомерСтроки = НомерСтроки + 1;
				
			КонецЦикла;
			
		КонецЦикла;
		
		//	
		Табдок.Защита = Истина;
	Иначе
		Если ПустаяСтрока(рез.ОписаниеОшибки) Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Немає даних для показу!");
		Иначе
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(рез.ОписаниеОшибки);
		КонецЕсли;

	КонецЕсли; 
	 
	 
КонецПроцедуры
 


