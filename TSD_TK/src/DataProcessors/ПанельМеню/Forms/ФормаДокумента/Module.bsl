&НаКлиенте
Процедура ТоварыОК(Команда)
	
	ДанныеСтроки =  ТаблицаСтрока[0];
	ДанныеСтроки.КоличествоРасхождение =  ДанныеСтроки.КоличествоПоставщика - ДанныеСтроки.КоличествоВведено;
	
	Если ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Комплектация") Тогда
		
		Если ДанныеСтроки.ЭтоТара = 0 Тогда
			Если ДанныеСтроки.Количество < ДанныеСтроки.КоличествоВведено Тогда
				
				Если ДанныеСтроки.Весовой = 1 Тогда
					
					чКол = ДанныеСтроки.Количество*1.3;
					Если чКол <  ДанныеСтроки.КоличествоВведено Тогда
						Сообщить("Весовой товар! макс. "+Формат(чКол,"ЧЦ=15; ЧДЦ=3"));
						Возврат;
					КонецЕсли;
					
				Иначе
					Сообщить("Нельзя отгружать больше чем заказано!");
					Возврат;
				КонецЕсли;
				
				
			КонецЕсли;
		КонецЕсли;
	ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Задание") Тогда
		
		Если ДанныеСтроки.Количество < ДанныеСтроки.КоличествоВведено Тогда
			
			
			
			Сообщить("Нельзя отгружать больше чем в заявке!");
			Возврат;
			
		КонецЕсли;
  	ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ПриемПоПриходу") И ДанныеСтроки.АМ = 0 Тогда
		
		Если ДанныеСтроки.КоличествоВведено <> 0 Тогда
			Сообщить("товар не матриці");
		КонецЕсли; 
		ПричиныРасхождения = ПредопределенноеЗначение("Перечисление.ПричиныРасхождения.НеАМ");
		ДанныеСтроки.КоличествоВведено =0;   
		ДанныеСтроки.ПричинаРасхождения = ПричиныРасхождения;
		ДанныеСтроки.КоличествоРасхождение = ДанныеСтроки.КоличествоПоставщика;
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ДанныеПоТоваруГруппа", "Видимость",Ложь);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ПричиныРасхожденияГруппа", "Видимость",Истина);
		Возврат;
	
		
	Иначе	
		Если ДанныеСтроки.КоличествоПоставщика = 0  И ДанныеСтроки.КоличествоВведено >0 Тогда
			Сообщить("Укажите количество поставщика");
			Возврат;
		КонецЕсли;
		
		Если ДанныеСтроки.ЭтоТара = 0 Тогда
			
			
			Если ДанныеСтроки.Количество < ДанныеСтроки.КоличествоВведено Тогда
				Весовой = (НРег(Лев(ДанныеСтроки.НаименованиеЕдиницы,2)) = "кг");
				Если Весовой Тогда
					чКол = ДанныеСтроки.Количество*1.3;
					Если чКол <  ДанныеСтроки.КоличествоВведено Тогда
						Сообщить("Весовой товар! макс. "+Формат(чКол,"ЧЦ=15; ЧДЦ=3"));
						Возврат;
					КонецЕсли;
				Иначе
					Сообщить("Нельзя принимать больше чем заказано!");
					Возврат;
				КонецЕсли;
				
			КонецЕсли;
		КонецЕсли;
		
		Если ДанныеСтроки.КоличествоПоставщика < ДанныеСтроки.КоличествоВведено Тогда
			Сообщить("Нельзя принимать больше чем в накладной поставщика!");
			Возврат;
		КонецЕсли;
		
		
		Если ДанныеСтроки.КоличествоПоставщика <> ДанныеСтроки.КоличествоВведено Тогда
			
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ДанныеПоТоваруГруппа", "Видимость",Ложь);
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ПричиныРасхожденияГруппа", "Видимость",Истина);
			Возврат;
		КонецЕсли;
		
	КонецЕсли;
	
	
	ОбработатьСтрокуПриемаТовара();
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "СтраницаТовары,СтрокаПоискаТовары,ПричиныРасхожденияГруппа,ГруппаПодвалКнопки", "Видимость",Истина);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "СтраницаСтрока", "Видимость",Ложь);
	
КонецПроцедуры

