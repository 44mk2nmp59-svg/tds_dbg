	СтрокаТовара.ТоварыЗаписьПоСтроке = ЗаписьПоСтроке;
	СтрокаТовара.ТоварыЗаписьПоСтроке2 = ЗаписьПоСтроке2;
	СтрокаТовара.ИтогСтрокаДокумента = ЗаписьПоСтроке + Символы.ПС + ЗаписьПоСтроке2;
	
КонецПроцедуры


&НаСервере
Процедура ОбработатьСтрокуПриемаТовара()
	ДанныеСтроки =  ТаблицаСтрока[0];
	СтрокаТовара = Объект.Товары.НайтиПоИдентификатору(ДанныеСтроки.ИдентификаторСтроки);
	ЗаполнитьЗначенияСвойств(СтрокаТовара,ДанныеСтроки,"КоличествоВведено,КоличествоПоставщика,КоличествоРасхождение,ПричинаРасхождения");
	СтрокаТовара.ПричинаРасхожденияСтрока = Строка(СтрокаТовара.ПричинаРасхождения);
	ПорядокРасхождения  = "0";
	Если  СтрокаТовара.ПричинаРасхождения = Перечисления.ПричиныРасхождения.Недовоз Тогда
		ПорядокРасхождения = "1";
	ИначеЕсли    СтрокаТовара.ПричинаРасхождения = Перечисления.ПричиныРасхождения.ОтсутствиеВЗаказе Тогда
		ПорядокРасхождения = "2";
	ИначеЕсли    СтрокаТовара.ПричинаРасхождения = Перечисления.ПричиныРасхождения.Пересортица Тогда
		ПорядокРасхождения = "3";
	ИначеЕсли    СтрокаТовара.ПричинаРасхождения = Перечисления.ПричиныРасхождения.Бой Тогда
		ПорядокРасхождения = "4";
	ИначеЕсли    СтрокаТовара.ПричинаРасхождения = Перечисления.ПричиныРасхождения.НеАМ Тогда
		ПорядокРасхождения = "5";
	
	КонецЕсли;
	
	СтрокаТовара.ПричинаРасхожденияПорядок = ПорядокРасхождения;	
	
	Если ТипДокумента = Справочники.ТипыДокументов.ПриемПоЗаказу Тогда	
		текСтрокаСтруктура = ОбщегоНазначенияКлиентСервер.СтруктураДанныеВРаботе();
		ЗаполнитьЗначенияСвойств(текСтрокаСтруктура,СтрокаТовара);
		текСтрокаСтруктура.ДокументUUID = ОснованиеUUID;
		текСтрокаСтруктура.ТипДокумента = ТипДокумента;
		
		
		ЗаписатьДанныеПотоваруНаСервере(текСтрокаСтруктура); 
	КонецЕсли;
	
    ВводВручнуюТовар = ВводВручнуюТовар +1; 
	
	СтруктураРаботы = Новый Структура("ДокументUUID,ТипДокумента,НачалоРаботыСдокументом,ДокументОткрытСекунд,ОтсканированоТовар,ВводВручнуюТовар");
	Если ТипДокумента = Справочники.ТипыДокументов.ПриемПоЗаказу Тогда
		СтруктураРаботы.ДокументUUID =  ОснованиеUUID;  
	Иначе
		СтруктураРаботы.ДокументUUID =  ДокументUUID;  
	КонецЕсли;
	
	СтруктураРаботы.ТипДокумента = ТипДокумента;
	СтруктураРаботы.НачалоРаботыСдокументом = НачалоРаботыСдокументом;
	СтруктураРаботы.ДокументОткрытСекунд = ДокументОткрытСекунд +  (ТекущаяДата() -НачалоКонтроля) ;
	СтруктураРаботы.ОтсканированоТовар = ОтсканированоТовар;
	СтруктураРаботы.ВводВручнуюТовар = ВводВручнуюТовар;
	
	ЗаписатьВремяРаботыСДокументомНаСервере(СтруктураРаботы);	
	ОбновитьЗаписьПоСтроке(,СтрокаТовара);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьСтрокуМарштрутныйЛист(ИД)
	
	
	ИД_Строка = ОпределитьСтрокуМаршрутныйЛист(ИД);
	
	Если ИД_Строка = Неопределено Тогда
		
		ЗвукОшибки(Истина,"Накладної немає у маршрутному листі!");
		Возврат;
	КонецЕсли;
	
	ДанныеСтроки = Новый Структура("Пересчет",Истина);
	
	ОбработатьСтроку(ИД_Строка,ДанныеСтроки);
	

	
КонецПроцедуры

&НаСервере
Функция ОпределитьСтрокуМаршрутныйЛист(ИД)
  	 	
	мБуферИд =  БуферИД.НайтиСтроки(Новый Структура("ИД",ИД));
	
	Если мБуферИд.Количество() =1 Тогда	
		СтрокиТЧ = Объект.Товары.НайтиСтроки(Новый Структура("ДокументИД",мБуферИд[0].ИД_Док));
		Если СтрокиТЧ.Количество() = 1 Тогда
			Возврат СтрокиТЧ[0].ПолучитьИдентификатор();
		КонецЕсли;	
	
	КонецЕсли;
	
	Возврат Неопределено;	

КонецФункции


&НаСервере
Функция ТипыДопПринять()
	
	РезВозврат = (ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ПриемПоЗаказу")	
	ИЛИ ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ПриемПоПриходу"));
	
	Возврат РезВозврат;
	
КонецФункции

&НаСервере
Функция ТипыИнвентаризация()
	
	РезВозврат = (ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ИнвентаризацияТБД")	
	ИЛИ ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеИН")  
	ИЛИ ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Инвентаризация")
	ИЛИ ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЛокальнаяИнвентаризация") );
	
	Возврат РезВозврат;

КонецФункции


&НаСервере
Функция ТипыДокПодтвердить()
	
	РезВозврат = (ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Комплектация")
	ИЛИ ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Контролер"));
	
	Возврат РезВозврат;
	
КонецФункции



&НаСервере
Процедура ОбработатьСрокуВыбор(ДанныеТовара);
	
	Артикул      = ДанныеТовара.Артикул;
	НаименованиеТовара = ДанныеТовара.НаименованиеТовара;
	НаименованиеЕдиницы      = ДанныеТовара.НаименованиеЕдиницы;
	
	Если ДанныеТовара.Свойство("Остаток") Тогда
		Остаток      = ДанныеТовара.Остаток;
	Иначе
		Остаток = 0;
	КонецЕсли;
	
	Если ДанныеТовара.Свойство("Количество") Тогда
		Количество   = ДанныеТовара.Количество;
	Иначе
		Количество = 0;
	КонецЕсли;
	
	Если ДанныеТовара.Свойство("Коэффициент") Тогда
		Коэффициент   = ДанныеТовара.Коэффициент;
	Иначе
		Коэффициент = 0;
	КонецЕсли;
	
	
	Если ДанныеТовара.Свойство("ШтрихКод") Тогда
		ШтрихКод   = ДанныеТовара.ШтрихКод;
	Иначе
		ШтрихКод = "";
	КонецЕсли;

	Если ДанныеТовара.Свойство("Продажи") Тогда
		Продажи   = ДанныеТовара.Продажи;
	Иначе
		Продажи = 0;
	КонецЕсли;
	Если ДанныеТовара.Свойство("ИспМРЦ") Тогда
		ТекИспМРЦ = ДанныеТовара.ИспМРЦ;
	Иначе
		ТекИспМРЦ = 0;
	КонецЕсли;
	
	Если ДанныеТовара.Свойство("МРЦ") Тогда
		ТекМРЦ = Формат(ДанныеТовара.МРЦ,"ЧГ=");
	Иначе
		ТекМРЦ ="";
	КонецЕсли;
	
	Если ДанныеТовара.Свойство("СрокВозврата") Тогда
		УсловиеВозврата = ДанныеТовара.СрокВозврата;
		ДатаВозврата = ?(УсловиеВозврата = 0, Неопределено,ТекущаяДата() + (60*60*24* УсловиеВозврата));
	Иначе  
		ДатаВозврата = Неопределено;
		УсловиеВозврата = 0;
	КонецЕсли;
	

	
	
	
	СтрокаНаименование = НСтр("ru = '%Артикул% %ШтрихКод% %НаименованиеТовара%'");
	
	СтрокаНаименование = СтрЗаменить(СтрокаНаименование, "%Артикул%", "["+Артикул+"]");
	СтрокаНаименование = СтрЗаменить(СтрокаНаименование, "%ШтрихКод%", "["+ШтрихКод+"]");
	СтрокаНаименование = СтрЗаменить(СтрокаНаименование, "%НаименованиеТовара%", Символы.ПС+НаименованиеТовара)+?(ЗначениеЗаполнено(ТекМРЦ)," МРЦ-"+ТекМРЦ,"");
	
	
	//ШтрихКод     = ДанныеТовара.ШтрихКод;
	
	НайденныеСтроки = Объект.Товары.НайтиСтроки(Новый Структура("Артикул,МРЦ",Артикул,ТекМРЦ));
	тКоличествоВДокументе = 0;
	
	
	Если ТипДокумента  = ПредопределенноеЗначение("Справочник.ТипыДокументов.Контролер")Тогда
		тКоличествоПоставщика = 0;
		
		для Каждого СтрНС Из НайденныеСтроки Цикл 
			тКоличествоПоставщика = тКоличествоПоставщика + СтрНС.КоличествоПоставщика;
			тКоличествоВДокументе = тКоличествоВДокументе + СтрНС.КоличествоВведено;
		КонецЦикла;
		
		КоличествоПоставщика = тКоличествоПоставщика;	
	ИначеЕсли  ТипДокумента  = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеТНП")Тогда
		
		для Каждого СтрНС Из НайденныеСтроки Цикл 
			  СтрНС.Пересчет = Истина;
			  СтрНС.СканированиеТовар = СтрНС.СканированиеТовар +1;
			  тКоличествоВДокументе = тКоличествоВДокументе + СтрНС.КоличествоВведено;
		  КонецЦикла;
		  Если ЗначениеЗаполнено(ТекМРЦ) Тогда
			  НайденныеСтроки = Объект.Товары.НайтиСтроки(Новый Структура("Артикул,МРЦ",Артикул,""));		
			  для Каждого СтрНС Из НайденныеСтроки Цикл 
				  СтрНС.Пересчет = Истина;
				  СтрНС.СканированиеТовар = СтрНС.СканированиеТовар +1;
				  тКоличествоВДокументе = тКоличествоВДокументе + СтрНС.КоличествоВведено;
			  КонецЦикла; 
		  КонецЕсли;
 
         Количество = 0;
	Иначе
		стрСкан =  ?(ТипДокумента  = ПредопределенноеЗначение("Справочник.ТипыДокументов.ИнвентаризацияТБД"),"КоличествоВведено","Количество");
		для Каждого СтрНС Из НайденныеСтроки Цикл 
			тКоличествоВДокументе = тКоличествоВДокументе + СтрНС[стрСкан];
		КонецЦикла;
		
	КонецЕсли;
	
	КоличествоВДокументе = тКоличествоВДокументе;
	
	Если Элементы.СтраницыПролистывания.ТекущаяСтраница <> Элементы.СтраницаСканирование Тогда
		ЭтаФорма.ТекущийЭлемент = Элементы.СтраницаСканирование;
	КонецЕсли;
	

	
	
КонецПроцедуры

