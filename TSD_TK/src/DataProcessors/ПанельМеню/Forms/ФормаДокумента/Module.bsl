		  ЗаписьПоСтроке2 = СтрЗаменить(ЗаписьПоСтроке2, "%Количество%",           Формат(?(СтрокаТовара.Коэффициент>1,СтрокаТовара.КоличествоПоставщика/СтрокаТовара.Коэффициент,СтрокаТовара.КоличествоПоставщика), ЗначениеНастроекПовтИсп.ФорматКоличественныхПолей()));
		  ЗаписьПоСтроке2 = СтрЗаменить(ЗаписьПоСтроке2, "%НаименованиеЕдиницы%",  Строка(СтрокаТовара.НаименованиеЕдиницы));
		  ЗаписьПоСтроке2 = СтрЗаменить(ЗаписьПоСтроке2, "%Коэффициент%",          Строка(СтрокаТовара.Коэффициент));

		  
		  
	  Иначе
		  
		  ЗаписьПоСтроке2 = НСтр("ru = 'Подтв. %КоличествоВведено% %НаименованиеЕдиницы% Х %Коэффициент%  ост. %Остаток%'");
		  
		  ЗаписьПоСтроке2 = СтрЗаменить(ЗаписьПоСтроке2, "%КоличествоВведено%",    Формат(?(СтрокаТовара.Коэффициент>1,СтрокаТовара.Количество/СтрокаТовара.Коэффициент,СтрокаТовара.Количество), ЗначениеНастроекПовтИсп.ФорматКоличественныхПолей()));
		  ЗаписьПоСтроке2 = СтрЗаменить(ЗаписьПоСтроке2, "%НаименованиеЕдиницы%",  Строка(СтрокаТовара.НаименованиеЕдиницы));
		  ЗаписьПоСтроке2 = СтрЗаменить(ЗаписьПоСтроке2, "%Коэффициент%",          Строка(СтрокаТовара.Коэффициент));
		  ЗаписьПоСтроке2 = СтрЗаменить(ЗаписьПоСтроке2, "%Остаток%",           Формат(Остаток, ЗначениеНастроекПовтИсп.ФорматКоличественныхПолей()));
		  
	  КонецЕсли
	ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеТБД") ИЛИ ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеВФ") Тогда
		Если ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеВФ") Тогда
			СтрокаТовара.СканированиеТовар = СтрокаТовара.СканированиеТовар + ДанныеТовара.БезЦенника; 
		ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеТБД") Тогда
	        СтрокаТовара.СканированиеТовар = СтрокаТовара.СканированиеТовар + ?( ДанныеТовара.БезЦенника = 1,  ДанныеТовара.Количество,0);
		Иначе
			СтрокаТовара.СканированиеТовар = СтрокаТовара.СканированиеТовар + ДанныеТовара.Количество; 
		КонецЕсли;
		
	    СтрокаТовара.СканированиеЦенник = СтрокаТовара.СканированиеЦенник + ДанныеТовара.ЕстьСверка;
		СтрокаТовара.ЦенаПроверена = СтрокаТовара.ЦенаПроверена + ДанныеТовара.ЦенаПроверена;
		СтрокаТовара.СпецЦена =  ДанныеТовара.СпецЦена;

		Если ЗначениеЗаполнено(ДанныеТовара.ЦенаЦенник) И ДанныеТовара.ЦенаЦенник <> СтрокаТовара.ЦенаЦенник Тогда
			СтрокаТовара.ЦенаЦенник = ДанныеТовара.ЦенаЦенник;
		КонецЕсли;
		
		
		Если СтрокаТовара.СканированиеТовар > 0 И  СтрокаТовара.СканированиеЦенник > 0 Тогда
			СтрокаТовара.Пересчет  = Истина;
			СтрокаТовара.КоличествоРасхождение = 0
		Иначе
			СтрокаТовара.КоличествоРасхождение = 1
		КонецЕсли;
		
		СтрокаПодстановки = НСтр("ru = 'к.Тов. %1 / к.Цен. %2 тЦ. %3 / цЦ. %4 Ост. %5'; ua = 'к.Тов. %1 / к.Цін. %2  тЦ. %3 / цЦ. %4 Ост. %5'");

		ЗаписьПоСтроке2 = ОбщегоНазначенияКлиентСервер.ПодставитьПараметрыВСтроку(СтрокаПодстановки,
		Формат(СтрокаТовара.СканированиеТовар,?(СтрокаТовара.Весовой,ЗначениеНастроекПовтИсп.ФорматВес(),ЗначениеНастроекПовтИсп.ФорматЦелоеЧисло())),
		Формат(СтрокаТовара.СканированиеЦенник,ЗначениеНастроекПовтИсп.ФорматЦелоеЧисло()),
		Формат(СтрокаТовара.Цена,ОбщегоНазначенияПовтИсп.ФорматСуммовыхПолей()),
		Формат(СтрокаТовара.ЦенаЦенник,ОбщегоНазначенияПовтИсп.ФорматСуммовыхПолей()),
		Формат(СтрокаТовара.Остаток,ЗначениеНастроекПовтИсп.ФорматЦелоеЧисло())
		);
		
		Если ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеВФ") Тогда
			Если ДанныеТовара.Свойство("АМ") Тогда
				СтрокаТовара.АМ = ДанныеТовара.АМ;
			КонецЕсли;
			АМ = "н/а ";
			Если СтрокаТовара.АМ = 1 Тогда
			   АМ = "АМ ";
		   КонецЕсли;
		   
			ЗаписьПоСтроке2 = АМ + ЗаписьПоСтроке2;
		КонецЕсли;
		
		
	ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеТНП") Тогда
		СтрокаТовара.Пересчет  = Истина;
		СтрокаТовара.УсловиеВозврата   = ДанныеТовара.УсловиеВозврата;
		СтрокаТовара.КоличествоВведено = СтрокаТовара.КоличествоВведено + ДанныеТовара.Количество;
		СтрокаПодстановки = НСтр("ru = 'Дней %1 / %2 ост. %3'; ua = 'Днів %1 / %2 ост. %3'");
		Если ДанныеТовара.УсловиеВозврата = 0 Тогда
			тДатаВозврата = "ДО ПРОСРОКА";
		Иначе
			тДатаВозврата  = Формат(ТекущаяДата() + (60*60*24* ДанныеТовара.УсловиеВозврата),ЗначениеНастроекПовтИсп.ФорматДатыДата());
		КонецЕсли;
		
		ЗаписьПоСтроке2 = ОбщегоНазначенияКлиентСервер.ПодставитьПараметрыВСтроку(СтрокаПодстановки,
			СтрокаТовара.УсловиеВозврата,
			тДатаВозврата,
			Формат(СтрокаТовара.Остаток,ЗначениеНастроекПовтИсп.ФорматЦелоеЧисло()));
		
		
	Иначе
		КоличествоПостроке  =  СтрокаТовара.Количество + ?(ДанныеТовара.Количество = 0,1,ДанныеТовара.Количество);
		Остаток = ДанныеТовара.Остаток;

		
		Если КонтрольОстатка тогда
			СтрокаТовара.Количество	= Мин(КоличествоПостроке,Остаток);
		Иначе
			СтрокаТовара.Количество	= КоличествоПостроке;
		КонецЕсли;
		КоличествоВДокументе =  СтрокаТовара.Количество;
		Количество           =  СтрокаТовара.Количество;
		
	  
	  ЗаписьПоСтроке2 = НСтр("ru = '%Количество% %НаименованиеЕдиницы% Х %Коэффициент%'");
	  
	  ЗаписьПоСтроке2 = СтрЗаменить(ЗаписьПоСтроке2, "%Количество%",           Формат(СтрокаТовара.Количество, ЗначениеНастроекПовтИсп.ФорматКоличественныхПолей()));
	  ЗаписьПоСтроке2 = СтрЗаменить(ЗаписьПоСтроке2, "%НаименованиеЕдиницы%",  Строка(СтрокаТовара.НаименованиеЕдиницы));
	  ЗаписьПоСтроке2 = СтрЗаменить(ЗаписьПоСтроке2, "%Коэффициент%",          Строка(СтрокаТовара.Коэффициент));

	КонецЕсли;
	
	ЗаписьПоСтроке = СтрЗаменить(ЗаписьПоСтроке, "%Артикул%",            СтрокаТовара.Артикул);
	ЗаписьПоСтроке = СтрЗаменить(ЗаписьПоСтроке, "%ШтрихКод%",           СтрокаТовара.ШтрихКод);
	ЗаписьПоСтроке = СтрЗаменить(ЗаписьПоСтроке, "%НаименованиеТовара%", СтрокаНаименованиеТовара);
	
	СтрокаТовара.ТоварыЗаписьПоСтроке = ЗаписьПоСтроке;
	СтрокаТовара.ТоварыЗаписьПоСтроке2 = ЗаписьПоСтроке2;
	СтрокаТовара.ИтогСтрокаДокумента = ЗаписьПоСтроке + Символы.ПС + ЗаписьПоСтроке2;


		
	Если ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЛокальнаяИнвентаризация") 
		ИЛИ  ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеИН") 
		ИЛИ  ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ИнвентаризацияТБД") 
		Тогда
		СтрокаТовара.Пересчет = Истина;
	ИначеЕсли (ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ПриемПоЗаказу") ИЛИ ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ПриемПоПриходу")) И ВводкКоличества Тогда
		
		ТаблицаСтрока.Очистить();
		стТаблицаСтрока = ТаблицаСтрока.Добавить();
		ЗаполнитьЗначенияСвойств(стТаблицаСтрока,СтрокаТовара);
		стТаблицаСтрока.ИдентификаторСтроки = ИдентификаторСтроки;
		стТаблицаСтрока.НаименованиеТовара  = СтрокаНаименованиеТовара;
		стТаблицаСтрока.СтрокаЗакПод =  Формат(стТаблицаСтрока.Количество,"ЧЦ=15; ЧДЦ=3; ЧН=; ЧГ=")+" \ "+Формат(стТаблицаСтрока.КоличествоПодтверждено,"ЧЦ=15; ЧДЦ=3; ЧН=; ЧГ=");
		
		Элементы.ДекорацияАртикул.Заголовок = СтрокаТовара.Артикул+" ("+СтрокаТовара.НаименованиеЕдиницы+")";
		Если ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ПриемПоПриходу") И  СтрокаТовара.АМ =0 Тогда
		Иначе
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "СтраницаТовары,ПричиныРасхожденияГруппа,ГруппаПодвалКнопки", "Видимость",Ложь);
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "СтраницаСтрока,ДанныеПоТоваруГруппа", "Видимость",Истина);
		КонецЕсли;
	ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Комплектация") И ВводкКоличества Тогда
		
		ТаблицаСтрока.Очистить();
		стТаблицаСтрока = ТаблицаСтрока.Добавить();
		ЗаполнитьЗначенияСвойств(стТаблицаСтрока,СтрокаТовара);
		стТаблицаСтрока.ИдентификаторСтроки = ИдентификаторСтроки;

		стТаблицаСтрока.СтрокаЗакПод =  Формат(стТаблицаСтрока.Количество,"ЧЦ=15; ЧДЦ=3; ЧН=; ЧГ=")+" \ "+Формат(стТаблицаСтрока.КоличествоВведено,"ЧЦ=15; ЧДЦ=3; ЧН=; ЧГ=");
		
		Элементы.ДекорацияАртикул.Заголовок = СтрокаТовара.Артикул+" ("+СтрокаТовара.НаименованиеЕдиницы+")";
		
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "СтраницаТовары,ПричиныРасхожденияГруппа,ГруппаПодвалКнопки", "Видимость",Ложь);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "СтраницаСтрока,ДанныеПоТоваруГруппа", "Видимость",Истина);
	КонецЕсли;
	
	ДанныеВРаботеЗаписатьСтрокуТовара(СтрокаТовара);
	ОбновитьВремяРаботыСДокументом();
КонецПроцедуры

&НаСервере
Процедура ЗаписатьДанныевРаботе(ИдентификаторСтроки) 
	
	СтрокаТовара = Объект.Товары.НайтиПоИдентификатору(ИдентификаторСтроки);

	ДанныеВРаботеЗаписатьСтрокуТовара(СтрокаТовара); 
	
КонецПроцедуры 

&НаСервере
Процедура ОбновитьВремяРаботыСДокументом()
	
	СтруктураРаботы = Новый Структура("ДокументUUID,ТипДокумента,НачалоРаботыСдокументом,ДокументОткрытСекунд,ОтсканированоТовар,ВводВручнуюТовар");
	Если ТипДокумента = Справочники.ТипыДокументов.ПриемПоЗаказу Тогда
		СтруктураРаботы.ДокументUUID =  ОснованиеUUID;  
	Иначе
		СтруктураРаботы.ДокументUUID =  ДокументUUID;  
	КонецЕсли;
	
	СтруктураРаботы.ТипДокумента = ТипДокумента;
	СтруктураРаботы.НачалоРаботыСдокументом = НачалоРаботыСдокументом;
	СтруктураРаботы.ДокументОткрытСекунд = ДокументОткрытСекунд +  (ТекущаяДата() -НачалоКонтроля) ;
	СтруктураРаботы.ОтсканированоТовар = ОтсканированоТовар;
	СтруктураРаботы.ВводВручнуюТовар = ВводВручнуюТовар;
	
	
	ЗаписатьВремяРаботыСДокументомНаСервере(СтруктураРаботы);
	
КонецПроцедуры


&НаСервере
Процедура ДанныеВРаботеЗаписатьСтрокуТовара(ТекДанные,УдалитьЗапись = Ложь)
	
	Если  ТипДокумента = Справочники.ТипыДокументов.ЗаданиеТБД 
		ИЛИ ТипДокумента = Справочники.ТипыДокументов.ЗаданиеИН 
		ИЛИ ТипДокумента = Справочники.ТипыДокументов.ЗаданиеТНП 
		ИЛИ ТипДокумента = Справочники.ТипыДокументов.ПеремещениеТоваров
		ИЛИ ТипДокумента = Справочники.ТипыДокументов.ЗаданиеВФ Тогда
		
		Набор = РегистрыСведений.ДанныеВРаботе.СоздатьНаборЗаписей();
		Набор.Отбор.ДокументUUID.Установить(ДокументUUID);
		Набор.Отбор.ТипДокумента.Установить(ТипДокумента);
		Набор.Отбор.Артикул.Установить(ТекДанные.Артикул);
		Набор.Отбор.МРЦ.Установить(ТекДанные.МРЦ);
		Если УдалитьЗапись Тогда
			Набор.Записать();
		Иначе
			Запись = Набор.Добавить();
			ЗаполнитьЗначенияСвойств(Запись,ТекДанные);
			Запись.ДокументUUID = ДокументUUID;
			Запись.ТипДокумента = ТипДокумента;
			Набор.Записать();
		КонецЕсли;
	КонецЕсли;

	
КонецПроцедуры




&НаСервере
Процедура ОбновитьЗаписьПоСтроке(ИдентификаторСтроки = Неопределено,Знач Строка = Неопределено)
	
	Если НЕ ИдентификаторСтроки = Неопределено Тогда
		СтрокаТовара = Объект.Товары.НайтиПоИдентификатору(ИдентификаторСтроки);
	Иначе
		СтрокаТовара = Строка;
	КонецЕсли;
	
	
	Если СтрокаТовара.ИспМРЦ  Тогда
		тНаименованиеТовара = СтрокаТовара.НаименованиеТовара  + " МРЦ - " + СтрокаТовара.МРЦ;
	Иначе
		тНаименованиеТовара = СтрокаТовара.НаименованиеТовара;
	КонецЕсли;
	
	
	ЗаписьПоСтроке = НСтр("ru = '%Артикул% %ШтрихКод% %НаименованиеТовара%'");
	ЗаписьПоСтроке = СтрЗаменить(ЗаписьПоСтроке, "%Артикул%",      СтрокаТовара.Артикул);
	ЗаписьПоСтроке = СтрЗаменить(ЗаписьПоСтроке, "%ШтрихКод%", СтрокаТовара.ШтрихКод);
	ЗаписьПоСтроке = СтрЗаменить(ЗаписьПоСтроке, "%НаименованиеТовара%",      тНаименованиеТовара);
	
	//СтрокаТовара.ТоварыЗаписьПоСтроке = ЗаписьПоСтроке;

	Если ТипыДопПринять() Тогда 		
		ЗаписьПоСтроке2 = НСтр("ru = '%сдп% Прий. %КоличествоВведено% из %Количество%%НаименованиеЕдиницы% Х %Коэффициент%'");
		ЗаписьПоСтроке2 = СтрЗаменить(ЗаписьПоСтроке2, "%КоличествоВведено%",    Формат(СтрокаТовара.КоличествоВведено, ЗначениеНастроекПовтИсп.ФорматКоличественныхПолей()));
		ЗаписьПоСтроке2 = СтрЗаменить(ЗаписьПоСтроке2, "%Количество%",           Формат(СтрокаТовара.Количество, ЗначениеНастроекПовтИсп.ФорматКоличественныхПолей()));
		ЗаписьПоСтроке2 = СтрЗаменить(ЗаписьПоСтроке2, "%НаименованиеЕдиницы%",  Строка(СтрокаТовара.НаименованиеЕдиницы));
		ЗаписьПоСтроке2 = СтрЗаменить(ЗаписьПоСтроке2, "%Коэффициент%",          Строка(СтрокаТовара.Коэффициент));
		
