КонецПроцедуры

&НаКлиенте
Процедура ОбработатьВводСтрокиШК()
	Если ПустаяСтрока(СтрокаПоиска) Тогда
		Возврат;
	КонецЕсли;

	
	Если ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ПеремещениеТоваров") 
		И ХозОперация = "ПеремещениеТоваровВФилиал" И СкладUUID = "b0855ae2-fd3e-11e3-8e10-0050568c0032" Тогда //РЦ Харьков
		 Сообщить("Не можна додавати, відскануйте об'єкт");
		Возврат;
	КонецЕсли;



	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("Форма", ЭтаФорма);
	ОбработатьПолученныйШтрихкод(СтрокаПоиска, ДополнительныеПараметры);
	
КонецПроцедуры



&НаКлиенте
Процедура КоличествоПриИзменении(Элемент)

	Если КонтрольОстатка Тогда
		Если Количество> Остаток Тогда
			Сообщить("Превышение остатка");
		КонецЕсли;
		
		Количество = Мин(Остаток,Количество);
	КонецЕсли;
	
КонецПроцедуры


&НаКлиенте
Процедура ТоварыВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	//Если ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Контролер") 
		Если ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.МаршрутныйЛист")
			Или ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ВозвратПеремещение")  
			ИЛИ ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Рекламация") 
		 Тогда
		Возврат;
	КонецЕсли;
	
	
	ОчиститьСообщения();
	ПараметрыСтроки = ПолучитьПараметрыСтроки();
	
	Если НЕ ПараметрыСтроки = Неопределено Тогда
		
		Если  ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ПриемПоЗаказу") 
			ИЛИ ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Комплектация") 
			ИЛИ ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Задание") 
			ИЛИ ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ПриемПоПриходу") Тогда
			
			
			ПоказатьСтраницуВводаСтрокиТовара(ПараметрыСтроки);
			
		Иначе
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма,"СтрокаПоиска","Вид",ВидПоляФормы.ПолеНадписи);

			ДополнительныеПараметры = Новый Структура;
			ДополнительныеПараметры.Вставить("ИдентификаторСтроки", ПараметрыСтроки.ИдентификаторСтроки);
			
			ОписаниеОповещения = Новый ОписаниеОповещения("ОповещениеИзменитьСтроку", ЭтотОбъект, ДополнительныеПараметры);
			
			ОткрытьФорму("ОбщаяФорма.РедактированиеСтрокиV2", ПараметрыСтроки, ЭтаФорма,,,,ОписаниеОповещения);
		КонецЕсли;
		
		
	КонецЕсли;
	
	
	
КонецПроцедуры


&НаКлиенте
Процедура ПоказатьСтраницуВводаСтрокиТовара(ПараметрыСтроки)
	ТаблицаСтрока.Очистить();
	стТаблицаСтрока = ТаблицаСтрока.Добавить();
	ЗаполнитьЗначенияСвойств(стТаблицаСтрока,ПараметрыСтроки);
	
	Если ПараметрыСтроки.Свойство("МРЦ") И ЗначениеЗаполнено(ПараметрыСтроки.МРЦ) Тогда 
		стТаблицаСтрока.НаименованиеТовара	 = стТаблицаСтрока.НаименованиеТовара + " МРЦ - "+ПараметрыСтроки.МРЦ;
	КонецЕсли;
	
	Если  ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Комплектация") Тогда
		стТаблицаСтрока.СтрокаЗакПод =  Формат(стТаблицаСтрока.Количество,"ЧЦ=15; ЧДЦ=3; ЧН=; ЧГ=")+" \ "+Формат(стТаблицаСтрока.КоличествоПодтверждено,"ЧЦ=15; ЧДЦ=3; ЧН=; ЧГ=");
	Иначе
		стТаблицаСтрока.СтрокаЗакПод =  Формат(стТаблицаСтрока.Количество,"ЧЦ=15; ЧДЦ=3; ЧН=; ЧГ=")+" \ "+Формат(стТаблицаСтрока.КоличествоПодтверждено,"ЧЦ=15; ЧДЦ=3; ЧН=; ЧГ=");
	КонецЕсли;
	Элементы.ДекорацияАртикул.Заголовок = ПараметрыСтроки.Артикул+" ("+ПараметрыСтроки.НаименованиеЕдиницы+")";
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "СтраницаТовары,СтрокаПоискаТовары,ПричиныРасхожденияГруппа,ГруппаПодвалКнопки", "Видимость",Ложь);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "СтраницаСтрока,ДанныеПоТоваруГруппа", "Видимость",Истина);

	
КонецПроцедуры


&НаКлиенте
Процедура ОповещениеИзменитьСтроку(Результат, ДополнительныеПараметры) Экспорт
	
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма,"СтрокаПоиска","Вид",ВидПоляФормы.ПолеВвода);

	Если Результат = Неопределено ИЛИ Результат = КодВозвратаДиалога.Отмена Тогда
		Возврат;
	КонецЕсли;
	
	ИдентификаторСтроки = ДополнительныеПараметры.ИдентификаторСтроки;
	СтрокаТаблицы = Объект.Товары.НайтиПоИдентификатору(ИдентификаторСтроки);
	
	
	Если Результат.Свойство("УдалитьСтроку") Тогда
		
		ИндексСтроки = Объект.Товары.Индекс(СтрокаТаблицы);
		Объект.Товары.Удалить(ИндексСтроки);
		//Объект.Товары.Сортировать("НомерСтрокиДокумента");

		Модифицированность = Истина;
		
	ИначеЕсли Результат.Свойство("Сохранить") Тогда
		
		ЗаполнитьЗначенияСвойств(СтрокаТаблицы, Результат);
		
		Если ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ПеремещениеТоваров") И ЦветоваяИндикация Тогда
			СтрокаТаблицы.КоличествоВведено = СтрокаТаблицы.Количество;
			СтрокаТаблицы.КоличествоРасхождение =      СтрокаТаблицы.Количество-СтрокаТаблицы.КоличествоПоставщика;
		ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеТБД") Тогда
			
			
			Если СтрокаТаблицы.СканированиеТовар > 0 И  СтрокаТаблицы.СканированиеЦенник > 0 Тогда
				СтрокаТаблицы.Пересчет  = Истина;
				СтрокаТаблицы.КоличествоРасхождение = 0
			Иначе  
				СтрокаТаблицы.Пересчет  = Ложь;
				
				СтрокаТаблицы.КоличествоРасхождение = 1
			КонецЕсли;
		ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Пересортица") Тогда  
			 СтрокаТаблицы.КоличествоВведено =  СтрокаТаблицы.Количество * СтрокаТаблицы.КоличествоПоставщика;
		
		КонецЕсли;
		
		
		
		ОбновитьЗаписьПоСтроке(ИдентификаторСтроки);
		
		текСтрокаСтруктура = ОбщегоНазначенияКлиентСервер.СтруктураДанныеВРаботе();
		ЗаполнитьЗначенияСвойств(текСтрокаСтруктура,СтрокаТаблицы);
		текСтрокаСтруктура.ДокументUUID = ДокументUUID;
		текСтрокаСтруктура.ТипДокумента = ТипДокумента;

		ЗаписатьДанныеПотоваруНаСервере(текСтрокаСтруктура);
		Модифицированность = Истина;
	//	Объект.Товары.Сортировать("НомерСтрокиДокумента");
		ПодсветитьСтроку(ИдентификаторСтроки);
	КонецЕсли;

	Если ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Zak") Тогда
		ОбновитьСуммуЗаказа();
	КонецЕсли;
	
	
КонецПроцедуры 

&НаКлиенте
Процедура ОбновитьСуммуЗаказа()  
	смЗам = 0;
	
	Для Каждого СтрЗам Из Объект.Товары Цикл 
		СумЗамСтрока =  СтрЗам.Количество * СтрЗам.Коэффициент * СтрЗам.Цена;
		смЗам = смЗам +СумЗамСтрока; 
	КонецЦикла;
	
	Элементы.ДекорацияСумЗам.Заголовок = "Сум. зам.- "  +Формат(смЗам,"ЧЦ=6");
	
КонецПроцедуры



&НаСервереБезКонтекста
Процедура ЗаписатьДанныеПотоваруНаСервере(СтруктураСтрокаТовара)
	РегистрыСведений.ДанныеВРаботе.ДобавитьЗапись(СтруктураСтрокаТовара);
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ЗаписатьВремяРаботыСДокументомНаСервере(СтруктураДанныеРаботы)
	РегистрыСведений.ВремяРаботыСДокументом.ДобавитьЗапись(СтруктураДанныеРаботы);
КонецПроцедуры

&НаКлиенте
Процедура ПодготовкаВыгрузкаПеремещенияКлиенте()
	
	тРасхождения.Очистить();

	ВсегоПринято = Объект.Товары.Итог("КоличествоВведено");
	Если ВсегоПринято = 0 Тогда
		Для Каждого пТовары Из Объект.Товары Цикл 
			нтРс = тРасхождения.Добавить();	 
			нтРс.Количество = -пТовары.КоличествоПоставщика;
			нтРс.СтрокаТовара = пТовары.ИтогСтрокаДокумента;
		КонецЦикла; 
		
	Иначе
		
		Для Каждого пТовары Из Объект.Товары Цикл 
			расх = пТовары.КоличествоВведено - пТовары.КоличествоПоставщика;
			Если расх <> 0 Тогда
				нтРс = тРасхождения.Добавить();	 
				нтРс.Количество = расх;
				нтРс.СтрокаТовара = пТовары.ИтогСтрокаДокумента;
			КонецЕсли;
			
		КонецЦикла; 
	КонецЕсли;
	Если тРасхождения.Количество() Тогда
		
		ДополнительныеПараметры = Новый Структура;
		ДополнительныеПараметры.Вставить("ТаблицаРасхождений", тРасхождения);
			
		ОписаниеОповещения = Новый ОписаниеОповещения("ОповещениеАктПоПриему", ЭтотОбъект);
		
		ОткрытьФорму("ОбщаяФорма.ФормаВопрос", ДополнительныеПараметры, ЭтаФорма,,,,ОписаниеОповещения);
		
	Иначе
		ТекстВопроса = "Принято: "+Формат(ВсегоПринято,"ЧЦ=15; ЧДЦ=3; ЧН=0")+" из "+Формат(Объект.Товары.Итог("КоличествоПоставщика"),"ЧЦ=15; ЧДЦ=3; ЧН=0")+" шт/кг "+Символы.ПС+"Закрыть окно с сохранением прихода?";	
		Оповещение = Новый ОписаниеОповещения("ПослеЗакрытияВопроса", ЭтотОбъект);
		ПоказатьВопрос(Оповещение, ТекстВопроса, РежимДиалогаВопрос.ДаНет);
	
	КонецЕсли;
   // ВыгрузитьДокументНаКлиенте();
КонецПроцедуры
	

&НаКлиенте
Процедура ВыгрузитьДокумент(Команда)
	
	Если ХозОперация = "ПеремещениеТоваровИзФилиала" Тогда
		ПодготовкаВыгрузкаПеремещенияКлиенте();
	Иначе
		ПоказатьВопрос(Новый ОписаниеОповещения("ОповещенияОтправки",ЭтотОбъект),"Вивантажити дані на сервер?",РежимДиалогаВопрос.ДаНет);
	КонецЕсли;

КонецПроцедуры


&НаСервере
Функция ВыгрузитьДокументНаСервере()
	
	СтруктураДокумента = Новый Структура();
	
	Если ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Заявка") Тогда
		СтруктураДокумента.Вставить("info",СокрЛП(НаименованиеТовара));
		СтруктураДокумента.Вставить("usluga",КонтрагентUUID);
		СтруктураДокумента.Вставить("UUID_Сотрудник", ПараметрыСеанса.Сотрудник_ID);
		Если ФотоДокумента.Количество()>0 Тогда
			МассивФото = Новый Массив;
			
			Для Каждого Фото Из ФотоДокумента Цикл 
				СодержимоеФайла	 = Base64Строка(ПолучитьИзВременногоХранилища(Фото.ФотоСсылка));
				МассивФото.Добавить(Новый Структура("Фото",СодержимоеФайла));
			КонецЦикла;
			СтруктураДокумента.Вставить("ФотоДокумента", МассивФото);
			
		КонецЕсли;

		
		Рез = ИнтеграцияТК_ВызовСервера.ПередатьДокументНаСервер(СтруктураДокумента,ТипДокумента);
		Возврат Рез;
	КонецЕсли;
	
	
	
	СтруктураДокумента.Вставить("ПечатьТСД",?(ЗначениеНастроекВызовСервераПовтИсп.ИспользуетсяПечатьНаПринтер(),1,0));
	Если ТочкаМаршрута = 4 Тогда
		СтруктураДокумента.Вставить("КоличествоСтикеров",КоличествоСтикеров); 
		СтруктураДокумента.Вставить("UUID_Принтер",ИД_Принтер);
	КонецЕсли;
	
	МассивТоваров = Новый Массив;
	
	
	Если ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Комплектация") Тогда
		СтруктураДокумента.Вставить("ТочкаДоставкиGLN",ТочкаДоставкиGLN);
		СтруктураДокумента.Вставить("ДатаЗаказа",Формат(ОбщепитДатаЗаказа,"ДФ=yyyyMMdd"));
		ПеремСтуктура = "Артикул,КоличествоВведено";
		Если Не ПустаяСтрока(ДокументUUID) Тогда
			СтруктураДокумента.Вставить("UUID_Документ",ДокументUUID);
		КонецЕсли;
	ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Контролер") Тогда
		СтруктураДокумента.Вставить("UUID_Сотрудник", ПараметрыСеанса.Сотрудник_ID);
		СтруктураДокумента.Вставить("UUID_Документ",ДокументUUID);
		СтруктураДокумента.Вставить("ДоументСервер",Истина);
		СтруктураДокумента.Вставить("НачалоКонтроля",Формат(НачалоКонтроля,"ДФ=yyyyMMddЧЧммсс"));
		ПеремСтуктура = "Артикул,Количество,МРЦ,Коэффициент,КоличествоВведено";   
	ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Пересортица") Тогда
		СтруктураДокумента.Вставить("UUID_Сотрудник", ПараметрыСеанса.Сотрудник_ID);
		Если Не ПустаяСтрока(ДокументUUID) Тогда
			СтруктураДокумента.Вставить("UUID_Документ",ДокументUUID);
		КонецЕсли;

		ПеремСтуктура = "Артикул,Артикул2,Количество,МРЦ,Коэффициент,КоличествоВведено";   

	Иначе
		ПеремСтуктура = "Артикул,МРЦ,Количество,КоличествоВведено";
		
		СтруктураДокумента.Вставить("UUID_Склад",СкладUUID);
		СтруктураДокумента.Вставить("UUID_Сотрудник", ПараметрыСеанса.Сотрудник_ID);
		СтруктураДокумента.Вставить("ДоументСервер",Ложь);
		Если Не ПустаяСтрока(ДокументUUID) Тогда
			СтруктураДокумента.Вставить("UUID_Документ",ДокументUUID);
		КонецЕсли;
		
		Если ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Уценка") Тогда
			СтруктураДокумента.Вставить("ПроцентУценки",ТипУценки.Код);
		ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ВозвратТоваров") Тогда
			СтруктураДокумента.Вставить("UUID_Контрагент",КонтрагентUUID);
			ПеремСтуктура = ПеремСтуктура + ",Коэффициент";
			
		ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Задание") 
			ИЛИ ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеИН") 
			ИЛИ	ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЛокальнаяИнвентаризация") Тогда
			
			ПеремСтуктура = ПеремСтуктура+",КоличествоВведено";
		ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Zak") Тогда
			СтруктураДокумента.Вставить("ДоументСервер",Истина);
			ПеремСтуктура = ПеремСтуктура + ",Коэффициент";
		ИначеЕсли  ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеТБД") Тогда
			
			ПеремСтуктура = ПеремСтуктура + ",СканированиеТовар,СканированиеЦенник,ЦенаПроверена,Продажи,Остаток";
			
		ИначеЕсли ТипДокумента=ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеВФ") Тогда
			ПеремСтуктура = ПеремСтуктура + ",СканированиеТовар,СканированиеЦенник,ЦенаПроверена";
		КонецЕсли;
		
		
	КонецЕсли;
	
	
	
	Если ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Списание2") Тогда 		
		
		СтруктураДокумента.Вставить("Статья", СтатьяСписания.Код);				
		ПеремСтуктура = ПеремСтуктура + ",Коэффициент";						
		
	ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Инвентаризация") 
		ИЛИ	ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЛокальнаяИнвентаризация")
		ИЛИ	ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеИН")
		ИЛИ ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ИнвентаризацияТБД")Тогда 
		
		ПеремСтуктура = ПеремСтуктура+",Продажи";	
	ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ПриемПоЗаказу") 
		ИЛИ  ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ПриемПоПриходу") Тогда
		ОбновитьВремяРаботыСДокументом();
		СтруктураДокумента.Вставить("ЗакрыватьЗаказ",ЗакрыватьЗаказ);
		СтруктураДокумента.Вставить("ПНомер",ПоставщикаНомерНакладной);
		СтруктураДокумента.Вставить("ПДата",Формат(ПоставщикаДатаДокумента,"ДФ=yyyyMMdd"));
		СтруктураДокумента.Вставить("ОснованиеUUID",ОснованиеUUID);
		
		Если ФотоДокумента.Количество()>0 Тогда
			МассивФото = Новый Массив;
			
			Для Каждого Фото Из ФотоДокумента Цикл 
				СодержимоеФайла	 = Base64Строка(ПолучитьИзВременногоХранилища(Фото.ФотоСсылка));
				МассивФото.Добавить(Новый Структура("Фото",СодержимоеФайла));
			КонецЦикла;
			СтруктураДокумента.Вставить("ФотоДокумента", МассивФото);
			
		КонецЕсли;
		
		Если ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ПриемПоЗаказу") Тогда
			СтруктураВремяРаботы =	СтруктураВремяРаботыСДокументом(ОснованиеUUID,ТипДокумента);
		Иначе
			СтруктураВремяРаботы = СтруктураВремяРаботыСДокументом(ДокументUUID,ТипДокумента);
		КонецЕсли;

		СтруктураДокумента.Вставить("ВремяРаботы",СтруктураВремяРаботы);
		
		
		
		ПеремСтуктура = ПеремСтуктура +",КоличествоПоставщика,КоличествоВведено,КоличествоРасхождение,ПричинаРасхожденияСтрока,ПричинаРасхожденияПорядок"; 
	ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеТНП") Тогда	 
		ПеремСтуктура = ПеремСтуктура+",КоличествоВведено,Коэффициент,СканированиеТовар,СканированиеЦенник";
		СтруктураДокумента.Вставить("UUID_Причина", ПричинаПеремещенияUUID);
		СтруктураДокумента.Вставить("UUID_СкладОтправитель", СкладОтправительUUID);

	КонецЕсли;
	
	Если ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Задание") Тогда
		Для Каждого СтрТовар Из Объект.Товары Цикл 
			Если СтрТовар.КоличествоВведено > 0 Тогда
				СтруктураСтрока = Новый Структура(ПеремСтуктура);
				ЗаполнитьЗначенияСвойств(СтруктураСтрока,СтрТовар,ПеремСтуктура);
				МассивТоваров.Добавить(СтруктураСтрока);
			КонецЕсли;
		КонецЦикла; 
		Если МассивТоваров.Количество() =  0 Тогда
			ВызватьИсключение "Таблица товаров пустая!";	
		КонецЕсли;
		
			
	ИначеЕсли  ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ИнвентаризацияТБД") Тогда
		Для Каждого СтрТовар Из Объект.Товары Цикл 
			Если СтрТовар.Пересчет  Тогда
				СтруктураСтрока = Новый Структура(ПеремСтуктура);
				ЗаполнитьЗначенияСвойств(СтруктураСтрока,СтрТовар,ПеремСтуктура);
				МассивТоваров.Добавить(СтруктураСтрока);
			КонецЕсли;
		КонецЦикла;
	ИначеЕсли  ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ИнвентаризацияТБД") Тогда
	ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.МаршрутныйЛист") Тогда
		Для Каждого СтрТовар Из Объект.Товары Цикл 
			Если СтрТовар.Пересчет Тогда
				СтруктураСтрока = Новый Структура("docid",СтрТовар.ДокументИД);
				МассивТоваров.Добавить(СтруктураСтрока); 
			КонецЕсли;
		КонецЦикла;
	Иначе
		
		Для Каждого СтрТовар Из Объект.Товары Цикл 
			
			СтруктураСтрока = Новый Структура(ПеремСтуктура);
			ЗаполнитьЗначенияСвойств(СтруктураСтрока,СтрТовар,ПеремСтуктура);
			МассивТоваров.Добавить(СтруктураСтрока);
			
		КонецЦикла;
	КонецЕсли;
	СтруктураДокумента.Вставить("Товары",МассивТоваров);
	
	Если  ЗначениеНастроекВызовСервераПовтИсп.ЭтоРежимПодключениеТК() Тогда
		Рез = ИнтеграцияТК_ВызовСервера.ПередатьДокументНаСервер(СтруктураДокумента,ТипДокумента);
	Иначе
		Рез = ИнтеграцияТК_ВызовСервера.ОтправитьДанныеОбщепит("Отгрузка",ТочкаДоставкиGLN,СтруктураДокумента);
	КонецЕсли;
	
	Возврат Рез;

КонецФункции

&НаСервере
Функция ПодготовитьСруктуруАкта()
	
	СтруктураДокумента = Новый Структура();
	СтруктураДокумента.Вставить("UUID_Склад",СкладUUID);
	СтруктураДокумента.Вставить("UUID_Сотрудник", ПараметрыСеанса.Сотрудник_ID);
	СтруктураДокумента.Вставить("ПНомер",ПоставщикаНомерНакладной);
	СтруктураДокумента.Вставить("ПДата",Формат(ПоставщикаДатаДокумента,"ДФ=yyyyMMdd"));
	СтруктураДокумента.Вставить("ОснованиеUUID",ОснованиеUUID);
	СтруктураДокумента.Вставить("ДоументСервер",Ложь);

	
	МассивТоваров = Новый Массив;
	ПеремСтуктура = "Артикул,КоличествоПоставщика,КоличествоВведено,КоличествоРасхождение,ПричинаРасхожденияСтрока";

	Для Каждого СтрТовар Из Объект.Товары Цикл 
		Если СтрТовар.КоличествоРасхождение = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		
		СтруктураСтрока = Новый Структура(ПеремСтуктура);
		ЗаполнитьЗначенияСвойств(СтруктураСтрока,СтрТовар,ПеремСтуктура);
		МассивТоваров.Добавить(СтруктураСтрока);
		
	КонецЦикла;
	СтруктураДокумента.Вставить("Товары",МассивТоваров);

	Возврат СтруктураДокумента;
	
КонецФункции

&НаСервере
Функция ПолучитьСтруктуруПереоценки()
	
	СтруктураДокумента = Новый Структура();
	СтруктураДокумента.Вставить("ИД_Переоценки",ИД_Переоценки);

	//
	МассивТоваров = Новый Массив;
	ПеремСтуктура = "Артикул,МРЦ";

	Для Каждого СтрТовар Из ТоварыПереоценки Цикл 
		Если СтрТовар.Вкл = Ложь Тогда
			Продолжить;
		КонецЕсли;
		
		
		СтруктураСтрока = Новый Структура(ПеремСтуктура);
		ЗаполнитьЗначенияСвойств(СтруктураСтрока,СтрТовар,ПеремСтуктура);
		МассивТоваров.Добавить(СтруктураСтрока);
		
	КонецЦикла;
	СтруктураДокумента.Вставить("Товары",МассивТоваров);

	Возврат СтруктураДокумента;
	
КонецФункции




&НаСервере
Функция Печать()
	
	СтруктруаДокумента = ПодготовитьСруктуруАкта();
	ТипАкта = "АктПриемаЗаказ";
	Если ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ПриемПоПриходу") Тогда
		ТипАкта = "АктПриемаПриход";
	КонецЕсли;
	
	
	Рез = ИнтеграцияТК_ВызовСервера.ИнициализироватьДанныеДляПечати(СтруктруаДокумента,ТипАкта);
	Если НЕ Рез.Результат Тогда
		Сообщить("Ошибка печати Акта!!" +Символы.ПС+ Рез.ОписаниеОшибки);
		Возврат Неопределено;
	КонецЕсли;
	
	
	
	ТабДок = Обработки.ПанельМеню.ПечатьАкта(Рез.Ответ);
	
	Рез = ИнтеграцияТК_ВызовСервера.ПоставитьВочередьНаПечать(ТабДок,"АктПоставки");	
	
	Возврат Рез;
КонецФункции

&НаСервере
Функция ПечатьПереоценки() 
	
	СтруктураДокумента = ПолучитьСтруктуруПереоценки();
	
	Если ЗначениеНастроекВызовСервераПовтИсп.ИспользуетсяПечатьНаПринтер() Тогда	
		СтруктураДокумента.Вставить("ТипДокумента","ПечатьЦенниковТСД");
		Рез =  ИнтеграцияТК_ВызовСервера.ЗапросПечатнаяФорма(СтруктураДокумента);
	Иначе
		Рез =  ИнтеграцияТК_ВызовСервера.ПечатьЦенниковОбъекта(СтруктураДокумента);
	КонецЕсли;
	
	Возврат  Рез
	
КонецФункции

&НаКлиенте
Процедура ПоказатьВопросЗавершение(РезультатВопроса,ДопоплнительныеПараметры) Экспорт
	
	Если РезультатВопроса = Неопределено Тогда 
		ЗавершениеВыгрузкиДокументаНаКлиенте();
	КонецЕсли;
	
	Если РезультатВопроса.Значение = "Да" Тогда
		
		РезПечать =  ИнтеграцияТК_ВызовСервера.ЗапросПечатнаяФорма(ДопоплнительныеПараметры);
		
		Если РезПечать.Результат Тогда
			ОбщегоНазначенияКлиент.ВывестиПДФ_НаПечать(РезПечать.Ответ);
		Иначе
			Сообщить(РезПечать.ОписаниеОшибки);
		КонецЕсли;
	КонецЕсли;
	
	ЗавершениеВыгрузкиДокументаНаКлиенте();	
	
КонецПроцедуры   

&НаКлиенте
Процедура ЗавершениеВыгрузкиДокументаНаКлиенте()
	
	Сообщить("Документ вивантажено успішно");
	ВыполняетсяЗакрытие = Истина;
	Если ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Задание")
		ИЛИ ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеИН") 
		ИЛИ ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеТБД")
		ИЛИ ТипДокумента=ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеВФ")
		ИЛИ ТипДокумента=ПредопределенноеЗначение("Справочник.ТипыДокументов.Уведомление")
		ИЛИ ТипДокумента=ПредопределенноеЗначение("Справочник.ТипыДокументов.ВыдачаДС")Тогда
		Оповестить("ОбновитьЗадания");
	КонецЕсли;
	//удаляем накопленные данные
	Если ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ПриемПоЗаказу") Тогда
		УдалитьДанныеВРаботе(ОснованиеUUID,ТипДокумента);
	Иначе
		УдалитьДанныеВРаботе(ДокументUUID,ТипДокумента);
	КонецЕсли;
	Если ДокументСервер Тогда
		Закрыть(Новый Структура("УдалитьСтроку"));
	Иначе
		Закрыть();
	КонецЕсли;
	

КонецПроцедуры


&НаКлиенте
Процедура ВыгрузитьДокументНаКлиенте(ТаблицаАкт = Неопределено,ФормироватьТУ = Ложь)
	  	
	Отказ = ПроверитьКорректность();
	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	
	
	
	Если ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ПеремещениеТоваров") Тогда 
		Рез = ВыгрузитьДокументПеремещениеНаСервере(ТаблицаАкт,ФормироватьТУ);
	Иначе
		Рез = ВыгрузитьДокументНаСервере();
	КонецЕсли;
	
	
	Если Рез.Результат Тогда
		КоличествоСтикеров = 0;
		ИД_Принтер = "";
		
		Если ТипЗнч(Рез.Ответ) = Тип("Структура") И Рез.Ответ.Свойство("print")
			И ЗначениеНастроекВызовСервераПовтИсп.ИспользуетсяПечатьНаПринтер() Тогда
			
			Кнопки = Новый СписокЗначений;
			Кнопки.Добавить("Да", "Так");
			Кнопки.Добавить("Нет", "Ні");
			ПараметрыНапоминания = Новый Структура;
			ПараметрыНапоминания.Вставить("Заголовок", "Увага");
			ПараметрыНапоминания.Вставить("ПредлагатьБольшеНеЗадаватьЭтотВопрос", Ложь);
			СтандартныеПодсистемыКлиент.ПоказатьВопросПользователю(
			Новый ОписаниеОповещения("ПоказатьВопросЗавершение",ЭтотОбъект,Рез.Ответ.print), "Друкувати документ?", Кнопки, ПараметрыНапоминания);
			
		Иначе
			
			Если (ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ПриемПоЗаказу") ИЛИ ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ПриемПоПриходу"))  И  ЕстьАктРасхождения()
				И НЕ ЗначениеНастроекВызовСервераПовтИсп.ИспользуетсяПечатьНаПринтер() Тогда
				
				Рез = Печать();
				Если Не Рез.Результат Тогда
					Сообщить("Не удалось распечатать Акт "+ Символы.ПС+ Рез.ОписаниеОшибки);
					Возврат;
				КонецЕсли;
			КонецЕсли;
			
			
			
			ЗавершениеВыгрузкиДокументаНаКлиенте();
			
		КонецЕсли;
		
		
	Иначе	
		
		Если ПустаяСтрока(Рез.ОписаниеОшибки) Тогда
			Сообщить("Помилка вивантаження документа!");
		Иначе
			Сообщить(Рез.ОписаниеОшибки);
		КонецЕсли;
		
	КонецЕсли;	
	
	Если ТипЗнч(Рез.Ответ) = Тип("Структура") Тогда
		
		Если Рез.Ответ.Свойство("UUID_Документ")Тогда
			ДокументUUID = Рез.Ответ.UUID_Документ;
		КонецЕсли;
		
	КонецЕсли;
	

КонецПроцедуры

&НаСервереБезКонтекста
Процедура УдалитьДанныеВРаботе(ДокументUUID,ТипДокумента);
	РегистрыСведений.ДанныеВРаботе.ОчиститьДанныеВРаботе(ДокументUUID,ТипДокумента);    
	РегистрыСведений.ВремяРаботыСДокументом.ОчиститьДанныеВРаботе(ДокументUUID,ТипДокумента); 
КонецПроцедуры

&НаСервереБезКонтекста
Функция СтруктураВремяРаботыСДокументом(ДокументUUID,ТипДокумента)   
	Возврат РегистрыСведений.ВремяРаботыСДокументом.ПолучитьСтруктуруВремяРаботыСдокументом(ДокументUUID,ТипДокумента); 
КонецФункции


&НаКлиенте
Функция ПроверитьКорректность()
	
	Отказ = Ложь;
	ОчиститьСообщения();
	Если ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Уведомление")
		ИЛИ ТипДокумента =  ПредопределенноеЗначение("Справочник.ТипыДокументов.Заявка") 
		ИЛИ ТипДокумента =  ПредопределенноеЗначение("Справочник.ТипыДокументов.ВыдачаДС") Тогда
		Возврат Ложь;
	КонецЕсли;
	
	
	Если Объект.Товары.Количество() = 0 Тогда
		 Сообщить("Таблица товаров пустая!");
		 Возврат Истина;
	КонецЕсли;
	
	
	Если ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЛокальнаяИнвентаризация")
		ИЛИ ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеИН") 	 Тогда
		
		Отказ = ПроверитьТоварыИН();
	
		Если Отказ Тогда
			Сообщить("Не всі товари пораховані");	
			ЭтаФорма.ТекущийЭлемент = Элементы.СтраницаТовары;
		КонецЕсли;   
		
		Для Каждого стТов Из Объект.Товары Цикл 
			Если стТов.Весовой Тогда
				ТекОстаток = ?(стТов.Остаток<0,0,стТов.Остаток);	
				Если ТекОстаток = 0 И стТов.КоличествоВведено > 20 
					ИЛИ  стТов.КоличествоВведено > ТекОстаток * 1.2 Тогда
					Отказ = Истина;
					Сообщить("Введено підозріло велику кількість, перевірте товар "+стТов.НаименованиеТовара);
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
		
		
		
	ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Контролер") Тогда
		Отказ = ПроверитьТоварыКонтроль();
		Если Отказ Тогда
			Сообщить("Немає товару для збереження");	
			ЭтаФорма.ТекущийЭлемент = Элементы.СтраницаТовары;
		КонецЕсли;

	ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ИнвентаризацияТБД") Тогда
			Отказ = ПроверитьТоварыИНТБД();
			Если Отказ Тогда
				Сообщить("Немає порахованих товарів");	
				ЭтаФорма.ТекущийЭлемент = Элементы.СтраницаТовары;
			КонецЕсли;

	ИначеЕсли  ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Списание2") 
		ИЛИ ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ВозвратТоваров") 
		ИЛИ ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Уценка") Тогда 
		
		Если ПустаяСтрока(СкладUUID) Тогда
			Сообщить("Не выбран склад");
			Отказ =  Истина;
		КонецЕсли;

		Если ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Уценка") И Не ЗначениеЗаполнено(ТипУценки) Тогда
			Сообщить("Не выбран тип уценки");
			Отказ =  Истина;
		КонецЕсли;
		
		Если ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Списание2") И Не ЗначениеЗаполнено(СтатьяСписания) Тогда
			Сообщить("Не выбрана статья списания");
			Отказ =  Истина;
		КонецЕсли;

		
		Если ПроверитьПревышениеОстаткаВТЧТовары() Тогда
			Отказ = Истина;
			ЭтаФорма.ТекущийЭлемент = Элементы.СтраницаТовары;
		КонецЕсли;
		
		УстановитьОформление(Отказ,1);
		
	ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ПриемПоЗаказу")
		ИЛИ ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ПриемПоПриходу") Тогда
		Если НЕ ЗначениеЗаполнено(ПоставщикаДатаДокумента) Тогда
			Отказ = Истина;
			Сообщить("Укажите дату накладной поставщика");
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(ПоставщикаНомерНакладной) Тогда
			Отказ = Истина;
			Сообщить("Укажите номер накладной поставщика");
		КонецЕсли;
		КоличествоПринято = Объект.Товары.Итог("КоличествоВведено");
		Если КоличествоПринято = 0 Тогда
			 Сообщить("Документ необходимо заполнить");
			Отказ = Истина;
		КонецЕсли;
		
		Если ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ПриемПоПриходу") Тогда
			стрОшибки = "";
			Для Каждого СтрТ Из Объект.Товары Цикл 
				Если СтрТ.КоличествоПоставщика <> СтрТ.КоличествоВведено И НЕ ЗначениеЗаполнено(СтрТ.ПричинаРасхождения) Тогда
					стрОшибки = стрОшибки + "Не принята строка №"+ СтрТ.НомерСтроки  +", "+ СтрТ.ТоварыЗаписьПоСтроке+Символы.ПС;
				КонецЕсли;
			КонецЦикла;
			
			Если НЕ ПустаяСтрока(стрОшибки) Тогда
				Отказ = Истина;
				стрОшибки = стрОшибки+"Укажите причину расхождения.";
				Сообщить(стрОшибки);
			КонецЕсли;
			
		КонецЕсли;
		
		
		
	ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ПеремещениеТоваров") Тогда 

		Если ПустаяСтрока(СкладUUID) Тогда 
			Отказ = Истина;
			Сообщить("Не выбран склад");
		КонецЕсли;
		
		Если ПустаяСтрока(СкладОтправительUUID) Тогда 
			Отказ = Истина;
			Сообщить("Не заполнен склад отправитель");
		КонецЕсли;		

		Если ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ПеремещениеТоваров") И СкладТНП И ПустаяСтрока(ПричинаПеремещенияUUID) Тогда
			Отказ = Истина;
			Сообщить("Укажите причину перемещения на склад ТНП");
		КонецЕсли;
		
		
		Если ПустаяСтрока(ХозОперация) Тогда 
			Отказ = Истина;
			Сообщить("Не заполнена Хоз операция перемещения!");
		КонецЕсли;
		Если ХозОперация = "ПеремещениеТоваровИзФилиала" Тогда
			 Если ПроверитьПревышениеПриходаВТЧТовары() Тогда
				Отказ = Истина;
				ЭтаФорма.ТекущийЭлемент = Элементы.СтраницаТовары;
			КонецЕсли;
			
		Иначе	
			Если ПроверитьПревышениеОстаткаВТЧТовары() Тогда
				Отказ = Истина;
				ЭтаФорма.ТекущийЭлемент = Элементы.СтраницаТовары;
			КонецЕсли;
		КонецЕсли;
		

		
	ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Комплектация") Тогда 
	ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеТБД") Тогда
	ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеВФ") Тогда 
  	ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Пересортица") Тогда 
	ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Zak") Тогда 
		
		
		Если МинимальнаяСумма>0 Тогда   
			СуммаДок = 0;
			Для Каждого стТов Из Объект.Товары Цикл 
				    СумСтрока =  стТов.Количество*стТов.Коэффициент * стТов.Цена;
					СуммаДок = СуммаДок + СумСтрока
			КонецЦикла;
			
			Если СуммаДок < МинимальнаяСумма Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				   НСтр("ru='Минимальная сумма заказа %1 сумма документа %2'"),МинимальнаяСумма,СуммаДок));
				Отказ = Истина;
			КонецЕсли;
			
			
		КонецЕсли;
		
		
	ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.МаршрутныйЛист") Тогда 
		мДокументы = Объект.Товары.НайтиСтроки(Новый Структура("Пересчет",Истина)); 
		Если мДокументы.Количество() = 0 Тогда
			Сообщить("Нема документів!");	
			Отказ = Истина;
		КонецЕсли;
		
	ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Задание") Тогда  
		Если ТочкаМаршрута = 3 Тогда 
			Возврат Отказ;
		КонецЕсли;
		
		Если ПроверитьПревышениеОстаткаВТЧТовары("КоличествоВведено") Тогда
			Отказ = Истина;
			ЭтаФорма.ТекущийЭлемент = Элементы.СтраницаТовары;
		КонецЕсли;
	
		
	Иначе		
		
		Если ПустаяСтрока(СкладUUID) Тогда
			Сообщить("Не выбран склад");
			Отказ =  Истина;
		КонецЕсли;
	КонецЕсли;

	Возврат Отказ;

КонецФункции

&НаКлиенте
Функция ЕстьАктРасхождения()
	
	КоличествоРасхождение =  Объект.Товары.Итог("КоличествоРасхождение");
	
	Возврат КоличествоРасхождение <> 0;
	
КонецФункции


&НаКлиенте
Функция ПроверитьПревышениеОстаткаВТЧТовары(КоличествоПроверки = "Количество")
	КоличествоПревышаетОстаток = Ложь;
	
	КолвоТоваров = Объект.Товары.Количество();
	
	Если КолвоТоваров = 0 Тогда 
		Возврат Ложь;
	КонецЕсли;		
	
	Для Ит = 0 По КолвоТоваров - 1 Цикл
		ТекСтрока = Объект.Товары[Ит];
		ТекСтрока.ПревышенОстаток = ТекСтрока[КоличествоПроверки] > ТекСтрока.Остаток - ТекСтрока.Продажи;
		
		Если ТекСтрока.ПревышенОстаток Тогда 
			КоличествоПревышаетОстаток = Истина;								
			
			текстМРЦ = "";
			Если ТекСтрока.ИспМРЦ Тогда
				текстМРЦ = " МРЦ - "+  ТекСтрока.МРЦ+" "; 
			КонецЕсли;
			
			ТекстОшибки = "[" + СокрЛП(ТекСтрока.Артикул) + "] " + СокрЛП(ТекСтрока.НаименованиеТовара)+ текстМРЦ + " нет достаточного количества, доступное количество - " + Строка(ТекСтрока.Остаток - ТекСтрока.Продажи);
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Поле = "Товары[" + Ит + "].ТоварыКоличество";
			Сообщение.Текст = ТекстОшибки;
			Сообщение.УстановитьДанные(ЭтотОбъект);
			Сообщение.Сообщить();
		КонецЕсли;
	КонецЦикла;
	
	Если КоличествоПревышаетОстаток Тогда 
		Сообщить("Отредактируйте количество!");
	КонецЕсли;
	
	Возврат КоличествоПревышаетОстаток;
КонецФункции

///Прием перемещения не больше отгрузки
&НаКлиенте
Функция ПроверитьПревышениеПриходаВТЧТовары()
	КоличествоПревышаетОстаток = Ложь;
	
	КолвоТоваров = Объект.Товары.Количество();
	
	Если КолвоТоваров = 0 Тогда 
		Возврат Ложь;
	КонецЕсли;		
	
	Для Ит = 0 По КолвоТоваров - 1 Цикл
		ТекСтрока = Объект.Товары[Ит];
		ТекСтрока.ПревышенОстаток = ТекСтрока.Количество >ТекСтрока.КоличествоПоставщика;
		
		Если ТекСтрока.ПревышенОстаток Тогда 
			КоличествоПревышаетОстаток = Истина;								
			
			текстМРЦ = "";
			Если ТекСтрока.ИспМРЦ Тогда
				текстМРЦ = " МРЦ - "+  ТекСтрока.МРЦ+" "; 
			КонецЕсли;
			
			ТекстОшибки = "[" + СокрЛП(ТекСтрока.Артикул) + "] " + СокрЛП(ТекСтрока.НаименованиеТовара)+ текстМРЦ + " можно принять максимум - " + Строка(ТекСтрока.КоличествоПоставщика);
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Поле = "Товары[" + Ит + "].ТоварыКоличество";
			Сообщение.Текст = ТекстОшибки;
			Сообщение.УстановитьДанные(ЭтотОбъект);
			Сообщение.Сообщить();
		КонецЕсли;
	КонецЦикла;
	
	Если КоличествоПревышаетОстаток Тогда 
		Сообщить("Отредактируйте количество!");
	КонецЕсли;
	
	Возврат КоличествоПревышаетОстаток;
КонецФункции




