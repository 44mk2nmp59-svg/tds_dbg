		КонецЕсли;
		
		ЗаписьПоСтроке2 = ОбщегоНазначенияКлиентСервер.ПодставитьПараметрыВСтроку(СтрокаПодстановки,
			СтрокаТовара.УсловиеВозврата,
			тДатаВозврата,
			Формат(СтрокаТовара.Остаток,ЗначениеНастроекПовтИсп.ФорматЦелоеЧисло())); 
	ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.МаршрутныйЛист") Тогда
		 ЗаписьПоСтроке = тНаименованиеТовара;
		 ЗаписьПоСтроке2 = СтрокаТовара.Получатель;
	ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ВозвратПеремещение") 
		 Или ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.БезакцептныйПрием") Тогда
		 ЗаписьПоСтроке = тНаименованиеТовара;
		 ЗаписьПоСтроке2 = СтрокаТовара.Получатель;
    ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Пересортица") Тогда
		ЗаписьПоСтроке =  СтрокаТовара.НаименованиеТовара +" х "+ Формат(СтрокаТовара.Количество, ?(СтрокаТовара.Весовой,ЗначениеНастроекПовтИсп.ФорматВес(),ЗначениеНастроекПовтИсп.ФорматЦелоеЧисло()));
		ЗаписьПоСтроке2 =  СтрокаТовара.НаименованиеТовара2 +" х "+ Формат(СтрокаТовара.КоличествоВведено, ?(СтрокаТовара.Весовой,ЗначениеНастроекПовтИсп.ФорматВес(),ЗначениеНастроекПовтИсп.ФорматЦелоеЧисло()));

	Иначе
		
		ЗаписьПоСтроке2 = НСтр("ru = '%Количество% %НаименованиеЕдиницы% Х %Коэффициент%'");
		
		ЗаписьПоСтроке2 = СтрЗаменить(ЗаписьПоСтроке2, "%Количество%",           Формат(СтрокаТовара.Количество, ЗначениеНастроекПовтИсп.ФорматКоличественныхПолей()));
		ЗаписьПоСтроке2 = СтрЗаменить(ЗаписьПоСтроке2, "%НаименованиеЕдиницы%",  Строка(СтрокаТовара.НаименованиеЕдиницы));
		ЗаписьПоСтроке2 = СтрЗаменить(ЗаписьПоСтроке2, "%Коэффициент%",          Строка(СтрокаТовара.Коэффициент));
		
