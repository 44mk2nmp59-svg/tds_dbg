&НаКлиенте
Процедура ПечатьВыдачаДС(Команда)  
	Рез =  ДанныеПечатиВыдачиДС(ДокументUUID);	
	Если Не Рез.Результат Тогда 
		Если не ПустаяСтрока(Рез.ОписаниеОшибки) Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю( Рез.ОписаниеОшибки);
		КонецЕсли;
		Возврат;
	КонецЕсли;
	
	Если Рез.Ответ.Свойство("print") Тогда
		
		Кнопки = Новый СписокЗначений;
		Кнопки.Добавить("Да", "Так");
		Кнопки.Добавить("Нет", "Ні");
		ПараметрыНапоминания = Новый Структура;
		ПараметрыНапоминания.Вставить("Заголовок", "Увага");
		ПараметрыНапоминания.Вставить("ПредлагатьБольшеНеЗадаватьЭтотВопрос", Ложь);
		СтандартныеПодсистемыКлиент.ПоказатьВопросПользователю(
		Новый ОписаниеОповещения("ПоказатьВопросПечатьЗавершение",ЭтотОбъект,Рез.Ответ.print), "Друкувати документ?", Кнопки, ПараметрыНапоминания);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПоказатьВопросПечатьЗавершение(РезультатВопроса,ДопоплнительныеПараметры) Экспорт
	
	Если РезультатВопроса = Неопределено Тогда 
		Возврат;
	КонецЕсли;

	Если РезультатВопроса.Значение = "Да" Тогда
		ПечатьЛокальныйПринтер = ЗначениеНастроекВызовСервераПовтИсп.ИспользуетсяПечатьНаПринтер();
		Если НЕ ПечатьЛокальныйПринтер Тогда
			 ДопоплнительныеПараметры.Вставить("Printss");
		 КонецЕсли;
		 
		РезПечать =  ИнтеграцияТК_ВызовСервера.ЗапросПечатнаяФорма(ДопоплнительныеПараметры);
		
		Если РезПечать.Результат Тогда
			Если ПечатьЛокальныйПринтер Тогда
				ОбщегоНазначенияКлиент.ВывестиПДФ_НаПечать(РезПечать.Ответ);
			Иначе 
				ОчиститьСообщения();
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Відправлено на друк");
			КонецЕсли;
		Иначе
			Сообщить(РезПечать.ОписаниеОшибки);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры   


