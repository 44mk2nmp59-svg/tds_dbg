	  	ЗаписьПоСтроке2 = СтрЗаменить(ЗаписьПоСтроке2, "%КоличествоВведено%",    Формат(СтрокаТовара.КоличествоВведено, ЗначениеНастроекПовтИсп.ФорматКоличественныхПолей()));
		ЗаписьПоСтроке2 = СтрЗаменить(ЗаписьПоСтроке2, "%Количество%",           Формат(СтрокаТовара.Остаток, ЗначениеНастроекПовтИсп.ФорматКоличественныхПолей()));
		ЗаписьПоСтроке2 = СтрЗаменить(ЗаписьПоСтроке2, "%НаименованиеЕдиницы%",  Строка(СтрокаТовара.НаименованиеЕдиницы));
		ЗаписьПоСтроке2 = СтрЗаменить(ЗаписьПоСтроке2, "%Коэффициент%",          Строка(СтрокаТовара.Коэффициент));
		ЗаписьПоСтроке2 = СтрЗаменить(ЗаписьПоСтроке2, "%Продажи%",          	 Строка(СтрокаТовара.Продажи));
		
	
		
	ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеТБД") ИЛИ ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеВФ")Тогда
		
		
		СтрокаПодстановки = НСтр("ru = 'к.Тов. %1 / к.Цен. %2 тЦ. %3 / цЦ. %4 Ост. %5'; ua = 'к.Тов. %1 / к.Цін. %2  тЦ. %3 / цЦ. %4 Ост. %5'");
		
		ЗаписьПоСтроке2 = ОбщегоНазначенияКлиентСервер.ПодставитьПараметрыВСтроку(СтрокаПодстановки,
		Формат(СтрокаТовара.СканированиеТовар,?(СтрокаТовара.Весовой,"ЧЦ=15; ЧДЦ=3; ЧРД=.; ЧН=0",ЗначениеНастроекПовтИсп.ФорматЦелоеЧисло())),
		Формат(СтрокаТовара.СканированиеЦенник,ЗначениеНастроекПовтИсп.ФорматЦелоеЧисло()),
		Формат(СтрокаТовара.Цена,ОбщегоНазначенияПовтИсп.ФорматСуммовыхПолей()),
		Формат(СтрокаТовара.ЦенаЦенник,ОбщегоНазначенияПовтИсп.ФорматСуммовыхПолей()),
		Формат(СтрокаТовара.Остаток,ЗначениеНастроекПовтИсп.ФорматЦелоеЧисло())
