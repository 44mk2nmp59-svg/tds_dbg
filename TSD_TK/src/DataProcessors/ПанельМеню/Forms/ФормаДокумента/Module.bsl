&НаКлиенте
Процедура ВыполнитьПослеЗакрытияВводаСотрудника(Результат,ДополнительныеПараметры)Экспорт 
	
	Если НЕ ЗначениеНастроекВызовСервераПовтИсп.ЭтоРежимПодключениеТК() Тогда
		
		Если ЗначениеЗаполнено(Результат) Тогда
			ПолучитьДанныеПоАдресуДоставки(Результат);
		КонецЕсли;
	КонецЕсли;
	
	
КонецПроцедуры

&НаСервере
Процедура ПолучитьДанныеПоАдресуДоставки(ДанныеШК)
	
	Рез =  ИнтеграцияТК_ВызовСервера.ПолучитьДанныеОбщепит("GetTovarZakaza",Формат(ОбщепитДатаЗаказа,"ДФ=yyyyMMdd")+"|"+ДанныеШК);
	ТочкаДоставкиGLN =  ДанныеШК;
	Если Рез.Результат Тогда
		Документ = Рез.Ответ;
		ПользовательИнициализирован = Истина;
		
		
		Для Каждого СтрТовары Из Документ.Товары Цикл 
			нСтрокаТовары = Объект.Товары.Добавить();
			нСтрокаТовары.Артикул 			  = СтрТовары.Артикул;
			нСтрокаТовары.НаименованиеТовара  = СтрТовары.Товар;
			нСтрокаТовары.НаименованиеЕдиницы = СтрТовары.Единица;
			нСтрокаТовары.Коэффициент		  = 1;
			нСтрокаТовары.Количество 		  = СтрТовары.Количество;
			нСтрокаТовары.Весовой 			  = СтрТовары.Весовой;
			ОбновитьЗаписьПоСтроке(,нСтрокаТовары);
		КонецЦикла;
		Элементы.СообщениеИнициализацииПользователя.Заголовок = Документ.Магазин;

		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "СтраницаСведения,СтраницаСканирование,ГруппаОбщепит,ГруппаОстатокПродажи,ВыгрузитьДокумент,СтрокаТоварыДопустимоеКоличествоПриема,СтрокаТоварыКоличествоПоставщика", "Видимость", Ложь);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "Страницы,СтраницаВертикальная,СтраницаТовары,СтрокаПоискаТовары,ГруппаПодвал,ГруппаПодвалКнопки", "Видимость", Истина);

		
	Иначе
		 Сообщить(Рез.ОписаниеОшибки);
		
	КонецЕсли;
	
	
	
КонецПроцедуры

&НаСервере
Процедура ПолучитьДанныеПоРезерву(ДанныеШК)
	
	ПараметрыДокумента = Новый Структура;
	ПараметрыДокумента.Вставить("ВидДокумента", "REZ");
	ПараметрыДокумента.Вставить("ДокументUUID", ДанныеШК);
	НачалоКонтроля = ТекущаяДата();
	
	ДанныеОтвет = ИнтеграцияТК_ВызовСервера.ПолучитьДанныеДокумента(ПараметрыДокумента);
	Если ДанныеОтвет.Результат Тогда
		ДанныеДокумента = ДанныеОтвет.Ответ;
		ДокументUUID    = ДанныеШК;
		Склад           = ДанныеДокумента.Sklad;
		СкладUUID       = ДанныеДокумента.SkladUUID;
		 Элементы.СообщениеНеобходимоОтсканироватьДокумент.Заголовок = ДанныеДокумента.Заголовок;
		 Элементы.СообщениеНеобходимоОтсканироватьДокумент.ЦветТекста = WebЦвета.Зеленый;
		Для Каждого стрДок Из ДанныеДокумента.Tovary Цикл 
			нСтрокаТовары = Объект.Товары.Добавить();
			нСтрокаТовары.Артикул 			  = стрДок.Art;
			нСтрокаТовары.НаименованиеТовара  = стрДок.Tovar;
			нСтрокаТовары.НаименованиеЕдиницы = стрДок.EdIzm;
			нСтрокаТовары.Коэффициент		  = стрДок.Kof;
			нСтрокаТовары.Количество 		  = стрДок.Kol;
			нСтрокаТовары.КоличествоПоставщика = стрДок.Kol;
			нСтрокаТовары.МРЦ 		          = стрДок.МРЦ;
			нСтрокаТовары.ИспМРЦ 		      = стрДок.ИспМРЦ;
			нСтрокаТовары.КоличествоРасхождение = стрДок.Kol;
			нСтрокаТовары.Весовой 			  = стрДок.Ves;
			ОбновитьЗаписьПоСтроке(,нСтрокаТовары);
		КонецЦикла;
		
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "Страницы", "Видимость", Истина);
	
	Иначе
		Сообщить(ДанныеОтвет.ОписаниеОшибки);
	КонецЕсли;
	
	
КонецПроцедуры

&НаСервере
Процедура ПолучитьДанныеМаршрутныйЛист(ДанныеШК)
	
	ПараметрыДокумента = Новый Структура;
	ПараметрыДокумента.Вставить("ВидДокумента", "MAR");
	ПараметрыДокумента.Вставить("ДокументUUID", ДанныеШК);
	НачалоКонтроля = ТекущаяДата();
	
	ДанныеОтвет = ИнтеграцияТК_ВызовСервера.ПолучитьДанныеДокумента(ПараметрыДокумента);   
	БуферИД.Очистить();	

	Если ДанныеОтвет.Результат Тогда
		ДанныеДокумента = ДанныеОтвет.Ответ;
		ДокументUUID    = ДанныеШК;
		ЗаголовокДок = ДанныеДокумента.doc+Символы.ПС+ДанныеДокумента.avto+Символы.ПС+ДанныеДокумента.vod;
		Элементы.СообщениеНеобходимоОтсканироватьДокумент.Заголовок = ЗаголовокДок;
		Элементы.СообщениеНеобходимоОтсканироватьДокумент.ЦветТекста = WebЦвета.Зеленый;
		Для Каждого стрДок Из ДанныеДокумента.docsID Цикл 
			
			мСтрок = ОбщегоНазначенияКлиентСервер.РазложитьСтрокуВМассивПодстрок(стрДок.docid,"_");
			Если мСтрок.Количество() = 2 Тогда
				ИД = мСтрок[1];
			Иначе
				Продолжить;
			КонецЕсли;

			
			нСтрокаТовары = Объект.Товары.Добавить();
			нСтрокаТовары.ДокументИД = стрДок.docid;
			нСтрокаТовары.НаименованиеТовара =  стрДок.doc; 
			нСтрокаТовары.Получатель =  стрДок.adr;
			ОбновитьЗаписьПоСтроке(,нСтрокаТовары); 
			ИД_Док = стрДок.docid;		
			
			стБуфер = БуферИД.Добавить();
			стБуфер.ИД_Док = стрДок.docid;  
			стБуфер.ИД = ИД;
					
		КонецЦикла;
		
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "Страницы", "Видимость", Истина);
	
	Иначе
		Сообщить(ДанныеОтвет.ОписаниеОшибки);
	КонецЕсли;
	
	
КонецПроцедуры

&НаСервере
Процедура ИзменитьСтатусДокументаПеремещение(ДанныеШК)
	
	ПараметрыДокумента = Новый Структура;
	ПараметрыДокумента.Вставить("ДокументUUID", ДанныеШК);
	ПараметрыДокумента.Вставить("UUID_Сотрудник", ПараметрыСеанса.Сотрудник_ID);
   	стрСтатус = "Завантажений";
	Если ТипДокумента = Справочники.ТипыДокументов.БезакцептныйПрием Тогда
		ПараметрыДокумента.Вставить("ВидДокумента", "acprtt");	 
		стрСтатус = "Доставлено";
		ДанныеОтвет = ИнтеграцияТК_ВызовСервера.ПередатьДокументНаСервер(ПараметрыДокумента,ТипДокумента);   
	Иначе
		ПараметрыДокумента.Вставить("ВидДокумента", "logprvoz");
		//НачалоКонтроля = ТекущаяДата();
		ДанныеОтвет = ИнтеграцияТК_ВызовСервера.ПередатьДокументНаСервер(ПараметрыДокумента,Справочники.ТипыДокументов.ВозвратПеремещение);   
	КонецЕсли;

	Если ДанныеОтвет.Результат Тогда
		ДанныеДокумента = ДанныеОтвет.Ответ;
		нСтроки = Объект.Товары.НайтиСтроки(Новый Структура("ДокументИД",ДанныеШК));
		Если нСтроки.Количество()> 0 Тогда
			нСтрокаТовары = нСтроки[0];
		Иначе
			нСтрокаТовары = Объект.Товары.Добавить();
		КонецЕсли;
		нСтрокаТовары.НаименованиеТовара =  стрСтатус +" " + ДанныеДокумента.doc; 
		нСтрокаТовары.Получатель =  ДанныеДокумента.adr; 
		нСтрокаТовары.ДокументИД =  ДанныеШК;
        нСтрокаТовары.Пересчет =  Истина;

        ОбновитьЗаписьПоСтроке(,нСтрокаТовары); 
	Иначе
		Сообщить(ДанныеОтвет.ОписаниеОшибки);
	КонецЕсли;
	
	
КонецПроцедуры

&НаСервере
Процедура ПолучитьСписокПеремещенийВозвратТочки(ДанныеШК)  
	
	
	Объект.Товары.Очистить();
	ПараметрыДокумента = Новый Структура;
	ПараметрыДокумента.Вставить("ВидДокумента", "ttprvoz");
	ПараметрыДокумента.Вставить("НомерТочки", ДанныеШК);
	
	ДанныеОтвет = ИнтеграцияТК_ВызовСервера.ПередатьДокументНаСервер(ПараметрыДокумента,Справочники.ТипыДокументов.ВозвратПеремещение);   
	Если ДанныеОтвет.Результат Тогда
		Массивданных = ДанныеОтвет.Ответ; 
		Элементы.СообщениеВведитеНомерТТ.Заголовок = Строка(ДанныеШК) +"-"+Массивданных.ttotpr; 
		
		Для Каждого сДок Из  Массивданных.doc Цикл 
			нСтрокаТовары = Объект.Товары.Добавить();
			нСтрокаТовары.НаименованиеТовара =  "Зіб. "+ сДок.docDate+"/"+ сДок.doc; 
			нСтрокаТовары.Получатель = сДок.adr;
			нСтрокаТовары.ДокументИД = сДок.docUUID;
			ОбновитьЗаписьПоСтроке(,нСтрокаТовары); 
		КонецЦикла;
		
	Иначе
		Элементы.СообщениеВведитеНомерТТ.Заголовок  = "Введіть номер ТТ";
		Сообщить(ДанныеОтвет.ОписаниеОшибки);
		
	КонецЕсли;
	
КонецПроцедуры




