&НаКлиенте
Процедура ПечатьЦенников(Команда)
	
	Если ТоварыПереоценки.НайтиСтроки(Новый Структура("Вкл",Истина)).Количество() = 0 Тогда
		
		Сообщить("Не выбран товар для печати!");
		Возврат;
	КонецЕсли;
	
	
	ТекстВопроса = "Выполнить печать?";
	
	Оповещение = Новый ОписаниеОповещения("ПослеЗакрытияВопросаПечать", ЭтотОбъект);
	ПоказатьВопрос(Оповещение, ТекстВопроса, РежимДиалогаВопрос.ДаНет);

	
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗакрытияВопросаПечать(Результат,Параметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Нет Тогда
		Возврат;
	КонецЕсли;
	
	ДанныеДляПечати = ПечатьПереоценки();
	Если ДанныеДляПечати.Результат Тогда
		Если ТипЗнч(ДанныеДляПечати.Ответ) = Тип("Строка") Тогда
			Сообщить(ДанныеДляПечати.Ответ);
		ИначеЕсли ТипЗнч(ДанныеДляПечати.Ответ) = Тип("ДвоичныеДанные") Тогда
			
			ОбщегоНазначенияКлиент.ВывестиПДФ_НаПечать(ДанныеДляПечати.Ответ);
		КонецЕсли;
		Если НЕ ПустаяСтрока(ДанныеДляПечати.ОписаниеОшибки) Тогда
			Сообщить(ДанныеДляПечати.ОписаниеОшибки);
		КонецЕсли;
		
		ВыполняетсяЗакрытие = Истина;
		
		Закрыть(Новый Структура("ОбработатьСтрокиПоПереоценки,ДанныеПоПечати",Истина,ДанныеДляПечати.ДанныеПоПечати));
		
	Иначе
		Сообщить(ДанныеДляПечати.ОписаниеОшибки);
	КонецЕсли;
	
	
КонецПроцедуры


&НаКлиенте
Процедура ВыполнитьЗакрытиеПечати(Результат,Параметры) Экспорт 
	Если Результат = "ОК" Тогда
		ВыполняетсяЗакрытие = Истина;
		Закрыть(Новый Структура("ОбработатьСтрокиПоПереоценки,ДанныеПоПечати",Истина,Параметры.ДанныеПоПечати));
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ТоварыПередУдалением(Элемент, Отказ)
	
	Если ТипДокумента	= ПредопределенноеЗначение("Справочник.ТипыДокументов.Инвентаризация") 
		ИЛИ   ТипДокумента	= ПредопределенноеЗначение("Справочник.ТипыДокументов.ЛокальнаяИнвентаризация")
		ИЛИ ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеИН") 
		ИЛИ ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Контролер") Тогда
		Отказ = Истина;
		
	КонецЕсли;
	

КонецПроцедуры

&НаКлиенте
Процедура СотрудникПриход(Команда)


	сДаныеСотрудника =  Элементы.ТаблицаСотрудник.ТекущиеДанные;
	Если сДаныеСотрудника = Неопределено Тогда
		Сообщить("Сотрудник не выбран");
		Возврат;
	КонецЕсли;
	
	
	
	ДаныеСотрудника = Новый Структура("ДолжностьUUID,СотрудникUUID", сДаныеСотрудника.ДолжностьUUID ,сДаныеСотрудника.СотрудникUUID);
	Рез = ЗафиксироватьПриходНаСервере(ДаныеСотрудника,ТекущаяДата(),1);
	
	Если Рез.Результат Тогда
		ВыполняетсяЗакрытие = Истина;
		Закрыть();
	Иначе
		Сообщить("Не удалось записать время прихода!");
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СотрудникУход(Команда)
	сДаныеСотрудника =  Элементы.ТаблицаСотрудник.ТекущиеДанные;

	Если сДаныеСотрудника = Неопределено Тогда
		Сообщить("Сотрудник не выбран");
		Возврат;
	КонецЕсли;

	
	ДаныеСотрудника = Новый Структура("ДолжностьUUID,СотрудникUUID", сДаныеСотрудника.ДолжностьUUID ,сДаныеСотрудника.СотрудникUUID);
	Рез = ЗафиксироватьПриходНаСервере(ДаныеСотрудника,ТекущаяДата(),2);
	
	Если Рез.Результат Тогда
		ВыполняетсяЗакрытие = Истина;
		Закрыть();
	Иначе
		Сообщить("Не удалось записать время ухода!");
	КонецЕсли;

КонецПроцедуры

&НаСервере
Функция ЗафиксироватьПриходНаСервере(ДаныеСотрудника,Дата,ТипЗаписи)
	

	СтруктураДокумента = Новый Структура();
	СтруктураДокумента.Вставить("ДолжностьUUID",ДаныеСотрудника.ДолжностьUUID);
	СтруктураДокумента.Вставить("СотрудникUUID",ДаныеСотрудника.СотрудникUUID);
	СтруктураДокумента.Вставить("ДоументСервер",Ложь);
	СтруктураДокумента.Вставить("Дата",Дата);
	СтруктураДокумента.Вставить("ТипЗаписи",ТипЗаписи);
	Рез = ИнтеграцияТК_ВызовСервера.ПередатьДокументНаСервер(СтруктураДокумента,ТипДокумента);
	
	Возврат Рез;
	
	
КонецФункции

&НаКлиенте
Процедура Начисления(Команда)
	ОчиститьСообщения();
	сДаныеСотрудника =  Элементы.ТаблицаСотрудник.ТекущиеДанные;
	Если сДаныеСотрудника = Неопределено Тогда
		Сообщить("Співробітника не обрано");
		Возврат;
	КонецЕсли;

	
	
