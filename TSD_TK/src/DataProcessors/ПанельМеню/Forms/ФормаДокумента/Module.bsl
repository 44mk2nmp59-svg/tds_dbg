	    СтрокаВозврат = "НомерСтроки,ШтрихКод,Артикул,НаименованиеТовара,НаименованиеЕдиницы,Коэффициент,Количество,КоличествоПоставщика,ЭтоТара,ИспМРЦ,МРЦ,Весовой,ПриемДо";
	ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ИнвентаризацияТБД") Тогда
		СтрокаВозврат = "НомерСтроки,Артикул,НаименованиеТовара,НаименованиеЕдиницы,Коэффициент,Количество,Остаток,Продажи,ИспМРЦ,МРЦ,Весовой";
	ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеТНП") Тогда
		СтрокаВозврат = "НомерСтроки,Артикул,НаименованиеТовара,НаименованиеЕдиницы,Коэффициент,Количество,КоличествоВведено,Остаток,Продажи,ИспМРЦ,МРЦ";
	ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Контролер") Тогда
		СтрокаВозврат = "НомерСтроки,НаименованиеТовара,НаименованиеЕдиницы,Коэффициент,КоличествоВведено,КоличествоПоставщика,ИспМРЦ,МРЦ,Весовой";
	ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеИН") ИЛИ ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЛокальнаяИнвентаризация")  Тогда
		СтрокаВозврат = "НомерСтроки,Артикул,НаименованиеТовара,НаименованиеЕдиницы,Коэффициент,Количество,Остаток,Продажи,ИспМРЦ,МРЦ,Весовой";
	ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеТБД") 
		ИЛИ ТипДокумента=ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеВФ")Тогда
		СтрокаВозврат = "НомерСтроки,Артикул,НаименованиеТовара,СканированиеТовар,СканированиеЦенник,Остаток,АМ,ЦенаЦенник,Цена,ИспМРЦ,МРЦ,Весовой,Продажи";
 	ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Пересортица") Тогда
       	СтрокаВозврат = "НомерСтроки,Артикул,Артикул2,НаименованиеТовара,НаименованиеТовара2,Количество,КоличествоВведено,КоличествоПоставщика,ИспМРЦ,МРЦ,Весовой";

	Иначе
		СтрокаВозврат = "НомерСтроки,НаименованиеТовара,НаименованиеЕдиницы,Коэффициент,Количество,Весовой";
	КонецЕсли;
	
	Возврат СтрокаВозврат;
			
КонецФункции


