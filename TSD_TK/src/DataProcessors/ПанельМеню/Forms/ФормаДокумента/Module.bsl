	ПричинаПеремещения ="";
	ПричинаПеремещенияUUID="";
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ПричинаПеремещения", "Видимость", Ложь);

	
