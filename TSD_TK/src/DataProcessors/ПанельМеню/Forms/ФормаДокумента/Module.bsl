&НаСервере
Процедура ЗаполнитьДокумент(Отказ)
	
	//ВидДокумента = Параметры.ВидДокумента;
	ДокументUUID  = Параметры.ДокументUUID;
	ДокументСервер = Истина; 
	//ДатаДокумента = ТекущаяДата();
	
	НачалоКонтроля = ТекущаяДата();
	НачалоРаботыСдокументом = ТекущаяДата();
	
	ДанныеДокумента = ИнтеграцияТК_ВызовСервера.ПолучитьДанныеДокумента(Параметры);
	// 
	Если ДанныеДокумента.Результат Тогда
	//	
		Документ = ДанныеДокумента.Ответ; 
		
		Если Документ.Свойство("tochkamar")Тогда
			ТочкаМаршрута = Документ.tochkamar;	
		КонецЕсли;
		Если ТочкаМаршрута = 5 Тогда 
			Сообщить("Прийом переміщення доступне через - ""Прийом товарів"" - ""Безакцептне приймання РЦ""");
			Отказ = Истина;  
			Возврат;
		КонецЕсли;
		
		
		Если Документ.Свойство("SkladOn") Тогда
			СкладВидимость = Документ.SkladOn;
		КонецЕсли;
		
		Если Документ.Свойство("sumzak") Тогда
			МинимальнаяСумма = Документ.sumzak;
		КонецЕсли;

		Если Документ.Свойство("СкладСбоки") Тогда
			Элементы.ДекорацияСклад.Заголовок = Документ.СкладСбоки;
		КонецЕсли;
		Если Документ.Свойство("Причина") Тогда
			Элементы.ДекорацияПричина.Заголовок = Документ.Причина;
		КонецЕсли;
			
		
		Если ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ПриемПоЗаказу")
			ИЛИ ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ПриемПоПриходу")   Тогда
			
			ОснованиеUUID = Параметры.ДокументUUID;
			ДокументUUID          = "";
			
			Если Документ.Свойство("ВхДокНомер") Тогда
				ПоставщикаНомерНакладной = Документ.ВхДокНомер;
				ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ПоставщикаНомерНакладной", "Доступность", Ложь);
			КонецЕсли;
			
			Если Документ.Свойство("ПриходUUID") Тогда
				 ДокументUUID =  Документ.ПриходUUID;
			КонецЕсли;
			

			Если Документ.Свойство("ВхДокДата") Тогда
				ПоставщикаДатаДокумента = Дата(Документ.ВхДокДата);
				ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ПоставщикаДатаДокумента", "Доступность", Ложь);
			КонецЕсли;
			
			Если Документ.Свойство("PredNak") И Документ.PredNak Тогда   
				ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "СтрокаТоварыКоличествоПоставщика", "Доступность", Ложь);
			КонецЕсли;
			
			
			
			Для Каждого СтрТовары Из Документ.Tovary Цикл 
				нСтрокаТовары = Объект.Товары.Добавить();
				ЗаполнитьЗначенияСвойств(нСтрокаТовары,СтрТовары);   
				Если СтрТовары.Свойство("sht") Тогда 
					Если СтрТовары.Свойство("sht2")	И СтрТовары.sht2 <> 0 Тогда  
						нСтрокаТовары.ПриемДо = ТекущаяДата()+(СтрТовары.sht/100)*СтрТовары.sht2*86400;
					Иначе
						нСтрокаТовары.ПриемДо = ТекущаяДата()+(СтрТовары.sht/3*2)*86400;   
					КонецЕсли;
				КонецЕсли;
				
				ОбновитьЗаписьПоСтроке(,нСтрокаТовары);
			КонецЦикла; 
			
			ОбработатьДанныеВРаботе();
            ПолучитьВремяРаботыСДокументом();
		Иначе
			Если ТипыИнвентаризация() Тогда
				Если Документ.Свойство("СкладUUID") Тогда
					Документ.Свойство("СкладUUID",СкладUUID);
				КонецЕсли;
				Для Каждого СтрТовары Из Документ.Tovary Цикл 
					нСтрокаТовары = Объект.Товары.Добавить();
					нСтрокаТовары.Артикул 			  = СтрТовары.Art;
					нСтрокаТовары.НаименованиеТовара  = СтрТовары.Tovar;
					нСтрокаТовары.НаименованиеЕдиницы = СтрТовары.EdIzm;
					нСтрокаТовары.Коэффициент		  = СтрТовары.Kof;
					нСтрокаТовары.Количество 		  = 0;
					
					Если СтрТовары.Свойство("МРЦ") Тогда
						Если ЗначениеЗаполнено(СтрТовары.МРЦ) Тогда
							нСтрокаТовары.ИспМРЦ = Истина;
						КонецЕсли;
						нСтрокаТовары.МРЦ = СтрТовары.МРЦ;
					КонецЕсли;
					
					Если СтрТовары.Свойство("Весовой") Тогда
						нСтрокаТовары.Весовой  = СтрТовары.Весовой;
					КонецЕсли;


					Если СтрТовары.Свойство("Остаток") Тогда
						нСтрокаТовары.Остаток  = СтрТовары.Остаток;
					КонецЕсли;

					ОбновитьЗаписьПоСтроке(,нСтрокаТовары);
				КонецЦикла;
				Если ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ИнвентаризацияТБД") Тогда
					ДокументUUID          = "";
				КонецЕсли;
				
				
			Иначе
				Если Документ.Свойство("UUID_Склад") Тогда
					Документ.Свойство("UUID_Склад",СкладUUID);
				КонецЕсли;
				Если Документ.Свойство("UUID_СкладОтправитель") Тогда
					Документ.Свойство("UUID_СкладОтправитель",СкладОтправительUUID);
				КонецЕсли;
				
				
				Если Документ.Свойство("ОтправительРекламации") Тогда 
					ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ГруппаДокумент,ДекорацияСообщение","Видимость", Истина);

					ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ДекорацияСообщение", "Заголовок", Документ.ОтправительРекламации);
				КонецЕсли;

				
				Для Каждого СтрТовары Из Документ.Tovary Цикл 
					нСтрокаТовары = Объект.Товары.Добавить();
					нСтрокаТовары.Артикул 			  = СтрТовары.Art;
					нСтрокаТовары.НаименованиеТовара  = СтрТовары.Tovar;
					нСтрокаТовары.НаименованиеЕдиницы = СтрТовары.EdIzm;
					нСтрокаТовары.Коэффициент		  = ?(СтрТовары.Kof=0,1,СтрТовары.Kof);
					нСтрокаТовары.Количество 		  = СтрТовары.Kol;
					Если ТочкаМаршрута = 2 ИЛИ ТочкаМаршрута = 3 ИЛИ ТочкаМаршрута = 4 Тогда 
						нСтрокаТовары.КоличествоВведено 		  = СтрТовары.Kol;
					Иначе
						нСтрокаТовары.КоличествоРасхождение = СтрТовары.Kol; 
					КонецЕсли;

					Если СтрТовары.Свойство("МРЦ") Тогда
						Если ЗначениеЗаполнено(СтрТовары.МРЦ) Тогда
							нСтрокаТовары.ИспМРЦ = Истина;
						КонецЕсли;
						нСтрокаТовары.МРЦ = СтрТовары.МРЦ;
					КонецЕсли;
					Если СтрТовары.Свойство("Остаток") Тогда
						нСтрокаТовары.Остаток  = СтрТовары.Остаток;
					КонецЕсли;
					Если СтрТовары.Свойство("Весовой") Тогда
						нСтрокаТовары.Весовой  = СтрТовары.Весовой;
					КонецЕсли;
                   	Если СтрТовары.Свойство("cen") Тогда
						нСтрокаТовары.Цена  = СтрТовары.cen;
					КонецЕсли;

						
					
					//	нСтрокаТовары.Остаток 			  = СтрТовары.Kol;
					ОбновитьЗаписьПоСтроке(,нСтрокаТовары);
				КонецЦикла;
			КонецЕсли; 
			//Задания, возврат только несходняк  
			ЗагружатьДанныеВРаботе = Истина;
			Если Документ.Свойство("КраснаяКнопка") И  Документ.КраснаяКнопка Тогда
				ЗагружатьДанныеВРаботе = Ложь;
			КонецЕсли;
			
			Если ЗагружатьДанныеВРаботе  Тогда 
				ОбработатьДанныеВРаботе(); 
			КонецЕсли;
		КонецЕсли;
		
		Элементы.СтраницыПролистывания.ТекущаяСтраница = Элементы.СтраницаСканирование;

	Иначе
		Отказ = Истина;
		Если НЕ ПустаяСтрока(ДанныеДокумента.ОписаниеОшибки) Тогда
			Сообщить(ДанныеДокумента.ОписаниеОшибки);
		Иначе
			Сообщить("Ошибка получение данных с сервера");
		КонецЕсли;
	КонецЕсли;
	//
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДеревоУслуг(Отказ)

	
	ДанныеДокумента = ИнтеграцияТК_ВызовСервера.ПолучитьMarketDoc("ZAYVKA");
	Если  ДанныеДокумента.Результат = Ложь Тогда
		Отказ = Истина;
		Если НЕ ПустаяСтрока(ДанныеДокумента.ОписаниеОшибки) Тогда
			Сообщить(ДанныеДокумента.ОписаниеОшибки);
		КонецЕсли;
		Возврат;
	КонецЕсли;
	
	стрДереваГруппа  = Услуга.ПолучитьЭлементы();

	Для Каждого СтрГр Из ДанныеДокумента.Ответ Цикл
		
		грДерева = стрДереваГруппа.Добавить();
		грДерева.Наименование = СтрГр.Наименование;   
		грДерева.ЭтоГруппа = Истина;
		грДерева.Код = СтрГр.Код;

		стрДерева = грДерева.ПолучитьЭлементы();

		Для Каждого стрУсл ИЗ СтрГр.Услуги Цикл
			нстрДерева = стрДерева.Добавить();
			нстрДерева.Наименование = стрУсл.Наименование;
			нстрДерева.Код = стрУсл.Код;
		КонецЦикла;
		
	КонецЦикла;

КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПараметрыПроверкиСтандартов(Отказ)
	
	ДокументUUID  = Параметры.ДокументUUID;
	КонтрагентUUID  = Параметры.КонтрагентUUID;
	
КонецПроцедуры


&НаСервере
Процедура ОбработатьДанныеВРаботе()
	
	Если ТипДокумента = Справочники.ТипыДокументов.ЗаданиеТБД ИЛИ
		 ТипДокумента = Справочники.ТипыДокументов.ЗаданиеИН  ИЛИ
		 ТипДокумента = Справочники.ТипыДокументов.ЗаданиеТНП ИЛИ 
		 ТипДокумента = Справочники.ТипыДокументов.ПеремещениеТоваров ИЛИ
		 ТипДокумента = Справочники.ТипыДокументов.ЗаданиеВФ Тогда
		
		
		Если РегистрыСведений.ДанныеВРаботе.ЕстьДанныеВРаботе(ДокументUUID,ТипДокумента) Тогда
			 ВыбратьДанныеВРаботе();
		КонецЕсли;
		
	ИначеЕсли ТипДокумента = Справочники.ТипыДокументов.ПриемПоЗаказу Тогда
	  	Если РегистрыСведений.ДанныеВРаботе.ЕстьДанныеВРаботе(ОснованиеUUID,ТипДокумента) Тогда
			 ВыбратьДанныеВРаботе();
		КонецЕсли;

	Иначе
		Возврат;
	КонецЕсли;
	
	
КонецПроцедуры  

&НаСервере
Процедура ПолучитьВремяРаботыСДокументом()
	
	
	Если ТипДокумента = Справочники.ТипыДокументов.ПриемПоЗаказу ИЛИ ТипДокумента = Справочники.ТипыДокументов.ПриемПоПриходу Тогда
		
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ *
		|ИЗ
		|	РегистрСведений.ВремяРаботыСДокументом КАК ВремяРаботы
		|ГДЕ
		|	ВремяРаботы.ДокументUUID = &ДокументUUID
		|	И ВремяРаботы.ТипДокумента = &ТипДокумента";
		
		Если ТипДокумента = Справочники.ТипыДокументов.ПриемПоЗаказу Тогда
			Запрос.УстановитьПараметр("ДокументUUID", ОснованиеUUID);  
		Иначе
			Запрос.УстановитьПараметр("ДокументUUID", ДокументUUID);  
		КонецЕсли;
		Запрос.УстановитьПараметр("ТипДокумента", ТипДокумента);
		
		РезультатЗапроса = Запрос.Выполнить();
			
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		Если ВыборкаДетальныеЗаписи.Следующий() Тогда
			
			ДокументОткрытСекунд = ВыборкаДетальныеЗаписи.ДокументОткрытСекунд; 
			НачалоРаботыСдокументом = ВыборкаДетальныеЗаписи.НачалоРаботыСдокументом; 
			ОтсканированоТовар = ВыборкаДетальныеЗаписи.ОтсканированоТовар; 
			ВводВручнуюТовар = ВыборкаДетальныеЗаписи.ВводВручнуюТовар; 
 
		КонецЕсли;
		
	КонецЕсли;
	
	
КонецПроцедуры


&НаСервере
Процедура ВыбратьДанныеВРаботе() 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ *
		|ИЗ
		|	РегистрСведений.ДанныеВРаботе КАК ДанныеВРаботе
		|ГДЕ
		|	ДанныеВРаботе.ДокументUUID = &ДокументUUID
		|	И ДанныеВРаботе.ТипДокумента = &ТипДокумента";
	
	Если ТипДокумента = Справочники.ТипыДокументов.ПриемПоЗаказу Тогда
		Запрос.УстановитьПараметр("ДокументUUID", ОснованиеUUID);  
	Иначе
		Запрос.УстановитьПараметр("ДокументUUID", ДокументUUID);  
	КонецЕсли;
	Запрос.УстановитьПараметр("ТипДокумента", ТипДокумента);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		 мСтроки =  Объект.Товары.НайтиСтроки(Новый Структура("Артикул,МРЦ",ВыборкаДетальныеЗаписи.Артикул,ВыборкаДетальныеЗаписи.МРЦ));
		 
		 Если мСтроки.Количество()=0 Тогда
			 нСтрокаТовары = Объект.Товары.Добавить();
		 Иначе
			 нСтрокаТовары = мСтроки[0];
		 КонецЕсли;
		 
		   ЗаполнитьЗначенияСвойств(нСтрокаТовары,ВыборкаДетальныеЗаписи);
		   ОбновитьЗаписьПоСтроке(,нСтрокаТовары);

	 КонецЦикла;
	
	
КонецПроцедуры


