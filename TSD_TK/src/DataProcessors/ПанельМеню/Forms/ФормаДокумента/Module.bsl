&НаКлиенте
Функция ОбработатьШтрихКодПриходУход(ПолученныйШтрихкод,Параметры)
	Результат	= ИнтеграцияТК_Клиент.ПолучитьСотрудника(ПолученныйШтрихкод+"|zup|"+ВерунутьУИДПодразделения());
	
	Если Результат.Результат = ложь Тогда
		
		Если Не ПустаяСтрока(Результат.ОписаниеОшибки)Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Результат.ОписаниеОшибки);	
		КонецЕсли;
		
		Возврат Результат;
	КонецЕсли;
	
	
	ТаблицаСотрудник.Очистить();
	ДекорацияСтатусСотрудник = "";
	
	Если Результат.Ответ.Свойство("zup") Тогда
		Для Каждого  тzup Из Результат.Ответ.zup Цикл 
			НоваяСтрока = ТаблицаСотрудник.Добавить();
			НоваяСтрока.Сотрудник =  тzup.EmployeeNeme;
			НоваяСтрока.СотрудникUUID =  тzup.EmployeeUUID;
			НоваяСтрока.Должность =  тzup.Position;
			НоваяСтрока.ДолжностьUUID =  тzup.PositionUUID;
			
			
			ДекорацияСтатусСотрудник = НоваяСтрока.Сотрудник;
			
		КонецЦикла;	
	КонецЕсли;
	
	Если Результат.Ответ.Свойство("zupPrihod") Тогда
		
		zupPrihod =  Результат.Ответ.zupPrihod;
		Если zupPrihod.Количество()= 1 Тогда
			Status = zupPrihod[0].Status; 
			Time   = zupPrihod[0].Time; 
			Если Не Status = Неопределено Тогда
				ДекорацияСтатусСотрудник = ДекорацияСтатусСотрудник+Символы.ПС +?( Status = Истина,"Приход","Уход");
			КонецЕсли; 
			
			Если Не Time = Неопределено Тогда
				ДекорацияСтатусСотрудник = ДекорацияСтатусСотрудник +" "+ Time;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если Результат.Ответ.Свойство("КоличествоАнкет") Тогда
		Если Результат.Ответ.КоличествоАнкет > 0 Тогда
			Элементы.ДекорацияАнкетирование.Заголовок = "Информация по проверкам "+Формат(Результат.Ответ.КоличествоАнкет,"ЧЦ=2; ЧДЦ=0; ЧН=0");
			Элементы.ДекорацияАнкетирование.Видимость = Истина;
		Иначе 
			Элементы.ДекорацияАнкетирование.Видимость = Ложь;

		КонецЕсли;
	КонецЕсли;

	
	Элементы.ДекорацияСтатусСотрудник.Заголовок = ДекорацияСтатусСотрудник;
	
	Возврат Результат;
	
КонецФункции


&НаКлиенте
Процедура ОбработатьПолученныйШтрихкод(ПолученныйШтрихкод, Параметры) Экспорт
	Если ПустаяСтрока(ПолученныйШтрихкод) Тогда
		Возврат;
	КонецЕсли;
	
	Если ЗначениеНастроекВызовСервераПовтИсп.ЭтоРежимПодключениеТК() Тогда
		
		Если НЕ ПользовательИнициализирован Тогда
			
			Если ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ПриходУход")  Тогда
				Результат	= ОбработатьШтрихКодПриходУход(ПолученныйШтрихкод,Параметры);			
				
			Иначе	
				Результат	= ИнтеграцияТК_Клиент.ПолучитьСотрудника(ПолученныйШтрихкод);
			
			КонецЕсли;
			Если Результат.Результат Тогда
				Оповестить("ИзмененСотрудник");
			Иначе
				Сообщить("Необхідна авторизація користувача");
			КонецЕсли;
			
			Возврат;
		ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Рекламация") Тогда
			Возврат;
		ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ПриходУход")  Тогда
				ОбработатьШтрихКодПриходУход(ПолученныйШтрихкод,Параметры);	
				Возврат;
		ИначеЕсли ПустаяСтрока(ДокументUUID) И ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Контролер") Тогда
			
			ПолучитьДанныеПоРезерву(ПолученныйШтрихкод);
			Возврат;
		ИначеЕсли  ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.МаршрутныйЛист") Тогда
			Если ПустаяСтрока(ДокументUUID)  Тогда
				ПолучитьДанныеМаршрутныйЛист(ПолученныйШтрихкод);	
				Возврат; 
			КонецЕсли;
			
			ОбработатьСтрокуМарштрутныйЛист(ПолученныйШтрихкод);
			Возврат;
		ИначеЕсли  ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ВозвратПеремещение")Тогда
			Если Параметры.Свойство("ДокументыТочки") Тогда
				ПолучитьСписокПеремещенийВозвратТочки(ПолученныйШтрихкод);	
			Иначе
				ИзменитьСтатусДокументаПеремещение(ПолученныйШтрихкод);
			КонецЕсли;
			Возврат;
      	ИначеЕсли  ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.БезакцептныйПрием")Тогда
            ИзменитьСтатусДокументаПеремещение(ПолученныйШтрихкод);
            Возврат;
			
		КонецЕсли;
		
		
		
		ПараметрыТовара = "Остаток|ШтрихКод|ИспМРЦ";
		СкладЗапроса = "";
 		ЗапросНоменклатураВозрарт = ложь;
		//Если ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Инвентаризация") 
		//	ИЛИ  ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЛокальнаяИнвентаризация")
		//	ИЛИ  ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеИН")
		//	ИЛИ  ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ИнвентаризацияТБД")

		Если ТипыИнвентаризация() Тогда
			Если ПустаяСтрока(СкладUUID) Тогда
				Сообщить("Не выбран склад!");
				Возврат;
			КонецЕсли;
			
			ПараметрыТовара = ПараметрыТовара+"|Продажи|Коэффициент|АМ";
			СкладЗапроса = СкладUUID;
		ИначеЕсли  ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ПеремещениеТоваров")  Тогда
			
			Если ПустаяСтрока(СкладОтправительUUID) Тогда
				Сообщить("Не выбран склад!");
				Возврат;
			КонецЕсли;
			
			ПараметрыТовара = ПараметрыТовара+"|Продажи|Коэффициент";
			СкладЗапроса = СкладОтправительUUID;
			
		ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Списание2")Тогда
			Если ПустаяСтрока(СкладUUID) Тогда
				Сообщить("Не выбран склад!");
				Возврат;
			КонецЕсли;
			
			ПараметрыТовара = ПараметрыТовара+"|Коэффициент";
			СкладЗапроса = СкладUUID;
		ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ВозвратТоваров") Тогда
			Если ПустаяСтрока(СкладUUID) Тогда
				Сообщить("Не выбран склад!");
				Возврат;
			КонецЕсли;
			ПараметрыТовара = КонтрагентUUID;
			СкладЗапроса = СкладUUID;
			ЗапросНоменклатураВозрарт = Истина;
		ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ПриемПоЗаказу")  Тогда
			Если Элементы.СтраницаТовары.Видимость = Ложь Тогда
				Возврат;
			КонецЕсли;
			
			ОтсканированоТовар = ОтсканированоТовар + 1;
			ПараметрыТовара  = "ШтрихКод|Тара|ИспМРЦ";
		ИначеЕсли  ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ПриемПоПриходу") Тогда
			Если Элементы.СтраницаТовары.Видимость = Ложь Тогда
				Возврат;
			КонецЕсли;
			
			ОтсканированоТовар = ОтсканированоТовар + 1;

			ПараметрыТовара  = "ШтрихКод|Тара";
		ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Контролер") Тогда
			ПараметрыТовара  = "ШтрихКод|Тара|ИспМРЦ";
		ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеТБД") Тогда	
			ПараметрыТовара   = "ШтрихКод|TBD|Цена|Остаток|ИспМРЦ|Продажи";
			Если ЗначениеЗаполнено(СкладUUID) Тогда
				СкладЗапроса = СкладUUID;
			КонецЕсли;
			
		ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеТНП") Тогда	
			ПараметрыТовара   = "ШтрихКод|Остаток|ИспМРЦ|ТНП";
			СкладЗапроса = СкладОтправительUUID;
		ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеВФ") Тогда	
			ПараметрыТовара   = "ШтрихКод|TBD|АМ|Цена|Остаток";  
		ИначеЕсли  ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Пересортица") Тогда	
			ПараметрыТовара = ПараметрыТовара+"|Продажи|Пересорт";

		КонецЕсли;
		
		ДанныеПоТовару = ИнтеграцияТК_Клиент.ПолучитьДанныеПоТоваруКлиент(ПолученныйШтрихкод,,Ложь,ПараметрыТовара,СкладЗапроса,ЗапросНоменклатураВозрарт);
	Иначе
		
		Если НЕ ПользовательИнициализирован Тогда
			
			ПолучитьДанныеПоАдресуДоставки(ПолученныйШтрихкод);	
				
			Возврат;
		КонецЕсли;

		ДанныеПоТовару = ИнтеграцияТК_Клиент.ПолучитьданныеПоТоваруОбщепит(ПолученныйШтрихкод);
		
	КонецЕсли;

	ОбработатьПолученныеДанные(ДанныеПоТовару,Параметры);
	
КонецПроцедуры


&НаКлиенте
Процедура ОткрытьДиалогВводаМРЦ(СтруктураОтвета)
	
	
	Подсказка = НСтр("ru = '"+СтруктураОтвета.НаименованиеТовара+" МРЦ '");
	Подсказка = НСтр("ru = ' МРЦ '");
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ЗаголовокФормы", Подсказка);
	ПараметрыФормы.Вставить("ФорматРедактирования", "ЧЦ=15; ЧДЦ=2");
	ПараметрыФормы.Вставить("ЗапросМРЦ");
	ПараметрыФормы.Вставить("Артикул",СтруктураОтвета.Артикул);
	ПараметрыФормы.Вставить("НаименованиеТовара",СтруктураОтвета.НаименованиеТовара);
	
	Оповещение = Новый ОписаниеОповещения("ОповещениеВыбраноМРЦ", ЭтотОбъект,Новый Структура("Форма,СтруктураОтвета",ЭтаФорма,СтруктураОтвета));
	
	ОткрытьФорму("ОбщаяФорма.ВводЧисла", ПараметрыФормы,ЭтаФорма ,,,,Оповещение,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);

КонецПроцедуры

&НаКлиенте
Процедура ОповещениеВыбраноМРЦ(Результат, ДополнительныеПараметры) Экспорт
	
	СтрокаПоиска = "";
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма,"СтрокаПоиска","Вид",ВидПоляФормы.ПолеВвода);

	Если Результат = Неопределено ИЛИ Результат = 0 ИЛИ Результат = КодВозвратаДиалога.Отмена Тогда
		Возврат;
	КонецЕсли;  
	
	Если  ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ПеремещениеТоваров")
		ИЛИ ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеТНП") Тогда
		СкладUUIDОстатка = СкладОтправительUUID;
	Иначе
		СкладUUIDОстатка = СкладUUID;
	КонецЕсли;

	РезОтвет = ИнтеграцияТК_ВызовСервера.ПолучитьОстатокТовара(ДополнительныеПараметры.СтруктураОтвета.Артикул,Результат,СкладUUIDОстатка);
	
	Если РезОтвет.Результат Тогда
		ДополнительныеПараметры.СтруктураОтвета.Вставить("Остаток",РезОтвет.Ответ.Остаток);
		Если РезОтвет.Ответ.Свойство("Продажа") Тогда
			ДополнительныеПараметры.СтруктураОтвета.Вставить("Продажи",РезОтвет.Ответ.Продажа);
		КонецЕсли;

	КонецЕсли;
	ДополнительныеПараметры.СтруктураОтвета.Вставить("МРЦ",Результат);
	
		
	ОбработатьПолученныеДанныеВыбор(ДополнительныеПараметры.СтруктураОтвета,ДополнительныеПараметры,Строка(Результат));	
	
КонецПроцедуры

&НаКлиенте
Процедура ОповещениеВыбранКонтрагент(Результат,ДанныеТовара)Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	КонтрагентUUID =  Результат.UUID;
	Контрагент      =  Результат.Name;
	КонтрагентВыбран = Истина;
	Элементы.Контрагент.Заголовок = Контрагент;
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("Форма", ЭтаФорма);

	
	ОбработатьПолученныеДанныеВыбор(ДанныеТовара, ДополнительныеПараметры) 

	
КонецПроцедуры


&НаКлиенте
Процедура ЗвукОшибки(ВыполнитьОшибку = Ложь,ТекстОшибки ="")
	
	#Если МобильноеПриложениеКлиент Тогда
		
		СредстваМультимедиа.ВоспроизвестиЗвуковоеОповещение("errorscan",Истина);
		
	#КонецЕсли
	
	Если ВыполнитьОшибку Тогда
		
		 ВызватьИсключение ТекстОшибки;
	КонецЕсли;
	
	
КонецПроцедуры


&НаКлиенте
Процедура ОбработатьПолученныеДанныеВыбор(ДанныеТовара, ДополнительныеПараметры,МРЦ="") 
	
		
	
	Если ВводкКоличества Тогда
		
		Если ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ПриемПоЗаказу") 
			ИЛИ ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ПриемПоПриходу")
			ИЛИ ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Комплектация") 
			ИЛИ ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Контролер") Тогда
			
			ИД_Строка = ОпределитьСтроку(ДанныеТовара.Артикул,МРЦ);
			Если ИД_Строка = Неопределено Тогда
				
				ЗвукОшибки(Истина,"Товара нет в накладной!");
				
			КонецЕсли;
			
			Если ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Контролер") Тогда
				ОбработатьСрокуВыбор(ДанныеТовара);
			Иначе
				ОбработатьСтроку(ИД_Строка,ДанныеТовара);
				ПодсветитьСтроку(ИД_Строка);
			КонецЕсли;
			
		Иначе
			ОбработатьСрокуВыбор(ДанныеТовара);
			Если ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеТНП") Тогда
				ИД_Строка = ОпределитьСтроку(ДанныеТовара.Артикул,МРЦ);
				Если ИД_Строка = Неопределено Тогда
					
					ЗвукОшибки(Истина,"Товара нет в накладной!");
				Иначе
					ЗаписатьДанныевРаботе(ИД_Строка);
				КонецЕсли;

			КонецЕсли;
			
		КонецЕсли;
		
	Иначе
		
		ИД_Строка = ОпределитьСтроку(ДанныеТовара.Артикул,МРЦ);
		
		Если ИД_Строка = Неопределено Тогда
			
			ЗвукОшибки(Истина,"Товара нет в накладной!");
			Возврат;
		КонецЕсли;

		
		ОбработатьСтроку(ИД_Строка,ДанныеТовара);
		
		//Если ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЛокальнаяИнвентаризация")
		//	ИЛИ ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Контролер") 
		//	ИЛИ  ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеТБД") 
		//	ИЛИ  ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеВФ") Тогда
			ПодсветитьСтроку(ИД_Строка);
		//КонецЕсли;
	КонецЕсли;
	
	СтрокаПоиска ="";
КонецПроцедуры



&НаКлиенте
Процедура ОбработатьПолученныеДанные(ДанныеПоТовару, ДополнительныеПараметры) Экспорт
	
	Если ДанныеПоТовару.Результат = ложь Тогда
		Сообщить(?(ЗначениеЗаполнено(ДанныеПоТовару.ОписаниеОшибки), ДанныеПоТовару.ОписаниеОшибки,"Данные по штрих коду не получены"));
		Возврат;
	КонецЕсли;
	
	ДанныеТовара = ДанныеПоТовару.Ответ;
	
	Если ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ПеремещениеТоваров") 
		И ХозОперация = "ПеремещениеТоваровВФилиал" И СкладUUID = "b0855ae2-fd3e-11e3-8e10-0050568c0032" Тогда //РЦ Харьков
		МожемДобавлять = ДоступныеАртикулаНаВозвратРЦ(ДанныеТовара.Артикул);	
		Если Не МожемДобавлять Тогда
			Сообщить("Не можна додавати товар "+	ДанныеТовара.НаименованиеТовара);
			Возврат;
		КонецЕсли;  
	ИначеЕсли ТипыИнвентаризация() Тогда
		Если ДанныеТовара.АМ  = 0 И ДанныеТовара.Остаток = 0 Тогда
			Сообщить("Товар не в асортименті, перерахунок не можливий "+	Символы.ПС + ДанныеТовара.НаименованиеТовара); 
			Возврат;
	    КонецЕсли;
	КонецЕсли;
	
	
	Если ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ВозвратТоваров") И НЕ КонтрагентВыбран Тогда
		Если ДанныеТовара.Контрагент.UUID.Количество()= 1 Тогда
			КонтрагентUUID =  ДанныеТовара.Контрагент.UUID[0];
			Контрагент      =  ДанныеТовара.Контрагент.Name[0];
			КонтрагентВыбран = Истина;
			Элементы.Контрагент.Заголовок = Контрагент;
			ОбработатьПолученныеДанныеВыбор(ДанныеТовара, ДополнительныеПараметры) 
		Иначе
			ОповещениеКонтрагент = Новый ОписаниеОповещения("ОповещениеВыбранКонтрагент", ЭтотОбъект,ДанныеТовара);
			ОткрытьФорму("ОбщаяФорма.ФормаВыбораКонтрагента",ДанныеТовара.Контрагент,ЭтаФорма,,,,ОповещениеКонтрагент,РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
		КонецЕсли;
		
	ИначеЕсли ДанныеТовара.Свойство("ИспМРЦ")  И Булево(ДанныеТовара.ИспМРЦ) Тогда
		
		
		///Костыль
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма,"СтрокаПоиска","Вид",ВидПоляФормы.ПолеНадписи);
		
		ОткрытьДиалогВводаМРЦ(ДанныеТовара);
		
	Иначе
		ОбработатьПолученныеДанныеВыбор(ДанныеТовара, ДополнительныеПараметры) 
	КонецЕсли;
	
Конецпроцедуры


&НаСервере
Процедура ДобавитьСтроку()
	
	
	
	Если Количество > 0 ИЛИ  (ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЛокальнаяИнвентаризация") 
		ИЛИ ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Инвентаризация")
		ИЛИ ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ИнвентаризацияТБД")) Тогда
		
		ИдентификаторСтроки =	ОпределитьСтроку(Артикул,ТекМРЦ);
		
		ДанныеТовара = Новый Структура();
		ДанныеТовара.Вставить("Артикул",Артикул);
		ДанныеТовара.Вставить("НаименованиеТовара",НаименованиеТовара);
		ДанныеТовара.Вставить("НаименованиеЕдиницы",НаименованиеЕдиницы);
		ДанныеТовара.Вставить("ШтрихКод",ШтрихКод);
		ДанныеТовара.Вставить("Количество",Количество);
		ДанныеТовара.Вставить("Остаток",Остаток);
		ДанныеТовара.Вставить("Продажи",Продажи);
		ДанныеТовара.Вставить("Коэффициент",Коэффициент);
		ДанныеТовара.Вставить("ИспМРЦ",ТекИспМРЦ);
		ДанныеТовара.Вставить("МРЦ",ТекМРЦ);
		ДанныеТовара.Вставить("УсловиеВозврата",УсловиеВозврата);
		ДанныеТовара.Вставить("ДатаВозврата",ДатаВозврата);

	
		ОбработатьСтроку(ИдентификаторСтроки,ДанныеТовара);
		
	КонецЕсли;
	
	СтрокаНаименование = "";
	Артикул = "";
	НаименованиеТовара = "";
	НаименованиеЕдиницы = "";
	ШтрихКод = "";
	Количество = 0;
	Остаток =0;
	КоличествоВДокументе = 0;
	Продажи = 0;
	ТекМРЦ = "";
	ТекИспМРЦ=0;
	КоличествоПоставщика=0;
	ДатаВозврата = Неопределено;
	УсловиеВозврата = 0;

КонецПроцедуры


&НаСервере
Функция ОпределитьСтроку(Артикул,МРЦ="")
	
	Если ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ПриемПоПриходу") 
		ИЛИ  ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Zak") 
	   
		ИЛИ ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеТНП") 
		ИЛИ ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеВФ")	Тогда
		НайденныеСтроки = Объект.Товары.НайтиСтроки(Новый Структура("Артикул", Артикул));
		Если НайденныеСтроки.Количество() = 0 Тогда
			Возврат Неопределено;
			//ВызватьИсключение("Товара нет в накладной!");
		КонецЕсли;
		
	Иначе
		
		
		НайденныеСтроки = Объект.Товары.НайтиСтроки(Новый Структура("Артикул,МРЦ", Артикул,МРЦ));
		Если (ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Контролер") ИЛИ ХозОперация = "ПеремещениеТоваровИзФилиала"
			ИЛИ ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеТБД") ) И НайденныеСтроки.Количество() = 0 Тогда
			Возврат Неопределено;
		КонецЕсли;	

	КонецЕсли;                                                                     
	
	Если НайденныеСтроки.Количество() = 0 Тогда
		СтрокаТЧ = Объект.Товары.Добавить();
	Иначе
		СтрокаТЧ = НайденныеСтроки[0];
		
	КонецЕсли;
	
	Возврат СтрокаТЧ.ПолучитьИдентификатор();
	
КонецФункции


&НаСервере
Процедура ОбработатьСтроку(ИдентификаторСтроки,ДанныеТовара)

	
	ТекИдентификаторСтроки = ИдентификаторСтроки;
	
	СтрокаТовара = Объект.Товары.НайтиПоИдентификатору(ИдентификаторСтроки);

	
	Если ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Контролер") Тогда
		нКоличество =  СтрокаТовара.КоличествоВведено +Число(ДанныеТовара.Количество);
		Если нКоличество > СтрокаТовара.КоличествоПоставщика Тогда
			Сообщить("Отсканировано: "+Формат(нКоличество, "ЧЦ=15; ЧДЦ=3; ЧН=; ЧГ=")+Символы.ПС +" в Резерве: "+Формат(СтрокаТовара.КоличествоПоставщика, "ЧЦ=15; ЧДЦ=3; ЧН=; ЧГ="),СтатусСообщения.ОченьВажное);
		Иначе
			СтрокаТовара.КоличествоВведено = нКоличество;
			СтрокаТовара.Пересчет = Истина;
			СтрокаТовара.ПричинаРасхожденияПорядок = ?(СтрокаТовара.КоличествоВведено = СтрокаТовара.КоличествоПоставщика,"2","");
			СтрокаТовара.КоличествоРасхождение = СтрокаТовара.Количество -  нКоличество;
			ОбновитьЗаписьПоСтроке(,СтрокаТовара);
		КонецЕсли;
		Возврат;
	ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.МаршрутныйЛист") Тогда
		
		ЗаписьПоСтроке = СтрокаТовара.НаименованиеТовара;
		ЗаписьПоСтроке2 = СтрокаТовара.Получатель;
		Если ДанныеТовара.Свойство("Пересчет") Тогда
			СтрокаТовара.Пересчет = ДанныеТовара.Пересчет; 
		КонецЕсли;
		Возврат;
	ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Пересортица") Тогда
		ЗаполнитьЗначенияСвойств(СтрокаТовара,ДанныеТовара,"Артикул,ИспМРЦ,НаименованиеЕдиницы");
		СтрокаТовара.НаименованиеТовара = ДанныеТовара.НаименованиеТовара;
		СтрокаТовара.НаименованиеТовара2 = ДанныеТовара.Пересорт.НаименованиеТовара;
        СтрокаТовара.Весовой = ДанныеТовара.Весовой;
        СтрокаТовара.Артикул2 = ДанныеТовара.Пересорт.Артикул; 
		СтрокаТовара.Количество = СтрокаТовара.Количество+ДанныеТовара.Количество;	
		СтрокаТовара.КоличествоВведено = СтрокаТовара.КоличествоВведено+ДанныеТовара.Пересорт.Количество;
		СтрокаТовара.КоличествоПоставщика = ДанныеТовара.Пересорт.Количество;
