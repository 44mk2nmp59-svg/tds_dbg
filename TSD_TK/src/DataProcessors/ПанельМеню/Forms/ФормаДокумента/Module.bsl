			Если ПустаяСтрока(нстрТовары.СпецЦена) Тогда
				нстрТовары.СпецЦена = "Розница";
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат ТаблицаТоварыДляПечати.Количество();
	
КонецФункции

&НаКлиенте
Процедура ДекорацияПечатьЦенниковНажатие(Элемент)
	
	ВариантыПечати = ПечатьЦенникиКлиент.ПолучитьВариантыЦенников(ЭтаФорма);
	Если ВариантыПечати.Количество() = 0 Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Немає цінників для друку");
		Возврат;
	КонецЕсли;
	
	ОповещениеПечати = Новый ОписаниеОповещения("ВыборВариантаПечатии",ЭтотОбъект,Новый Структура);
	
	ПоказатьВыборИзМеню(ОповещениеПечати,ВариантыПечати);

КонецПроцедуры

&НаКлиенте
Процедура ВыборВариантаПечатии(ВариантыПечати,ПараметрыПечати) Экспорт
	
	
	Если ВариантыПечати = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Ответ = ПечатьНаСервере(ВариантыПечати.Значение);
	Если Ответ.Результат = Ложь Тогда
		Сообщить(Ответ.ОписаниеОшибки);
	Иначе
		Если ЗначениеНастроекВызовСервераПовтИсп.ИспользуетсяПечатьНаПринтер() Тогда	
			ОбщегоНазначенияКлиент.ВывестиПДФ_НаПечать(Ответ.Ответ);
		Иначе
			Сообщить("Отправлено на печать");
		КонецЕсли;
		
	КонецЕсли;
		

КонецПроцедуры


&НаСервере
Функция ПечатьНаСервере(ТипЦены)
	
	
	МассивТоваров = Новый Массив;
	нТовары = Новый Массив;

	Для Каждого СтрТовары Из ТаблицаТоварыДляПечати Цикл 
		Если СтрТовары.СпецЦена = ТипЦены  Тогда
			МассивТоваров.Добавить(Новый Структура("Артикул,МРЦ",СтрТовары.Артикул,""));
			нТовары.Добавить(СтрТовары);
		КонецЕсли;
	КонецЦикла;                       
	
	СтруктураДокумента = Новый Структура();
	СтруктураДокумента.Вставить("Товары",МассивТоваров);
	
	Если ЗначениеНастроекВызовСервераПовтИсп.ИспользуетсяПечатьНаПринтер() Тогда
	
		СтруктураДокумента.Вставить("ТипДокумента","ПечатьЦенниковТСД");
		Ответ =  ИнтеграцияТК_ВызовСервера.ЗапросПечатнаяФорма(СтруктураДокумента);

	Иначе
		
		СтруктураДокумента.Вставить("ТипДокумента","ПечатьЦенников");
		Ответ =  ИнтеграцияТК_ВызовСервера.ПередатьТоварыДляЦенников(СтруктураДокумента);
	КонецЕсли;
	
	Если Ответ.Результат Тогда
		Для Каждого СтрТовары Из нТовары Цикл 
			ТаблицаТоварыДляПечати.Удалить(СтрТовары);
		КонецЦикла;
		счЦен = ТаблицаТоварыДляПечати.Количество();
		Если счЦен = 0 Тогда
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ДекорацияПечатьЦенников", "Видимость",Ложь);
		Иначе
			Элементы.ДекорацияПечатьЦенников.Заголовок = "Друк цінників ("+Формат(счЦен,"ЧЦ=10; ЧН=0")+")";
		КонецЕсли;
	КонецЕсли;
	
	Возврат Ответ;
	
КонецФункции



