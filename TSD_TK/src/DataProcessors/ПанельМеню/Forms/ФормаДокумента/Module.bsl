&НаКлиенте
Процедура ПослеЗакрытияВопросаРекламация(Результат,Параметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Отмена Тогда
		Возврат; 
	КонецЕсли;
	
	Рез = ЗаписатьРекламацию(Параметры.Статус);
	Если Рез.Результат Тогда  
		Сообщить("Документ вивантажено успішно");
		ВыполняетсяЗакрытие = Истина;
		Если ДокументСервер Тогда
			Закрыть(Новый Структура("УдалитьСтроку"));
		Иначе
			Закрыть();
		КонецЕсли;
		
	Иначе
		Если ПустаяСтрока(Рез.ОписаниеОшибки) Тогда
			Сообщить("Помилка вивантаження документу!");
		Иначе
			Сообщить(Рез.ОписаниеОшибки);
		КонецЕсли;
		
	КонецЕсли;
	
	
КонецПроцедуры



&НаСервере
Функция ЗаписатьРекламацию(Статус)
	
	
	
	СтруктураДокумента = Новый Структура();                     
	СтруктураДокумента.Вставить("UUID_Документ",ДокументUUID);
	СтруктураДокумента.Вставить("UUID_Сотрудник", ПараметрыСеанса.Сотрудник_ID);
	СтруктураДокумента.Вставить("Статус",Статус);
	Возврат ИнтеграцияТК_ВызовСервера.ПередатьДокументНаСервер(СтруктураДокумента,ТипДокумента);
			
КонецФункции


