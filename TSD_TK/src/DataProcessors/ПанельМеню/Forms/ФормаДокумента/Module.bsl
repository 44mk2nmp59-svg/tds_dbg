		И ЗначениеНастроекВызовСервераПовтИсп.ЭтоРежимПодключениеТК()
		);
		
		Возврат;
	ИначеЕсли  ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Рекламация") И Инициализирован Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ГруппаРекламация", "Видимость",Истина);
