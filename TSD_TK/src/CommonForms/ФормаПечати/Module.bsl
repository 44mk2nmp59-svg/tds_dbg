
&НаСервере
Функция СформироватьОтчетРезультатыАнкет(ДанныеЗапроса)
	
	
	Отказ = Ложь;
	ПараметрыДокумента = Новый Структура;
	ПараметрыДокумента.Вставить("ВидДокумента", "Proverki");
	ПараметрыДокумента.Вставить("ДокументUUID", ДанныеЗапроса.СотрудникUUID);
	рез = ИнтеграцияТК_ВызовСервера.ПолучитьДанныеДокумента(ПараметрыДокумента);
	Если рез.Результат  Тогда
		
		ДанныеАнкетирования =  рез.Ответ;
		
		//	//ТекущаяПечатнаяФорма  = Новый ТабличныйДокумент;
		//	
		МакетОтчета = ПолучитьОбщийМакет("Анкетирование");
		Область = МакетОтчета.ПолучитьОбласть("Шапка");
		ТекущаяПечатнаяФорма.Вывести(Область);
		
		Для Каждого Анкета Из ДанныеАнкетирования Цикл 
			Область = МакетОтчета.ПолучитьОбласть("ттАнкета");
			Область.Параметры.Анкета = "Анкета №"+Анкета.Номер +" від "+ Формат(Дата(Анкета.Дата),"ДФ=yyyy-MM-dd");
			Область.Параметры.ТТ = Анкета.Респондент;
			ТекущаяПечатнаяФорма.Вывести(Область);
			
			Область = МакетОтчета.ПолучитьОбласть("Итого");
			Область.Параметры.Результат = Формат(Анкета.ПроцентВыполнения,"ЧЦ=3; ЧН=0")+"%";
			Область.Параметры.Сумма = Анкета.ИтогОценка;
			ТекущаяПечатнаяФорма.Вывести(Область);

			Строка = МакетОтчета.ПолучитьОбласть("Строка");
			СтрокаЦвет = МакетОтчета.ПолучитьОбласть("СтрокаЦвет");
			
			НомерСтроки = 1;
			
			
			Для Каждого стрВопрос Из  Анкета.Вопросы Цикл 
				
				Если НомерСтроки % 2 = 0 Тогда
					СтрокаМакета = СтрокаЦвет;
				Иначе
					СтрокаМакета = Строка;
				КонецЕсли;
				
				СтрокаМакета.Параметры.Статья = стрВопрос.Формулировка;
				СтрокаМакета.Параметры.Сумма  = стрВопрос.Оценка;
				ТекущаяПечатнаяФорма.Вывести(СтрокаМакета); 
				
				НомерСтроки = НомерСтроки + 1;
				
			КонецЦикла;
			
		КонецЦикла;
		
		//	
		ТекущаяПечатнаяФорма.Защита = Истина;
		//	
	Иначе
		Если ПустаяСтрока(рез.ОписаниеОшибки) Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Немає даних для показу!");
		Иначе
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(рез.ОписаниеОшибки);
		КонецЕсли;
		
		Отказ = Истина;
	КонецЕсли;
	
	
	Возврат Отказ;
	
	
КонецФункции



&НаСервере
Функция Сформироватьотчетначисления(ДанныеЗапроса)
	
	   Отказ = Ложь;
		ПараметрыДокумента = Новый Структура;
		ПараметрыДокумента.Вставить("ВидДокумента", "nchEmployee");
		ПараметрыДокумента.Вставить("ДокументUUID", ДанныеЗапроса.СотрудникUUID);
		рез = ИнтеграцияТК_ВызовСервера.ПолучитьДанныеДокумента(ПараметрыДокумента);
		Если рез.Результат И рез.Ответ.Количество()=1 Тогда
			
			ДанныеНачислений =  рез.Ответ[0];
			
			Если ДанныеНачислений.СуммаНачисления = 0 И ДанныеНачислений.СуммаУдержания = 0 Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Немає даних для показу!");
				Возврат Истина;
			КонецЕсли;
			
			//ТекущаяПечатнаяФорма  = Новый ТабличныйДокумент;
			
			МакетОтчета = ПолучитьОбщийМакет("Начисления");
			Область = МакетОтчета.ПолучитьОбласть("ЗаголовокНачисление");
			ТекущаяПечатнаяФорма.Вывести(Область);
			Область = МакетОтчета.ПолучитьОбласть("Шапка");
			ТекущаяПечатнаяФорма.Вывести(Область);
			
			
			Строка = МакетОтчета.ПолучитьОбласть("Строка");
			СтрокаЦвет = МакетОтчета.ПолучитьОбласть("СтрокаЦвет");
			
			НомерСтроки = 1;
			
			
			Для Каждого стрНач Из  ДанныеНачислений.ТаблицаНачислений Цикл 
				
				Если НомерСтроки % 2 = 0 Тогда
					СтрокаМакета = СтрокаЦвет;
				Иначе
					СтрокаМакета = Строка;
				КонецЕсли;
				
				СтрокаМакета.Параметры.Точка  = стрНач.Подразделение;
				СтрокаМакета.Параметры.Статья = стрНач.Статья;
				СтрокаМакета.Параметры.Сумма  = стрНач.Сумма;
				ТекущаяПечатнаяФорма.Вывести(СтрокаМакета); 

				НомерСтроки = НомерСтроки + 1;
				
			КонецЦикла;
			
			Область = МакетОтчета.ПолучитьОбласть("Итого");
			Область.Параметры.Сумма =   ДанныеНачислений.СуммаНачисления;
			ТекущаяПечатнаяФорма.Вывести(Область); 
			
			
			
			Область = МакетОтчета.ПолучитьОбласть("ЗаголовокУдержание");
			ТекущаяПечатнаяФорма.Вывести(Область);
			Область = МакетОтчета.ПолучитьОбласть("Шапка");
			ТекущаяПечатнаяФорма.Вывести(Область);

			НомерСтроки = 1;
			
			Для Каждого стрНач Из  ДанныеНачислений.ТаблицаУдержаний Цикл 
				
				Если НомерСтроки % 2 = 0 Тогда
					СтрокаМакета = СтрокаЦвет;
				Иначе
					СтрокаМакета = Строка;
				КонецЕсли;
				
				СтрокаМакета.Параметры.Точка  = стрНач.Подразделение;
				СтрокаМакета.Параметры.Статья = стрНач.Статья;
				СтрокаМакета.Параметры.Сумма  = стрНач.Сумма;
				ТекущаяПечатнаяФорма.Вывести(СтрокаМакета); 

				НомерСтроки = НомерСтроки + 1;
				
			КонецЦикла;
			
			Область = МакетОтчета.ПолучитьОбласть("Итого");
			Область.Параметры.Сумма =   ДанныеНачислений.СуммаУдержания;
			ТекущаяПечатнаяФорма.Вывести(Область); 
			
			
			Область = МакетОтчета.ПолучитьОбласть("Подвал");
			Область.Параметры.Сумма =   ДанныеНачислений.СуммаНачисления-ДанныеНачислений.СуммаУдержания;
			ТекущаяПечатнаяФорма.Вывести(Область); 
			
			ТекущаяПечатнаяФорма.Защита = Истина;
			
		Иначе
			Если ПустаяСтрока(рез.ОписаниеОшибки) Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Немає даних для показу!");
			Иначе
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(рез.ОписаниеОшибки);
			КонецЕсли;

			Отказ = Истина;
		КонецЕсли;
	
	
	  Возврат Отказ;
	
	
КонецФункции

&НаСервере
Функция СформироватьОтчетВыплаты(ДанныеЗапроса)
	
	Отказ = Ложь;
	ПараметрыДокумента = Новый Структура;
	ПараметрыДокумента.Вставить("ВидДокумента", "vypEmployee");
	ПараметрыДокумента.Вставить("ДокументUUID", ДанныеЗапроса.СотрудникUUID);
	рез = ИнтеграцияТК_ВызовСервера.ПолучитьДанныеДокумента(ПараметрыДокумента);
	Если рез.Результат И рез.Ответ.Количество()=1 Тогда
		
		ДанныеНачислений =  рез.Ответ[0];
		
		Если ДанныеНачислений.СуммаВыплат = 0 Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Немає даних для показу!");
			Возврат Истина;
		КонецЕсли;
		
		//ТекущаяПечатнаяФорма  = Новый ТабличныйДокумент;
		
		МакетОтчета = ПолучитьОбщийМакет("ЗП_К_Выдаче");
		Область = МакетОтчета.ПолучитьОбласть("ОбластьЗаголовок");
		ТекущаяПечатнаяФорма.Вывести(Область);
		Область = МакетОтчета.ПолучитьОбласть("ОбластьШапка");
		ТекущаяПечатнаяФорма.Вывести(Область);
		
		ОбластьСтрока = МакетОтчета.ПолучитьОбласть("ОбластьСтрока");
		ОбластьСтрокаЦвет = МакетОтчета.ПолучитьОбласть("ОбластьСтрокаЦвет");

		
		НомерСтроки = 1;

		
		Для Каждого стрНач Из  ДанныеНачислений.ТаблицаВыплат Цикл 
			
			Если НомерСтроки % 2 = 0 Тогда
				СтрокаМакета = ОбластьСтрокаЦвет;
			Иначе
				СтрокаМакета = ОбластьСтрока;
			КонецЕсли;
			
			

			СтрокаМакета.Параметры.ТТ = ДанныеНачислений.DRFO;	
			СтрокаМакета.Параметры.Реализатор = стрНач.Сотрудник;			
			СтрокаМакета.Параметры.КВыдаче = стрНач.Сумма;			

			ТекущаяПечатнаяФорма.Вывести(СтрокаМакета); 
			
			НомерСтроки = НомерСтроки + 1;
			
		КонецЦикла;
		
		Область = МакетОтчета.ПолучитьОбласть("ОбластьПодвал");
		Область.Параметры.СуммаИтого = ДанныеНачислений.СуммаВыплат;
		ТекущаяПечатнаяФорма.Вывести(Область); 

		ТекущаяПечатнаяФорма.Защита = Истина;
		
	Иначе
		Если ПустаяСтрока(рез.ОписаниеОшибки) Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Немає даних для показу!");
		Иначе
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(рез.ОписаниеОшибки);
		КонецЕсли;

		Отказ = Истина;
	КонецЕсли;
	
	
	Возврат Отказ;
	
	
КонецФункции

&НаСервере
Функция СформироватьОтчетИнвентаризацияРасхождение(ДанныеЗапроса)
	
	    Отказ = Ложь;
		МакетОтчета = ПолучитьОбщийМакет("РасхождениеИнвентаризация");
		Область = МакетОтчета.ПолучитьОбласть("Заголовок");
