		ТекущаяПечатнаяФорма.Вывести(Область);
		Область = МакетОтчета.ПолучитьОбласть("Шапка");
		ТекущаяПечатнаяФорма.Вывести(Область);
		
		
		Строка = МакетОтчета.ПолучитьОбласть("Строка");
		СтрокаЦвет = МакетОтчета.ПолучитьОбласть("Строка2");
		
		НомерСтроки = 1;
		
		
		Для Каждого стрТч Из  ДанныеЗапроса.Товары Цикл 
			
			Если НомерСтроки % 2 = 0 Тогда
				СтрокаМакета = СтрокаЦвет;
			Иначе
				СтрокаМакета = Строка;
			КонецЕсли;
			
			СтрокаМакета.Параметры.Товар  = стрТч.ТоварыЗаписьПоСтроке;
			СтрокаМакета.Параметры.Данные = стрТч.ТоварыЗаписьПоСтроке2;
			ТекущаяПечатнаяФорма.Вывести(СтрокаМакета); 
			
			НомерСтроки = НомерСтроки + 1;
			
		КонецЦикла;
		
		ТекущаяПечатнаяФорма.Защита = Истина;
		
		Возврат Отказ;
	
	
КонецФункции

