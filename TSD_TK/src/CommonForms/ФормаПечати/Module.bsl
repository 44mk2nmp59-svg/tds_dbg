&НаСервере
Функция СформироватьОтчетPKG()
	
	    Отказ = Ложь; 
		
	
		МакетОтчета = ПолучитьОбщийМакет("ДанныеPKG");
		Область = МакетОтчета.ПолучитьОбласть("Заголовок");
		Область.Параметры.Заголовок = Параметры.ТочкаДоставки;
		ТекущаяПечатнаяФорма.Вывести(Область);
		Область = МакетОтчета.ПолучитьОбласть("Шапка");
		ТекущаяПечатнаяФорма.Вывести(Область);
		
		
		Строка = МакетОтчета.ПолучитьОбласть("Строка");
		СтрокаЦвет = МакетОтчета.ПолучитьОбласть("Строка2");
		
		НомерСтроки = 1;
		//
		
		Для Каждого стрТч Из  Параметры.ДанныеPKG Цикл 
			
			Если НомерСтроки % 2 = 0 Тогда
				СтрокаМакета = СтрокаЦвет;
			Иначе
				СтрокаМакета = Строка;
			КонецЕсли;
			
			СтрокаМакета.Параметры.СкладСборки  = стрТч.СкладСборки;
			СтрокаМакета.Параметры.сч_скан = стрТч.сч_скан; 
			СтрокаМакета.Параметры.НомерТУ = стрТч.НомерТУ;

			ТекущаяПечатнаяФорма.Вывести(СтрокаМакета); 
			
			НомерСтроки = НомерСтроки + 1;
			
		КонецЦикла;
		
		ТекущаяПечатнаяФорма.Защита = Истина;
		
		Возврат Отказ;
КонецФункции


&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ТекущаяПечатнаяФорма.Очистить();
	ФормаПечатьПДФ = Ложь;
	Если Параметры.Свойство("ПечатьПДФ") Тогда
		ФормаПечатьПДФ = Истина;
	КонецЕсли;
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ГруппаПечтьТабДок", "Видимость", НЕ ФормаПечатьПДФ);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ГруппаПечатьПДФ", "Видимость", ФормаПечатьПДФ);
	
	
	
	Если Параметры.Свойство("СформироватьОтчетНачисления") Тогда
