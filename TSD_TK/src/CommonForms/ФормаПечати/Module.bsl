&НаСервере
Процедура ЗаполнитьHTML(ДвоичныеДанныеPDF)
	
	СтрокаBase64 = Base64Строка(ДвоичныеДанныеPDF);
	
	// Формируем HTML-контейнер
	ТекстHTML = "
	
	|<html>
	|<body style='margin:0; padding:0; overflow:hidden;'>
	|   <embed src='data:application/pdf;base64," + СтрокаBase64 + "' 
	
	|          type='application/pdf' 
	|          width='100%' 
	|          height='100%' />
	
	|</body>
	|</html>";
	
	// Присваиваем реквизиту, который связан с Полем HTML-документа
	ПутьФайлHTML = ТекстHTML; 
КонецПроцедуры

&НаКлиенте
Процедура Печать(Команда)
	
	ТекущаяПечатнаяФорма.Напечатать(РежимИспользованияДиалогаПечати.Использовать);	
	Закрыть("ОК");
КонецПроцедуры
