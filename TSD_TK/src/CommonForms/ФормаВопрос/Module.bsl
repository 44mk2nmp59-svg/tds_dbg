 &НаКлиенте
Перем ВыполняетсяЗакрытие;
	
 
&НаСервере 
Процедура СоздатьТаблицуПричинНаСервере()  

	ТаблицаПричины.Очистить();	
	НачСтрока = 5;
	Для сч = 1 По СтрокТовара Цикл   
		
		чт  =Формат(НачСтрока,"ЧЦ=10; ЧГ=");
		облстрТов =   ТекущаяПечатнаяФорма.Область("R"+чт+"C2:R"+чт+"C4");
		мстрока = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(облстрТов.Текст," ");

		чт  =Формат(НачСтрока+2,"ЧЦ=10; ЧГ=");
		облстрПричина =   ТекущаяПечатнаяФорма.Область("R"+чт+"C2:R"+чт+"C4");
		НачСтрока = НачСтрока +	3;

		Если облстрПричина.Значение = Справочники.ПричиныВозврата.УкажитеПричину Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не вибрано причину"+Символы.ПС+ облстрТов.Текст);

			Продолжить;
		КонецЕсли;
		нстртз = ТаблицаПричины.Добавить();
		Если ПарамВопрос = "ПриемPKG" Тогда 
			нстртз.СтрокаИД = мстрока[0];
			нстртз.Артикул = мстрока[1];
		Иначе
			нстртз.Артикул = мстрока[0];     
		КонецЕсли;
		нстртз.Причина = облстрПричина.Значение;
		
	КонецЦикла; 
	
КонецПроцедуры
 
  
&НаКлиенте
Процедура Создать(Команда)
	
	СоздатьТаблицуПричинНаСервере();
	Если ТаблицаПричины.Количество() <> СтрокТовара Тогда 
		Возврат;
	КонецЕсли;
	ВыполняетсяЗакрытие = Истина;      
		
		
	 Закрыть(Новый Структура("СоздатьАКТ,ТабицаПричин",Истина,ТаблицаПричины));

КонецПроцедуры

