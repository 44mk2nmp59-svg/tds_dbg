&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ТекущаяПечатнаяФорма.Очистить();
	Если Параметры.Свойство("ПарамФормы") И Параметры.ПарамФормы = "ТекстВопроса" Тогда
		ЗаполнитьТекстВопроса(Параметры.Вопрос); 
	ИначеЕсли Параметры.Свойство("ПарамВопрос") И Параметры.ПарамВопрос = "ПриемPKG" Тогда
		ПарамВопрос = "ПриемPKG"; 
		ТаблицаРасхождений = Параметры.ТаблицаРасхождений;
		ЗаполнитьПечФорму(ТаблицаРасхождений); 
	
	Иначе
		ТаблицаРасхождений = Параметры.ТаблицаРасхождений;
		ЗаполнитьПечФорму(ТаблицаРасхождений); 
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТекстВопроса(тВопрос)

    ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ГруппаКнопки", "Видимость", Ложь);  

	Макет = ПолучитьОбщийМакет("МакетВопрос");
	Область = Макет.ПолучитьОбласть("ОбластьВопрос");
	Область.Параметры.тВопрос = тВопрос;	
	
	ТекущаяПечатнаяФорма.Вывести(Область); 
	
	ТекущаяПечатнаяФорма.Защита = Истина;

КонецПроцедуры

&НаСервере
Функция ЗаполнитьПечФорму(ТаблицаРасхождений)
	
	    ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ГруппаКнопкиВопрос", "Видимость", Ложь);  

		//ТекущаяПечатнаяФорма  = Новый ТабличныйДокумент;
		
		Макет = ПолучитьОбщийМакет("ЗапросСформироватьАКТ");
		Область = Макет.ПолучитьОбласть("Заголовок");
		ТекущаяПечатнаяФорма.Вывести(Область);
		Область = Макет.ПолучитьОбласть("Шапка");
		ТекущаяПечатнаяФорма.Вывести(Область);
		
		ОбластьСтрока = Макет.ПолучитьОбласть("Строка");
		ОбластьСтрокаЦвет = Макет.ПолучитьОбласть("СтрокаЦвет");
		
		
		НомерСтроки = 1;
		
		
		Для Каждого стр Из  ТаблицаРасхождений Цикл 
			
			Если НомерСтроки % 2 = 0 Тогда
				СтрокаМакета = ОбластьСтрокаЦвет;
			Иначе
				СтрокаМакета = ОбластьСтрока;
			КонецЕсли;
			
			СтрокаМакета.Параметры.Товар = ?(ПарамВопрос= "ПриемPKG",Формат(стр.СтрокаИД,"ЧЦ=3; ЧН=0; ЧГ=")+" "+стр.СтрокаТовара,стр.СтрокаТовара);	
			СтрокаМакета.Параметры.Количество = стр.Количество;			
			//ст = СтрокаМакета.Область("R3C4");
			//ст.СодержитЗначение = Истина;
			СтрокаМакета.Параметры.Причина  = Справочники.ПричиныВозврата.УкажитеПричину;
			ТекущаяПечатнаяФорма.Вывести(СтрокаМакета); 
			
			НомерСтроки = НомерСтроки + 1;
			
		КонецЦикла;
		СтрокТовара = НомерСтроки-1;	
		ТекущаяПечатнаяФорма.Защита = Истина;
		
	
КонецФункции


&НаКлиенте
Процедура ПриОткрытии(Отказ)
	ВыполняетсяЗакрытие = Ложь;
КонецПроцедуры


&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	Если НЕ ВыполняетсяЗакрытие Тогда
		Отказ = Истина;
	КонецЕсли;
КонецПроцедуры


&НаКлиенте
Процедура ТекущаяПечатнаяФормаВыбор(Элемент, Область, СтандартнаяОбработка) 
	СтандартнаяОбработка = Ложь;
	ТекОбласть = ТекущаяПечатнаяФорма.ТекущаяОбласть;	
	Попытка 
		Если ТекОбласть.Значение = Неопределено Тогда
			Возврат;
		КонецЕсли;
	Исключение 
		Возврат
	КонецПопытки;
	
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("тОбласть", ТекОбласть.Имя);
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ОповещениеВыбранПричина", ЭтотОбъект, ДополнительныеПараметры);
   ОткрытьФорму("Справочник.ПричиныВозврата.Форма.ФормаВыбора",,,,,,ОписаниеОповещения);

  // ОткрытьФорму("Справочник.ПричиныВозврата.Форма.ФормаВыбора",,ЭтаФорма,,,,ДополнительныеПараметры,ОписаниеОповещения);
	
КонецПроцедуры

 
&НаКлиенте
Процедура ОповещениеВыбранПричина(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено  Тогда
		Возврат;
	КонецЕсли;   
	
	Область = ТекущаяПечатнаяФорма.Область(ДополнительныеПараметры.тОбласть);	
	Область.Значение =Результат;

КонецПроцедуры

