&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	//Сообщить(ИмяСобытия);

    Если ИмяСобытия = "ИзмененыЗначенияНастроек" Тогда

        НастроитьФормуПоЗначениямНастроек();
		
//	ИначеЕсли ПодключаемоеОборудованиеКлиент.ЭтоОповещениеСканераШтрихкода(ИмяСобытия) И ВводДоступен() Тогда

    ИначеЕсли ИмяСобытия = "KeyPress" И ВводДоступен() Тогда
        нПарам =  НРег(Параметр);

        Если нПарам = "enter" И ПозицияВвода = 1 Тогда
            Если Не ЕстьНомерСтрокиДок Тогда
                Готово(Неопределено);
            Иначе
                ПозицияВвода = 2;
            КонецЕсли;
            Возврат;

        КонецЕсли;

        Если нПарам = "enter" И ПозицияВвода = 2 Тогда

            Готово(Неопределено);
            Возврат;
        КонецЕсли;
        Если нПарам = "scan:11" Тогда
            нПарам = "0";
        КонецЕсли;
		
		//Сообщить("Позиция "+ПозицияВвода);
        Если ПозицияВвода = 2 Тогда

            тЧислоСтрокой = Формат(Количество, "ЧЦ=10; ЧГ=");
            Если нПарам = "bksp" Тогда
                н = СтрДлина(тЧислоСтрокой);
                Если н = 0 Или н = 1 Тогда
                    Количество = 0;
                Иначе
                    нч =   Лев(тЧислоСтрокой, н - 1);
                    Количество = Число(нч);
                КонецЕсли;
            Иначе
                Попытка
                    Количество = Число(тЧислоСтрокой + Строка(нПарам));
                Исключение
                КонецПопытки;
            КонецЕсли;
			//Сообщить("Позиция 2 ,парам "+нПарам);
        ИначеЕсли ПозицияВвода = 1 Тогда
            тЧислоСтрокой = Формат(НомерСтрокиДокумента, "ЧЦ=10; ЧГ=");
            Если нПарам = "bksp" Тогда
                н = СтрДлина(тЧислоСтрокой);
                Если н = 0 Или н = 1 Тогда
                    НомерСтрокиДокумента = 0;
                Иначе
                    нч =   Лев(тЧислоСтрокой, н - 1);
                    НомерСтрокиДокумента = Число(нч);
                КонецЕсли;
            Иначе
                Попытка
                    НомерСтрокиДокумента = Число(тЧислоСтрокой + Строка(нПарам));
                Исключение
                КонецПопытки;
            КонецЕсли;
			//Сообщить("Позиция 1 ,парам "+нПарам);

        КонецЕсли;

    КонецЕсли;

КонецПроцедуры

#КонецОбласти

