&НаСервере
Процедура ЗаполнитьРеквизитыФормы()

    ТипДокумента        = Параметры.ТипДокумента;
    ИдентификаторСтроки = Параметры.ИдентификаторСтроки;
    Если Параметры.Свойство("НомерСтроки") Тогда
        НомерСтроки = Параметры.НомерСтроки;
    КонецЕсли;

    Если Параметры.Свойство("ИспМРЦ") Тогда
        ИспМРЦ = Параметры.ИспМРЦ;
    КонецЕсли;
    Если Параметры.Свойство("ХозОперация") Тогда
        ХозОперация = Параметры.ХозОперация;
    КонецЕсли;
    Если Параметры.Свойство("НаименованиеТовара") Тогда
        Если Параметры.Свойство("НаименованиеЕдиницы") Тогда
            НаименованиеТовара = Параметры.НаименованиеТовара + " " + Параметры.НаименованиеЕдиницы + " " + ?(ИспМРЦ,
                " МРЦ - " + Параметры.МРЦ, "");
        Иначе
            НаименованиеТовара = Параметры.НаименованиеТовара + ?(ИспМРЦ, " МРЦ - " + Параметры.МРЦ, "");
        КонецЕсли;
    КонецЕсли;
	
	//Если Параметры.Свойство("НаименованиеЕдиницы") Тогда
	//	НаименованиеЕдиницы = Параметры.НаименованиеЕдиницы;
	//КонецЕсли;

    Если Параметры.Свойство("Количество") Тогда
        Количество = Параметры.Количество;
    КонецЕсли;
    Если Параметры.Свойство("Весовой") Тогда
        Весовой = Параметры.Весовой;
    КонецЕсли;
    Если Параметры.Свойство("ПриемДо") Тогда
        ПриемДо = Параметры.ПриемДо;
    КонецЕсли;
    Если ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Пересортица") Тогда
        КоличествоВведено = Параметры.КоличествоВведено;
        НаименованиеТовара2 = Параметры.НаименованиеТовара2;
        КофПересорт = Параметры.КоличествоПоставщика;

    Иначе
        Если Параметры.Свойство("КоличествоВведено") Тогда
            Количество = Параметры.КоличествоВведено;
        КонецЕсли;
    КонецЕсли;
    Коэффициент = 1;
    Если Параметры.Свойство("Коэффициент") Тогда
        Коэффициент = Параметры.Коэффициент;
        Если ТипЗнч(Коэффициент) = Тип("Число") Тогда
            Коэффициент =?(Коэффициент = 0, 1, Коэффициент);
        Иначе
            Коэффициент = 1;
        КонецЕсли;
        Количество = Количество / Коэффициент;
    КонецЕсли;
    Если Параметры.Свойство("КоличествоПоставщика") Тогда
        КоличествоОжидаемое  = Параметры.КоличествоПоставщика / Коэффициент;
    КонецЕсли;

    Если Параметры.Свойство("Остаток") Тогда
        Остаток = Параметры.Остаток;
    КонецЕсли;

    Если Параметры.Свойство("Продажи") Тогда
        Продажи = Параметры.Продажи;
    КонецЕсли;

    Если Параметры.Свойство("СканированиеТовар") Тогда
        СканированиеТовар = Параметры.СканированиеТовар;
    КонецЕсли;
    Если Параметры.Свойство("СканированиеЦенник") Тогда
        СканированиеЦенник = Параметры.СканированиеЦенник;
    КонецЕсли;

    Если ТипДокумента = Справочники.ТипыДокументов.ЗаданиеИН Или ТипДокумента = Справочники.ТипыДокументов.Инвентаризация
        Или ТипДокумента = Справочники.ТипыДокументов.ЛокальнаяИнвентаризация Или ТипДокумента
        = Справочники.ТипыДокументов.ЗаданиеТБД Тогда
        зМРЦ = ?(ЗначениеЗаполнено(Параметры.МРЦ), Параметры.МРЦ, 0);
        РезОтвет = ИнтеграцияТК_ВызовСервера.ПолучитьОстатокТовара(Параметры.Артикул, зМРЦ, Параметры.СкладUUID);
        Если РезОтвет.Результат Тогда
            Остаток = РезОтвет.Ответ.Остаток;
            Продажи = РезОтвет.Ответ.Продажа;
        КонецЕсли;
    КонецЕсли;
КонецПроцедуры
#КонецОбласти

