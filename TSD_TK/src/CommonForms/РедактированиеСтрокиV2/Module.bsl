&НаКлиенте
Функция пЗакрытия()
    СтруктураВозврат = Новый Структура;
    СтруктураВозврат.Вставить("Сохранить");
    СтруктураВозврат.Вставить("Пересчет", Истина);

    СтруктураВозврат.Вставить("НомерСтрокиДокумента", НомерСтрокиДокумента);

    Если ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Контролер") Тогда
        СтруктураВозврат.Вставить("КоличествоВведено", Количество);
        СтруктураВозврат.Вставить("ПричинаРасхожденияПорядок", ?(КоличествоОжидаемое = Количество, "2", ""));
        СтруктураВозврат.Вставить("КоличествоРасхождение", КоличествоОжидаемое - Количество);
    ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеВФ") Тогда

        СтруктураВозврат = Новый Структура;
    ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеТБД") Тогда
        СтруктураВозврат.Вставить("СканированиеТовар", СканированиеТовар);
        СтруктураВозврат.Вставить("Остаток", Остаток);
        СтруктураВозврат.Вставить("Продажи", Продажи);
    ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ПриемPKG") Тогда

        СтруктураВозврат.Вставить("КоличествоВведено", Количество);
        СтруктураВозврат.Вставить("КоличествоРасхождение", КоличествоОжидаемое - Количество);

    Иначе
        КоличествоБаз = Количество * Коэффициент;
        СтруктураВозврат.Вставить("Количество", КоличествоБаз);

        Если ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ИнвентаризацияТБД") Или ТипДокумента
            = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеТНП") Тогда
            СтруктураВозврат.Вставить("КоличествоВведено", Количество);
        КонецЕсли;
        Если ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеИН") Или ТипДокумента
            = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЛокальнаяИнвентаризация") Тогда
            СтруктураВозврат.Вставить("Остаток", Остаток);
            СтруктураВозврат.Вставить("Продажи", Продажи);
            СтруктураВозврат.Вставить("КоличествоВведено", КоличествоБаз);
        КонецЕсли;
    КонецЕсли;
    Возврат СтруктураВозврат;
КонецФункции
&НаКлиенте
Процедура ОбработкаАктивизации(АктивныйОбъект, Источник)
КонецПроцедуры

&НаКлиенте
Процедура НомерСтрокиДокументаПриИзменении(Элемент)
    Попытка
        НомерСтрокиДокумента = Формат(Число(НомерСтрокиДокумента), "ЧЦ=10");
    Исключение
        Количество = 0;
    КонецПопытки;
    ЭтаФорма.ТекущийЭлемент = Элементы.Количество;
#Если МобильноеПриложениеКлиент Тогда
    НачатьРедактированиеЭлемента();
#КонецЕсли

КонецПроцедуры

&НаКлиенте
Процедура ПровертьЗакрытиеФормы()

    Если ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Контролер") Тогда
        Если Количество > КоличествоОжидаемое Тогда
            Сообщить("Введено: " + Формат(Количество, "ЧЦ=15; ЧДЦ=3; ЧН=; ЧГ=") + Символы.ПС + " в Резерве: " + Формат(
                КоличествоОжидаемое, "ЧЦ=15; ЧДЦ=3; ЧН=; ЧГ="), СтатусСообщения.ОченьВажное);

            Возврат;
        КонецЕсли;
    ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ПриемPKG") Тогда
        Если Количество > КоличествоОжидаемое Тогда
            Сообщить("Можна прийняти: " + Формат(КоличествоОжидаемое, "ЧЦ=15; ЧДЦ=3; ЧН=; ЧГ=") + Символы.ПС
                + " введено " + Формат(Количество, "ЧЦ=15; ЧДЦ=3; ЧН=; ЧГ="), СтатусСообщения.ОченьВажное);

            Возврат;
        КонецЕсли;
    КонецЕсли;

    ПараметрыЗакрытия = пЗакрытия();

    Закрыть(ПараметрыЗакрытия);

КонецПроцедуры
&НаКлиенте
Процедура КоличествоПриИзменении(Элемент)
    Попытка
        Количество = Формат(Число(Количество), "ЧЦ=15; ЧДЦ=3");
        ЭтаФорма.ТекущийЭлемент  = Элементы.Готово;

    Исключение
        Количество = 0;
    КонецПопытки;
    ПодключитьОбработчикОжидания("ПровертьЗакрытиеФормы", 0.01, Истина);

КонецПроцедуры

&НаКлиенте
Процедура СканированиеТоварПриИзменении(Элемент)

    Попытка
        Количество = Формат(Число(СканированиеТовар), "ЧЦ=15; ЧДЦ=3");
        ЭтаФорма.ТекущийЭлемент  = Элементы.Готово;

    Исключение
        Количество = 0;
    КонецПопытки;

    ПодключитьОбработчикОжидания("ПровертьЗакрытиеФормы", 0.01, Истина);

КонецПроцедуры
&НаКлиенте
Процедура КоличествоНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)

    ЭтаФорма.ТекущийЭлемент = Элементы.Количество;

КонецПроцедуры

&НаКлиенте
Процедура НомерСтрокиДокументаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)

    ЭтаФорма.ТекущийЭлемент = Элементы.НомерСтрокиДокумента;

КонецПроцедуры