&НаКлиенте
Процедура УдалитьСтроку(Команда)

    ПараметрыЗакрытия = Новый Структура;
    ПараметрыЗакрытия.Вставить("УдалитьСтроку");

    Закрыть(ПараметрыЗакрытия);

КонецПроцедуры

&НаКлиенте
Процедура Готово(Команда)
    ПровертьЗакрытиеФормы();
КонецПроцедуры

&НаКлиенте
Процедура СканироватьШтрихкод(Команда)

    ДополнительныеПараметры = Новый Структура;
    ДополнительныеПараметры.Вставить("Форма", ЭтаФорма);
    ДополнительныеПараметры.Вставить("ИмяОбработчикаЗакрытияСканирования", "ОбработкаЗакрытияСканирования");

    ПодключаемоеОборудованиеКлиент.ПолучитьШтрихкод(ДополнительныеПараметры);

КонецПроцедуры
#КонецОбласти

#Область СлужебныеПроцедурыИФункции
&НаСервере
Процедура ОформитьСтатичныеЗаголовкиИПоля()
	
	// заголовок формы
    ЗаголовокФормы = НСтр("ru = 'Строка №%НомерСтроки%'");
    ЗаголовокФормы = СтрЗаменить(ЗаголовокФормы, "%НомерСтроки%", НомерСтроки);
    Заголовок      = ЗаголовокФормы;
	
	// количество
    ЗаголовокКоличества =  НСтр("ru = 'Количество, %ЕдИзм%'");
    ЗаголовокКоличества = СтрЗаменить(ЗаголовокКоличества, "%ЕдИзм%", НаименованиеЕденицы);
    Элементы.Количество.Заголовок = ЗаголовокКоличества;
    Если ТолькоПросмотрФормы Тогда
        Элементы.Отмена.Заголовок = НСтр("ru = 'Закрыть'");
        ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "Готово, УдалитьСтроку", "Видимость",
            Ложь);

        ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "Количество", "КнопкаРегулирования",
            Ложь);
        ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "Количество", "ТолькоПросмотр", Истина);

    КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура НастроитьФормуПоЗначениямНастроек()
    ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "МаксимальноеКоличествоИнфо", "Видимость",
        Параметры.Свойство("МаксимальноеКоличествоИнфо"));
    ОбщегоНазначения.УстановитьЦветИнформационныхНадписей(ЭтаФорма, "МаксимальноеКоличествоИнфо");
	
	//ИсключенныеСвойства = "ЗакрыватьПриВыборе, ЗакрыватьПриЗакрытииВладельца, ТолькоПросмотр,НаименованиеТовара";
	//ЗаполнитьЗначенияСвойств(ЭтаФорма, Параметры, ,ИсключенныеСвойства);

    ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "КоличествоОжидаемое", "Видимость",
        Параметры.Свойство("КоличествоОжидаемое") Или Параметры.Свойство("КоличествоПоставщика"));
    ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "Продажи", "Видимость", Параметры.Свойство(
        "Продажи"));
    ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "Остаток", "Видимость", Параметры.Свойство(
        "Остаток"));
    ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "НомерСтрокиДокумента", "Видимость",
        Параметры.Свойство("НомерСтрокиДокумента"));

    Если ХозОперация = "ПеремещениеТоваровИзФилиала" Тогда
        ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "УдалитьСтроку", "Видимость", Ложь);

    ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЛокальнаяИнвентаризация")
        Или ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ИнвентаризацияТБД") Или ТипДокумента
        = ПредопределенноеЗначение("Справочник.ТипыДокументов.Инвентаризация") Или ТипДокумента
        = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеИН") Или ТипДокумента = ПредопределенноеЗначение(
        "Справочник.ТипыДокументов.ЗаданиеТНП") Или ТипДокумента = ПредопределенноеЗначение(
        "Справочник.ТипыДокументов.Zak") Или ТипДокумента = ПредопределенноеЗначение(
        "Справочник.ТипыДокументов.Контролер") Тогда

        ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "УдалитьСтроку", "Видимость", Ложь);
    ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеТБД") Тогда
        ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма,
            "КоличествоОжидаемое,Продажи,Количество,УдалитьСтроку", "Видимость", Ложь);
        ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "СканированиеЦенник,СканированиеТовар",
            "Видимость", Истина);
    ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ЗаданиеВФ") Тогда
        ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма,
            "КоличествоОжидаемое,Продажи,Количество,УдалитьСтроку", "Видимость", Ложь);
        ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма,
            "СканированиеЦенник,СканированиеТовар,ГруппаВФ", "Видимость", Истина);
    ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.ПриемPKG") Тогда
        ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "УдалитьСтроку", "Видимость", Ложь);
    ИначеЕсли ТипДокумента = ПредопределенноеЗначение("Справочник.ТипыДокументов.Пересортица") Тогда
        ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ГруппаПересорт", "Видимость", Истина);
        ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "КоличествоОжидаемое", "Видимость",
            Ложь);
    Иначе
        ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "УдалитьСтроку", "ЦветРамки",
            ЦветаСтиля.ЦветФонаФормы);
    КонецЕсли;
    ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементовФормы(ЭтаФорма, "ПриемДо", "Видимость", ЗначениеЗаполнено(
        ПриемДо));
    ЭтаФорма.ТекущийЭлемент = Элементы.Количество;
	//Элементы.Количество.УстановитьГраницыВыделения(СтрДлина(Элементы.Количество),СтрДлина(Элементы.Количество)+1);
    Элементы.Количество.АктивизироватьПоУмолчанию = Истина;

    ОбщегоНазначения.УстановитьШрифт(ЭтаФорма);
    ОбщегоНазначения.ОформитьКоличественныеПоляВвода(ЭтаФорма,
        "КоличествоОжидаемое,Продажи,Остаток,Количество,СканированиеТовар", Весовой);
//	Количество = Формат(Число(Количество), ?(Весовой,"ЧЦ=15; ЧДЦ=3; ЧН=","ЧРД=."));

    ОбщегоНазначения.УстановитьВысотуПоляНаименованиеТовара(ЭтаФорма, , "Номенклатура");
КонецПроцедуры
#КонецОбласти

