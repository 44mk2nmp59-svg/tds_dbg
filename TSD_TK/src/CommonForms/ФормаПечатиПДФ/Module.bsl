&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	
	// 1. Проверяем, передали ли файл в параметрах формы
	Если Параметры.Свойство("ДанныеФайла") И ЗначениеЗаполнено(Параметры.ДанныеФайла) Тогда
		
		ДвоичныеДанныеФайла = Параметры.ДанныеФайла;
		
		// 2. Создаем новый пустой объект Форматированного документа
		ФормДок = Новый ФорматированныйДокумент;
		
		// 3. Готовим структуру внутренних ресурсов
		СтруктураРесурсов = Новый Структура;
		
		// ИСПРАВЛЕНО: Убрали точку из имени атрибута структуры
		ИмяВнутреннегоРесурса = "embedded_document_pdf"; 
		СтруктураРесурсов.Вставить(ИмяВнутреннегоРесурса, ДвоичныеДанныеФайла);
		
		// 4. Формируем HTML-код (ссылаемся на имя без точки)
		ТекстHTML = "

		|<html>
		|<head>
		|	<meta name='viewport' content='width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no'>

		|	<style>
		|		html, body { margin:0; padding:0; width:100%; height:100%; overflow:hidden; background-color:#404040; }
		|		object, embed { width:100%; height:100%; border:none; }

		|	</style>
		|</head>
		|<body>

		|	<object data='" + ИмяВнутреннегоРесурса + "' type='application/pdf'>
		|		<embed src='" + ИмяВнутреннегоРесурса + "' type='application/pdf' />
		|	</object>

		|</body>
		|</html>";
		
		// 5. Загружаем HTML и структуру ресурсов в Форматированный документ
		ФормДок.УстановитьHTML(ТекстHTML, СтруктураРесурсов);
		
		// 6. Привязываем к реквизиту формы
		ДокументДляПросмотра = ФормДок;
		
	Иначе
		Отказ = Истина;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Файл PDF не передан для просмотра.");
	КонецЕсли;КонецПроцедуры  

