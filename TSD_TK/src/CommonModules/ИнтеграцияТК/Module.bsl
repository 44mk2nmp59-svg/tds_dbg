Функция HTTPСоединение() Экспорт
	
	ПараметрыСоеденения = ИнтеграцияПовИсп.ПараметрыПодключения(); 
	ПараметрыАвторизации = ПараметрыАвотризации();
	СтруктураСоединения = СтруктураСоеденения();
	
	Попытка 
		HTTPСоединение = Новый  HTTPСоединение(ПараметрыСоеденения.АдресСервера, ПараметрыСоеденения.ПортСоединения,ПараметрыАвторизации.Пользоваталь,ПараметрыАвторизации.Пароль,,,?(ПараметрыСоеденения.ИспользуетсяЗащищенноеСоединение,Новый ЗащищенноеСоединениеOpenSSL(Неопределено,Неопределено),Неопределено));
		СтруктураСоединения.HTTPСоединение = HTTPСоединение;
		СтруктураСоединения.СоединениеУстановлено = Истина;
		СтруктураСоединения.СообщениеОбОшибке = "";
		СтруктураСоединения.ИмяСервиса = ПараметрыСоеденения.ИмяСервиса;
	Исключение
		СтруктураСоединения.СообщениеОбОшибке =  КраткоеПредставлениеОшибки(ИнформацияОбОшибке());

	КонецПопытки;
	
	
	Возврат СтруктураСоединения;
	
	
КонецФункции



Функция СоставныеСтрокиАдреса()
	
	Структура = Новый Структура();
	Структура.Вставить("АдресСервера", "");
	Структура.Вставить("ИмяКаталога", "");
	Структура.Вставить("ИмяСервиса", "");
	Структура.Вставить("ПортСоединения", 0);
	Структура.Вставить("ИспользуетсяЗащищенноеСоединение", Ложь);
	Структура.Вставить("ОшибкаСтроки", Ложь);
	
	Возврат Структура;
КонецФункции

Функция ПараметрыАвотризации()Экспорт
	
	СтруктураВозврата = 	Новый Структура("Пользоваталь,Пароль",ЗначениеНастроекВызовСервераПовтИсп.Логин(),ЗначениеНастроекВызовСервераПовтИсп.Пароль());
	Возврат  СтруктураВозврата;
КонецФункции

Функция ПараметрыПодключения() Экспорт
	
	
	
	Структура = СоставныеСтрокиАдреса();

	АдресWS = ЗначениеНастроекВызовСервераПовтИсп.АдресСервера();
	
	ЗащищенныйПротокол = Ложь;
	Если Лев(АдресWS, 5) = "https" Тогда
		ЗащищенныйПротокол = Истина;
	КонецЕсли;
	
	Если ЗащищенныйПротокол Тогда
		КоличествоСимволовПодHTTP = 9; // "https://"
	Иначе 
		КоличествоСимволовПодHTTP = 8; // "http://"
	КонецЕсли;
	
	СтрокаНаЗабор = Сред(АдресWS, КоличествоСимволовПодHTTP);
	ПозицияСлеша = Найти(СтрокаНаЗабор, "/");
	ИмяБД = Сред(СтрокаНаЗабор,ПозицияСлеша + 1);
	
	IP = Лев(СтрокаНаЗабор, ПозицияСлеша - 1);
	
	ПозицияДвоеточия = Найти(IP, ":");
	Если ПозицияДвоеточия = 0 Тогда
		Если ЗащищенныйПротокол Тогда
			Порт = 443;
		Иначе
			Порт = 80;
		КонецЕсли;
		IPБезПорта = IP;  
	Иначе
		Порт = Число(Сред(IP,ПозицияДвоеточия + 1));
		IPБезПорта = Лев(IP, ПозицияДвоеточия - 1);
	КонецЕсли;
	
	
	Структура.АдресСервера = IPБезПорта;
	Структура.ИмяКаталога  =	ИмяБД;
	Структура.ИмяСервиса   = ИмяБД+"/hs/TSD";
	Структура.ПортСоединения = Порт;
	Структура.ИспользуетсяЗащищенноеСоединение = ЗащищенныйПротокол;
	
	Возврат Структура;
	
	
КонецФункции

Функция СтруктураСоеденения() Экспорт
	СтруктураСоединения = Новый Структура;
	СтруктураСоединения.Вставить("HTTPСоединение");
	СтруктураСоединения.Вставить("ИмяСервиса","");
	СтруктураСоединения.Вставить("СоединениеУстановлено", Ложь);
	СтруктураСоединения.Вставить("СообщениеОбОшибке","");
	СтруктураСоединения.Вставить("Ответ",Неопределено);

	
	Возврат  СтруктураСоединения;
	
КонецФункции

Функция ПараметрыПодключенияФайлаКартинки(АдресWS)Экспорт
	Структура = СоставныеСтрокиАдреса();

	ЗащищенныйПротокол = Ложь;
	Если Лев(АдресWS, 5) = "https" Тогда
		ЗащищенныйПротокол = Истина;
	КонецЕсли;
	
	Если ЗащищенныйПротокол Тогда
		КоличествоСимволовПодHTTP = 9; // "https://"
	Иначе 
		КоличествоСимволовПодHTTP = 8; // "http://"
	КонецЕсли;
	
	СтрокаНаЗабор = Сред(АдресWS, КоличествоСимволовПодHTTP);
	ПозицияСлеша = Найти(СтрокаНаЗабор, "/");
	ИмяБД = Сред(СтрокаНаЗабор,ПозицияСлеша + 1);
	
	IP = Лев(СтрокаНаЗабор, ПозицияСлеша - 1);
	
	ПозицияДвоеточия = Найти(IP, ":");
	Если ПозицияДвоеточия = 0 Тогда
		Если ЗащищенныйПротокол Тогда
			Порт = 443;
		Иначе
			Порт = 80;
		КонецЕсли;
		IPБезПорта = IP;  
	Иначе
		Порт = Число(Сред(IP,ПозицияДвоеточия + 1));
		IPБезПорта = Лев(IP, ПозицияДвоеточия - 1);
	КонецЕсли;
	
	
	Структура.АдресСервера = IPБезПорта;
	Структура.ИмяКаталога  =	ИмяБД;
	//Структура.ИмяСервиса   = ИмяБД+"/hs/TSD";
	Структура.ПортСоединения = Порт;
	Структура.ИспользуетсяЗащищенноеСоединение = ЗащищенныйПротокол;
	
	Возврат Структура;
	

КонецФункции
