Процедура ПрочитатьДанныеПоСкладам(ОбменДанными,Результат) Экспорт
	
	Если ОбменДанными.Ответ.КодСостояния <> 200  Тогда
		Результат.Результат = Ложь;
		Результат.ОписаниеОшибки = "Ошибка выполнения запроса складов, код состояния " +  ОбменДанными.Ответ.КодСостояния;
		Возврат;
	КонецЕсли;
	
	ПотокДанных = ОбменДанными.Ответ.ПолучитьТелоКакСтроку();
	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(ПотокДанных);
	
	СтруктураДанных = ПрочитатьJSON(ЧтениеJSON);
	
	
	Результат.Результат      = СтруктураДанных.Результат;
	Результат.ОписаниеОшибки = СтруктураДанных.ОписаниеОшибки;
	
	Если СтруктураДанных.Результат Тогда
		СписокЗначенийОтвет = Новый СписокЗначений;
		
		Для Каждого СтрСклад Из    СтруктураДанных.Ответ Цикл 
			Если СтрСклад.Свойство("ТНП")Тогда
				ПометкаСкладТНП  = ?(СтрСклад.ТНП = 0 ,ложь, Истина);
			Иначе
				ПометкаСкладТНП = Ложь;
			КонецЕсли;
			
			СписокЗначенийОтвет.Добавить(СтрСклад.СкладUUID,СтрСклад.Склад,ПометкаСкладТНП)
		КонецЦикла;
		
		Результат.Ответ = СписокЗначенийОтвет;
	КонецЕсли;
	 
	
КонецПроцедуры

