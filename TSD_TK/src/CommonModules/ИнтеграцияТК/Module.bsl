

Процедура ПрочитатьДанныеПодразделения(ОбменДанными,Результат) Экспорт
	
	Если ОбменДанными.Ответ.КодСостояния <> 200  Тогда
		Результат.ОписаниеОшибки = "Ошибка выполнения запроса подразделения, код состояния " +  ОбменДанными.Ответ.КодСостояния;
		Сообщить("Код ответа" + ОбменДанными.Ответ.КодСостояния);
		Возврат;
	КонецЕсли;       
	
	СтароеПодразделение = ПараметрыСеанса.UUID;
	
	ПотокДанных = ОбменДанными.Ответ.ПолучитьТелоКакСтроку();
	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(ПотокДанных);
	СтруктураДанных = ПрочитатьJSON(ЧтениеJSON);
	ОбщегоНазначения.УстановитьUUID(СтруктураДанных.UUID);
	ОбщегоНазначения.УстановитьПодразделение(СтруктураДанных.Name);
	ОбщегоНазначенияВызовСервера.УстановитьЗначениеКонстанты("UUID",СтруктураДанных.UUID);
	ОбщегоНазначенияВызовСервера.УстановитьЗначениеКонстанты("Подразделение",СтруктураДанных.Name);
	
	Если СтруктураДанных.Свойство("ATT") Тогда
		ОбщегоНазначенияВызовСервера.УстановитьЗначениеКонстанты("ЭтоАттика",СтруктураДанных.ATT);
		ОбщегоНазначения.УстановитьАТТ(?(СтруктураДанных.ATT=1,Истина,Ложь));
	КонецЕсли;
	
	Если СтруктураДанных.Свойство("ID") Тогда
		ОбщегоНазначенияВызовСервера.УстановитьЗначениеКонстанты("НомерТТ",СтруктураДанных.ID);
		ОбщегоНазначения.УстановитьНомерТТ(СтруктураДанных.ID);
	КонецЕсли;
	
	Если СтароеПодразделение <> ПараметрыСеанса.UUID Тогда
		СисИнфо = Новый СистемнаяИнформация;  
		МодельУстройства = СисИнфо.ВерсияОС;
		ID_Устройства = Строка(СисИнфо.ИдентификаторКлиента);
		
		Токен = ОбщегоНазначенияВызовСервера.ПолучитьСохраненныйТокен(ID_Устройства);
		Если НЕ ПустаяСтрока(Токен) Тогда	
			Ответ = ИнтеграцияТК_ВызовСервера.ОтправитьТокен(ID_Устройства,МодельУстройства,Токен);	
			Если Ответ.Результат Тогда
				ОбщегоНазначенияВызовСервера.ЗаписатьНовыйТокен(ID_Устройства,Токен);
			КонецЕсли;
		КонецЕсли;	
		
		
	КонецЕсли;
	

	
	Результат.Результат = Истина;
	Результат.Ответ = СтруктураДанных.Name;


КонецПроцедуры

Процедура ПрочитатьДанныеСотрудника(ОбменДанными,Результат) Экспорт
	
	Если ОбменДанными.Ответ.КодСостояния <> 200  Тогда
		Результат.ОписаниеОшибки = "Ошибка выполнения запроса подразделения, код состояния " +  ОбменДанными.Ответ.КодСостояния+Символы.ПС+ОбменДанными.Ответ.ПолучитьТелоКакСтроку();
		Возврат;
	КонецЕсли;
	
	ПотокДанных = ОбменДанными.Ответ.ПолучитьТелоКакСтроку();
	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(ПотокДанных);
	СтруктураДанных = ПрочитатьJSON(ЧтениеJSON);
	Если СтруктураДанных.Результат  Тогда
		 
		ОбщегоНазначения.УстановитьСотрудник_ID(СтруктураДанных.Ответ.UUID);
