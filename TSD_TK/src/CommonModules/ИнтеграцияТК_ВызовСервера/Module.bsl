#Область СлужебныеПроцедурыИФункции

Процедура ВыполнитьЗапросHTTP(ОбменДанными,Знач Запрос)
	
	Попытка
		HTTPЗапрос = Новый HTTPЗапрос(ОбменДанными.ИмяСервиса + Запрос);
		ИдентификаторЗапроса = Строка(Новый УникальныйИдентификатор);
		HTTPЗапрос.Заголовки.Вставить("X-1C-Request-UID", ИдентификаторЗапроса);	
		ОтветИБ = ОбменДанными.HTTPСоединение.Получить(HTTPЗапрос); 
		ОбменДанными.Ответ = ОтветИБ;
	Исключение
		ОбменДанными.СоединениеУстановлено = Ложь;
		ОбменДанными.СообщениеОбОшибке =  КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
	КонецПопытки;
	
КонецПроцедуры


Процедура ОтправитьДляОбработки(ОбменДанными,Знач Запрос,Запись)
	Попытка
		HTTPЗапрос = Новый HTTPЗапрос(ОбменДанными.ИмяСервиса + Запрос); 
		HTTPЗапрос.Заголовки.Вставить("Content-type", "application/json; charset=utf-8");
		HTTPЗапрос.Заголовки.Вставить("Accept","application/json");
		ИдентификаторЗапроса = Строка(Новый УникальныйИдентификатор);
      	HTTPЗапрос.Заголовки.Вставить("X-1C-Request-UID", ИдентификаторЗапроса);

		HTTPЗапрос.УстановитьТелоИзСтроки(Запись.Закрыть(),КодировкаТекста.UTF8,ИспользованиеByteOrderMark.НеИспользовать);
		
		ОтветИБ = ОбменДанными.HTTPСоединение.ОтправитьДляОбработки(HTTPЗапрос); 
		ОбменДанными.Ответ = ОтветИБ;
	Исключение
		ОбменДанными.СоединениеУстановлено = Ложь;
		ОбменДанными.СообщениеОбОшибке =  "Ошибка отправки "+Символы.ПС+КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
	КонецПопытки;

	
КонецПроцедуры


