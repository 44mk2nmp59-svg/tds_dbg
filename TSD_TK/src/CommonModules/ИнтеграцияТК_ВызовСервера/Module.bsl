Функция ПолучитьДанныеПоТоваруТК(ШтрихКод,Подразделение,Склад,Кратко,ВерификацияЦен,ПараметрыТовара,ВозвратПоставщику)
	Результат = Новый Структура;
	Результат.Вставить("Результат",Ложь);
	Результат.Вставить("ОписаниеОшибки","");
	Результат.Вставить("Ответ","");

	
	ОбменДанными = ИнтеграцияТК.HTTPСоединение();

	//ОбменДанными = ИнтеграцияПовИсп.УстановитьПодключение();	
	
	Если НЕ ОбменДанными.СоединениеУстановлено Тогда
		Результат.Результат = Ложь;
		Результат.ОписаниеОшибки = ОбменДанными.СообщениеОбОшибке;
		Возврат Результат;
	КонецЕсли;

	Если ВерификацияЦен Тогда
		Если ПустаяСтрока(ПараметрыТовара) Тогда
			текстЗапроса = "/Market/"+Подразделение+"/InfoTtovara/"+ШтрихКод;
		Иначе
			текстЗапроса = "/Market/"+Подразделение+"/InfoTtovara/"+ШтрихКод+"/id/"+ПараметрыТовара;
		КонецЕсли;
	ИначеЕсли ВозвратПоставщику Тогда
		текстзапроса = "/Market/"+Подразделение+"/Sklad/"+Склад+"/BarCode/"+ШтрихКод+"/Contract/"+?(ПустаяСтрока(ПараметрыТовара),"null",ПараметрыТовара);
	ИначеЕсли НЕ ПустаяСтрока(Склад) Тогда
		текстзапроса = "/Market/"+Подразделение+"/Sklad/"+Склад+"/BarCode/"+ШтрихКод+"/Param/"+ПараметрыТовара;
	ИначеЕсли Не ПустаяСтрока(ПараметрыТовара) Тогда
		текстзапроса = "/Market/"+Подразделение+"/BarCode/"+ШтрихКод+"/Param/"+ПараметрыТовара;
	Иначе
		текстзапроса = "/Market/"+Подразделение+"/BarCode/"+ШтрихКод+"/Min/"+?(Кратко,1,0);
	КонецЕсли;
	
	ВыполнитьЗапросHTTP(ОбменДанными,текстзапроса);
	
	Если ОбменДанными.СоединениеУстановлено Тогда
		Попытка
			ИнтеграцияТК.ПрочитатьДанныеПоТовару(ОбменДанными,Результат,Кратко,ВерификацияЦен);
		Исключение
			Результат.ОписаниеОшибки = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());			
			
		КонецПопытки;
		
	Иначе
		Результат.ОписаниеОшибки =  ОбменДанными.СообщениеОбОшибке;
		
	КонецЕсли;
	
	Возврат Результат;
	
