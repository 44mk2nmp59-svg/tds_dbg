		Копий = 2;
	Иначе
		Копий = 1;
	КонецЕсли;
	
	Попытка
		HTTPЗапрос = Новый HTTPЗапрос(ОбменДанными.ИмяСервиса + "/Market/"+Подразделение+"/Type/"+ТипДокумента+"/Copy/"+Формат(Копий,"ЧН=; ЧГ="));
		
