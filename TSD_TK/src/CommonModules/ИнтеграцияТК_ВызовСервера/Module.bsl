		КонецЕсли;
		
		
		
	Исключение
		Результат.Вставить("ОписаниеОшибки","Ошибка отпавки!"+Символы.ПС+ОписаниеОшибки());
	КонецПопытки;
	
	
	Возврат Результат;
	
	

