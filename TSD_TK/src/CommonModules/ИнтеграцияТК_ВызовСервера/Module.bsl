Функция ОтправитьДокумент(ТипДокумента,Документ,Подразделение)
	Результат = Новый Структура;
	Результат.Вставить("Результат",Ложь);
	Результат.Вставить("ОписаниеОшибки","");
	Результат.Вставить("Ответ","");
	
	ОбменДанными = ИнтеграцияТК.HTTPСоединение();
	
	
	Если НЕ ОбменДанными.СоединениеУстановлено Тогда
		Результат.Результат = Ложь;
		Результат.ОписаниеОшибки = ОбменДанными.СообщениеОбОшибке;
		Возврат Результат;
	КонецЕсли;
	
	
	ЗаписьJSON = Новый ЗаписьJSON; 
	ЗаписьJSON.УстановитьСтроку(); 
	ЗаписатьJSON(ЗаписьJSON, Документ); 
	
	Если ТипЗнч(ТипДокумента) = Тип("СправочникСсылка.ТипыДокументов") Тогда
		сТД = Строка(ТипДокумента.ИмяПредопределенныхДанных);
		Если ТипДокумента = Справочники.ТипыДокументов.ЗаданиеТБД Тогда
			сТД = сТД+"V2";
		КонецЕсли;
		ОтправитьДляОбработки(ОбменДанными,"/Market/"+Подразделение+"/DocV2/"+сТД,ЗаписьJSON);

	Иначе
		ОтправитьДляОбработки(ОбменДанными,"/Market/"+Подразделение+"/Doc/"+ТипДокумента,ЗаписьJSON);	
	КонецЕсли;
	
	Если ОбменДанными.СоединениеУстановлено Тогда
		Если ОбменДанными.Ответ.КодСостояния = 200  Тогда
			
			
			ПотокДанных = ОбменДанными.Ответ.ПолучитьТелоКакСтроку();
			ЧтениеJSON = Новый ЧтениеJSON;
			ЧтениеJSON.УстановитьСтроку(ПотокДанных);
			
			СтруктураДанных = ПрочитатьJSON(ЧтениеJSON);
			
			
			Результат.Результат      = СтруктураДанных.Результат;
			Результат.ОписаниеОшибки = СтруктураДанных.ОписаниеОшибки;
			
			Результат.Ответ = СтруктураДанных.Ответ;
			
		//	Результат.Результат = Истина;
		КонецЕсли;
	Иначе
		Результат.ОписаниеОшибки =  ОбменДанными.СообщениеОбОшибке;
	КонецЕсли;
	
	
	Возврат Результат;

	

