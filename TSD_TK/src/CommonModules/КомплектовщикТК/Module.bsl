 

Функция ЗаписатьОтветJSON(СтруктураВозврата)
	
	
	ЗаписьJSON = Новый ЗаписьJSON; 
	ЗаписьJSON.УстановитьСтроку(); 
	
	НастройкиСериализации = Новый НастройкиСериализацииJSON;
	НастройкиСериализации.ВариантЗаписиДаты = ВариантЗаписиДатыJSON.ЛокальнаяДата;
	НастройкиСериализации.ФорматСериализацииДаты = ФорматДатыJSON.ISO;
	
	ЗаписатьJSON(ЗаписьJSON, СтруктураВозврата,НастройкиСериализации);	
	СтрокаВозврата = ЗаписьJSON.Закрыть();	
	
	Возврат СтрокаВозврата;
	
КонецФункции
   
 
Процедура ВыполнитьЗапросHTTP_Комплектовщик(ОбменДанными,Знач Запрос,ОтправитьДляОбработки = Ложь,ТелоЗапроса = "")
	
	Попытка
		HTTPЗапрос = Новый HTTPЗапрос(ОбменДанными.ИмяСервиса + Запрос);
		ИдентификаторЗапроса = Строка(Новый УникальныйИдентификатор);
		HTTPЗапрос.Заголовки.Вставить("X-1C-Request-UID", ИдентификаторЗапроса);	
		Если ОтправитьДляОбработки Тогда  
			
			HTTPЗапрос.УстановитьТелоИзСтроки(ТелоЗапроса,КодировкаТекста.UTF8);
			
			ОтветИБ = ОбменДанными.HTTPСоединение.ОтправитьДляОбработки(HTTPЗапрос);

		Иначе
			ОтветИБ = ОбменДанными.HTTPСоединение.Получить(HTTPЗапрос);
		КонецЕсли;
		ОбменДанными.Ответ = ОтветИБ;
	Исключение
		ОбменДанными.СоединениеУстановлено = Ложь;
		ОбменДанными.СообщениеОбОшибке =  КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
	КонецПопытки;
	
КонецПроцедуры
   
   
   
Функция ПодготовитьGETЗапрос(ТекстЗапроса,ИмяПолеДата="")Экспорт  
	
	Результат = Новый Структура;
	Результат.Вставить("Результат",Ложь);
	Результат.Вставить("ОписаниеОшибки","");
	Результат.Вставить("Ответ","");
	
	ОбменДанными = ИнтеграцияТК.HTTPСоединение();
	
	Если НЕ ОбменДанными.СоединениеУстановлено Тогда
		Результат.ОписаниеОшибки = ОбменДанными.СообщениеОбОшибке;
		Возврат Результат;
	КонецЕсли; 
	
	ВыполнитьЗапросHTTP_Комплектовщик(ОбменДанными,ТекстЗапроса);
	
	Если ОбменДанными.СоединениеУстановлено Тогда
		Попытка
			ИнтеграцияТК.ПрочитатьДанные(ОбменДанными,Результат,ИмяПолеДата);
		Исключение
			Результат.ОписаниеОшибки = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());			
		КонецПопытки;
	Иначе
		Результат.ОписаниеОшибки =  ОбменДанными.СообщениеОбОшибке;
	КонецЕсли;
	
	
	Возврат Результат;
	

КонецФункции

