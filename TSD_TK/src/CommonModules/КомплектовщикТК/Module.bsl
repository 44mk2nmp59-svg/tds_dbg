Функция ОтправитьНаСервер(СтруктураДокумента,ТекстЗапроса)Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Результат",Ложь);
	Результат.Вставить("ОписаниеОшибки","");
	Результат.Вставить("Ответ","");
	
	ОбменДанными = ИнтеграцияТК.HTTPСоединение();
	
	Если НЕ ОбменДанными.СоединениеУстановлено Тогда
		Результат.ОписаниеОшибки = ОбменДанными.СообщениеОбОшибке;
		Возврат Результат;
	КонецЕсли;    
	//текстЗапроса = "/Complect/"+ПараметрыСеанса.UUID+"/DocFinih";
	ВыполнитьЗапросHTTP_Комплектовщик(ОбменДанными,ТекстЗапроса,Истина,ЗаписатьОтветJSON(СтруктураДокумента)); 
	Если ОбменДанными.СоединениеУстановлено Тогда
		Попытка
			ИнтеграцияТК.ПрочитатьДанные(ОбменДанными,Результат);
		Исключение
			Результат.ОписаниеОшибки = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());			
		КонецПопытки;
	Иначе
		Результат.ОписаниеОшибки =  ОбменДанными.СообщениеОбОшибке;
	КонецЕсли;
	
	Возврат Результат;

КонецФункции

