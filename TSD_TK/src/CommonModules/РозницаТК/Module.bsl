Функция ПолучитьСписокДокументовPKG(ТипДокумента)Экспорт
	
	Если ТипДокумента = Справочники.ТипыДокументов.БезакцептныйПриемPKG Тогда 
		текстЗапроса = "/Roznitsa/"+ПараметрыСеанса.UUID+"/PKGRC?uuidcom=0&bpPKG=1"; 
	Иначе
		текстЗапроса = "/Roznitsa/"+ПараметрыСеанса.UUID+"/PKGRC?uuidcom=0&bpPKG=0";
	КонецЕсли;
	
	РезОтвет = КомплектовщикТК.ПодготовитьGETЗапрос(текстЗапроса,"Дата");
	
	Возврат РезОтвет;	

КонецФункции

Функция ВыгрузитьДокументПриемРЦ(СтруктураДокумент,БезТоваров = Ложь) Экспорт  
	
	текстЗапроса = "/Roznitsa/"+ПараметрыСеанса.UUID+"/PKGloadRC"+"?aktsep="+?(БезТоваров,"0","1");
	РезОтвет = КомплектовщикТК.ОтправитьНаСервер(СтруктураДокумент,текстЗапроса);
		
	Возврат РезОтвет;	
	
КонецФункции

