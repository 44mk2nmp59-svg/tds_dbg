Функция ОтправитьТокенНаСервер(ID_Устройства,Модель,Токен)Экспорт 
	
	СтруктураДокумент = Новый Структура;
	СтруктураДокумент.Вставить("token",Токен);
	СтруктураДокумент.Вставить("device_id",ID_Устройства);
	СтруктураДокумент.Вставить("model",Модель);
	
	
	текстЗапроса = "/Roznitsa/"+ПараметрыСеанса.UUID+"/token?uuidcom=0";
	РезОтвет = КомплектовщикТК.ОтправитьНаСервер(СтруктураДокумент,текстЗапроса);
		
	Возврат РезОтвет;	


КонецФункции
