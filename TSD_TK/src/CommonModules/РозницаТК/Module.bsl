


Функция ПолучитьДанныеPKG(ШК,БезТоваров = Ложь) Экспорт  
	
	текстЗапроса = "/Roznitsa/"+ПараметрыСеанса.UUID+"/PKG?uuidcom="+ПараметрыСеанса.Сотрудник_ID+"&chk="+ШК+"&aktsep="+?(БезТоваров,"0","1");
	РезОтвет = КомплектовщикТК.ПодготовитьGETЗапрос(текстЗапроса,"Дата");
		
	Возврат РезОтвет;	
	
КонецФункции

