// Заказы клиентов

Процедура СоздатьЗаказКлиента(МассивНоменклатуры, ДополнительныеПараметры, Сканирование = Ложь) Экспорт
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("СозданиеПослеСканирования", Сканирование);
