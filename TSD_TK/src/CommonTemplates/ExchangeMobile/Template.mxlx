		<row>
			<c>
				<c>
					<f>1</f>
					<tl>
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>&lt;xs:schema xmlns:ns1="http://v8.1c.ru/8.1/data/core" xmlns:ns2="http://v8.1c.ru/8.1/data/enterprise" xmlns:tns="http://www.digma.ua/Mobile/Exchange" xmlns:xs="http://www.w3.org/2001/XMLSchema" targetNamespace="http://www.digma.ua/Mobile/Exchange" attributeFormDefault="unqualified" elementFormDefault="qualified"&gt;
	&lt;xs:import namespace="http://v8.1c.ru/8.1/data/core"/&gt;
	&lt;xs:import namespace="http://v8.1c.ru/8.1/data/enterprise"/&gt;
	&lt;xs:complexType name="CatalogObject.Контрагенты"&gt;
		&lt;xs:sequence&gt;
			&lt;xs:element name="Ref" type="xs:string"/&gt;
			&lt;xs:element name="DeletionMark" type="xs:boolean"/&gt;
			&lt;xs:element name="Code" type="xs:string"/&gt;
			&lt;xs:element name="Description" type="xs:string"/&gt;
			&lt;xs:element name="ListDogovor" nillable="true" minOccurs="0"&gt;
				&lt;xs:complexType&gt;
					&lt;xs:sequence&gt;
						&lt;xs:element name="List" nillable="true" minOccurs="0" maxOccurs="unbounded"&gt;
							&lt;xs:complexType&gt;
								&lt;xs:sequence&gt;
									&lt;xs:element name="Ref" type="xs:string"/&gt;
									&lt;xs:element name="DeletionMark" type="xs:boolean"/&gt;
									&lt;xs:element name="Description" type="xs:string"/&gt;
								&lt;/xs:sequence&gt;
							&lt;/xs:complexType&gt;
						&lt;/xs:element&gt;
					&lt;/xs:sequence&gt;
				&lt;/xs:complexType&gt;
			&lt;/xs:element&gt;
		&lt;/xs:sequence&gt;
	&lt;/xs:complexType&gt;
	&lt;xs:complexType name="CatalogObject.Номенклатура"&gt;
		&lt;xs:sequence&gt;
			&lt;xs:element name="Ref" type="xs:string"/&gt;
			&lt;xs:element name="IsFolder" type="xs:boolean"/&gt;
			&lt;xs:element name="DeletionMark" type="xs:boolean"/&gt;
			&lt;xs:element name="Parent" type="xs:string"/&gt;
			&lt;xs:element name="Code" type="xs:string"/&gt;
			&lt;xs:element name="Description" type="xs:string"/&gt;
			&lt;xs:element name="КоличествоЕденицОсновной" type="xs:decimal"/&gt;
			&lt;xs:element name="КоличествоЕденицЗаказа" type="xs:decimal"/&gt;
		&lt;/xs:sequence&gt;
	&lt;/xs:complexType&gt;
	&lt;xs:complexType name="CatalogObject.ТипЦен"&gt;
		&lt;xs:sequence&gt;
			&lt;xs:element name="Ref" type="xs:string"/&gt;
			&lt;xs:element name="DeletionMark" type="xs:boolean"/&gt;
			&lt;xs:element name="Description" type="xs:string"/&gt;
		&lt;/xs:sequence&gt;
	&lt;/xs:complexType&gt;
	&lt;xs:complexType name="CatalogObject.ТочкиДоставки"&gt;
		&lt;xs:sequence&gt;
			&lt;xs:element name="Ref" type="xs:string"/&gt;
			&lt;xs:element name="Owner" type="xs:string"/&gt;
			&lt;xs:element name="DeletionMark" type="xs:boolean"/&gt;
			&lt;xs:element name="Description" type="xs:string"/&gt;
		&lt;/xs:sequence&gt;
	&lt;/xs:complexType&gt;
	&lt;xs:complexType name="InformationBarCode"&gt;
		&lt;xs:sequence&gt;
			&lt;xs:element name="Ref" type="xs:string"/&gt;
			&lt;xs:element name="ListBarCod" nillable="true" minOccurs="0"&gt;
				&lt;xs:complexType&gt;
					&lt;xs:sequence&gt;
						&lt;xs:element name="List" nillable="true" minOccurs="0" maxOccurs="unbounded"&gt;
							&lt;xs:complexType&gt;
								&lt;xs:sequence&gt;
									&lt;xs:element name="BarCode" type="xs:string" minOccurs="0"/&gt;
									&lt;xs:element name="Cof" type="xs:decimal" minOccurs="0"/&gt;
								&lt;/xs:sequence&gt;
							&lt;/xs:complexType&gt;
						&lt;/xs:element&gt;
					&lt;/xs:sequence&gt;
				&lt;/xs:complexType&gt;
			&lt;/xs:element&gt;
		&lt;/xs:sequence&gt;
	&lt;/xs:complexType&gt;
	&lt;xs:complexType name="InformationPrice"&gt;
		&lt;xs:sequence&gt;
			&lt;xs:element name="TypePrice" type="xs:string" minOccurs="0"/&gt;
			&lt;xs:element name="Goods" type="xs:string"/&gt;
			&lt;xs:element name="Price" type="xs:decimal" minOccurs="0"/&gt;
		&lt;/xs:sequence&gt;
	&lt;/xs:complexType&gt;
	&lt;xs:complexType name="MessageExchange"&gt;
		&lt;xs:sequence&gt;
			&lt;xs:element name="ResultMessage" type="ns1:ValueStorage"/&gt;
			&lt;xs:element name="Success" type="xs:boolean"/&gt;
			&lt;xs:element name="Continue" type="xs:boolean"/&gt;
		&lt;/xs:sequence&gt;
	&lt;/xs:complexType&gt;
	&lt;xs:complexType name="Order"&gt;
		&lt;xs:sequence&gt;
			&lt;xs:element name="UUID" type="xs:string"/&gt;
			&lt;xs:element name="Regl" type="xs:boolean"/&gt;
			&lt;xs:element name="Number" type="xs:string"/&gt;
			&lt;xs:element name="Date" type="xs:dateTime"/&gt;
			&lt;xs:element name="Buyer" type="xs:string"/&gt;
			&lt;xs:element name="Contract" type="xs:string"/&gt;
			&lt;xs:element name="Address" type="xs:string"/&gt;
			&lt;xs:element name="DeliveryDate" type="xs:dateTime"/&gt;
			&lt;xs:element name="Comment" type="xs:string"/&gt;
			&lt;xs:element name="ListGoods" nillable="true" minOccurs="0"&gt;
				&lt;xs:complexType&gt;
					&lt;xs:sequence&gt;
						&lt;xs:element name="List" nillable="true" minOccurs="0" maxOccurs="unbounded"&gt;
							&lt;xs:complexType&gt;
								&lt;xs:sequence&gt;
									&lt;xs:element name="Ref" type="xs:string"/&gt;
									&lt;xs:element name="Quantity" type="xs:decimal"/&gt;
									&lt;xs:element name="Packsize" type="xs:decimal" nillable="true" minOccurs="0"/&gt;
									&lt;xs:element name="Price" type="xs:decimal" nillable="true" minOccurs="0"/&gt;
								&lt;/xs:sequence&gt;
							&lt;/xs:complexType&gt;
						&lt;/xs:element&gt;
					&lt;/xs:sequence&gt;
				&lt;/xs:complexType&gt;
			&lt;/xs:element&gt;
		&lt;/xs:sequence&gt;
	&lt;/xs:complexType&gt;
	&lt;xs:complexType name="Permit"&gt;
		&lt;xs:sequence&gt;
			&lt;xs:element name="ResultMessage" type="xs:string"/&gt;
			&lt;xs:element name="Success" type="xs:boolean"/&gt;
			&lt;xs:element name="DeleteAppData" type="xs:boolean"/&gt;
		&lt;/xs:sequence&gt;
	&lt;/xs:complexType&gt;
&lt;/xs:schema&gt;</v8:content>
